https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088382.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9596492"}, {"article_id": "9596065", "title": "史上首次！3台將同日先發 寫下台灣年輕旅美農場奮鬥新篇章", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088004.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9596065"}, {"article_id": "9595957", "title": "阿根廷世足「悲劇英雄」 資深菜鳥30歲終於初登場還進球圓夢", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087938.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9595957"}]}, {"name": "最新文章", "articles": [{"article_id": "9598334", "title": "世足賽／荷蘭海牙街頭摩洛哥球迷歡欣鼓舞 與警爆衝突遭壓制逮捕", "summary": "摩洛哥世足賽32強戰在戲劇性的PK大戰中擊敗荷蘭。擁有大量摩洛哥社群的荷蘭海牙今天為之沸騰，但是現場也因群眾與警方爆發衝...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35091275.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 18:52", "link": "/news/story/123107/9598334"}, {"article_id": "9598242", "title": "中職／光總會調！張奕告別山本由伸回歸初衷 找回投球穩定度", "summary": "富邦悍將隊張奕時隔近三個月再「盜」走勝投，近期狀況回穩，關鍵在於5月31日在台北大巨蛋登板遭到重擊後，總教練後藤光尊找他傳接，點出自己的觀察，張奕在這之後告別山本由伸，回到自己過往的投球動作。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35091137.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 17:43", "link": "/news/story/7001/9598242"}, {"article_id": "9598087", "title": "加拿大羽賽／繼美國站之後 蘇力揚拚男單連2週奪冠", "summary": "BWF超級300的加拿大羽球公開賽今晚開打，台灣戰將共23組人馬從會內賽開打，包括剛奪冠的男單蘇力揚、混雙劉廣珩/許尹鏸...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35091062.jpg&M=1&s=Y&x=0&y=0&sw=671&sh=447&exp=3600&sl=W&fw=360", "date": "2026-06-30 17:22", "link": "/news/story/7005/9598087"}, {"article_id": "9598143", "title": "世足攻略／墨西哥坐擁主場優勢 有望小勝厄瓜多", "summary": "墨西哥在世足淘汰賽首戰面對厄瓜多，擁有主場優勢與強勁防守。儘管厄瓜多小組賽表現較佳，墨西哥憑藉高原地勢與球迷支持，有望小勝或進入點球大戰。能否破解厄瓜多的防守將是關鍵。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35091007.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 17:16", "link": "/news/story/122629/9598143"}, {"article_id": "9598162", "title": "中職／光總有責任感的選秀「看顏值排序」 點名2左投注意很久", "summary": "富邦悍將隊總教練後藤光尊首度參與中職選秀會，深深感受到極大的責任感，「因為每個選擇，都可能改變一位選手的人生。」但聊著聊著還是藏不住調皮本性，笑答：「我是看顏值排序的。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090985.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 17:02", "link": "/news/story/7001/9598162"}, {"article_id": "9598093", "title": "世足攻略／冠軍熱門法國狀況火熱 碰瑞典至少進兩球", "summary": "法國在世足賽表現火熱，小組賽3戰全勝，攻擊力強勁，預計對瑞典將進兩球以上。儘管瑞典防守嚴謹，但中場核心傷缺，攻擊效率受影響，雙方對決歷史上法國佔優。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090908.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 16:43", "link": "/news/story/122629/9598093"}, {"article_id": "9597818", "title": "MLB／大谷翔平、詹姆斯菜鳥球員卡 各逾250萬美金天價成交", "summary": "棒球明星大谷翔平與籃球名人詹姆斯兩人稀有的菜鳥球員卡，昨天晚間在拍賣會各以逾250萬美元（新台幣8000萬元）成交，再次...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090850.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 16:31", "link": "/news/story/6999/9597818"}, {"article_id": "9596962", "title": "世足賽／追趕梅西的車尾燈 姆巴佩、哈蘭德拚進球數", "summary": "金靴獎熱門人選，法國隊的姆巴佩(Kylian Mbappe)、挪威的哈蘭德(Erling Haaland)，均將於30日(周二)在32強出賽，分別在新澤西球場對陣瑞典、在德州達拉斯球場出戰象牙海岸；兩人的最大目標當然是領軍擊敗對手，順利搶下16強門票。法國在小組賽三連勝狂攻十球，和荷蘭、德國並列領先，除了核心人物姆巴佩，還擁有令人膽寒的進攻深度。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35089024.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 16:30", "link": "/news/story/123107/9596962"}, {"article_id": "9598048", "title": "世足攻略／哈蘭德火力旺 看好對象牙海岸小勝一個球", "summary": "挪威將對陣象牙海岸，期待以哈蘭德的火力小勝一球。雖然象牙海岸在數據上略具優勢，挪威的高空攻擊和防守漏洞將是關鍵焦點。觀察雙方的臨場表現，勝負難以預測。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090839.jpg&M=1&s=Y&x=0&y=134&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 16:25", "link": "/news/story/122629/9598048"}, {"article_id": "9598031", "title": "中職／嘉大棒球隊雙投高順位圓夢 李崧睿、顏承恩獲龍、鷹指名", "summary": "嘉義大學棒球隊在2026年中華職棒季中新人選秀傳出捷報，體育與健康休閒學系二年級投手李崧睿、顏承恩分別獲味全龍、台鋼雄鷹高順位指名，校長林翰謙今天接見表揚，勉勵兩人延續KANO精神，在職棒舞台持續發光發熱。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090785.jpg&M=1&s=Y&x=0&y=0&sw=999&sh=666&exp=3600&sl=W&fw=360", "date": "2026-06-30 16:11", "link": "/news/story/7001/9598031"}, {"article_id": "9598003", "title": "NBA／釣魚冠軍想加入76人或熱火 西蒙斯：籃球在我的DNA裡", "summary": "現年29歲的2016年狀元西蒙斯（Ben Simmons）正加強訓練，為可能重返NBA做準備，76人和熱火隊是他想要去的球隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090745.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 16:06", "link": "/news/story/7002/9598003"}, {"article_id": "9597999", "title": "世足賽／PK大戰氣走荷蘭 摩洛哥教頭神預言：早夢到迪奧普會建功", "summary": "2026年世足賽淘汰賽戰況白熱化，「北非鐵騎」摩洛哥今天在PK大戰擊敗荷蘭，連續兩屆在淘汰賽擊退歐洲勁旅晉級，教練沃阿比（Mohamed Ouahbi）賽後透露，之前就曾夢過迪奧普（Issa Diop）將會透過頭錘為球隊建功，沒想到就發生在今天的32強賽幫助球隊扳平戰局，並將比賽帶入PK大戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090779.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 16:01", "link": "/news/story/123107/9597999"}, {"article_id": "9597986", "title": "世足運彩／轟轟轟！挪威神鋒哈蘭德活力滿滿 要衝破象牙海岸鋼鐵防線推大分", "summary": "2026年世界盃32強淘汰賽，挪威將對上象牙海岸，雙方進攻火力強勁。挪威主力哈蘭德與厄德高需突破象牙海岸的防線，並減少失球風險。預測本場比賽將出現2.5大分。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090736.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 15:59", "link": "/news/story/123105/9597986"}, {"article_id": "9597793", "title": "NBA／補強最缺的外線火力 活塞3年2700萬鎂續留射手赫爾特", "summary": "底特律活塞與後衛赫爾特簽下3年2700萬美元合約，旨在強化外線火力。赫爾特自2月加盟後，平均得分8.6，三分命中率29.4％，表現未達預期。活塞還從雷霆交易來射手喬伊，希望改善上季的三分球命中率。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090358.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&sl=W&fw=360", "date": "2026-06-30 15:53", "link": "/news/story/7002/9597793"}, {"article_id": "9597850", "title": "世足運彩／神鋒哈蘭德蓄力滿格！象牙海岸恐難接刀 Gemini看好挪威2:1或3:1", "summary": "2026世界盃32強淘汰賽火熱開踢，挪威在分組賽最後一戰對陣法國時，老謀深算地將當家神鋒哈蘭德等多名主力高掛免戰牌，雖以1比4吞敗，卻成功蓄積了淘汰賽所需的關鍵體能，並如願挑中象牙海岸作為對手。這種策", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090716.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 15:52", "link": "/news/story/123105/9597850"}, {"article_id": "9597978", "title": "影／苗栗市全民運動館迎開幕 7月起市公所連辦3波體驗券抽獎", "summary": "苗栗市全民運動館將於7月中旬開幕啟用，市公所特別將部分權利金收入回饋市民，規畫提供1萬張免費體驗運動券，7月1日起開放三波網路登記及抽獎。希望透過實際體驗方式鼓勵更多民眾接觸運動、培養規律運動習慣，進而提升苗栗市整體運動風氣與市民健康。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090700.jpg&M=1&s=Y&x=0&y=0&sw=1081&sh=721&exp=3600&sl=W&fw=360", "date": "2026-06-30 15:47", "link": "/news/story/7005/9597978"}, {"article_id": "9597851", "title": "世足運彩／對決象牙海岸晉級壓力推高主動性 GPT看好挪威正賽不讓分勝出", "summary": "32強淘汰賽一戰定生死，排名第31的挪威只比象牙海岸高2席，卻被國際盤壓到客勝2.274，這不是單純尊重排名，而是莊家認定挪威在必須贏球的情境下，進攻端更有能力把比賽推向自己熟悉的節奏。\n象牙海岸小組", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090681.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 15:45", "link": "/news/story/123105/9597851"}, {"article_id": "9597945", "title": "NBA／傳湖人有意8位自由球員 將和唐西奇欣賞的中鋒杜倫會面", "summary": "湖人隊休賽季以4年1.85億美元留里夫斯（Austin Reave）後，還有超過5000萬美元薪資空間，填補陣容上許多空缺，多位自由球員傳出已在湖人補強雷達範圍內。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090676.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-30 15:44", "link": "/news/story/7002/9597945"}, {"article_id": "9597867", "title": "世足運彩／墨西哥和厄瓜多將展開高強度防守肉搏 Gemini推薦雙方和局", "summary": "在世界盃32強生死戰中，墨西哥面對厄瓜多的賠率異常，主勝高達8.965。歷史交鋒裡墨國優勢明顯，防守尚未失球。但市場傾向看好和局，可能成為最佳投資選擇。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090635.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 15:35", "link": "/news/story/123105/9597867"}, {"article_id": "9597916", "title": "日職／孫易磊二軍6局失2分優質先發勝 助火腿擊敗樂天", "summary": "日職北海道日本火腿鬥士隊台灣投手孫易磊21日下二軍，今天在二軍先發出賽，投6局失2分優質先發，火腿終場以5比2擊敗樂天金...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090623.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-30 15:33", "link": "/news/story/7001/9597916"}, {"article_id": "9597866", "title": "世足運彩／墨西哥背著全勝包袱 GPT看好厄瓜多不讓分勝、正比2：1", "summary": "在2026美加墨世足淘汰賽中，墨西哥雖然近5戰全勝，但在投注市場卻遭遇逆風，厄瓜多被視為熱門。推薦投注厄瓜多勝出，預期比分2比1。墨西哥需面對能否承受必勝壓力的挑戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090617.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 15:30", "link": "/news/story/123105/9597866"}, {"article_id": "9597861", "title": "世足運彩／法國體能亮紅燈、強碰北歐鐵壁瑞典 Gemini推薦雙方和局", "summary": "法國足球隊因主力球員體能負擔沉重，面臨迎戰瑞典的挑戰。瑞典以強勁防守著稱，雙方預計將陷入防守拉鋸，常規時間有望以1比1和局結束，市場對瑞典勝算反應異常看好。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090583.jpg&M=1&s=Y&x=0&y=0&sw=1185&sh=790&exp=3600&sl=W&fw=360", "date": "2026-06-30 15:24", "link": "/news/story/123105/9597861"}, {"article_id": "9597906", "title": "日職／林安可二軍待1個月狂炸6轟重返一軍 參戰西武、軟銀首位攻防戰", "summary": "台灣強打林安可在日職二軍待了1個月，今天確定重返前線，西武獅隊今天起展開與軟銀鷹隊3連戰，也是太平洋聯盟首位攻防戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34937736.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-30 15:19", "link": "/news/story/7001/9597906"}, {"article_id": "9597860", "title": "世足運彩／姆巴佩遭中衛線壓縮進攻空間 GPT看好瑞典不讓分勝法國、正比2：1", "summary": "瑞典在與法國的世足賽中，雖然排名僅第38，但市場觀點卻將其視為優勢方，預測法國將面臨挑戰。面對姆巴佩，瑞典中衛線的防守策略可能壓縮法國的進攻空間，進而影響比賽結果。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35090544.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 15:19", "link": "/news/story/123105/9597860"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9597351", "title": "世足賽／摩洛哥PK大戰險勝荷蘭 再次晉級16強迎戰加拿大", "date": "2026-06-30 12:04", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35089607.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9597351"}, {"article_id": "9597135", "title": "世足賽／首度PK吞敗 德國球星：我很抱歉⋯⋯⋯⋯", "date": "2026-06-30 11:01", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35089302.jpg&M=1&s=Y&x=0&y=13&sw=997&sh=665&exp=3600&w=300", "link": "/news/story/123107/9597135"}, {"article_id": "9596933", "title": "世足賽／PK大戰擋下德國兩球 巴拉圭門將曝關鍵原因", "date": "2026-06-30 10:03", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35088986.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9596933"}, {"article_id": "9598334", "title": "世足賽／荷蘭海牙街頭摩洛哥球迷歡欣鼓舞 與警爆衝突遭壓制逮捕", "date": "2026-06-30 18:52", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35091275.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9598334"}, {"article_id": "9596962", "title": "世足賽／追趕梅西的車尾燈 姆巴佩、哈蘭德拚進球數", "date": "2026-06-30 16:30", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35089024.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&w=300", "link": "/news/story/123107/9596962"}]}, {"name": "世足運彩大預測", "articles": [{"article_id": "9597986", "title": "世足運彩／轟轟轟！挪威神鋒哈蘭德活力滿滿 要衝破象牙海岸鋼鐵防線推大分", "date": "2026-06-30 15:59", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.u