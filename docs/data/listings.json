e": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35002315.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9538339", "title": "中職／英雄不怕出身低 李東洺、曾家輝野球人生倒吃甘蔗", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35001531.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9542315", "title": "法網／20歲門西克首闖4強 締造捷克最年輕紀錄", "summary": "20歲的捷克小將門西克（Jakub Mensik）今年法網打出代表作，台灣時間今天凌晨他以6：4、6：3、7：6（7：3）力退巴西新星豐塞卡（Joao Fonseca） ，闖進4強，持續改寫個人在大滿貫的最佳成績。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_7.jpg", "date": "2026-06-03 08:51"}, {"article_id": "9542301", "title": "法網／男單新生代對決 門西克直落三勝豐塞卡挺進4強將戰澤瑞夫", "summary": "法網今天凌晨上演新生代好手對決，在男單8強賽上20歲的捷克新星門西克（Jakub Mensik）展現強大氣場，以6：4、6：3、7：6（7：3）直落三盤，終結了19歲巴西黑馬豐塞卡（Joao Fonseca）的黑馬之旅，強勢挺進男單4強。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_3.jpg", "date": "2026-06-03 08:41"}, {"article_id": "9542293", "title": "NBA／總冠軍賽明燃戰火 尼克羅賓森手指骨折仍渴望上陣", "summary": "NBA總冠軍賽即將在明天點燃戰火，相隔27年重返冠軍賽舞台的尼克，卻在賽前傳出傷兵隱憂，主力禁區悍將羅賓森（Mitchell Robinson）因上周動刀治療右手骨折，目前被球隊列為「出賽成疑」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_9.jpg", "date": "2026-06-03 08:31"}, {"article_id": "9542247", "title": "NBA／黑衫軍暌違12年重返總冠軍賽 「波波文化」成精神支柱", "summary": "馬刺在驚險贏得西區冠軍賽搶七大戰後，宣告暌違12年再度挺進NBA總冠軍賽，雖然這也是黑衫軍首次在沒有傳奇教頭波波維奇（Gregg Popovich）坐鎮的情況下爭奪總冠軍獎盃，但這位名人堂教頭留下的冠軍DNA，依然是年輕馬刺最頂級的精神財富。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_7.jpg", "date": "2026-06-03 07:58"}, {"article_id": "9542014", "title": "中職／再度燃起的旅外夢 張育成進化成最強全方位打者", "summary": "張育成於2024年進化為中職最強全方位打者，以37場比賽打擊三圍0.356/0.453/0.591及7轟的驚人成績，表現優於去年最佳打者林安可。富邦悍將與他簽下9250萬元合約，期望助力球隊衝擊首冠。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006557.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 07:00"}, {"article_id": "9541372", "title": "日職／阿部事件引社會譁然 日本棒球為何無法擺脫暴力形象？", "summary": "阿部慎之助因家暴醜聞被巨人隊開除，揭示日本棒球界根深蒂固的暴力文化。過去多起事件顯示，體罰與霸凌問題影響選手與球隊形象，暴力行為仍未根除，引發社會廣泛關注與討論。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005941.jpg&M=1&s=Y&x=0&y=40&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 07:00"}, {"article_id": "9541372", "title": "日職／阿部事件引社會譁然 日本棒球為何無法擺脫暴力形象？", "summary": "阿部慎之助因家暴醜聞被巨人隊開除，揭示日本棒球界根深蒂固的暴力文化。過去多起事件顯示，體罰與霸凌問題影響選手與球隊形象，暴力行為仍未根除，引發社會廣泛關注與討論。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005941.jpg&M=1&s=Y&x=0&y=40&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 07:00"}, {"article_id": "9542014", "title": "中職／再度燃起的旅外夢 張育成進化成最強全方位打者", "summary": "張育成於2024年進化為中職最強全方位打者，以37場比賽打擊三圍0.356/0.453/0.591及7轟的驚人成績，表現優於去年最佳打者林安可。富邦悍將與他簽下9250萬元合約，期望助力球隊衝擊首冠。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006557.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 07:00"}, {"article_id": "9541971", "title": "棒球／竹市組城市棒球隊 找來陳瑞振任教頭", "summary": "新竹市政府為推動棒球運動發展，市長高虹安昨宣布六月籌組「新竹市城市棒球隊」，在副市長林琨瀚及市政顧問張泰山見證下，授帽給總教練陳瑞振。市府指出，未來城市棒球隊除投入各項成棒賽事外，也將積極與新竹市三級棒球體系合作，鼓勵棒球人才深耕新竹。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006498.jpg&M=1&s=Y&x=200&y=113&sw=910&sh=607&exp=3600&sl=W&fw=360", "date": "2026-06-03 00:00"}, {"article_id": "9541878", "title": "中職／王建民怒了！狠甩牛棚電話門 連轉播台都嚇到", "summary": "中信兄弟隊今天以3：7不敵統一獅隊，投手群出現8次四壞球保送，第九局盧孟揚登板連投3保送，投手教練王建民怒摔電話門，不只球迷驚呼，連轉播台上都直言這很少見。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006435.jpg&M=1&s=Y&x=0&y=32&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-02 22:51"}, {"article_id": "9541821", "title": "中職／飛力獅→菲力士 林岳平觀察有一樣也有不一樣", "summary": "「飛力獅」化為「菲力士」後，今天首度面對前東家統一獅隊，以5.2局失5分承擔敗投，此役呈現出來的狀態，獅隊教頭林岳平指出，在獅隊時期也有看過，若看球速的話，是與去年最好時期確實有落差。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006375.jpg&M=1&s=Y&x=29&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-06-02 22:19"}, {"article_id": "9541807", "title": "TPBL／球員時期完成過大逆轉 簡浩激勵夢想家「不能放棄」", "summary": "球員時期曾在冠軍賽1比3絕對落後下連勝3場奪冠，簡浩接下福爾摩沙夢想家兵符後又陷入同樣絕境，他以自身經驗勉勵球員「不能放棄」，今天回到台中主場團隊就以105：69大勝衛冕軍新北國王，將總冠軍賽延長到第6戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006357.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 22:12"}, {"article_id": "9541780", "title": "印尼羽賽／李家雙胞胎力退奧運銀牌 男雙將上演寶島內戰", "summary": "總獎金145萬美金的印尼羽球公開賽今天點燃戰火，台灣羽將在雙打突圍，李哲輝／楊博軒3局力退地主卡爾南多（Leo Rolly Carnando）／馬丁（Daniel Marthin），雙胞胎李芳任／李芳至更扳倒列第5種子的巴黎奧運銀牌中國組合梁偉鏗／王昶，和李楊配第二輪會師，「寶島內戰」等於為台將預約一席8強門票。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006331.jpg&M=1&s=Y&x=40&y=0&sw=1160&sh=773&exp=3600&sl=W&fw=360", "date": "2026-06-02 21:53"}, {"article_id": "9541770", "title": "中職／勝率確定沒5成 上半季爭冠已經沒兄弟的事", "summary": "中信兄弟隊今天以3：7不敵統一獅隊，2連勝畫下句點，輸球後戰績13勝30敗1和，確定上半季勝率未達5成，也篤定無緣季冠軍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006318.jpg&M=1&s=Y&x=0&y=0&sw=1023&sh=682&exp=3600&sl=W&fw=360", "date": "2026-06-02 21:46"}, {"article_id": "9541733", "title": "TPBL／回主場36分大勝國王 夢想家總冠軍賽延長戰線", "summary": "陷入退無可退局面的福爾摩沙夢想家，主戰洋將霍爾曼雖因手掌骨骨折賽季提前報銷，但今天冠軍賽第5戰本土、洋將都有發揮，第三節打出35：17攻勢奠定勝基，被水一戰在主場以105：69力退衛冕軍新北國王，將總冠軍賽延長到周四的第6戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006285.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 21:27"}, {"article_id": "9541272", "title": "中職／陳鏞基關節發炎已調整恢復 預計3日回到一軍", "summary": "中職統一7-ELEVEn獅隊42歲老將陳鏞基先前因為關節發炎下二軍，總教練林岳平表示，陳鏞基已經調整恢復，時間到了明天就...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005978.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 18:44"}, {"article_id": "9541400", "title": "中職／彭政閔接領隊主要任務戰力統籌 行政、談薪交給專業", "summary": "中信兄弟隊今天進行人事異動，彭政閔升任中信兄弟球團領隊，二軍總教練將由中信兄弟農場野手發展總監林明憲兼任，周思齊則接掌中信兄弟農場主管。對於接下領隊任務，彭政閔坦言：「心情複雜，就盡力而為，盡力把球隊現階段狀況給予更多正向能量，讓球隊越來越好。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005963.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 18:27"}, {"article_id": "9541388", "title": "NBA／爆料前太陽主帥有酗酒問題 諾基奇：甚至教KD怎麼得分", "summary": "前鳳凰城太陽中鋒諾基奇（Jusuf Nurkic）近日在節目中公開談到效力太陽期間與前總教練布丹霍澤（Mike Budenholzer）的合作經驗，並對這位冠軍教頭提出嚴厲批評。他不僅質疑布丹霍澤的領導方式與球隊內部溝通環境，甚至指稱對方當時存在酗酒問題，讓太陽更衣室與執教狀況再度成為話題。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005950.jpg&M=1&s=Y&x=85&y=89&sw=1103&sh=735&exp=3600&sl=W&fw=360", "date": "2026-06-02 18:25"}, {"article_id": "9541340", "title": "中職／兄弟異動無關戰績 劉志威：一直以來都沒有考量教練團調整", "summary": "中信兄弟隊今天公布人事異動，並非教練團異動，而是由兩位隊史傳奇球星彭政閔、周思齊接手球隊運作，分別出任領隊、農場主管，中信育樂營運長劉志威表示，這項異動與球隊戰績沒有任何關係，一直以來也都沒有教練團調整的考量。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005907.jpg&M=1&s=Y&x=0&y=0&sw=1259&sh=840&exp=3600&sl=W&fw=360", "date": "2026-06-02 18:01"}, {"article_id": "9541244", "title": "NBA／阿努諾比等待7年再闖總冠軍賽 感嘆「才知道重返舞台有多難」", "summary": "紐約尼克本季一路在季後賽打出火燙氣勢，自1998-99年賽季後再度闖進總冠軍賽。對於陣中側翼悍將阿努諾比（OG Anunoby）來說，這不只是尼克長年等待後的突破，也是他個人生涯第2次體驗總冠軍賽舞台。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005873.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 18:00"}, {"article_id": "9541099", "title": "韓職／明星賽投票開跑 先發投手韓華鷹推薦王彥程", "summary": "韓職明星賽將於7月11日在蠶室棒球場登場，先發投手位置韓華鷹並未推薦老將柳賢振、而是「台灣王子」王彥程，票選結果22日出...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005872.jpg&M=1&s=Y&x=64&y=0&sw=1159&sh=773&exp=3600&sl=W&fw=360", "date": "2026-06-02 17:59"}, {"article_id": "9541222", "title": "中職／洋將FA從228改115直言意義不大 餅總：不如設轉隊費", "summary": "中職聯盟昨天領隊會議確定「228洋將條款」走入歷史，洋將與原球隊議約最終日為1月15日，之後便視為自由球員，統一獅隊總教練林岳平看這項變革，直言沒有什麼意義，不需以時間點設限接觸、轉隊，「倒不如設轉隊費。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005689.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-02 17:15"}, {"article_id": "9541139", "title": "MLB／大谷翔平二刀流價值！9季累積全壘打聯盟第3、防禦率第2", "summary": "洛杉磯道奇日籍巨星大谷翔平本季持續以二刀流身分改寫大聯盟想像，而從他2018年登上MLB舞台以來的累積成績來看，他不只是一名歷史級打者，也是一名具備高度壓制力的頂尖投手。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005559.jpg&M=1&s=Y&x=37&y=0&sw=1100&sh=733&exp=3600&sl=W&fw=360", "date": "2026-06-02 17:08"}, {"article_id": "9541201", "title": "中職／獅隊愛開盲盒、兄弟買確認款 餅總不競價洋投考量投報率", "summary": "統一獅隊洋投近年成為各隊挖角市場，而獅隊也成最常嘗試全新面孔外援的球隊，總教練林岳平指出，原有洋投被挖走，代表合約價碼會更高，當投資報酬風險太高，就會思考能否用合理價碼找到同等戰力，他不諱言獅隊在看洋投上，「我認為我們有我們獨特的看法。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005635.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 17:07"}]}, {"name": "棒球", "articles": [{"article_id": "9541878", "title": "中職／王建民怒了！狠甩牛棚電話門 連轉播台都嚇到", "date": "2026-06-02 22:51", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006435.jpg&M=1&s=Y&x=0&y=32&sw=1280&sh=854&exp=3600&w=300"}, {"article_id": "9541770", "title": "中職／勝率確定沒5成 上半季爭冠已經沒兄弟的事", "date": "2026-06-02 21:46", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006318.jpg&M=1&s=Y&x=0&y=0&sw=1023&sh=682&exp=3600&w=300"}, {"article_id": "9541400", "title": "中職／彭政閔接領隊主要任務戰力統籌 行政、談薪交給專業", "date": "2026-06-02 18:27", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005963.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9541971", "title": "棒球／竹市組城市棒球隊 找來陳瑞振