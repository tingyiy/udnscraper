oto.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34965771.jpg&M=1&s=Y&x=0&y=0&sw=800&sh=533&exp=3600&w=300"}, {"article_id": "9515500", "title": "大聯盟指叉球使用量日增 為什麼左投手反而不投？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966735.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9520954", "title": "MLB／例行賽就是贏不了！道奇全場僅3安吞對戰釀酒人9連敗", "summary": "道奇今日面對釀酒人始終缺少關鍵一擊，全場道奇得點圈7打數0安打，留下9名殘壘，有跑者上壘時更是17打數僅1安。全隊僅敲3支安打，最終以1：5吞敗，苦吞例行賽對戰釀酒人9連敗，系列賽首戰失利也讓近期打線不穩問題再度浮現。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34974966.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-23 12:58"}, {"article_id": "9521010", "title": "世足賽／英格蘭26人名單大換血 老將馬奎爾落選全家心有不甘", "summary": "英格蘭總教練圖赫爾（Thomas Tuchel）公布了美加墨世界盃26人名單，陣容大幅換血，其中最大遺珠是切爾西的帕爾默（Cole Palmer）和皇家馬德里邊後衛阿諾德（Trent Alexander-Arnold），甚至也沒有應有一席之地的老將馬奎爾（Harry Maguire）。\n帕爾默曾在2024年歐洲盃決賽英格蘭1：2不敵西班牙之戰中進球，這次他是兩名落選的切爾西大咖之一，另一人是科維爾（Levi Colwill），因他仍未從持續困擾的膝傷中復原。\n阿諾德則再次被圖赫爾排除在外，這位德國籍教頭今年至今從未把這名前利物浦球員列入任何一期名單。在圖赫爾麾下，這位皇馬球員只踢了27分鐘，今夏只能在家裡沙發上看世界盃。\n而另一個讓人意外的是老將馬奎爾也不在名單中，事實上他在官方公布前已被告知落選，自己則對未被列入英格蘭名單感到「震驚」。\n現年33歲的馬奎爾已為英格蘭出賽66場，曾參加2018年與2022年世界盃，以及2020年歐洲盃。他提前一天在Instagram上抒發挫折感：「以我本季的表現，我原本很有信心能在今夏為國家隊扮演重要角色。這個決定讓我感到震驚，也非常難受。」\n「這些年", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34975047.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-23 12:48"}, {"article_id": "9520972", "title": "韓職／「沒有王彥程韓華鷹怎麼辦！」 韓媒讚：台灣的柳賢振", "summary": "韓職韓華鷹隊左投王彥程昨天繳出7局僅失2分好投，拿下第5勝並列KBO勝投王。王彥程幫助球隊止敗的表現，韓媒紛紛下標「如果...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34975001.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-23 12:28"}, {"article_id": "9520885", "title": "NBA／馬刺開賽15：0白忙 雷霆板凳狂飆76分系列賽2：1反超", "summary": "NBA西區冠軍賽第三戰今天移師到聖安東尼奧舉行，回到主場出賽的馬刺隊在迎回主控福克斯（De'Aaron Fox）的情況下，今天開賽雖然一度打出15：0的攻勢，但雷霆隊靠著板凳群的凶猛進攻火力逆轉戰局，最終在板凳球員合力攻下76分下，最終以123：108擊敗馬刺，系列賽以2：1領先。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34974880.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-23 11:35"}, {"article_id": "9520804", "title": "MLB／黃金年代傳奇落幕！「道奇瑞士刀」泰勒告別12年大聯盟生涯", "summary": "曾效力於道奇長達10年的工具人名將泰勒(Chris Taylor)，今日正式宣布退休，結束12年大聯盟生涯。這位生涯累積2座世界大賽冠軍，並在2017年國聯冠軍賽拿下共同MVP的「道奇瑞士刀」，也替自己的職棒旅程劃下句點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34974769.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-23 11:02"}, {"article_id": "9520782", "title": "MLB／洋基王牌回歸！柯爾復出首戰6局無失分 牛棚放火勝投飛了", "summary": "紐約洋基隊投手柯爾（Gerrit Cole）暌違569天重返大聯盟投手丘，今天出戰美聯東區龍頭坦帕灣光芒隊，繳出6局無失分的表現，僅被敲2支安打，送出2次三振，宣告「王牌回歸」，但他退場後牛棚放火，洋基隊最終以2：4遭逆轉，柯爾復出首勝飛了。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34974739.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-23 10:37"}, {"article_id": "9520739", "title": "MLB／李灝宇雙安都有打點 老虎兩度領先被年薪6億投手燒光慘吞7連敗", "summary": "台灣好手李灝宇先發出賽3打數貢獻雙安、兩分打點，兩支安打都曾為球隊打下優勢，但最終老虎隊仍以4：7不敵金鶯隊，吞下7連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34974705.png&M=1&s=Y&x=82&y=0&sw=1052&sh=701&exp=3600&sl=W&fw=360", "date": "2026-05-23 10:20"}, {"article_id": "9520722", "title": "NBA／「我甚至還沒家庭旅行」詹姆斯透露未來決定恐拖至8月", "summary": "現年41歲的「小皇帝」詹姆斯（LeBronJames）近日在自己的節目《Mind the Game》中談到未來動向時坦言，目前不急著決定下一步，甚至透露關於下一站的去向，可能得一路拖到7月甚至8月才會明朗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34974683.jpg&M=1&s=Y&x=0&y=286&sw=853&sh=569&exp=3600&sl=W&fw=360", "date": "2026-05-23 10:20"}, {"article_id": "9520728", "title": "NBA／單場83分後的溫柔 暖男阿德巴約獲頒社會正義獎", "summary": "本賽季曾單場狂飆83分、寫下NBA歷史次高紀錄的熱火隊當家球星阿德巴約（Bam Adebayo），在球場上是摧枯拉朽的內線禁區野獸，然而在球場之外，他選擇將個人的榮耀與影響力，化作守護弱勢孩童的巨大溫柔，並在今天獲頒「賈霸社會正義冠軍獎」，肯定他長期為弱勢群體爭取平等與權益的無私奉獻。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34974664.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-23 10:14"}, {"article_id": "9520616", "title": "NBA／年度防守陣容出爐 溫班亞瑪全票入選領銜「新長人時代」", "summary": "NBA聯盟在今天公布今年年度防守陣容，本季以「全票之姿」獲選年度最佳防守球員的馬刺中鋒溫班亞瑪（Victor Wembanyama），再度毫無懸念地以全票入選防守第一隊，這位法國長人不僅連續三季稱霸聯盟阻攻王，更用驚人的防守覆蓋率，宣告屬於新世代長人的防守帝國正式來臨。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34974612.jpg&M=1&s=Y&x=0&y=0&sw=1200&sh=800&exp=3600&sl=W&fw=360", "date": "2026-05-23 08:45"}, {"article_id": "9520277", "title": "中職／拿莫．伊漾化悲傷為力量 大巨蛋開轟獻給過世舅舅", "summary": "味全龍隊拿莫．伊漾化悲傷為力量，今天對中信兄弟代打開轟，敲出超前2分砲助隊搶勝，他將生涯第2發代打轟、也是睽違630天的...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34973959.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-22 23:19"}, {"article_id": "9520287", "title": "中職／桃猿PitchCom首位使用投手 曾家輝節奏被打亂首局就喊停", "summary": "樂天桃猿今天在主場出戰富邦悍將隊，新到貨PitchCom（電子暗號發送器）正式啟用，曾家輝、宋嘉翔成為隊上搶先配戴的投捕搭檔，但開賽因還不習慣，曾家輝坦言投球節奏有點被打亂，之後改回由捕手用手比暗號的方式，狀況才回穩。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34974648.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-22 22:48"}, {"article_id": "9520248", "title": "中職／拿莫．伊漾代打轟助龍6連勝 開季二軍出發非狀況差", "summary": "中職味全龍隊今天9局上靠著拿莫．伊漾代打2分砲，以7比2擊敗中信兄弟、本季首度6連勝；龍隊總教練葉君璋透露，拿莫．伊漾其...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34974624.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 22:35"}, {"article_id": "9520271", "title": "中職／桃猿PitchCom到貨後直接一軍啟用 投捕都還在適應", "summary": "樂天桃猿新購入的PitchCom（電子暗號發送器）周二到貨，今天面對富邦悍將隊的比賽，賽前球隊也沒有透露相關消息，今天就首度在比賽中啟用，但開賽投捕都還在適應，先發投手曾家輝的狀況也因此受影響，總教練曾豪駒說：「如果慢慢適應了，相信會越來越好。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/2025/11/09/realtime/33606997.jpg&s=Y&x=0&y=0&sw=3539&sh=2359&exp=3600&sl=W&fw=360", "date": "2026-05-22 22:30"}, {"article_id": "9520216", "title": "中職／王柏融No.101轟炸裂！ 台鋼3：1賞獅子軍3連敗", "summary": "台鋼雄鷹結束花蓮賽事後，今天回到主場澄清湖棒球場對戰統一獅隊，雙方前5局打完戰成1：1平手，6局下「台鋼大王」王柏融揮出本季第5轟、生涯第101轟超前比數，打下勝利打點，終場雄鷹就以3：1勝出，終止近期2連敗，獅隊則是吞下3連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34973873.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 21:50"}, {"article_id": "9520157", "title": "高球／TLPGA大聯大女子公開賽 李欣續領先、曾雅妮緊追", "summary": "TLPGA大聯大女子高爾夫公開賽，今天在揚昇高爾夫俱樂部進行第2回合，地主好手李欣抓5博蒂、0柏忌，繳出全場最低67桿，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34974642.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 21:34"}, {"article_id": "9520189", "title": "中職／曾家輝5局好投、林智平致勝一擊 桃猿3：2逆轉悍將收2連勝", "summary": "樂天桃猿隊今起在主場和富邦悍將隊展開3連戰，23歲曾家輝先發5局失1分，打線則敲出8支安打，靠41歲林智平在3局下敲出致勝一擊，終場猿隊以3：2擊敗近況正旺的悍將隊，收下二連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34932271.jpg&M=1&s=Y&x=145&y=8&sw=824&sh=549&exp=3600&sl=W&fw=360", "date": "2026-05-22 21:25"}, {"article_id": "9520087", "title": "中職／黃暐傑調整狀況「較特別」 葉君璋直言就差自信心", "summary": "中職味全龍隊投手黃暐傑下二軍往先發調整，總教練葉君璋表示「他比較特別」，直言「教練對他有信心，但他自己沒有信心」，現在就...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/03/34912071.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-05-22 20:43"}, {"article_id": "9520152", "title": "韓職／王彥程首度投滿7局失2分 奪本季第5勝", "summary": "韓職台灣左投王彥程休一周後，今天在主場迎戰斗山熊隊，前6局沒有失分，續投第7局被敲3支安打失2分，但成功守住球隊領先優勢，繳出7局失2分的優質先發，也是他旅韓首度投滿7局，幫助球隊以5：3拿下勝利，王彥程收下本季第5勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34974629.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 20:40"}, {"article_id": "9520033", "title": "亞運棒球／名古屋亞運棒球培訓24人名單 大學投手雷皓博入選", "summary": "2026年名古屋亞運棒球項目代表隊由總教練湯登凱領軍，培訓隊經過6場藍白賽，今天賽後篩選出24人名單，唯一入選的大學球員...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34974632.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-22 19:18"}, {"article_id": "9520038", "title": "全障運／呂如晃保齡球TPB10男子全項2連霸 還是百家團購店董事長", "summary": "67歲的呂如晃在115年全國身心障礙國民運動會，代表台南市勇奪2金、2銀、1銅，他謙虛表示是運氣好，想不到更厲害的是他慧眼獨具，當年看見團購商機開展事業，如今在全台坐擁超過百家加盟店，是南台灣團購第一品牌「莊敬生活百貨」董事長。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34973670.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 19:14"}, {"article_id": "9520037", "title": "中職／何品室融降二軍後長打連發 曾總：擊球紮實度穩定就上來", "summary": "樂天桃猿隊20歲新秀何品室融今年開季起在一軍出賽24場，但進入5月後手感急凍，在18日被降二軍調整，這兩天他在二軍長打連發，猿隊總教練曾豪駒也有看到，「如果他的擊球紮實度慢慢穩定，就可以馬上讓他上來。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951587.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 19:13"}, {"article_id": "9520003", "title": "中職／游竣宥找球速下滑原因 「藏球」特色盼放大優勢", "summary": "中信兄弟22歲左投游竣宥一軍初先發無關勝敗，今年球速稍微下滑，游竣宥找原因，嘗試降體重調整，自知非速球派投手，總教練平野...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966480.jpg&M=1&s=Y&x=0&y=1&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 19:11"}, {"article_id": "9520019", "title": "帕拉桌球／台北精英賽首度升格ITTF最高級賽事 中華隊狂掃4金", "summary": "「2026年台北市國際帕拉桌球精英賽」近日在中國文化大學大孝體育館正式落幕，本次賽事由運動部指導、中華帕拉林匹克總會主辦，首度升格為國際桌球總會（ITTF）最高等級的「Elite 精英賽」，中華隊在5天賽程中斬獲優異戰績，在單打項目拿下2金、2銀、3銅，雙打賽事再進帳2金、1銀、3銅。其中，巴黎帕運銀牌好手陳柏諺表現亮眼，包辦金、銀、銅3面獎牌。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34973635.jpg&M=1&s=Y&x=0&y=0&sw=864&sh=576&exp=3600&sl=W&fw=360", "date": "2026-05-22 19:00"}]}, {"name": "棒球", "articles": [{"article_id": "9520972", "title": "韓職／「沒有王彥程韓華鷹怎麼辦！」 韓媒讚：台灣的柳賢振", "date": "2026-05-23 12:28", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/23/34975001.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600