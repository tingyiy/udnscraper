": "/news/story/6999/9554538"}], "subsections": [{"name": "專欄", "articles": [{"article_id": "9554916", "title": "馬刺贏下G3生死戰減壓 過程險象環生對「神仙尼克」仍難樂觀", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026372.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9554916"}, {"article_id": "9553586", "title": "日職／可能陷連戰地獄又強碰軟銀 阪神要用鐵腕克服恐鷹症", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024466.jpg&M=1&s=Y&x=0&y=46&sw=800&sh=533&exp=3600&w=300", "link": "/news/story/122629/9553586"}, {"article_id": "9553409", "title": "世足攻略／K組葡萄牙獨強 烏茲別克處女秀扮攪局者", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024379.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9553409"}, {"article_id": "9552959", "title": "從場上指揮官到ESPN球評！林書豪用哈佛球商解析馬刺致命傷", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023594.jpg&M=1&s=Y&x=102&y=0&sw=864&sh=576&exp=3600&w=300", "link": "/news/story/122629/9552959"}, {"article_id": "9552856", "title": "「5-Out」並未摧毀溫班亞瑪體系 馬刺找到破解尼克新方向", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023398.jpg&M=1&s=Y&x=50&y=24&sw=1129&sh=753&exp=3600&w=300", "link": "/news/story/122629/9552856"}, {"article_id": "9551432", "title": "唐斯教訓溫班亞瑪當嚴父 馬刺青年軍眾多問題有待解答回應", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/07/35021188.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9551432"}]}, {"name": "最新文章", "articles": [{"article_id": "9555118", "title": "結合厭世迷因文化 海綿寶寶人生馬拉松北中南三地開跑", "summary": "《2026海綿寶寶人生馬拉松》正式登場，以「人生馬拉松，人生是場謎」為主題，結合近年最具共鳴的厭世迷因文化，將現代上班族職場壓力、生活疲憊與日常情緒，轉化為一場充滿幽默感與療癒的沉浸式路跑體驗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026540.png&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-09 13:22", "link": "/news/story/7005/9555118"}, {"article_id": "9555102", "title": "TPBL／前宇都宮冠軍教頭入港 紐西蘭籍齊科執掌海神兵符", "summary": "TPBL高雄全家海神今天宣布新賽季將由前日本B聯盟宇都宮皇者總教練、紐西蘭籍齊科（Zico Coronel）執掌兵符，雙方簽下複數年合約，齊科擁有超過20年執教資歷，擔任總教練及助理教練期間奪下7座總冠軍，2021年、2025年更分別獲紐西蘭NBL、日本B聯盟年度最佳教練殊榮。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026509.jpg&M=1&s=Y&x=0&y=0&sw=1023&sh=682&exp=3600&sl=W&fw=360", "date": "2026-06-09 13:14", "link": "/news/story/7003/9555102"}, {"article_id": "9555091", "title": "NBA／手感不佳卻投進關鍵球 溫班亞瑪談福克斯：最可靠的那種球員", "summary": "馬刺今天在總冠軍賽第3戰於尼克主場背水一戰，在第四節幾乎一路領先的情況下，卻又在比賽最後一分鐘被尼克步步近逼，但關鍵時刻整場比賽手感不佳的福克斯（De'Aaron Fox），卻在雙人包夾下投進致命中距離跳投，幫助馬刺守成，賽後溫班亞瑪（Victor Wembanyama）與卡瑟爾（Stephon Castle）也大讚福克斯的大心臟，並強調他絕對是球隊在關鍵時刻最可靠的球員。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026505.jpg&M=1&s=Y&x=0&y=139&sw=853&sh=569&exp=3600&sl=W&fw=360", "date": "2026-06-09 13:10", "link": "/news/story/7002/9555091"}, {"article_id": "9555088", "title": "MLB／亞土維奇襲跑壘幫太空人贏球 明天交給鄧愷威拚連勝", "summary": "太空人隊作客洛杉磯，今天對天使隊進行3連戰首戰，36歲老將亞土維（Jose Altuve）10局上發動奇襲，從三壘冒險衝向本壘得分，太空人終場以5：4獲勝，明天第2戰先發任務交給台灣投手鄧愷威。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026495.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-09 13:08", "link": "/news/story/6999/9555088"}, {"article_id": "9555039", "title": "NBA／不滿下半場罰球數24比8 尼克主帥：沒想過總冠軍賽會看到這種事", "summary": "尼克在總冠軍賽第3戰以111比115不敵馬刺，終結季後賽13連勝，同時系列賽也被追成2比1。賽後尼克總教練布朗（Mike Brown）公開表達對判罰尺度的不滿，尤其針對馬刺下半場獲得24次罰球，而尼克只有8次罰球，直言這樣的落差在總冠軍賽舞台上相當難以接受。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026445.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-09 13:01", "link": "/news/story/7002/9555039"}, {"article_id": "9555049", "title": "NBA／聯手卡瑟爾寫最年輕記錄 溫班亞瑪還創下70阻攻新里程碑", "summary": "在主場連輸兩戰後，馬刺今天在總冠軍賽第三戰作客尼克主場，總算在末節關鍵時刻頂住壓力、成功守成，其中年輕雙星溫班亞瑪（Victor Wembanyama）與卡瑟爾（Stephon Castle）更成為史上第一對在總冠軍賽同場皆拿下20分以上的22歲以下組合，展現了這支年輕勁旅的可怕天賦。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026457.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 12:59", "link": "/news/story/7002/9555049"}, {"article_id": "9554916", "title": "馬刺贏下G3生死戰減壓 過程險象環生對「神仙尼克」仍難樂觀", "summary": "馬刺在G3生死戰中以115：111險勝尼克，成功減輕壓力，系列賽追成1：2。然而，尼克球隊狀況良好，尤其是布朗森表現堅穩，馬刺需調整防守策略及強攻禁區，才能向G4發起反擊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026372.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 12:50", "link": "/news/story/122629/9554916"}, {"article_id": "9554933", "title": "NBA／22歲繳全能數據比肩兩大傳奇 溫班亞瑪：最艱難還在後面", "summary": "主場吞下2連敗的馬刺，今天在紐約客場的第四節關鍵時刻靠著卡瑟爾（Stephon Castle）、福克斯（De'Aaron Fox）的關鍵進球，穩住最後領先優勢，最終以4分之差驚險擊退尼克，斬斷對方季後賽13連勝，避免被聽牌的命運。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026267.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 12:27", "link": "/news/story/7002/9554933"}, {"article_id": "9554707", "title": "澳洲羽賽／我大軍壓境33組人馬參賽 頭號種子周天成首戰自家人", "summary": "BWF超級500等級的澳洲羽球公開賽今天登場，台灣大軍壓境共33組人馬參賽；根據籤表，男單世界第6的周天成列為頭號種子，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026226.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 12:07", "link": "/news/story/7005/9554707"}, {"article_id": "9554831", "title": "MLB／水手內野戰力亮紅燈！大物新秀賽前緊急退場、克勞佛傷癒不如預期", "summary": "水手今日正式宣布，將主力游擊手克勞佛（J.P. Crawford）放入10天傷兵名單，原先接替克勞佛守游擊的百大新秀第7艾默森（Colt Emerson），也在對金鶯系列賽首戰前因背部緊繃臨時退場。在雙重打擊下，水手從3A拉上內野手布利斯（Ryan Bliss）遞補戰力，並讓22歲內野手楊恩（Cole Young）生涯首度擔任大聯盟先發游擊手。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026077.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 12:05", "link": "/news/story/6999/9554831"}, {"article_id": "9554687", "title": "MLB／昔日經典賽王牌遭DFA！古巴「Y-Rod」藍鳥生涯恐畫下句點", "summary": "藍鳥今日宣布，將古巴29歲右投「Y-Rod」羅德里奎茲（Yariel Rodriguez）指定讓渡（DFA）。事實上，這已是他近6個月內第二次遭到指定讓渡。去年休賽季時，他就曾通過讓渡程序卻無球隊願意承接合約，最終被下放至3A。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025906.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 12:04", "link": "/news/story/6999/9554687"}, {"article_id": "9554824", "title": "城市運動場錢薇娟、郭泓志領軍出擊 文姿云、林郁婷上演女力對決", "summary": "迎接品牌50周年，迪卡儂於日前在台北三重旗艦店揭開「全台最大城市運動場」序幕，台灣迪卡儂執行長堯傑倫（Hugo Jehlen）率領跑團起跑，排出「50」軌跡，為今夏橫跨全台9間門市、七個城市的運動盛典祭出精彩開場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026067.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 11:47", "link": "/news/story/7005/9554824"}, {"article_id": "9554765", "title": "NBA／在川普面前斷尼克13連勝 溫班亞瑪轟32分馬刺G3扳回一城", "summary": "NBA總冠軍賽第三戰今天移師尼克主場麥迪遜花園廣場，不僅美國總統川普與林書豪都到場觀戰，兩隊也再度打出激烈的拉鋸戰，其中背水一戰的馬刺在上半場打完雖然一度落後，但第四節靠著嚴密的防守，加上卡瑟爾（Stephon Castle）、福克斯（De'Aaron Fox）關鍵時刻連續進球，幫助馬刺最終以115：111扳回一城，系列賽追到1：2，也中斷尼克季後賽13連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025996.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 11:34", "link": "/news/story/7002/9554765"}, {"article_id": "9544997", "title": "NBA／讓川普看到輸球！馬刺擋住尼克反撲115:111客場扳回一勝", "summary": "NBA總冠軍賽G3，馬刺前往紐約踢館，麥迪遜花園廣場相隔27年再次迎接最高舞台賽事，尼克取得2勝0敗優勢，渴望終結長達53年的冠軍荒！", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025729.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-09 11:29", "link": "/news/story/7002/9544997"}, {"article_id": "9554696", "title": "NBA／馬刺0比2落後仍有希望？三少組合淨效率值透露反攻可能", "summary": "聖安東尼奧馬刺在NBA總冠軍賽前2戰都不敵紐約尼克，系列賽陷入0比2落後。隨著戰線移師麥迪遜花園廣場，馬刺總教練強森（Mitch Johnson）除了必須想辦法喚醒球隊進攻，也面臨幾個關鍵輪替抉擇，其中最重要的問題，就是是否進一步增加菜鳥後衛哈波（Dylan Harper）的上場時間。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025918.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 11:27", "link": "/news/story/7002/9554696"}, {"article_id": "9554715", "title": "MLB／巨人李政厚連16場安打 追平秋信守、金河成並列南韓最強", "summary": "巨人隊今天回到舊金山主場，對國民隊展開3連戰首戰，外野手李政厚4局下揮出右外野方向一壘打，連續16場比賽出現安打，追平大聯盟南韓球員紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025944.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 11:22", "link": "/news/story/6999/9554715"}, {"article_id": "9554686", "title": "世足賽／內馬爾復原狀況良好 開幕戰仍打問號", "summary": "身為巴西隊史進球王，內馬爾（Neymar）世足賽前卻成傷兵，上個月檢查結果是肌肉二級撕裂，不過巴西足協發表好消息，指內馬爾小腿「復原狀況良好」，為森巴軍團注入一劑強心針。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025915.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 11:15", "link": "/news/story/123107/9554686"}, {"article_id": "9554685", "title": "MLB／岡本和真暫居藍鳥雙冠王 吞86K也是美聯第2多", "summary": "藍鳥隊作客費城，對費城人隊展開3連戰，日本好手岡本和真今天4次打數掛零、吞下兩次三振，中斷連續6場比賽安打紀錄，藍鳥終場2：5輸掉系列賽首戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025905.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 11:15", "link": "/news/story/6999/9554685"}, {"article_id": "9554538", "title": "MLB／台灣火球男蘇嵐鴻恐成交易籌碼！美媒曝道奇等3隊鎖定國民游擊手", "summary": "國民主戰游擊手阿布拉姆斯（CJ Abrams）被視為眾多球隊最理想的補強目標之一。根據美媒最新消息，道奇、洋基與教士成為最有機會出手的球隊。值得注意的是，來自台灣的高雄19歲右投蘇嵐鴻也被列入交易包裹。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025636.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 10:54", "link": "/news/story/6999/9554538"}, {"article_id": "9554558", "title": "NBA／詹姆斯遊艇揮桿把高爾夫球打進地中海惹議 最重可判刑6年", "summary": "洛杉磯湖人球星詹姆斯（LeBron James）近日在義大利卡布里島（Capri）度假，原本只是休賽季的悠閒行程，卻因一段在豪華遊艇上揮桿、將高爾夫球打入地中海的影片，引發義大利環保團體與消費者保護組織不滿。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025693.jpg&M=1&s=Y&x=0&y=50&sw=1176&sh=784&exp=3600&sl=W&fw=360", "date": "2026-06-09 10:48", "link": "/news/story/7002/9554558"}, {"article_id": "9554579", "title": "世足賽／飛到邁阿密被擋 索馬利亞裁判無緣執法", "summary": "索馬利亞裁判阿爾坦（Omar Artan）入選世界盃名單，但入境美國卻遭擋，且是人已經抵達邁阿密國際機場卻被拒絕入境。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025711.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 10:41", "link": "/news/story/123107/9554579"}, {"article_id": "9554501", "title": "日職／孫易磊後天對決橫濱 日媒：「台灣至寶」準備展現真正實力", "summary": "日本火腿隊今天將在北海道主場和橫濱隊交手，推出王牌投手伊藤大海登板先發，我國好手孫義磊預定後天3連戰最後一戰亮相；日本媒體Sponichi Annex指出，孫易磊本季首場先發被寄予厚望，希望他來到日本第3年能夠奪下期待已久的首勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025623.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-09 10:14", "link": "/news/story/7001/9554501"}, {"article_id": "9554451", "title": "日職／阿部慎之助涉施暴長女案 日警函送檢方偵辦", "summary": "日本警方今天透露，日本職棒前讀賣巨人隊監督阿部慎之助因涉嫌對18歲長女施暴，已遭警視廳以暴行罪嫌函送檢方偵辦", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025503.jpg&M=1&s=Y&x=38&y=25&sw=1242&sh=828&exp=3600&sl=W&fw=360", "date": "2026-06-09 10:06", "link": "/news/story/7001/9554451"}, {"article_id": "9554463", "title": "世足賽／阿根廷友誼賽最終戰 梅西開綠燈但出賽時間未定", "summary": "阿根廷當家球星「獅王」梅西（Lionel Messi）將連續六屆出征世界盃，總教練斯卡洛尼（Lionel Scaloni）今天證實，梅西將在世界盃的最後一場熱身賽上場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025506.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 09:57", "link": "/news/story/123107/9554463"}]}, {"name": "棒球", "articles": [{"article_id": "9554501", "title": "日職／孫易磊後天對決橫濱 日媒：「台灣至寶」準備展現真正實力", "date": "2026-06-09 10:14", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025623.jpg&M=1&s=Y&x=0&y=0&sw=12