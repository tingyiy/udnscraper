cle_id": "9414279", "title": "場外醜聞纏身場內連年衰退 「神鱒」楚奧特還能魚躍龍門嗎？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/03/31/34815689.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9423219", "title": "NBA／湖人再遭傷病重創！里夫斯例行賽報銷 主帥下動員令力拚首輪", "summary": "繼唐西奇（Luka Doncic）左腿筋二級拉傷例行賽提前報銷之後，洛杉磯湖人再度傳出噩耗！球團宣布，主力後衛里夫斯（Austin Reaves）確認左側腹斜肌二級拉傷，也被迫缺席本季剩餘所有例行賽。這一消息無疑讓原本已因傷勢而動盪的陣容雪上加霜。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/05/34828211.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-05 11:26"}, {"article_id": "9423174", "title": "NCAA／菜鳥關鍵外線建功！康乃狄克擊退伊利諾 4年內3度殺進決賽", "summary": "康乃狄克大學男籃今天在NCAA四強戰殺退伊利諾大學，連續4年3度闖進冠軍賽。全隊由穆林斯（Braylon Mullins）關鍵三分球與利德（Tarris Reed Jr.）雙十領軍，最後是以71比62奪勝，持續向隊史第7冠邁進。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/05/34828155.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-05 11:04"}, {"article_id": "9423181", "title": "MLB／史上最年輕村上宗隆美日通算250轟出爐 沒想過追平、超越王貞治！", "summary": "白襪隊今天在芝加哥主場以6：3擊敗藍鳥隊，日本重砲村上宗隆成為最大功臣，6局下兩分砲攻下勝利打點，成為史上最年輕達到美、日職棒生涯250轟的日本球員，超前「世界全壘打王」王貞治的成就，他說：「王貞治打了很多全壘打，我沒想過追平或超越他，只想繼續增加自己的全壘打紀錄。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/05/34828128.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-05 10:47"}, {"article_id": "9423108", "title": "MLB／鄧愷威中繼2.1局無失分 買不起「新人卡」成主播趣味話題", "summary": "太空人隊台灣投手鄧愷威今天以長中繼之姿登板，接在今井達也之後，精簡用球投完2.1局無失分，幫助球隊以11比0大勝運動家隊...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/05/34828067.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-05 10:40"}, {"article_id": "9423036", "title": "世足賽／義大利連3屆無緣會內賽球迷心碎 加拿大招手義裔改挺地主", "summary": "世足賽4屆冠軍義大利，上週在附加賽PK不敵對手，連續3屆無緣會內賽。本屆世界盃共同主辦國加拿大向心碎的義裔球迷提議，以他...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/05/34828004.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-05 09:58"}, {"article_id": "9423096", "title": "NBA／熱火狂轟152分退巫師 哈克斯趕場看妹妹NCAA冠軍賽", "summary": "熱火隊今天上演煙火秀，全隊飆進17記三分彈，7人得分兩位數下狂轟隊史第二高分，以152：136輕取巫師隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/05/34828005.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-05 09:54"}, {"article_id": "9423037", "title": "MiLB／鄭宗哲大雪紛飛3A連兩戰開轟 陳柏毓2A先發登板無關勝敗", "summary": "旅美波士頓紅襪隊台灣好手鄭宗哲維持好手感，今天3A出賽4局上敲出陽春砲、連2場出賽開轟；匹茲堡海盜隊投手陳柏毓2A先發登...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/05/34827982.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-05 09:51"}, {"article_id": "9423071", "title": "MLB／生涯前8戰4轟日本球員最猛 村上宗隆致勝一擊轟出一堆紀錄", "summary": "白襪隊日本重砲村上宗隆再展全壘打火力，今天對藍鳥隊之戰6局下轟出兩分砲，本季第4轟成為致勝一擊，幫助白襪6：3獲勝，大聯盟生涯前8戰出現4轟也是日本球員新紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/05/34827970.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-05 09:40"}, {"article_id": "9423021", "title": "MLB／今井達也5.2局9K奪大聯盟首勝 鄧愷威接替投2.1局送3K無失分", "summary": "休士頓太空人隊今天客場出戰運動家隊，日籍投手今井達也在大聯盟第二度登板，先發5.2局送出9次三振，之後由鄧愷威登板接替2.1局、送出3次三振，沒有失分，最終太空人單場掃出18支安打，以11：0勝出。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/05/34827922.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-05 09:13"}, {"article_id": "9423020", "title": "MLB／道奇四冠王帕赫斯連兩天開轟 大谷連39場上壘再創新高", "summary": "道奇隊作客華府，今天對國民隊展開3連戰第2戰，弗里曼（Freddie Freeman）前兩個打席都揮出兩分打點二壘打，帕赫斯（Andy Pages）連兩天開轟，道奇終場以10：5獲勝，對戰2連勝確定贏得系列賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/05/34827926.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-05 09:13"}, {"article_id": "9423002", "title": "NBA／溫班亞瑪錯過絕殺球 約柯奇40分率金塊斷馬刺11連勝", "summary": "馬刺隊和金塊隊今天上演西區前段班隊伍對決，兩軍都有頂尖歐陸長人坐鎮，馬刺當家球星溫班亞瑪（Victor Wembanyama）繳出34分、18籃板、5阻攻但錯過正規賽有機會的絕殺跳投，讓狂轟40分的約柯奇（Nikola Jokic）率金塊延長賽以136：134阻斷馬刺的11連勝，在主場迎接自身的8連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/05/34827905.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-05 08:52"}, {"article_id": "9422893", "title": "NBA／2026籃球名人堂揭曉 史陶德邁爾、瑞佛斯等攜手入選", "summary": "奈史密斯籃球名人堂（Naismith Basketball Hall of Fame）今天正式宣布2026年9組入選名單...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/05/34827948.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-05 04:13"}, {"article_id": "9422834", "title": "運動人生／莊佳佳：運動科學應從基層開始介入", "summary": "跆拳道曾是中華代表團參加國際賽的「獎牌庫」，但二○○四年奧運二金一銀的風光場面早已不再，上屆唯一參加奧運的女將甚至止步於十六強。莊佳佳認為，電子護具、比賽規則與賽制變動是原因之一，她建議運動科學要更早介入協助選手。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_9.jpg", "date": "2026-04-05 00:26"}, {"article_id": "9422835", "title": "運動人生／為比賽斤斤計較 莊佳佳40天狂降8公斤", "summary": "「一個半月狂降八公斤挑戰五十七公斤量級、賽前過磅猛灌水以符合七十三公斤級的最下限…」莊佳佳的跆拳人生，多次為了增加奪牌希望而「斤斤計較」；她坦言，為了降體重身心俱疲，選擇廿八歲退役也是考量心理狀態。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_2.jpg", "date": "2026-04-05 00:25"}, {"article_id": "9422838", "title": "運動人生／闖政界不認輸 莊佳佳勇於斜槓挑戰框架", "summary": "在運動競技場上，莊佳佳是世錦賽女子 六十七公斤金牌的跆拳道豪傑；在政壇，她是揮汗投入推動桃園市體育的政治新兵，最新身分成國家運動訓練中心副執行長。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827620.jpg&M=1&s=Y&x=0&y=0&sw=867&sh=578&exp=3600&sl=W&fw=360", "date": "2026-04-05 00:24"}, {"article_id": "9422655", "title": "中職／神奇逆轉勝「從地獄爬回天上」 洪總談王維中首戰「太過在乎」", "summary": "昨天領先了大半場卻被敲再見安打輸球，台鋼雄鷹今天再戰味全龍隊，從0：6的落後追回7分，終場以7：6演出神奇逆轉勝，總教練洪一中形容：「前一天是從天上掉到地獄，今天是從地獄慢慢爬回天上。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827421.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-04 21:28"}, {"article_id": "9422645", "title": "U18東岸聯盟／下勾邱丞軒投出自信 助台南聯隊晉4強", "summary": "U18東岸聯盟棒球賽台南市聯隊下勾投手邱丞軒5局無失分壓制，助隊4比0擊敗新北市聯隊晉級4強；