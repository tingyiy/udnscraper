"date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084486.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9593640"}, {"article_id": "9595708", "title": "世足攻略／陣容有優勢 德國破巴拉圭問題不大", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087515.jpg&M=1&s=Y&x=0&y=75&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9595708"}, {"article_id": "9595723", "title": "世足攻略／擁有對戰優勢 看好荷蘭再勝摩洛哥", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087526.jpg&M=1&x=&y=&sw=&sh=&exp=3600&w=300", "link": "/news/story/122629/9595723"}, {"article_id": "9593665", "title": "日職／巨人受惠入札左投 中日龍迷最懂火腿迷感受", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084527.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9593665"}]}, {"name": "最新文章", "articles": [{"article_id": "9596144", "title": "中職／選秀點評！陳柏凱成狀元後再狂補投手 悍將這屆選得好", "summary": "2026年中職選秀會於29日晚間落幕，富邦選擇高卒游擊手陳柏凱成狀元。儘管今年無旅外球員回歸，且不少潛力新秀未報名，六支球隊仍積極補強，尤其針對目前戰力缺口，展現未來期望。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088046.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 21:22", "link": "/news/story/122629/9596144"}, {"article_id": "9596145", "title": "中職／龍隊榜眼考慮2人無陳柏凱 葉總看廖永詮運動能力香到想養養看", "summary": "味全龍隊的榜眼籤挑選具備二刀流潛力的南華大學外野手廖永詮，即便陳柏凱未在狀元上榜，答案依然不會變，總教練葉君璋透露，考慮的兩位人選是廖永詮和邱文佑，對廖永詮的運動能力充滿好奇，「他的運動能力是真的很好，想說用這樣的方式去選看看，看可以好到什麼程度。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088019.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 20:48", "link": "/news/story/7001/9596145"}, {"article_id": "9596127", "title": "中職／陳柏凱能否衝擊簽約金600萬？悍將領隊：審慎評估、拭目以待", "summary": "每年中職選秀季，600萬簽約金天花板都成話題，中職會長蔡其昌致詞時強調「沒有這件事」，富邦悍將隊以狀元籤帶回陳柏凱，對於他的簽約金是否有機會突破600萬，領隊陳昭如回應：「審慎評估、拭目以待。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088007.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 20:31", "link": "/news/story/7001/9596127"}, {"article_id": "9596122", "title": "中職／林威助喊滿意！大讚陳柏凱應屆天花板最高 評估能成主力游擊", "summary": "富邦悍將隊今年在選秀會一共帶回9人，副領隊林威助評價是「滿有收穫」的一次選秀，狀元籤挑選陳柏凱早在他確定投入選秀的前一、兩天就已經有譜，早早沒有懸念，林威助說：「他應該是高中應屆畢業生裡天花板最高的游擊手，再養成幾年，應該會成為隊內主力游擊。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087998.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 20:25", "link": "/news/story/7001/9596122"}, {"article_id": "9595987", "title": "中職／悍將狀元陳柏凱看新聞才知道哥哥要來 陳品宏喊話：一起拿冠軍", "summary": "一如會前預期，富邦悍將隊狀元籤挑選來自大溪高中的游擊手陳柏凱，他與哥哥陳品宏將同隊打拚，被問到想跟即將成為隊友的弟弟說什麼？陳品宏說：「我們一起加油，一起拿總冠軍，可以嗎？」陳柏凱超乖巧，連忙回答：「可以、可以！」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087921.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-29 19:29", "link": "/news/story/7001/9595987"}, {"article_id": "9595946", "title": "世足賽／加拿大女球迷玩人浪 下秒手機「跳樓」網熱議：精彩一刻", "summary": "加拿大在這屆世界盃持續有好表現，該隊6月28日在32強賽「絕殺」南非，首度晉身16強。不過在賽事期間，看台上的一名加拿大女球迷就似乎過於投入，結果當場失去手機，更遭網友形容為「世界盃最佳片段」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087902.jpg&M=1&s=Y&x=62&y=0&sw=1055&sh=703&exp=3600&sl=W&fw=360", "date": "2026-06-29 19:18", "link": "/news/story/123107/9595946"}, {"article_id": "9595960", "title": "蔡家福、柳承敏續簽合作備忘錄 李洋見證持續深化夥伴關係", "summary": "中華奧會主席蔡家福、韓國奧會主席柳承敏今天在運動部長李洋見證下，共同正式續簽合作備忘錄，展現雙方持續深化夥伴關係、推動體育交流合作的共同承諾。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087900.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 19:11", "link": "/news/story/7005/9595960"}, {"article_id": "9595924", "title": "中職／大溪高中首度出狀元！悍將挑選陳柏凱 與陳品宏譜寫兄弟同隊", "summary": "富邦悍將球團史10年拿到的第4支狀元籤，今天確定挑選游擊手陳柏凱，他將與哥哥陳品宏同隊打拚，更一舉成為桃園大溪高中校史第一位中職選秀狀元。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087865.jpg&M=1&s=Y&x=0&y=48&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 18:44", "link": "/news/story/7001/9595924"}, {"article_id": "9595863", "title": "NBA／塞爾蒂克加入「魯超人」爭奪戰 尼克若放走羅賓森也想競逐", "summary": "塞爾蒂克傳出加入老將中鋒魯尼（Kevon Looney）的爭奪行列，同樣感興趣的還包含剛剛奪冠的尼克。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087744.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 18:08", "link": "/news/story/7002/9595863"}, {"article_id": "9595835", "title": "世足賽／運彩銷售超過40億 法國維持奪冠大熱門", "summary": "2026美加墨世界盃32強淘汰賽正式展開，台灣運彩表示，截至6月28日小組賽結束，台灣運彩銷售逾40億，淘汰賽開始後，比賽強度增加，單場銷售有機會再創高峰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087768.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 17:57", "link": "/news/story/123107/9595835"}, {"article_id": "9595781", "title": "NBA／哈利伯頓阿基里斯腱重傷找回健康 自信喊話：從沒感覺這麼強壯", "summary": "距離當年因阿基里斯腱撕裂重傷倒下已超過1年，溜馬當家後衛哈利伯頓（Tyrese Haliburton）如今感覺自己已經逐漸回到正常狀態。他在受訪時，談到自己預計在2026-27年賽季復出，並且對身體狀態表達高度信心。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087637.jpg&M=1&s=Y&x=7&y=0&sw=1256&sh=837&exp=3600&sl=W&fw=360", "date": "2026-06-29 17:53", "link": "/news/story/7002/9595781"}, {"article_id": "9595723", "title": "世足攻略／擁有對戰優勢 看好荷蘭再勝摩洛哥", "summary": "荷蘭在對摩洛哥的淘汰賽中擁有60%至65%的晉級機率，過去交手佔優勢，進攻火力強勁。然而，摩洛哥具備防守韌性與高效反擊，勢必成為強敵。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087526.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-29 17:07", "link": "/news/story/122629/9595723"}, {"article_id": "9595708", "title": "世足攻略／陣容有優勢 德國破巴拉圭問題不大", "summary": "德國在淘汰賽首戰中對巴拉圭具備較大優勢，若無重大失誤，勝率達8成。雖然巴拉圭防守穩健，但面對德國的強大攻勢，尤其在定位球方面，德國獲勝機率相對更高。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087515.jpg&M=1&s=Y&x=0&y=75&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 17:01", "link": "/news/story/122629/9595708"}, {"article_id": "9595627", "title": "世足賽／伊朗止步32強今返國 不滿美國入境限制：簡直是一場災難", "summary": "伊朗隊在世界盃足球賽小組賽遭到淘汰後，球隊官員今天表示，全隊將於29日搭機返國，結束本屆世界盃征程", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087495.jpg&M=1&s=Y&x=0&y=59&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 16:53", "link": "/news/story/123107/9595627"}, {"article_id": "9595682", "title": "世足攻略／矛盾對決 看好巴西小勝藍武士日本", "summary": "巴西在32強淘汰賽對陣日本的比賽中看似佔優，預測小勝進入下一輪。雖然八個月前日本逆轉勝出，但巴西擁有更強的攻擊火力和球星，如維尼修斯和內馬爾。日本需依賴穩固防守和高效定位球，方能製造冷門。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087473.jpg&M=1&s=Y&x=0&y=0&sw=1238&sh=825&exp=3600&sl=W&fw=360", "date": "2026-06-29 16:50", "link": "/news/story/122629/9595682"}, {"article_id": "9595622", "title": "高球／JLPGA地球蒙達明盃最終回 吳佳晏後來居上並列第9", "summary": "JLPGA史上獎金最高的2026年地球蒙達明盃，今天進行第3回合補賽及最終回合賽事，台灣好手吳佳晏以4天低於標準7桿的2...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087479.jpg&M=1&s=Y&x=0&y=34&sw=1144&sh=763&exp=3600&sl=W&fw=360", "date": "2026-06-29 16:49", "link": "/news/story/7005/9595622"}, {"article_id": "9595674", "title": "PLG／巔峰盃3X3籃球賽 勇士教練吳永仁帶女兒參與", "summary": "2026年夏季巔峰盃3X3籃球賽昨天落幕，去年帶著兒子參與親子組賽事的台灣職籃P.LEAGUE+台北富邦勇士教練吳永仁，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087476.jpg&M=1&s=Y&x=0&y=81&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 16:48", "link": "/news/story/7003/9595674"}, {"article_id": "9595670", "title": "世足運彩／森巴軍團強勢硬踩藍武士日本防守陣 推巴西不讓分", "summary": "日本隊將在6月30日凌晨1點迎戰世界盃強隊巴西，兩隊交手往績顯示日本處於劣勢。巴西擁有多名明星球員，雖然缺少拉菲尼亞，實力仍然優於日本。日本需謹慎防守並把握反擊機會，才能有機會晉級。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087422.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 16:38", "link": "/news/story/123105/9595670"}, {"article_id": "9595647", "title": "世足運彩／日耳曼戰車強勢前進 巴拉圭鐵桶閃開推德國讓分", "summary": "德國隊在世足小組賽中以強大攻勢迎戰巴拉圭，先前以7：1大勝庫拉索。儘管中衛施洛特貝夫受傷，陣中火力仍由維爾茨、穆斯拉及基米希主導。巴拉圭進攻乏力，主力D.戈麥斯禁賽，致使其防守策略將是關鍵。主推薦：德國讓分。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087388.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 16:29", "link": "/news/story/123105/9595647"}, {"article_id": "9595649", "title": "NBA／艾頓傳將執行810萬美元球員選項 湖人中鋒布局先有答案", "summary": "湖人已經與後場主力里夫斯（Austin Reaves）達成延長合約協議，詹姆斯（LeBron James）的去向仍是外界關注焦點，至於中鋒艾頓（Deandre Ayton）的答案可能已經逐漸明朗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087375.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 16:18", "link": "/news/story/7002/9595649"}, {"article_id": "9595610", "title": "世足運彩／大空翼時刻降臨！藍武士能否重溫漫畫再次狙擊森巴軍團？推正賽和局", "summary": "2026年世足賽淘汰賽將迎來巴西對日本的焦點對決。巴西欲證明強隊底蘊，而日本則希望再創擊敗巴西的歷史。亞洲盤開出巴西讓0.75球，顯示對日本的信心提升，建議關注日本正規時間不敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087662.jpg&M=1&s=Y&x=0&y=0&sw=1216&sh=810&exp=3600&sl=W&fw=360", "date": "2026-06-29 16:12", "link": "/news/story/123105/9595610"}, {"article_id": "9595600", "title": "NBA／傳湖人又盯上前鋒射手 金塊受制薪資壓力可能啟動交易", "summary": "湖人傳出正在關注金塊前鋒射手鋒強森（Cameron Johnson）的交易動向，據悉他已經在市場上引發多支球隊興趣，若金塊因薪資壓力必須再做調整，他可能很快會成為交易籌碼。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087328.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 16:02", "link": "/news/story/7002/9595600"}, {"article_id": "9595601", "title": "2026全民運動會10月桃園登場 估1.3萬人參賽", "summary": "2026年全民運動會將於10月17日至22日在桃園市登場，本屆共設32個競賽種類，預計吸引1萬3000人參與；賽會口號訂為「全民敢動 桃戰巔峰」，「敢動」除呼籲民眾培養運動習慣，更象徵社會各界感佩選手精神而挺身支持的「動容」力量，以雙關意涵串連賽事熱情與社會支持。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087325.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 15:56", "link": "/news/story/7005/9595601"}, {"article_id": "9595491", "title": "世足運彩／北非雄獅氣勢如虹壓過荷蘭 Gemini看摩洛哥勝出2:1", "summary": "2026世界盃32強淘汰賽迎來強強對決，世界排名第8的荷蘭與第7的摩洛哥提前硬碰硬。摩洛哥上屆高居四強，此役雖名為客隊，但近期在大型賽事中展現極強的心理優勢與適應力，加上小組賽取得2勝1和的不敗戰績，", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087317.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-29 15:56", "link": "/news/story/123105/9595491"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9594607", "title": "世足賽／南韓淘汰連總統都痛批 總教練洪明甫閃電請辭", "date": "2026-06-29 09:34", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35085744.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9594607"}, {"article_id": "9595946", "title": "世足賽／加拿大女球迷玩人浪 下秒手機「跳樓」網熱議：精彩一刻", "date": "2026-06-29 19:18", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087902.jpg&M=1&s=Y&x=62&y=0&sw=1055&sh=703&exp=3600&w=300", "link": "/news/story/123107/9595946"}, {"article_id": "9595835", "title": "世足賽／運彩銷售超過40億 法國維持奪冠大熱門", "date": "2026-06-29 17:57", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087768.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9595835"}, {"article_id": "9595627", "title": "世足賽／伊朗止步32強今返國 不滿美國入境限制：簡直是一場災難", "date": "2026-06-29 16:53", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087495.jpg&M=1&s=Y&x=0&y=59&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9595627"}, {"article_id": "9595582", "title": "世足賽／盼淘汰慘案成改變契機 南韓前國腳安貞桓怒斥媒體看衰國家隊", "date": "2026-06-29 15:43", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087313.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300