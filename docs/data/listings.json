hp?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35041187.jpg&M=1&s=Y&x=17&y=11&sw=1263&sh=842&exp=3600&w=300", "link": "/news/story/122629/9564608"}, {"article_id": "9564449", "title": "世足攻略／內馬爾缺陣考驗巴西平局機率近五成 瑞士穩定攪局卡達難爆冷", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040924.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9564449"}, {"article_id": "9563581", "title": "煮茶論戰／世足首戰就發3紅牌 後面還會更多", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35039525.jpg&M=1&s=Y&x=0&y=0&sw=1275&sh=850&exp=3600&w=300", "link": "/news/story/123107/9563581"}, {"article_id": "9563228", "title": "尼克示範如何把溫班亞瑪拉出禁區 馬刺必須面對的攻防課題", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35038965.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/122629/9563228"}, {"article_id": "9562529", "title": "世足攻略／美國碰「南美滾泥土」防爆冷 加拿大少戴維斯戰波赫怕逼和", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35037670.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9562529"}]}, {"name": "最新文章", "articles": [{"article_id": "9566304", "title": "煮茶論戰／2:0扳倒土耳其 澳洲示範如何擊敗強隊", "summary": "世足賽開賽第三天，看到了澳洲精準的示範如何擊敗實力較強的球隊。土耳其球員身價是澳洲六倍，再以這場比賽控球率來說，土耳其占了百分之七十二，澳洲只有百分之廿八，但最後澳洲不僅沒有失球，還進了兩球帶走勝利。澳洲以高效率進攻讓控球率高的土耳其灰頭土臉，贏得一點也不僥倖。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/15/35043674.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-15 00:16", "link": "/news/story/123107/9566304"}, {"article_id": "9566294", "title": "世足賽／卡達隊長追平頭錘 9000萬獎金卻可能飛了", "summary": "卡達在世界盃小組賽對瑞士之戰傷停補時階段驚喜以一比一逼平，原本被視為卡達隊長胡赫的關鍵頭球進球，卻在賽後被國際足球總會改判為瑞士後衛穆海姆的烏龍球，胡赫高額的進球獎金可能化為烏有，形成本屆比賽有趣插曲，也讓人再次感嘆卡達的「豐厚財力」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043567.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-15 00:15", "link": "/news/story/123107/9566294"}, {"article_id": "9566290", "title": "世足賽／巴西踢平摩洛哥 教頭不滿意", "summary": "當家球星內馬爾缺陣的巴西，昨天迎接二○二六美加墨世足賽首戰，面對非洲勁旅摩洛哥，五度奪冠的「森巴軍團」第廿一分鐘先失球，靠維尼修斯十一分鐘後就進球回應，才以一比一踢和，但只拿一分的結果讓冠軍熱門隊直喊糟糕。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/15/35043666.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-15 00:12", "link": "/news/story/123107/9566290"}, {"article_id": "9566284", "title": "NBA／翻轉1999年劇本 老爸當年輸馬刺 布朗森討回來", "summary": "老布朗森曾和尼克隊打進一九九九年的ＮＢＡ總冠軍賽，如今兒子布朗森不但率尼克打進同樣階段，昨天更狂轟四十五分，率隊以九十四比九十逆轉馬刺隊，終結五十三年的冠軍等待；布朗森和目前擔任尼克助理教練的爸爸老布朗森共享冠軍，締造史上第一對父子同隊捧冠的特別紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/15/35043664.jpg&M=1&s=Y&x=16&y=0&sw=1264&sh=843&exp=3600&sl=W&fw=360", "date": "2026-06-15 00:08", "link": "/news/story/7002/9566284"}, {"article_id": "9566282", "title": "NBA／把把都逆轉 韌性尼克再捧金盃", "summary": "尼克隊等待五十三年的總冠軍，今年總算到手，昨天於總冠軍賽第五戰客場踢館成功，在「戰神」布朗森狂轟四十五分領軍下再度演出逆轉勝，以九十四比九十氣走馬刺隊，帶回一九七三年之後的第一座金盃。在場上大殺四方的布朗森，奪勝後忍不住流下男兒淚。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043557.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-15 00:05", "link": "/news/story/7002/9566282"}, {"article_id": "9566371", "title": "中職／池恩齊被懲罰性調度隔天攻守好表現 光總：搞不好他有看新聞", "summary": "富邦悍將隊游擊手池恩齊昨天遭「懲罰性調度」，總教練後藤光尊今天賽前和媒體談起他的表現時，有一番嚴厲的發言，然而池恩齊今天繼續先發上陣，攻守都有好表現，讓「光總」賽後也笑說：「搞不好他有看到賽前的新聞。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043628.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 23:43", "link": "/news/story/7001/9566371"}, {"article_id": "9566321", "title": "中職／是李東洺自己想投的！ 中斷2小時hold住局面還想續投第6局", "summary": "富邦悍將今天在新莊棒球場對戰台鋼雄鷹，比賽在雨勢中開打，打到第3局還中斷了2小時，但先發投手李東洺請纓繼續上陣，投完5局後甚至要求再投第6局，但被教練勸退，最終繳出5局無失分的表現，拿下先發8連勝，登上聯盟勝投王。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043580.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 23:20", "link": "/news/story/7001/9566321"}, {"article_id": "9566288", "title": "籃球／產學攜手人才培育 中信學院征戰ABSOLUTE 3x3全台9站", "summary": "國內ABSOLUTE 3x3籃球聯盟賽2026賽季，台中羽田娛樂有限公司與中信金融管理學院攜手，協助學生球員參與國內大型籃球運動賽事，並與國家隊成員及職業運動選手同場較勁，持續培育更多的學生籃球運動員，以及透過賽事活動的參與，建立運動產業的合作發展，與培養學生辦理運動賽事的實務經驗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043565.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 23:07", "link": "/news/story/7003/9566288"}, {"article_id": "9566209", "title": "中職／李東洺等2小時後續投仍收先發8連勝 悍將7：0完封雄鷹", "summary": "富邦悍將隊本周最後一場賽事，比賽一度因雨中斷2小時，恢復進行後悍將打線有范國宸、王苡丞相繼開轟拉開領先差距，先發投手李東洺則是在比賽暫停後繼續登板，繳出5局0失分的表現，終場富邦以7：0完封台鋼雄鷹，上半季戰績擠下台鋼回到第2，李東洺則收下先發8連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043524.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 22:50", "link": "/news/story/7001/9566209"}, {"article_id": "9566096", "title": "PLG／領航猿主場又失守遭勇士聽牌 卡總預告：會有第7戰", "summary": "例行賽主場勝率百分百的桃園璞園領航猿，季後賽卻遇臺北富邦勇士強力挑戰，總冠軍賽首戰主場全勝紀錄就破功，今天第5戰上半場又找不到準星，最終以78：87失守，不過總教練卡米諾斯自信預告，絕對會有第7戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043391.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 21:29", "link": "/news/story/7003/9566096"}, {"article_id": "9566060", "title": "排球／女排亞洲盃不敵韓國奪亞軍 締造隊史最佳", "summary": "在菲律賓舉行的女子排球亞洲盃，隊史首度挺進冠軍戰的台灣隊今天以19比25、19比25、22比25不敵韓國，以亞軍作收，仍...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043367.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 21:20", "link": "/news/story/7005/9566060"}, {"article_id": "9566047", "title": "足球／安聯小小世界盃高雄預賽熱血落幕 南台灣小將燃燒足球魂", "summary": "由台灣安聯人壽掛名贊助的「2026安聯小小世界盃」高雄區預賽在鳳山體育場激烈開踢，代表營北國中女足出賽的國一小將高惠芯，在U15組剛結束一場以2：4惜敗的激戰。儘管對手是高大的福誠足球俱樂部且都是男球員，面對結果她展現出超齡的勝負心：「雖然因為太久沒在場上跑動，對自己的表現很不滿意，但每一次的挫折都是我進步的動力。」她堅定地表示，會將不甘心轉化為下一次贏球的能量。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043343.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 20:55", "link": "/news/story/7005/9566047"}, {"article_id": "9566034", "title": "PLG／古德溫遭禁賽G6缺陣 許晉哲啟動「B計畫」", "summary": "台北富邦勇士隊今天總冠軍賽第5戰踢館成功，但主戰洋將古德溫最後43秒被吹違反運動精神犯規，累積違反運動精神犯規達到第5次，將禁賽一場加上罰款2萬，周二進行的第6戰無法出賽，讓教練許晉哲將啟動「B計畫」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043332.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 20:41", "link": "/news/story/7003/9566034"}, {"article_id": "9565908", "title": "玉山盃／饒又語先發無失分學經驗 新北搶勝下戰碰桃園", "summary": "玉山盃青棒賽新北市今天投打發揮，終場以10比3擊敗雲林縣，先發投手饒又語3局無失分，但總教練楊孝承認為可以更好，下雨影響...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043304.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 20:18", "link": "/news/story/7001/9565908"}, {"article_id": "9565984", "title": "PLG／林志傑再現「野獸狂吼」 勇士踢館領航猿成功率先聽牌", "summary": "PLG總冠軍賽第5戰回到衛冕軍桃園璞園領航猿主場桃園巨蛋，但領航猿對自家籃框卻找不到準星，上半場三分球14投僅1中、僅拿29分，儘管第四節打出一波14：0的反撲攻勢，但台北富邦勇士靠古德溫、莫巴耶聯手飆分，加上吳永盛扮演板凳奇兵，最終仍以87：78踢館成功，7戰4勝制的系列賽搶下關鍵第3勝，率先「聽牌」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043281.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 19:55", "link": "/news/story/7003/9565984"}, {"article_id": "9565947", "title": "世足運彩／60萬人小國維德角 不會傻到首戰硬拚西班牙主推3.5小分", "summary": "維德角將在世界盃首戰對抗強敵西班牙，專注於後續對烏拉圭與沙烏地阿拉伯的比賽。西班牙陣中傷癒球員耶馬未必會先發，運彩開盤顯示西班牙讓球3分，總分大小3.5，反映出對西班牙取勝的期待。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043276.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 19:50", "link": "/news/story/123105/9565947"}, {"article_id": "9565970", "title": "NBA／尼克奪冠後紐約球迷狂歡變調 巴士遭縱火、少年中彈", "summary": "在紐約尼克於NBA總冠軍賽贏得歷史性勝利後，數以千計球迷昨天深夜湧入紐約街頭慶祝，但曼哈頓中城慶祝現場演變成混亂場面，期...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043272.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-14 19:43", "link": "/news/story/7002/9565970"}, {"article_id": "9565975", "title": "中職／李軍投球技能進職棒才被開發 爸爸李志傑多鼓勵盼他有依靠", "summary": "統一獅隊投手年僅20歲的左投李軍，今年球速大突破，最快曾飆到153公里，連他的家人都十分驚艷，他的爸爸、昔日兄弟球星李志傑也直呼「哦！不一樣了！」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043271.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 19:39", "link": "/news/story/7001/9565975"}, {"article_id": "9565949", "title": "中職／髙塩將樹砸鍋問題出在配球 餅總也對布雷克感到抱歉", "summary": "統一獅隊今天5：1領先打到5：5追平，最終仍在九局上再次掌握優勢，以7：5擊敗味全龍隊，在本周末2連戰橫掃龍頭、對戰3連勝，總教練林岳平也直言：「這兩天我們贏球，我想不會影響到他們（龍隊）接下來的戰況，我們戰績在中段，有贏的機會就要確實贏下來。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043256.jpg&M=1&s=Y&x=1&y=197&sw=848&sh=566&exp=3600&sl=W&fw=360", "date": "2026-06-14 19:27", "link": "/news/story/7001/9565949"}, {"article_id": "9565930", "title": "中職／其他4隊辦不到 本季唯有獅隊能讓「天空龍」吞對戰連敗", "summary": "味全龍隊的尾盤追分能力今天再次展現，八局下將1：5落後扭轉為5：5，卻在九局上也出現災難般的一局，投手林子昱失誤、暴投連發，讓統一獅隊再次掌握優勢，獅隊終場以7：5贏球，對戰龍隊取得3連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043260.jpg&M=1&s=Y&x=0&y=26&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 19:03", "link": "/news/story/7001/9565930"}, {"article_id": "9565926", "title": "世足運彩／瑞典雙鋒火力衝擊 突尼西亞嚴陣以待主推瑞典不讓分", "summary": "瑞典將在世足小組賽中對陣突尼西亞，擁有兩名頂級前鋒的瑞典隊被看好不讓分。突尼西亞近期欠佳，熱身賽連遭失利，後防堪憂。主流推薦瑞典不讓分，並建議總進球數在2-3球之間。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043234.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 19:02", "link": "/news/story/123105/9565926"}, {"article_id": "9565920", "title": "中職／太苦了…布雷克罕見拿到5分支援卻遭砸鍋 已36天沒勝投", "summary": "統一獅隊苦情洋投布雷克體會人生百味，今天面對味全龍隊，繳出6局僅失1分好投，罕見帶著5：1領先退場，卻依然等不到勝投，這次領到的劇本是髙塩將樹第八局救援砸鍋。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043212.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 18:45", "link": "/news/story/7001/9565920"}, {"article_id": "9565918", "title": "中職／「看能不能一年比一年更好」 凃壯勳擬再帶台鋼2捕手赴日進修", "summary": "台鋼雄鷹隊捕手教練凃壯勳已連兩年季後赴日進修，去年帶上雄鷹陳致嘉、陳世嘉兩人前往，今年則計畫帶上劉時豪及22歲捕手顏采丞前往，盼讓選手到不一樣的環境吸收新知，教練同時也持續精進，明年他還有意轉戰韓國再接觸不同國家的訓練方式。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043220.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 18:43", "link": "/news/story/7001/9565918"}, {"article_id": "9565849", "title": "NBA／一輩子的兄弟！「三劍客」大學到總決賽都奪冠 布朗森：這次經驗更特別", "summary": "過去曾幫助維拉諾瓦大學奪冠的布朗森（Jalen Brunson）、布里吉斯（Mikal Bridges）和哈特（Josh Hart），在今天NBA總冠軍G5他們成功以4分差逆轉馬刺，幫助尼克拿下睽違53年的冠軍金盃。布朗森在賽後採訪中，談到與另外兩位兄弟從大學一路到NBA都完成奪冠美夢，他表示這種感覺很棒，並強調這次代表紐約奪冠的經驗可能更特別。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043126.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 18:13", "link": "/news/story/7002/9565849"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9565492", "title": "世足賽／日本強碰荷蘭 菅原由勢無懼傷兵潮：會像過往一樣創造歷史", "date": "2026-06-14 12:50", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042500.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9565492"}, {"article_id": "9565308", "title": "世足賽／不滿意巴西首戰僅逼平 總教練：輸掉很多對抗和控球", "date": "2026-06-14 10:47", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042237.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9565308"}, {"article_id": "9566304", "title": "煮茶論戰／2:0扳倒土耳其 澳洲示範如何擊敗強隊", "date": "2026-0