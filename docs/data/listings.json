: [{"article_id": "9423002", "title": "NBA／溫班亞瑪錯過絕殺球 約柯奇40分率金塊斷馬刺11連勝", "summary": "馬刺隊和金塊隊今天上演西區前段班隊伍對決，兩軍都有頂尖歐陸長人坐鎮，馬刺當家球星溫班亞瑪（Victor Wembanyama）繳出34分、18籃板、5阻攻但錯過正規賽有機會的絕殺跳投，讓狂轟40分的約柯奇（Nikola Jokic）率金塊延長賽以136：134阻斷馬刺的11連勝，在主場迎接自身的8連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_3.jpg", "date": "2026-04-05 08:52"}, {"article_id": "9422834", "title": "運動人生／莊佳佳：運動科學應從基層開始介入", "summary": "跆拳道曾是中華代表團參加國際賽的「獎牌庫」，但二○○四年奧運二金一銀的風光場面早已不再，上屆唯一參加奧運的女將甚至止步於十六強。莊佳佳認為，電子護具、比賽規則與賽制變動是原因之一，她建議運動科學要更早介入協助選手。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_1.jpg", "date": "2026-04-05 00:26"}, {"article_id": "9422835", "title": "運動人生／為比賽斤斤計較 莊佳佳40天狂降8公斤", "summary": "「一個半月狂降八公斤挑戰五十七公斤量級、賽前過磅猛灌水以符合七十三公斤級的最下限…」莊佳佳的跆拳人生，多次為了增加奪牌希望而「斤斤計較」；她坦言，為了降體重身心俱疲，選擇廿八歲退役也是考量心理狀態。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_4.jpg", "date": "2026-04-05 00:25"}, {"article_id": "9422838", "title": "運動人生／闖政界不認輸 莊佳佳勇於斜槓挑戰框架", "summary": "在運動競技場上，莊佳佳是世錦賽女子 六十七公斤金牌的跆拳道豪傑；在政壇，她是揮汗投入推動桃園市體育的政治新兵，最新身分成國家運動訓練中心副執行長。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827620.jpg&M=1&s=Y&x=0&y=0&sw=867&sh=578&exp=3600&sl=W&fw=360", "date": "2026-04-05 00:24"}, {"article_id": "9422655", "title": "中職／神奇逆轉勝「從地獄爬回天上」 洪總談王維中首戰「太過在乎」", "summary": "昨天領先了大半場卻被敲再見安打輸球，台鋼雄鷹今天再戰味全龍隊，從0：6的落後追回7分，終場以7：6演出神奇逆轉勝，總教練洪一中形容：「前一天是從天上掉到地獄，今天是從地獄慢慢爬回天上。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827421.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-04 21:28"}, {"article_id": "9422645", "title": "U18東岸聯盟／下勾邱丞軒投出自信 助台南聯隊晉4強", "summary": "U18東岸聯盟棒球賽台南市聯隊下勾投手邱丞軒5局無失分壓制，助隊4比0擊敗新北市聯隊晉級4強；邱丞軒從正投改下勾，越投越...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827391.jpg&M=1&s=Y&x=0&y=68&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-04 21:12"}, {"article_id": "9422637", "title": "中職／從0：6落後演出大逆轉 台鋼雄鷹7：6擊敗味全龍", "summary": "台鋼雄鷹今天作客天母棒球場對戰味全龍隊，僅管王維中對戰前東家先發5局失6分，但雄鷹從0：6的落後局面演出大逆轉，6局起局局攻下分數，紀慶然在8局下敲出追平安，9局上魔鷹的安打送回超前分，終場以7：6逆轉勝出，拿下本季第4勝，龍隊則是中斷2連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827375.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-04 20:50"}, {"article_id": "9422526", "title": "韓職／王彥程6.1局先發奪勝 韓媒讚：來自台灣特級左投", "summary": "韓職韓華鷹隊台灣左投王彥程今天繳出先發6.1局好投，韓媒稱他「奇蹟的1.5億」、「來自台灣的特級左投」，備受關注。王彥程...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827445.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-04 20:26"}, {"article_id": "9422619", "title": "U18東岸聯盟／台南聯隊晉4強 整合有成效自信不輸人", "summary": "U18東岸聯盟棒球賽台南市聯隊整合收到成效，今天6強複賽靠著下勾投手邱丞軒5局無失分壓制，以4比0擊敗新北市聯隊晉4強；...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827392.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-04 20:20"}, {"article_id": "9422598", "title": "U18東岸聯盟／吳宣錠關鍵安 變更強拚國手正選", "summary": "U18東岸聯盟台中市聯隊吳宣錠今天6強複賽敲出關鍵安，助隊以2比0擊敗高雄市聯隊、晉級4強；捕手吳宣錠去年被選入U18世...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827341.jpg&M=1&s=Y&x=0&y=107&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-04 19:58"}, {"article_id": "9422557", "title": "籃球／前田顯藏有望接中華女籃主帥 阿巴西肯定執教功力", "summary": "日本職籃B.League秋田北部喜悅前總教練前田顯藏有望接任台灣女籃兵符，曾經與他合作的阿巴西認為，前田顯藏是非常好教練...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827354.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-04 19:54"}, {"article_id": "9422590", "title": "TPBL／高錦瑋6記三分球雲豹大勝31分 海神成首支遭淘汰球隊", "summary": "戰績龍頭位置被福爾摩沙夢想家步步進逼的桃園台啤永豐雲豹，今天回到主場出戰墊底的高雄全家海神，在主控高錦瑋全場投進6記三分球，團隊投進18記三分球下，以105：74大勝海神，將與夢想家勝差拉開到1.5場，至於海神則是遭到淘汰出局無緣季後賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827336.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-04 19:50"}, {"article_id": "9422565", "title": "U18東岸聯盟／賴承鍇69球完封勝 台中聯隊首闖4強", "summary": "U18東岸聯盟台中市聯隊靠著賴承鍇69球完封好投，率隊以2比0擊敗高雄市聯隊、隊史首度晉級4強；台中市聯隊目前為止，連5...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827329.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-04 19:46"}, {"article_id": "9422564", "title": "中職／準備好一軍先發 曾仁和等候機會「身心狀況都在軌道上」", "summary": "31歲投手「土虱」曾仁和本季轉戰味全龍隊，開季已在二軍出賽一場，預計下周二到二軍再投一場，最快有機會在四月中登一軍亮相，味全龍總教練葉君璋認為他的狀況已經差不多，曾仁和也自認已準備好，「身心狀況都滿ok，有在軌道上。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827331.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-04 19:10"}, {"article_id": "9422555", "title": "PLG／領航猿移師台中主場大勝洋基工程 送獵鷹前進季後賽", "summary": "桃園璞園領航猿今天前進台中洲際迷你蛋進行主場賽事，並且在與洋基工程之戰火力全開，在球隊一哥盧峻翔缺陣的情況下，包括葛拉漢拿下25分、10籃板、9助攻的準大三元，李家慷也攻下18分，最終領航猿就以124：103輕取洋基工程，也將排名第2名的獵鷹送入季後賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827284.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-04 18:53"}, {"article_id": "9422549", "title": "中職／劉基鴻3分砲打下5：0領先 龍鷹戰5局因雨暫停", "summary": "今天唯一一場順利開打的中職賽事，由味全龍隊在天母棒球場迎戰台鋼雄鷹，龍隊靠著劉基鴻在3局下轟出3分砲，打完4局以5：0領先，但比賽要進入5局下前，現場開始下起大雨，比賽因雨暫停中。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827274.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-04 18:33"}, {"article_id": "9422513", "title": "韓職／監督讚減輕牛棚負擔 王彥程遺憾沒把交付局數完成", "summary": "台灣左投王彥程轉戰韓職的前兩場出賽，都為韓華鷹隊貢獻好投，還多了「愛哭鬼左投」名號，王彥程自評今天表現，對於沒能完成交付給自己的局數仍有遺憾，「這是我需要改進的地方。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827240.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-04 17:59"}, {"article_id": "9422498", "title": "中職／不只野手有上壘慶祝動作 廖任磊守護1分領先激動握拳有原因", "summary": "富邦悍將隊投手廖任磊今年在官辦熱身賽令人眼睛一亮，延續到正式賽季，昨天被交付第8局3：2領先局面，完成1局任務後有激動慶祝，而這其實類似野手的上壘慶祝動作，廖任磊說希望透過這些動作、這些聲音，讓團隊有更好的化學效應，更爆料隊上有投手版的林安可，連慶祝動作都是小小的。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827209.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-04 17:42"}, {"article_id": "9422497", "title": "TPBL／特攻內部會議收成效 謝亞軒關鍵三分球斷夢想家9連勝", "summary": "日前拉出聯盟史上最長9連勝的福爾摩沙夢想家，今天作客新北中信特攻主場卻踢到鐵板，特攻謝亞軒在比賽最後三分鐘連續投進兩記三分球，加上阿巴西抓下決勝籃板，幫助特攻以108：104中斷夢想家9連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827208.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-04 17:41"}, {"article_id": "9422496", "title": "中職／「連走路都沒辦法」 劉時豪揭去年一軍「空白」原因", "summary": "35歲捕手劉時豪去年歷經一軍「空白」的球季，季後遭戰力外結束5年味全龍生涯，今年轉戰台鋼雄鷹隊，睽違一年在一軍亮相，且開季前5場比賽有4場先發蹲捕，劉時豪才揭露去年那段「連走路都走不了」的日子。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827207.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-04 17:41"}, {"article_id": "9422454", "title": "中職／只是一顆平凡飛球 曾峻岳接走張育成首轟：就這～樣～飛過來", "summary": "富邦悍將隊張育成本季首轟3月31日第9局降落在亞太棒球場，這一轟打向牛棚，由自家終結者曾峻岳接走全壘打球，至於球的去向，曾峻岳說：「我不知道。」並未收下這顆全壘打球，而是隨手交給教練，他的理由很理直氣壯，「我又不可能帶著球上場。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827154.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-04 16:59"}, {"article_id": "9422447", "title": "日職／「台灣對決」沒上演 林安可連7場安打、宋家豪奪本季首勝", "summary": "日職西武獅隊今天在主場迎戰樂天金鷲隊，兩名台灣選手同場出賽，但沒能上演「台灣對決」。西武外野手林安可續扛第4棒、指定打擊，3打數敲出1支安打，還選到1保送，連續7場比賽安打；宋家豪則是中繼1局無失分，奪下本季首勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827173.jpg&M=1&s=Y&x=0&y=52&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-04 16:53"}, {"article_id": "9422433", "title": "韓職／王彥程一暖心舉動被讚「人品好」韓網狂讚帥臉：能拿50億", "summary": "台灣左投王彥程以10萬美元年薪加盟韓職韓華鷹隊，今天迎來第2次登板，用85球投6.1局，被敲5安打，4次三振、2次保送，失3分都非