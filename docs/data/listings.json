articles": [{"article_id": "9592297", "title": "世足攻略／英格蘭攻守成熟巴拿馬難擋 克羅埃西亞迎戰迦納關鍵在調度", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082193.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9592297"}, {"article_id": "9592272", "title": "世足攻略／J組阿爾及利亞防空拉警報 K組C羅角色成葡萄牙勝負關鍵", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082146.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9592272"}, {"article_id": "9590591", "title": "世足攻略／姆巴佩、哈蘭德金靴巔峰對決 比利時戰紐西蘭可望火力解放", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35079836.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9590591"}, {"article_id": "9590550", "title": "世足攻略／西班牙將遇烏拉圭鐵血考驗 維德角黑馬奇蹟在望", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35079783.jpg&M=1&s=Y&x=0&y=39&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9590550"}, {"article_id": "9588393", "title": "中職／選秀小年！悍將是挑兩大高中游擊 還是震撼選擇火球男黃玠瀚", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076672.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9588393"}, {"article_id": "9588772", "title": "字母哥成為「油頭」萊里戰士 熱火一年奪冠最少兩年成功", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35077219.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9588772"}]}, {"name": "最新文章", "articles": [{"article_id": "9592312", "title": "美國羽賽／蘇力揚直落二擊敗楊燦 勇闖男單4強", "summary": "BWF超級300系列的美國羽球公開賽，台灣男單好手蘇力揚今天在8強戰以21比19、21比8擊敗加拿大華裔選手楊燦，躋身4...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082234.jpg&M=1&s=Y&x=186&y=45&sw=994&sh=662&exp=3600&sl=W&fw=360", "date": "2026-06-27 14:50", "link": "/news/story/7005/9592312"}, {"article_id": "9592297", "title": "世足攻略／英格蘭攻守成熟巴拿馬難擋 克羅埃西亞迎戰迦納關鍵在調度", "summary": "「三獅軍團」英格蘭明天將在L組賽事迎戰已無緣晉級的巴拿馬，從兩隊的整體實力與首戰呈現的戰術執行力來看，我認為英格蘭不論在進攻組織或防守穩定度上，都顯著優於巴拿馬，巴拿馬若想贏球恐怕得寄望於對手犯下重大失誤。然而英格蘭這批年輕核心展現出的成熟度，讓我對這場比賽的風向有著相當明確的判斷，英格蘭預計能穩定掌控節奏，拿下這關鍵一勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082193.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 14:35", "link": "/news/story/122629/9592297"}, {"article_id": "9592305", "title": "MiLB／林維恩證實將動TJ手術本季落幕 「說不難過是騙人的」", "summary": "效力美職運動家隊的20歲台灣左投林維恩，近期因傷暫停出賽，他今天透過IG限時動態更新傷勢狀況，證實將進行TJ韌帶置換手術，坦言「說不難過是騙人的」，但也勉勵自己這不是結束、而是重新開始。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082258.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 14:29", "link": "/news/story/6999/9592305"}, {"article_id": "9592299", "title": "世足賽／40歲門將失誤後自請退場 烏拉圭成本屆排名最高遭淘汰隊伍", "summary": "世界排名第19的烏拉圭在本屆世界盃以0勝2和1敗收場，隊史首次連續兩屆在小組賽出局，也是本屆截至目前為止世界排名最高卻遭淘汰的球隊，總教練畢爾沙（Marcelo Bielsa）坦言，應該是可以拿到7分積分的，卻只有2分，但他也願意承擔所有責任。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082264.jpg&M=1&s=Y&x=0&y=28&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 14:24", "link": "/news/story/123107/9592299"}, {"article_id": "9592272", "title": "世足攻略／J組阿爾及利亞防空拉警報 K組C羅角色成葡萄牙勝負關鍵", "summary": "轉向K組與J組的激戰，四支隊伍都迎來攸關晉級排序的關鍵戰役，在J組方面，奧地利明天將強碰阿爾及利亞，阿爾及利亞前一場賽事雖然以2：1逆轉勝出，保住一線生機，但細看比賽過程，他們在防守端暴露出極大的防空漏洞，兩次失球邊緣都與制空權爭奪失敗有關。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082146.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 14:18", "link": "/news/story/122629/9592272"}, {"article_id": "9592289", "title": "世足賽／締造最迷你國晉級紀錄 維德角門將：我們每個人都是戰士", "summary": "2026年美加墨世足賽驚奇不斷，首度闖進會內賽的西非島國維德角（Cape Verde），在小組賽最終戰頂住壓力，以0：0逼平沙烏地阿拉伯。這支僅有52萬人口的「藍鯊」大軍，最終以3戰全和、分組第二的姿態爆冷挺進32強淘汰賽，打破世足賽歷史紀錄，成為有史以來晉級淘汰賽人口最少的國家。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082186.jpg&M=1&s=Y&x=271&y=234&sw=929&sh=619&exp=3600&sl=W&fw=360", "date": "2026-06-27 14:18", "link": "/news/story/123107/9592289"}, {"article_id": "9592273", "title": "MLB／佐佐木朗希4局5BB紅了眼眶 坦言球路狀況、球種選擇全都不順", "summary": "道奇隊今天以1：7不敵教士隊，先發投手佐佐木朗希投4局失3分，難以被忽視的是多達5次四壞球保送，而他在退場後被鏡頭捕捉到紅了眼眶，情緒明顯波動。朗希賽後表示，今天沒有任何一種球路讓自己感覺狀況是好的，在投球策略上的所有選擇，最終也都成反效果。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082148.jpg&M=1&s=Y&x=291&y=32&sw=989&sh=659&exp=3600&sl=W&fw=360", "date": "2026-06-27 14:04", "link": "/news/story/6999/9592273"}, {"article_id": "9588923", "title": "世足運彩／K組末輪決戰！力抗哥倫比亞要搶下小組第一推葡萄牙2:1", "summary": "2026年世界盃K組末輪將由葡萄牙對戰哥倫比亞，關鍵比賽定於6月28日07:30舉行。葡萄牙力求以勝利搶下小組第一，以避開淘汰賽強敵。盤口分析指向葡萄牙小幅讓球。預測比分為2-1，建議投注葡萄牙取勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35077356.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 14:00", "link": "/news/story/123105/9588923"}, {"article_id": "9592254", "title": "世足運彩／梅西大輪休！阿根廷實力強勁 約旦要進球難如登天", "summary": "德國與美國在踢完前2輪就確定拿到分組第1，第3輪走馬換將，結局令人相當錯愕的，德國輸給厄瓜多，美國輸給土耳其。現在早早拿到分組第1的阿根廷會不會如法炮製？", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082119.jpg&M=1&s=Y&x=0&y=28&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 13:56", "link": "/news/story/123105/9592254"}, {"article_id": "9592237", "title": "世足運彩／克羅埃西亞魔笛最後一曲 迦納放棄主動權銅牆鐵壁會被攻破", "summary": "英格蘭在第2輪被加納踢個0：0和局，現在變成3隊都有機會拿小組第1。迦納與英格蘭都是1勝1和，克羅埃西亞只有1勝1敗3分積分，如果克羅埃西亞這一場沒贏，3分積分而淨勝球負數，以小組第3來跟其他11小組比較，明顯會被刷掉。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082097.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 13:45", "link": "/news/story/123105/9592237"}, {"article_id": "9592222", "title": "世足賽／伊朗落入「分組3卡位」 送塞內加爾晉級、南韓拉最終警報", "summary": "世足賽小組賽最終輪賽事將在明天落幕，其中最受外界關注的「分組3卡位」戰也進入白熱化，在剛剛結束的G組賽事確定由伊朗以3戰全和、淨勝球「0」的成績落入分組第3名後，也將南韓在「分組3卡位」晉級排序擠到淘汰線上的最後一位，也就是第8席位置。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082065.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 13:22", "link": "/news/story/123107/9592222"}, {"article_id": "9592214", "title": "世足賽／伊朗絕殺不算與埃及戰和 南韓晉級之路只剩最後一口氣", "summary": "2026年世界盃足球賽G組小組賽最終輪，今天上演埃及、伊朗兩個中東國家過招，伊朗卡里扎赫（Shojae Khalilzadeh）在傷停補時第3分鐘進球，一度燃起直接晉級希望，隨後經影像輔助裁判（VAR）檢視後確認越位，伊朗空歡喜一場，最終1：1言和，G組分組底定第一比利時、第二埃及，伊朗能否晉級仍是未知數。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082062.jpg&M=1&s=Y&x=0&y=0&sw=1201&sh=801&exp=3600&sl=W&fw=360", "date": "2026-06-27 13:19", "link": "/news/story/123107/9592214"}, {"article_id": "9592159", "title": "NBA／謝謝「魯超人」！鵜鶘預計不執行魯尼球隊選項", "summary": "根據《NBA》記者海恩斯（Chris Haynes）報導，鵜鶘預計不執行中鋒「魯尼超人」（Kevon Looney）價值800萬美元（約新台幣2.36億元）的球隊選項，屆時這位3屆NBA總冠軍中鋒將成為完全自由球員。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35081972.jpg&M=1&s=Y&x=54&y=15&sw=1226&sh=817&exp=3600&sl=W&fw=360", "date": "2026-06-27 13:19", "link": "/news/story/7002/9592159"}, {"article_id": "9592134", "title": "NBA／球爸狂言再現！ 喊話灰狼簽齊「球家三兄弟」保證奪冠", "summary": "灰狼日前透過主力長人里德（Naz Reid）交易去黃蜂，換回「三球」明星後衛小鮑爾（LaMelo Ball）後，引發不少人質疑灰狼是否真的因此變得更強。然而，身為小鮑爾最大粉絲的父親「球爸」拉瓦爾（LaVar Ball），則對這筆交易感到相當興奮，甚至大膽預言灰狼應把另外兩個兒子一併簽下，保證2027年奪冠。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35081929.jpg&M=1&s=Y&x=0&y=9&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 13:18", "link": "/news/story/7002/9592134"}, {"article_id": "9592167", "title": "NBA／雷霆留奪冠禁區支柱 3年7500萬美元續約哈爾特斯坦", "summary": "衛冕失利的雷霆在今年休賽季可說是動作頻頻，接連清走維金斯（Aaron Wiggins）和喬伊（Isaiah Joe）兩大主力替補，重新調整陣容空間；今天更傳出消息，他們提前完成重要操作，與主戰中鋒哈爾特斯坦（Isaiah Hartenstein）達成一份3年7500萬美元的新合約協議，將續留至2028-29年賽季。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082048.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 13:17", "link": "/news/story/7002/9592167"}, {"article_id": "9592185", "title": "世足賽／特羅薩德梅開二度、盧卡庫傳射建功 比利時大勝紐西蘭晉級", "summary": "世足賽G組最後一輪賽事，「歐洲紅魔」比利時在前兩戰意外遭到埃及與伊朗踢平後，今天遭遇紐西蘭在進攻端大爆發，不僅特羅薩德（Leandro Trossard）梅開二度，德布勞內（Kevin De Bruyne）也在第66分鐘補上本屆賽事第一顆進球，加上盧卡庫（Romelu Lukaku）在比賽尾聲替補上陣後1進球、1助攻，幫助比利時最終以5：1勝出，並且搶下G組龍頭位置晉級到32強。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082039.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 13:06", "link": "/news/story/123107/9592185"}, {"article_id": "9592136", "title": "MLB／鄧愷威明先發有望對決李灝宇 老虎小編曬合照「台灣人快來按讚」", "summary": "太空人隊台灣投手鄧愷威明天迎接本季本季9場先發，客場出戰老虎隊，力拚個人本季第5勝，有望和老虎內野手李灝宇再次上演「台灣對決」，兩人今天賽前在球場相見歡留下合照，老虎社群發出照片還用中文寫下「台灣人快來按讚」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35081934.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 12:28", "link": "/news/story/6999/9592136"}, {"article_id": "9592123", "title": "MLB／「我一直做好準備！」 鄭宗哲首安誕生「基襪大戰」直呼不可思議", "summary": "鄭宗哲的首趟大聯盟之旅在去年以3場、7打席短暫落幕，未能再等到機會，就遭到海盜隊割捨；今天在紅襪隊首升大聯盟，第一場比賽解鎖首打點、首安打、首保送，賽後談到接到通知上大聯盟的心情，他坦言確實有點嚇到，「但當我在3A時，就一直準備好要來到這裡。」鄭宗哲拿回自己的首安球，將送給父母收藏。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35081919.jpg&M=1&s=Y&x=478&y=114&sw=625&sh=417&exp=3600&sl=W&fw=360", "date": "2026-06-27 12:15", "link": "/news/story/6999/9592123"}, {"article_id": "9592011", "title": "世足賽／南韓已羨慕！人口50萬維德角3積分勇闖32強 球員激動落淚", "summary": "首度闖進世界盃會內賽的維德角今天以0比0與沙烏地阿拉伯踢和，延續他們童話般的征戰之旅，接下來將在淘汰賽迎戰上屆冠軍阿根廷。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35081897.jpg&M=1&s=Y&x=19&y=0&sw=1247&sh=831&exp=3600&sl=W&fw=360", "date": "2026-06-27 12:12", "link": "/news/story/123107/9592011"}, {"article_id": "9592110", "title": "MLB／釀酒人火球男第3顆就飆169.8公里 史上第3快僅次查普曼", "summary": "釀酒人米蕭洛斯基（Jacob Misiorowski）再度投出超猛火球，本場比賽第3顆球就飆到105.5英里（約169.8公里），打破大聯盟先發投手紀錄，並列大聯盟史上第3快。米蕭洛斯基主投6局失1分，幫助釀酒人以6：2擊退小熊隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35081898.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 12:12", "link": "/news/story/6999/9592110"}, {"article_id": "9591938", "title": "MLB／腿傷打壞家鄉夢！「神鱒」楚奧特傾向放棄全壘打大賽", "summary": "天使球星「神鱒」楚奧特（Mike Trout）原本有望在今年明星賽期間首度參加全壘打大賽，不過因右腿後肌拉傷影響，他坦言目前傾向不參賽，家鄉圓夢計畫恐怕得再等等。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35081648.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 11:44", "link": "/news/story/6999/9591938"}, {"article_id": "9591985", "title": "MLB／先不進廣告！ 基襪大戰板凳清空 鄭宗哲升大聯盟見證大場面", "summary": "洋基與紅襪今天在芬威球場進行四連戰第2戰，然而比賽進行到5局下時，雙方的世仇戰再度擦出火花，洋基先發投手華倫（Will Warren）一顆偏高內角速球引爆全場衝突，雙方板凳球員全數衝進場內，不過最終僅止於口角，並未演變成肢體衝突。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35081728.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 11:44", "link": "/news/story/6999/9591985"}, {"article_id": "9592057", "title": "NBA／活塞兩枚二輪籤換來雷霆射手 強化外線替康寧漢拉開進攻空間", "summary": "底特律活塞持續在休賽季補強陣容，以兩枚未來二輪選秀權，向雷霆換來後衛射手喬伊（Isaiah Joe）。根據交易內容細節，雷霆所得到的兩個二輪選秀權分別是得2030年來自灰狼的二輪籤，以及2031年活塞的二輪籤。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35081806.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-27 11:42", "link": "/news/story/7002/9592057"}, {"article_id": "9592027", "title": "世足賽／烏拉圭首次連兩屆小組賽止步 主帥：我無法讓球隊發揮潛力", "summary": "南美強權烏拉圭今天在世界盃小組賽最終戰以0：1不敵西班牙，戰績2和1敗、一勝難求，隊史首次連續兩屆在小組賽止步，主帥畢爾沙（Marcelo Bielsa）賽後直言，自己沒能讓烏拉圭和陣中的球員發揮出潛力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35081842.jpg&M=1&s=Y&x=0&y=12&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-27 11:27", "link": "/news/story/1231