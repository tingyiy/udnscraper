&w=300"}, {"article_id": "9460637", "title": "火箭教練尤多卡宛如「西瓜」 拿湖人防守束手無策真該罵", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/23/34884221.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9466134", "title": "NBA／斑馬G4回歸狂搧7鍋 馬刺19分大逆轉拓荒者聽牌", "summary": "馬刺隊當家球星溫班亞瑪（Victor Wembanyama）今天第4戰回歸，立刻繳出27分、11籃板外帶7阻攻的全能數據，助隊演出19分逆轉勝，以114：93擊敗拓荒者隊，系列賽取得3勝1敗的「聽牌」優勢。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_0.jpg", "date": "2026-04-27 08:30"}, {"article_id": "9465306", "title": "中職／5大洋投坐鎮 味全龍打造投手王國不是夢", "summary": "味全龍本季投手群表現亮眼，防禦率僅2.03，領先全聯盟。新任外籍投手教練納瓦洛以及強大的洋投陣容，成為關鍵因素。洋投群的穩定表現，讓味全龍開季戰績長紅，顯示出打造投手王國的潛力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891260.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-27 07:00"}, {"article_id": "9465355", "title": "不到一個月炸10轟！村上宗隆一點也不「盲」", "summary": "村上宗隆在大聯盟開季前24場比賽中強勢擊出10支全壘打，追平新秀紀錄，並展現出卓越的擊球紀律和打擊能力。隨著數據顯示其表現可與重砲史瓦伯媲美，未來表現值得期待。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891365.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-27 07:00"}, {"article_id": "9465736", "title": "日職／季中大地震換主帥 真正見效在隔年", "summary": "日本職棒中日龍隊在開季表現不佳，監督井上一樹的處境受到關注，近期勝率驟升至0.292，但分析已開始揣測其可能在季中下台。歷史經驗顯示，季中更換主帥後，未來賽季能見效的幾率不高。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891822.jpg&M=1&s=Y&x=0&y=42&sw=1024&sh=683&exp=3600&sl=W&fw=360", "date": "2026-04-27 07:00"}, {"article_id": "9462843", "title": "不論是否有世足賽最後一舞 難忘「餐巾紙合約」打造的梅西傳奇", "summary": "梅西的足球傳奇始於一張「餐巾紙合約」。2000年12月14日，梅西在巴塞隆納與俱樂部達成重要協議，這張合約為他未來的職業生涯奠定基礎，並解決了其治療生長激素缺乏症的經濟問題。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887666.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-27 07:00"}, {"article_id": "9466076", "title": "NBA／巴恩斯殷格拉姆各繳23分 暴龍擊敗騎士系列賽2比2扳平", "summary": "美國職籃NBA多倫多暴龍的巴恩斯最後一分鐘罰球超前比分，與殷格拉姆各貢獻23分，讓球隊今天得以93比89擊敗克里夫蘭騎士...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/27/34892329.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-27 06:26"}, {"article_id": "9465737", "title": "全大運／克服傷勢和低潮 世錦賽金牌蔡和軒品勢再登頂", "summary": "中信學院跆拳道品勢隊，連兩年全大運在公開男生組個人登頂，前世錦賽金牌得主蔡和軒更克服近兩年低潮，贏得個人首面大運會金牌。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891807.jpg&M=1&s=Y&x=0&y=0&sw=1074&sh=716&exp=3600&sl=W&fw=360", "date": "2026-04-26 21:53"}, {"article_id": "9465725", "title": "全大運／王愷翊單日兩戰告捷 台師大寫網球男團5連霸", "summary": "臺灣師大在115年全國大專校院運動會公開男生組網球團體賽決賽，以2：0擊敗彰化師大奪金，完成五連霸壯舉，教練林岱樵開心之餘坦言，五連霸並非易事，他也期勉選手在後續的個人賽全力以赴。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891798.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 21:47"}, {"article_id": "9465712", "title": "中職／9下劉子杰打擊不用給指令 曾豪駒：他很有想法、攻擊都有策略", "summary": "樂天桃猿隊今天在主場面對味全龍隊，在比賽後段靠著兩名年輕「小猿」挺身而出，其中劉子杰在9局下以「生涯首轟就是再見轟」的表現，幫助猿隊以3：2打下勝利，總教練曾豪駒表示：「棒球就是這樣，還沒結束都想不到結果。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891774.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 21:36"}, {"article_id": "9465691", "title": "馬拉松／人類極限大突破！倫敦馬肯亞選手薩威 史上首位跑進2小時大關", "summary": "肯亞選手薩威（Sabastian Sawe）今天在倫敦馬拉松賽跑出不到2小時的成績，不但寫下新的世界紀錄，完成衛冕任務，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891740.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-26 21:28"}, {"article_id": "9465687", "title": "籃球／真人版「藤真」在北大高中 U19賽下剋上", "summary": "U19籃球聯盟在今天上演驚奇之戰，戰績墊底的北大高中籃球隊在大安國中賽區上演了「下剋上」逆轉大戲，最終以45：40力退強敵SP TEAMS。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891735.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 21:17"}, {"article_id": "9465673", "title": "中職／從沒想過生涯首轟就是再見轟 劉子杰成桃猿隊史第一人", "summary": "樂天桃猿隊23歲內野手劉子杰今天在生涯第4場出賽、第16打席敲出生涯首轟，在桃園球場面對味全龍隊，9局下轟出一發再見陽春砲，成為中職史上第12位、隊史首位生涯首轟就是再見轟的球員，劉子杰自己也坦言很震撼，「從沒想過這件事會發生。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891719.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 21:04"}, {"article_id": "9465669", "title": "TPBL／對戰神本土戰力有自信 丁聖儒盼盼成爭冠隊伍", "summary": "台北台新戰神今天浪費最多21分領先，遭新北中信特攻以111：103逆轉，不過總教練米蘭認為本土球員表現出色，仍是場好比賽，轟下個人新高34分的丁聖儒也相信，球隊是有爭冠本錢的隊伍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891716.jpg&M=1&s=Y&x=0&y=0&sw=852&sh=568&exp=3600&sl=W&fw=360", "date": "2026-04-26 21:03"}, {"article_id": "9465656", "title": "中職／拿兄弟牛棚當火種 悍將火力死灰復燃中止3連敗", "summary": "先發投手撐不長局數，就是中信兄弟隊悲慘的牛棚防禦率展示舞台，今天第六局耗了3任後援投手才止血，讓富邦悍將隊進攻12人次、狂刷7分，兄弟終場以5：8不敵悍將，各自的3連勝、3連敗畫下句點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891708.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 20:55"}, {"article_id": "9465639", "title": "TPBL／特攻24罰俱中 林韋翰：職籃不容易", "summary": "新北中信特攻今天上演21分逆轉勝，靠下半場65：40攻勢逆轉台北台新戰神，最終以111：103收下3連勝，其中全隊24罰全進，百分百命中率讓後場主力林韋翰喊「不容易」，個人8罰俱中的洋將飛克也特別提到自己罰球線上都沒失手，開心展現苦練成果。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891703.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 20:41"}, {"article_id": "9465577", "title": "中職／劉子杰生涯首轟就是驚天再見轟！ 猿隊3：2打退龍隊", "summary": "樂天桃猿隊今天在主場面對戰績排名第一的味全龍隊，兩隊先發投手都繳出6局無失分的表現，交由牛棚決勝負，猿隊先在7局下靠何品室融的安打敲回2分，但龍隊在9局上扳平比數，9局下猿隊劉子杰敲出左外野方向的再見陽春砲，生涯首轟就是驚天再見轟，助猿隊3：2勝出。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891688.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-26 20:03"}, {"article_id": "9465535", "title": "中職／首次雙響砲轟出明確目標 李勛傑發豪語「我要競爭全壘打王」", "summary": "樂天桃猿21歲強打李勛傑今年開季前12場比賽已轟出3發全壘打，與陳晨威並列全隊最多轟，包括在21日演出生涯首次雙響砲後，他也因此訂下今年賽季的目標，「我要競爭全壘打王。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891602.jpg&M=1&s=Y&x=0&y=51&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 19:29"}, {"article_id": "9465533", "title": "TPBL／27比2海嘯攻勢 特攻克服21分落後逆轉戰神", "summary": "台北台新戰神今天迎接本季主場最終戰，上半場在丁聖儒、謝銘駿聯手發揮下最多取得19分領先，但第四節被新北中信特攻打出瘋狂的27：2反撲攻勢，最終第四節狂轟41分的特攻在「拉尾盤」下完成逆轉勝，以111：103奪下3連勝，第19勝入袋超前18勝的新北國王，也追平排名第3的新竹御嵿攻城獅。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891598.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 19:29"}, {"article_id": "9465527", "title": "中職／南方王者！獅隊「南人祭」3戰被敲34安打竟能清盤雄鷹", "summary": "隊長陳傑憲歸隊成為統一獅隊的起爆劑，今天敲出雙安、包括一支陽春砲，帶動獅隊火力噴發，終場以9：5擊敗台鋼雄鷹隊。獅隊投手群在「南人祭」3場合計被敲34支安打，但獅隊神奇完成3連戰清盤。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891633.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 19:24"}, {"article_id": "9465518", "title": "中職／執行過兩次太空飛行+太空漫步 林琪兒：開球最可怕", "summary": "首位台灣出生的NASA太空人林琪兒，生涯曾執行過兩次太空飛行和兩次太空漫步，站上台灣的棒球場開球，卻也讓他留下難忘的經驗，今天再次造訪桃園棒球場擔任開球嘉賓，他笑說：「開球是我經歷過最可怕的事。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891573.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 19:15"}, {"article_id": "9465513", "title": "NBA／午睡達人出招！備戰暴龍騎士G4 英格倫要靠女友「逼睡」", "summary": "多倫多暴龍即將迎來關鍵第4戰，對於英格倫（Brandon Ingram）而言，與騎士的這場比賽的準備或許早在前一晚就已開始。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34891571.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-26 19:12"}, {"article_id": "9465500", "title": "中職／邱浩鈞百中繼達陣 史上累積5人有3人在獅隊締造", "summary": "統一獅隊今天在亞太棒球場迎戰台鋼雄鷹隊，邱浩鈞第7局兩出局、一三壘人時上場「拆彈」，面對陳世嘉賞出三振，在這一戰達成生涯百中繼里程碑，成為中職史上第5人。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=h