 "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35068759.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/122629/9583239"}, {"article_id": "9581485", "title": "下放11天救贖大覺醒！李灝宇攻守兩端精算 拚卡位老虎二遊", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35066096.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9581485"}, {"article_id": "9581615", "title": "中職／悍將別等威戈神了 補強洋投才不會白費上半季好戰績", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35066229.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9581615"}]}, {"name": "最新文章", "articles": [{"article_id": "9586896", "title": "世足賽／波赫3比1力克卡達 關鍵三分積分入袋保有晉級生機", "summary": "於2026年6月25日凌晨3點展開的世界盃B組小組賽，由波赫在主場迎戰卡達。在這場攸關晉級資格的關鍵戰役中，波赫憑藉著高效率的攻勢與對手防線的失誤，最終以3比1擊敗卡達，順利全取3分，繼續保有爭取淘汰", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_5.jpg", "date": "2026-06-25 05:44", "link": "/news/story/123107/9586896"}, {"article_id": "9586895", "title": "世足賽／瑞士2比1力克加拿大 兩勝一和穩居B組首位晉級", "summary": "2026年世界盃足球賽B組小組賽於台灣時間6月25日凌晨3時展開。由瑞士迎戰加拿大，雙方經過90分鐘激戰，最終瑞士憑藉下半場連下兩城，以2比1擊退加拿大，順利奠定分組龍頭的領先優勢。\\n本場控球節奏由", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074134.jpg&M=1&s=Y&x=34&y=0&sw=1051&sh=700&exp=3600&sl=W&fw=360", "date": "2026-06-25 05:36", "link": "/news/story/123107/9586895"}, {"article_id": "9586738", "title": "世足賽／史上第4人 「魔笛」莫德里奇200場國家隊出賽", "summary": "克羅埃西亞昨天在小組賽第二戰以一比○險勝巴拿馬，保住晉級卅二強的一線生機，也慶祝四十歲傳奇球星「魔笛」莫德里奇效力國家隊的第兩百場比賽，賽後全隊更是換上莫德里奇的紀念衣，並將他在場中高高拋起，紀念歷史性的一刻。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073871.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-25 00:00", "link": "/news/story/123107/9586738"}, {"article_id": "9586707", "title": "世足賽／川普受邀頒發大力神盃", "summary": "本屆世足賽除了球場上強權廝殺，頒獎典禮也將迎來歷史性一幕，國際足球總會主席因凡蒂諾昨天證實，美國總統川普將於七月廿日在紐澤西舉行的冠軍賽後，與他一同登台頒發象徵至高榮譽的「大力神盃」，打破近代世足賽由國際足總主席獨自頒獎的慣例。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073866.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-25 00:00", "link": "/news/story/123107/9586707"}, {"article_id": "9586605", "title": "世足賽／挺過低潮…C羅連6屆世界盃進球 再創紀錄", "summary": "生涯第六度參加世界盃足球賽，四十一歲的葡萄牙當家球星Ｃ羅因小組賽首戰未進球被罵翻，昨天馬上用強勢表現回應，面對烏茲別克第六分鐘就率先破網，成為史上首位連六屆世界盃都有進球紀錄的球員。Ｃ羅不但單場「梅開二度」，還用驚人演技掩護隊友門德斯踢進自由球，率領葡萄牙以五比○大勝，累積四分積分，為前進卅二強淘汰賽占據有利位置。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073788.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 00:00", "link": "/news/story/123107/9586605"}, {"article_id": "9586525", "title": "中職／曾家輝優質先發+林子崴後援3局4K 猿隊屠龍終止5連敗", "summary": "樂天桃猿隊下半季網羅洋砲的消息曝光後，今天在主場對上味全龍隊，本土投手展現價值，曾家輝先發6局失2分，加上林子崴3局送4K的強力後援，雙投聯手壓制上半季霸主，猿隊打線也回溫敲出14支安打，終場以7：2勝出，單場得分超過前5戰總和，終止本季最長5連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073748.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-24 21:57", "link": "/news/story/7001/9586525"}, {"article_id": "9586496", "title": "中職／陳品宏6局無失分封鎖台鋼奪生涯首勝 悍將再1勝平球團紀錄", "summary": "富邦悍將隊今天在澄清湖棒球場以3：1擊敗台鋼雄鷹，21歲左投陳品宏繳出6局無失分的出色表現，僅被敲1支安打，在進入職棒第3個球季收下生涯首勝；悍將則是拿下本季第31勝，接下來還有4場補賽，繼續力拚超越2019年下半季的32勝，挑戰球團史半季最多勝紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073695.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 21:29", "link": "/news/story/7001/9586496"}, {"article_id": "9586469", "title": "圍棋／王元均直落二奪得圍棋快棋王 終結3年冠軍荒", "summary": "台灣圍棋名將王元均今天在快棋爭霸戰決賽三番勝負第2局逆轉新星徐靖恩，最後以2比0奪得快棋王頭銜，並終結長達3年的「冠軍荒...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073674.jpg&M=1&s=Y&x=0&y=20&sw=1200&sh=800&exp=3600&sl=W&fw=360", "date": "2026-06-24 21:14", "link": "/news/story/7003/9586469"}, {"article_id": "9586417", "title": "世足賽／主辦方尊重國情宗教 沙國伊拉克國旗賽前儀式不落地", "summary": "世界盃足球賽進行期間，沙烏地阿拉伯和伊拉克的國旗在賽前儀式中不會被放置在地面上，因為國旗上有伊斯蘭教的神聖字句", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073652.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 20:54", "link": "/news/story/123107/9586417"}, {"article_id": "9586287", "title": "棒球／紅葉少棒首闖LLB亞太區預賽 力拚晉級前往美國威廉波特", "summary": "台東縣紅葉國小少棒隊首度取得世界少棒聯盟（LLB）台灣代表隊資格，今天啟程前往韓國參加6月27日至7月3日舉行的LLB亞太區資格賽，爭取前進美國威廉波特世界少棒賽的門票。桃園國際機場公司副總經理余崇立特別到場勉勵球員，希望小將們保持自信、全力以赴，在國際舞台展現平日訓練成果，為台灣爭取佳績。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073451.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-06-24 19:25", "link": "/news/story/7001/9586287"}, {"article_id": "9586199", "title": "射箭／玉山國手選拔賽25日開戰 亞運國手許芯慈、顏子翔領銜出賽", "summary": "由玉山銀行第三年贊助的「玉山射箭國手選拔賽」，今天於嘉義中正大學田徑場舉行盛大的開幕儀式，今年共有來自全國236名青年、青少年射箭好手參賽，其中更有今年名古屋亞運現役國手許芯慈（反曲弓）、顏子翔（複合弓）領銜出賽，選手將在25至27日進行多達12局432箭的高強度競爭，爭奪代表台灣參加12月亞洲青年暨青少年射箭錦標賽的代表隊國手資格。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073321.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-24 18:21", "link": "/news/story/7005/9586199"}, {"article_id": "9585775", "title": "世足運彩／資金與莊家態度明確倒向美洲雄鷹 Gemini推薦順應市場潮流預測墨西哥2：1勝", "summary": "2026世界盃A組小組賽，墨西哥迎戰捷克，勢必決定兩隊前景。墨西哥以優勢主場心理、實力差距，預測將2：1獲勝，並順利晉級淘汰賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073149.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:25", "link": "/news/story/123105/9585775"}, {"article_id": "9585774", "title": "世足運彩／捷克冷門條件不完整 地主6分在手不會放慢腳步GPT看好墨西哥2：1或3：1勝", "summary": "墨西哥在世足小組賽中以二連勝和零失球的佳績領先，面對捷克的壓力戰這場比賽顯示明顯優勢。捷克需全力以赴，墨西哥有機會利用反擊擴大優勢，預測最終比分為2比1或3比1。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073093.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:21", "link": "/news/story/123105/9585774"}, {"article_id": "9585928", "title": "世足運彩／墨西哥讓淺盤有鬼！捷克尊嚴之戰戰意滿點推薦受讓過關與正比1：1", "summary": "捷克與墨西哥將於6月25日展開生死戰，捷克需勝才能晉級，而墨西哥已提前出線並可能進行陣容輪換。主要球星施克的表現至關重要，捷克有望在對手防線重組中把握機會。建議選擇捷克受讓0.5球，預測比賽結果為平局1:1。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072874.jpg&M=1&s=Y&x=0&y=0&sw=1260&sh=840&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:17", "link": "/news/story/123105/9585928"}, {"article_id": "9586026", "title": "NBA／幫溫班亞瑪找替補幫手 馬刺首輪連拿兩個禁區怪物", "summary": "馬刺在NBA選秀中連挑兩名禁區新秀，選中康乃狄克大學中鋒里德，作為替補球員支援明星溫班亞瑪。另一名選手肯塔基大學的昆坦斯則因膝傷風險高，成為一場豪賭。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073074.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:13", "link": "/news/story/7002/9586026"}, {"article_id": "9586024", "title": "世足賽／哥倫比亞率先晉級 致勝功臣穆納茲：不以此滿足", "summary": "民主剛果門將姆帕西（Lionel Mpasi）今天開賽前20分鐘就擋下哥倫比亞5次猛攻，但第76分鐘仍被穆納茲（Daniel Munoz）攻破球門，這記全場唯一進球讓哥倫比亞以2連勝率先晉級，穆納茲獲選單場最佳球員。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073076.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:02", "link": "/news/story/123107/9586024"}, {"article_id": "9585883", "title": "世足賽／巴西世界盃的球衣政治學 穿紅穿綠意義大不同", "summary": "巴西隊今天在世界盃迎戰蘇格蘭隊時，門將貝克（Alisson Becker）將身穿綠色球衣出賽，而非國際足球總會（FIFA...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073049.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:02", "link": "/news/story/123107/9585883"}, {"article_id": "9585771", "title": "世足運彩／太極虎生死戰拒絕保守求和 強碰疲憊南非利多Gemini 推薦南韓2：1勝出", "summary": "南韓將迎戰南非，若能把握機會將有望順利晉級。儘管太極虎在先前比賽中失利，但目前士氣高昂，專注求勝。反觀南非面臨疲憊與壓力，賠率顯示支持南韓不敗，預測比分為南韓2比1南非。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072997.jpg&M=1&s=Y&x=0&y=27&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:00", "link": "/news/story/123105/9585771"}, {"article_id": "9585770", "title": "世足運彩／南非搶攻易出漏洞！南韓不會把命運交給對手GPT看好2：1或3：1勝出", "summary": "南韓在世足小組賽面對南非，前者目前穩居小組第二，賠率顯示南韓勝出優勢明顯。南非需全力搶分，希望逆轉形勢，預測總進球數可達至少3球。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072665.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:00", "link": "/news/story/123105/9585770"}, {"article_id": "9585763", "title": "世足運彩／讓球盤壓力落在淨勝球需求 摩洛哥對海地GPT看好2.5大分", "summary": "摩洛哥排名第7、海地第83，國際盤卻把主勝均價放在2.14，表面不像一面倒低賠，實際搭配和局5.627、客勝11.993來看，莊家真正的態度不是懷疑摩洛哥能否贏，而是把市場焦點推向讓球盤：北非雄獅若只", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073016.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 16:58", "link": "/news/story/123105/9585763"}, {"article_id": "9585762", "title": "世足運彩／搶分爭龍頭全力開火！北非雄獅將痛擊出局海地Gemini推摩洛哥3：0或4：0", "summary": "摩洛哥在世界盃小組賽決戰中面對海地，擁有高達4分的他們力爭小組第一，反觀海地已宣告出局。數據顯示，摩洛哥實力強大，預測將以3：0或4：0輕鬆取勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072944.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 16:53", "link": "/news/story/123105/9585762"}, {"article_id": "9585914", "title": "NBA／湖人交易補強內線又夢碎？公鹿恐無意再轉售韋爾", "summary": "湖人補強計畫恐遭損壞，年輕中鋒韋爾在公鹿被熱火交易後，公鹿不考慮再次交易他，讓多隊包括湖人失去機會。韋爾本季場均11.1分、9.0籃板，成為公鹿重建基石。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072838.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 16:51", "link": "/news/story/7002/9585914"}, {"article_id": "9585978", "title": "NBA／和老闆在「選秀戰情室」吵架 勇士總管：在討論高爾夫球場", "summary": "今天選秀會最大話題不是球員本身，而是勇士隊老闆拉卡柏（Joe Lacob）和總管鄧利維（Mike Dunleavy Jr.）在戰情室爭執畫面流出。鄧利維事後受訪時聲稱，兩人對於選擇密西根大學23歲前鋒倫德伯格（Yaxel Lendeborg）有共識。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/