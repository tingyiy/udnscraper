ttps://uc.udn.com.tw/photo/t3/2026/06/02/35005941.jpg&M=1&s=Y&x=0&y=40&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9541168", "title": "攻守伯仲之間、氣勢不相上下 尼克休9天紅利能破馬刺防線？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005672.jpg&M=1&s=Y&x=0&y=0&sw=1024&sh=683&exp=3600&w=300"}, {"article_id": "9540738", "title": "世足攻略／E組超強德國力爭洗刷前恥 象、厄對決成名次卡位戰", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005468.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9538984", "title": "建隊奪冠趨勢：「長輪替」創造餘裕 強隊不再只靠球星苦撐", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35002315.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9538339", "title": "中職／英雄不怕出身低 李東洺、曾家輝野球人生倒吃甘蔗", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35001531.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9542696", "title": "NBA／布朗森迎戰馬刺銅牆鐵壁 大讚卡瑟爾注定成為頂尖防守者", "summary": "NBA總冠軍賽明天點燃戰火，尼克隊暌違多年重返總冠軍賽，面對馬刺隊溫班亞瑪（Victor Wembanyama）坐鎮禁區，搭配「二年級」防守悍將卡瑟爾（Stephon Castle）組成的銅牆鐵壁，當家控衛布朗森（Jalen Brunson）坦言，這將是今年季後賽至今的最大挑戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/03/35007519.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 11:05"}, {"article_id": "9542617", "title": "MLB／賈吉肋骨挫傷本季首度缺陣 少主砲洋基主場被守護者攻破", "summary": "洋基球星賈吉因肋骨挫傷首次缺陣，最終以4：9不敵守護者。總教練布恩表示，賈吉狀況不佳影響近期表現，現被列為「每日觀察」。賈吉本季出賽59場，貢獻17支全壘打。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/03/35007396.jpg&M=1&s=Y&x=0&y=0&sw=1245&sh=830&exp=3600&sl=W&fw=360", "date": "2026-06-03 10:54"}, {"article_id": "9542632", "title": "世足賽／戰火與政治夾縫中出征 伊朗終獲美、墨簽證本周啟程", "summary": "2026年世足賽開幕在即，然而對於「波斯鐵騎」伊朗而言，這條世足賽之路卻走得無比艱辛，在首場分組賽倒數不到兩周的緊要關頭，伊朗足協主席塔季（Mehdi Taj）終於捎來好消息，預計將在本周前陸續取得墨西哥、美國入境簽證，為這趟充滿未知數的世足征途注入強心針。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/03/35007413.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 10:52"}, {"article_id": "9542441", "title": "法網／和納達爾同名 19歲西班牙小將止步8強仍寫驚奇", "summary": "「西班牙蠻牛」納達爾（Rafael Nadal）雖已退休，西班牙江山代有人才出，「小蠻牛」阿爾卡拉斯（Carlos Alcaraz）後，年僅19歲的霍達爾（Rafael Jodar）今年打進法網8強，雖敗在澤瑞夫（Alexander Zverev）拍下無緣再挺進，仍展現無窮潛力，實力也獲得澤瑞夫肯定。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/03/35007224.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-03 09:47"}, {"article_id": "9542358", "title": "MLB／李灝宇敲第2轟隔天被下放3A 老虎教頭：還會再回來", "summary": "底特律老虎隊23歲「台灣怪力男」李灝宇昨天敲出生涯在大聯盟的第2轟，但隨著陣中二壘手托瑞斯（Gleyber Torres）傷癒歸隊，老虎隊今天選擇將李灝宇下放3A，結束他46天的大聯盟之旅，讓他回小聯盟繼續累積穩定出賽的機會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/03/35007118.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 09:14"}, {"article_id": "9542315", "title": "法網／20歲門西克首闖4強 締造捷克最年輕紀錄", "summary": "20歲的捷克小將門西克（Jakub Mensik）今年法網打出代表作，台灣時間今天凌晨他以6：4、6：3、7：6（7：3）力退巴西新星豐塞卡（Joao Fonseca） ，闖進4強，持續改寫個人在大滿貫的最佳成績。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/03/35007156.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 08:51"}, {"article_id": "9542301", "title": "法網／20歲捷克新星直落三勝巴西黑馬 挺進4強將迎戰澤瑞夫", "summary": "法網今天凌晨上演新生代好手對決，在男單8強賽上20歲的捷克新星門西克（Jakub Mensik）展現強大氣場，以6：4、6：3、7：6（7：3）直落三盤，終結了19歲巴西黑馬豐塞卡（Joao Fonseca）的黑馬之旅，強勢挺進男單4強。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/03/35007157.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 08:41"}, {"article_id": "9542293", "title": "NBA／總冠軍賽4日燃戰火 尼克中鋒羅賓森手指骨折仍渴望上陣", "summary": "NBA總冠軍賽即將在明天點燃戰火，相隔27年重返冠軍賽舞台的尼克，卻在賽前傳出傷兵隱憂，主力禁區悍將羅賓森（Mitchell Robinson）因上周動刀治療右手骨折，目前被球隊列為「出賽成疑」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/03/35007209.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 08:31"}, {"article_id": "9542247", "title": "NBA／黑衫軍暌違12年重返總冠軍賽 「波波文化」成精神支柱", "summary": "馬刺在驚險贏得西區冠軍賽搶七大戰後，宣告暌違12年再度挺進NBA總冠軍賽，雖然這也是黑衫軍首次在沒有傳奇教頭波波維奇（Gregg Popovich）坐鎮的情況下爭奪總冠軍獎盃，但這位名人堂教頭留下的冠軍DNA，依然是年輕馬刺最頂級的精神財富。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/03/35007193.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 07:58"}, {"article_id": "9542014", "title": "中職／再度燃起的旅外夢 張育成進化成最強全方位打者", "summary": "張育成於2024年進化為中職最強全方位打者，以37場比賽打擊三圍0.356/0.453/0.591及7轟的驚人成績，表現優於去年最佳打者林安可。富邦悍將與他簽下9250萬元合約，期望助力球隊衝擊首冠。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006557.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 07:00"}, {"article_id": "9541372", "title": "日職／阿部事件引社會譁然 日本棒球為何無法擺脫暴力形象？", "summary": "阿部慎之助因家暴醜聞被巨人隊開除，揭示日本棒球界根深蒂固的暴力文化。過去多起事件顯示，體罰與霸凌問題影響選手與球隊形象，暴力行為仍未根除，引發社會廣泛關注與討論。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005941.jpg&M=1&s=Y&x=0&y=40&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 07:00"}, {"article_id": "9541168", "title": "攻守伯仲之間、氣勢不相上下 尼克休9天紅利能破馬刺防線？", "summary": "2026年NBA總決賽即將開打，紐約尼克隊對戰聖安東尼奧馬刺隊。馬刺在「外星人」溫班亞瑪的帶領下，近期表現亮眼，成功逆轉奪冠熱門雷霆；而尼克則以11連勝進入總決賽，並獲得九天的休息時間，有望挑戰馬刺的防線。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35005672.jpg&M=1&s=Y&x=0&y=0&sw=1024&sh=683&exp=3600&sl=W&fw=360", "date": "2026-06-03 07:00"}, {"article_id": "9542014", "title": "中職／再度燃起的旅外夢 張育成進化成最強全方位打者", "summary": "張育成於2024年進化為中職最強全方位打者，以37場比賽打擊三圍0.356/0.453/0.591及7轟的驚人成績，表現優於去年最佳打者林安可。富邦悍將與他簽下9250萬元合約，期望助力球隊衝擊首冠。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006557.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 07:00"}, {"article_id": "9542105", "title": "法網／澤瑞夫直落三橫掃霍達 再度晉級男單4強", "summary": "德國男網好手澤瑞夫克服開局的不穩，今天以7比6（7/3）、6比1、6比3拍落西班牙小將霍達（Rafael Jodar）...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/03/35006801.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-03 05:28"}, {"article_id": "9541971", "title": "棒球／竹市組城市棒球隊 找來陳瑞振任教頭", "summary": "新竹市政府為推動棒球運動發展，市長高虹安昨宣布六月籌組「新竹市城市棒球隊」，在副市長林琨瀚及市政顧問張泰山見證下，授帽給總教練陳瑞振。市府指出，未來城市棒球隊除投入各項成棒賽事外，也將積極與新竹市三級棒球體系合作，鼓勵棒球人才深耕新竹。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006498.jpg&M=1&s=Y&x=200&y=113&sw=910&sh=607&exp=3600&sl=W&fw=360", "date": "2026-06-03 00:00"}, {"article_id": "9541878", "title": "中職／王建民怒了！狠甩牛棚電話門 連轉播台都嚇到", "summary": "中信兄弟隊今天以3：7不敵統一獅隊，投手群出現8次四壞球保送，第九局盧孟揚登板連投3保送，投手教練王建民怒摔電話門，不只球迷驚呼，連轉播台上都直言這很少見。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006435.jpg&M=1&s=Y&x=0&y=32&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-02 22:51"}, {"article_id": "9541821", "title": "中職／飛力獅→菲力士 林岳平觀察有一樣也有不一樣", "summary": "「飛力獅」化為「菲力士」後，今天首度面對前東家統一獅隊，以5.2局失5分承擔敗投，此役呈現出來的狀態，獅隊教頭林岳平指出，在獅隊時期也有看過，若看球速的話，是與去年最好時期確實有落差。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006375.jpg&M=1&s=Y&x=29&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-06-02 22:19"}, {"article_id": "9541807", "title": "TPBL／球員時期完成過大逆轉 簡浩激勵夢想家「不能放棄」", "summary": "球員時期曾在冠軍賽1比3絕對落後下連勝3場奪冠，簡浩接下福爾摩沙夢想家兵符後又陷入同樣絕境，他以自身經驗勉勵球員「不能放棄」，今天回到台中主場團隊就以105：69大勝衛冕軍新北國王，將總冠軍賽延長到第6戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35006357.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 22:12"}, {"article_id": "9541780", "title": "印尼羽賽／李家雙胞胎力退奧運銀牌 男雙將上演寶島內戰", "summary": "總獎金145萬美金的印尼羽球公開賽今天點燃戰火，台灣羽將在雙打突圍，李哲輝／楊博軒3局力退地主卡爾南多（Leo Rolly Carnando）／馬丁（Da