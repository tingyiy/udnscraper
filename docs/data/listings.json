tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/12/34848166.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300"}, {"article_id": "9437331", "title": "日職／猛虎的真本事 想靠純本土達成連霸", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/12/34848536.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9441872", "title": "中職／鄭浩均3.1局爆8分 兄弟打11場已吞9敗又平最速紀錄", "summary": "中信兄弟隊打線爆發一場又開始漸凍，全場只出現5支安打，先發投手鄭浩均則是3.1局遭到暴打8分，兄弟終場以4：8輸給台鋼雄鷹隊。兄弟過去隊史最速9敗為1997年11戰9敗，今天輸球後追平最慘紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34855384.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=852&exp=3600&sl=W&fw=360", "date": "2026-04-14 22:18"}, {"article_id": "9441865", "title": "中職／3局滿壘沒換下陳品宏 「光總」抱持被打也是一種成長", "summary": "富邦悍將隊今天在9局下靠孔念恩再見安打以4：3擊敗味全龍隊，左投陳品宏的一軍初先發以3局失2分（責失1分）、無關勝敗收場，總教練後藤光尊評價此役，認為比預期好很多，也談到第3局滿壘沒換投，是抱持「就算被打也是一種成長」想法，但陳品宏反倒連抓2個出局數。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34855369.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 22:14"}, {"article_id": "9441843", "title": "中職／輝哥有料！孔念恩敲再見安 「第一顆滑球浮起來就大膽揮」", "summary": "新莊棒球場今天打到9局峰迴路轉，曾峻岳本季首度掉分，險些面臨敗場，9局下由孔念恩敲出兩分打點再見安打，以4：3中斷味全龍隊的3連勝。孔念恩首度在主場站上MVP舞台，賽後透露致勝打席的攻略就是來自打擊教練高國輝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34855346.jpg&M=1&s=Y&x=0&y=122&sw=853&sh=568&exp=3600&sl=W&fw=360", "date": "2026-04-14 22:02"}, {"article_id": "9441802", "title": "全大運／從對手變隊友 林暄芸、呂芯瑜首次搭檔雙人單槳艇賽就奪金", "summary": "115年全國大專運動會划船賽事在日月潭月牙灣舉行，代表輔仁大學出賽公開男子組輕量級單人雙槳艇的林暐哲，儘管賽前狀況自認不理想，但他努力展現訓練成果，最終划出7分51秒65，順利完成二連霸。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34855261.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 21:34"}, {"article_id": "9441801", "title": "中職／悍將超強韌性讓龍隊兩次BS 孔念恩敲再見安", "summary": "富邦悍將隊今天在新莊棒球場展現韌性，追平後再度面臨落後，仍在9局下由孔念恩敲出再見安打，以4：3中斷味全龍隊的3連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34855300.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 21:34"}, {"article_id": "9441796", "title": "BCL／國王連兩年交手領航猿都遭重挫 洪志善點出土洋陣容變化大是主因", "summary": "PLG與TPBL雙職籃衛冕軍桃園璞園領航猿、新北國王今天在BCL東亞區資格賽分組賽進行交鋒，不過比賽卻在第一節後出現一面倒的局勢，領航猿在多點開花攻勢下打出單節38：11攻勢，最多取得37分領先，最終領航猿也以25分差距大勝國王，賽後國王代理總教練洪志善也直言，球隊與兩年前在PLG冠軍賽遭遇領航猿相比，在土洋陣容上有相當大的變動，確實難與磨合多時的領航猿對抗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34855247.png&M=1&s=Y&x=0&y=213&sw=840&sh=560&exp=3600&sl=W&fw=360", "date": "2026-04-14 21:29"}, {"article_id": "9441755", "title": "圖輯／中職 悍將陳品宏生涯首先發3局退場 5局暫時落後味全", "summary": "富邦悍將今天在新莊主場對戰來訪的味全龍，進行本季首場交手，作客的味全龍隊由伍鐸先發應戰、主場的富邦悍將由陳品宏生涯首度先發出賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34855177.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 21:02"}, {"article_id": "9441727", "title": "BCL／雙職籃衛冕軍對決 領航猿一度領先國王37分輕鬆收下2連勝", "summary": "BCL東亞區資格賽桃園璞園領航猿與新北國王今天在北市大天母體育館交鋒，也是雙職籃聯盟衛冕軍的跨聯盟交鋒，不過上半場領航猿就火力全開轟下65分，其中洋將米爾納一人就拿下21分，幫助領航猿取得31分領先，最終領航猿在上場球員全數得分下，也以110：85輕取國王，拿下分組賽2連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34855136.png&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 20:38"}, {"article_id": "9441650", "title": "日職／再解鎖1項初體驗 林安可打14場首度雙安", "summary": "繼前一場解鎖日職生涯首轟，林安可今天再有突破，今天面對歐力士隊之戰敲出1支一壘打、1支二壘打，首度單場雙安，所屬的西武獅隊終場以1：5輸球。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34855094.jpg&M=1&s=Y&x=0&y=48&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 20:02"}, {"article_id": "9441479", "title": "NBA／狀元佛雷格4項數據領先全隊 比肩喬丹狂創史詩級紀錄", "summary": "獨行俠選秀狀元佛雷格（Cooper Flagg）的菜鳥球季正式落下帷幕，這位備受矚目的新星不僅逐步兌現頂級天賦，更成功追隨傳奇巨星「籃球之神」喬丹（Michael Jordan）的步伐，寫下了NBA史上極為罕見的史詩級紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854865.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-14 18:28"}, {"article_id": "9441476", "title": "中職／喜歡的球員自己印！「新莊城堡」啟用小卡機 5月還有女孩版", "summary": "「新莊城堡」再有新玩具，富邦悍將隊今日起在新莊棒球場啟用「收藏小卡機」，可由球迷自行選擇喜愛球員印製成PVC塑膠材質的紀念小卡，每張150元，5月還將有Fubon Angels款式機台推出。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854855.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 18:18"}, {"article_id": "9441474", "title": "中職／軟銀使用徐若熙不著眼「越多越好」 葉總說重點是品質", "summary": "「龍之子」徐若熙輸出軟銀後，味全龍隊總教練葉君璋持續關注，談到第3場出賽間隔8天再登板，直呼「我覺得這個安排很好！」他認為軟銀不是著眼於「越多越多」，而是想讓他的每場出賽都投出有品質的內容。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854859.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 18:17"}, {"article_id": "9441412", "title": "NBA／葛蘭德附加賽生死戰前高喊致敬 柯瑞感嘆「我真的老了！」", "summary": "勇士與快艇在例行賽最終戰交手後，將再度於附加賽狹路相逢，這場「一戰定生死」的對決也因為柯瑞（Stephen Curry）與葛蘭德（Darius Garland）的正面對話而備受矚目。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854796.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-14 18:04"}, {"article_id": "9441355", "title": "中職／吉力吉撈左膝韌帶傷仍練打是正常 葉總：不痛就可以", "summary": "味全龍隊劉俊緯前場跑壘出現傷情，經診斷後還不到拉傷程度，總教練葉君璋說是「拉傷邊緣」，預計休息3、4天應該就能上陣；至於左膝後十字韌帶受傷的主砲吉力吉撈．鞏冠，今天已在練打，葉總表示，這個傷勢對打擊不會有影響，「只要他不痛就可以。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854667.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 17:38"}, {"article_id": "9441322", "title": "中職／超越林益全登基悍將安打王 范國宸完全沒發現：真的嗎？", "summary": "幾乎全面由林益全占據的富邦悍將球團史（2017年起）各項打擊紀錄，近日有一項悄悄換了新主人，范國宸12日轟出全壘打，以684安登基球團史安打王，讓他聽聞後也嚇到，坦言完全沒注意到。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854647.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 17:23"}, {"article_id": "9441288", "title": "全民署推運動村里認證 讓規律運動成在地生活", "summary": "運動部全民運動署今天舉行「115年運動村里認證」全台起跑記者會暨北區說明會，盼藉由政策說明，引領全台村里轉型為健康活力社...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854619.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 17:20"}, {"article_id": "9441303", "title": "中職／鈴木駿輔求知慾滿到光總稱他「小笨蛋」 下一場出賽在一軍", "summary": "富邦悍將隊開季先發投手狀況不佳，拖累上周戰情，本周將有洋投異動，投手教練許銘傑談兩位日籍洋投鈴木駿輔、阿部雄大調整狀況，鈴木下一場出賽會是在一軍，阿部則預計還要看看他在夏天的出賽狀況，「目前成績看起來是不錯，希望他繼續保持下去，也要看看他在夏天的調整。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854605.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 17:15"}, {"article_id": "9441289", "title": "TPBL／助夢想家27分落後大逆轉 霍爾曼奪單周MVP", "summary": "TPBL今天公布第二十四周單周最有價值球員（MVP），由福爾摩沙夢想家隊洋將霍爾曼拿下。夢想家上周日作客新竹御嵿攻城獅主場，在最多落後27分的情況下上演驚天逆轉，不僅寫下聯盟史上最大逆轉勝紀錄，也終結長達兩年四個月未能在新竹縣體育館取勝的紀錄，霍爾曼也以宰制級表現榮膺單周MVP。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854540.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-14 17:11"}, {"article_id": "9441269", "title": "NBA／史上後衛場均30分最準賽季 亞歷山大超越「籃球之神」喬丹", "summary": "衛冕冠軍雷霆本季雖然陸續面臨傷病問題，但在當家球星亞歷山大（Shai Gilgeous-Alexander）的帶領下，仍舊打出64勝18敗的全聯盟最佳戰績，同時他更用歷史級效率完成這個巔峰賽季，再次成為年度MVP最大熱門。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854547.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-14 17:09"}, {"article_id": "9441263", "title": "中職／威戈神還沒找回最大武器 後藤談悍將打優於投先寄望先發吃局數", "summary": "富邦悍將隊洋投威戈神開季狀況不佳，3場先發防禦率高達6.92，已在昨天降下二軍，總教練後藤光尊指出，他最大的武器是控球，但目前調整狀況沒那麼好，希望他下二軍後的調整，可以修正到控球隨心所欲，「想丟到哪就丟到哪。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854603.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 16:59"}, {"article_id": "9441257", "title": "網球／開心有辛納當焦點 阿爾卡拉斯笑：這周不會想念他", "summary": "蒙地卡羅名人賽挑戰連霸失利，西班牙「小蠻牛」阿爾卡拉斯（Carlos Alcaraz）將球王寶座讓給剛在決賽擊敗自己的義大利宿敵辛納（Jannik Sinner），但他完全不見落敗的頹喪，反而笑容滿面，還說樂見辛納當焦點人物，自己也因為這位優秀對手更加進步。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854514.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 16:55"}, {"article_id": "9441250", "title": "中職／張育成賽前練球未現蹤是否出賽？「光總」保密", "summary": "富邦悍將隊今天在新莊棒球場面對味全龍隊，主砲張育成未現身場上參與賽前練習，引起關注，總教練後藤光尊對此表示：「他有在裡面練打」，並未回應是否在今天先發或出賽名單，當場向媒體請託，關於選手當天先發或出賽狀況的提問，基本上都不會回應。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854500.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-14 16:53"}, {"article_id": "9441181", "title": "NBA／41歲詹姆斯再創歷史！生涯70次單週最佳 獨步天下無人及", "summary": "41歲的湖人傳奇巨星詹姆斯（LeBron James）再次用表現證明自己仍站在聯盟頂端。聯盟日前公布例行賽最後一週東西區最佳球員名單，詹姆斯拿下生涯第70次「單週最佳球員」殊榮，將這項歷史紀錄推向前所未見的高度。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854434.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-14 16:32"}, {"article_id": "9441027", "title": "TPBL／戰神本季最後主場吹沖繩風 加碼抽沖繩來回機票", "summary": "台北台新戰神隊將於25、26日重返主場，球團今天宣布推出「沖繩夏日 いやささー」主題日，以沖繩文化特色為主軸，結合傳統表演帶來別具風格的觀賽體驗，還將抽出台北、沖繩來回機票，邀請戰友把握本季最後主場觀戰機會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854159.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-14 15:15"}]}, {"name": "棒球", "articles": [{"article_id": "9441650", "title": "日職／再解鎖1項初體驗 林安可打14場首度雙安", "date": "2026-04-14 20:02", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34855094.jpg&M=1&s=Y&x=0&y=48&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9441801", "title": "中職／悍將超強韌性讓龍隊兩次BS 孔念恩敲再見安", "date": "2026-04-14 21:34", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34855300.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9441250", "title": "中職／張育成賽前練球未現蹤是否出賽？「光總」保密", "date