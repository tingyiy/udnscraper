 "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062907.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600", "link": "/news/story/7001/9579341"}], "subsections": [{"name": "專欄", "articles": [{"article_id": "9579349", "title": "世足攻略／西班牙非勝不可 亞馬爾扮重要角色", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062895.jpg&M=1&s=Y&x=0&y=24&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/122629/9579349"}, {"article_id": "9578142", "title": "世足攻略／日、德兩強掌握主動權 慎防突尼西亞與象牙海岸的變數反撲", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/20/35061239.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9578142"}, {"article_id": "9576652", "title": "世足攻略／巴西沒退路碰海地鐵桶陣忌急躁 美國迎黑馬澳洲應能勝1球", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/19/35059219.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9576652"}, {"article_id": "9575298", "title": "棒球／林羿豪當年赴日是台灣之光 為何歐子喬卻成鑽漏洞？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35057370.jpg&M=1&s=Y&x=0&y=144&sw=917&sh=611&exp=3600&w=300", "link": "/news/story/122629/9575298"}, {"article_id": "9575115", "title": "大聯盟首次台灣對決充滿機緣巧合 鄧愷威、李灝宇18年後接棒王建民", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/16/35047751.png&M=1&s=Y&x=111&y=0&sw=1080&sh=720&exp=3600&w=300", "link": "/news/story/122629/9575115"}, {"article_id": "9575501", "title": "為柯瑞生涯拚爭冠最後一搏 勇士攻略 ：搶詹皇、短約續獨角獸", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35057707.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/122629/9575501"}]}, {"name": "最新文章", "articles": [{"article_id": "9579373", "title": "中職／遭鈴木駿輔完封「以為是山本由伸」 陳晨威連兩戰賽後跟他致歉", "summary": "樂天桃猿隊昨天遭到富邦悍將隊洋投鈴木駿輔以0：2完封，全場只有陳晨威從他手中敲出1支安打，也因為他的1安1保送表現，讓鈴木駿輔無緣「完全比賽」，陳晨威透露，賽後又跟他說了不好意思，「Perfect game, sorry.」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_2.jpg", "date": "2026-06-21 17:08", "link": "/news/story/7001/9579373"}, {"article_id": "9579349", "title": "世足攻略／西班牙非勝不可 亞馬爾扮重要角色", "summary": "西班牙選手亞馬爾將是關鍵，面對沙烏地阿拉伯，西班牙必須全力以赴，爭取勝利。首戰平局影響嚴重，戰術從傳控轉向兩側突破，以期在密集防守中找出破綻。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062895.jpg&M=1&s=Y&x=0&y=24&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-21 16:47", "link": "/news/story/122629/9579349"}, {"article_id": "9579341", "title": "中職／曾總說麥斯威尼「抹消」變「註銷」 榊原元稀及新秀下周亮相", "summary": "樂天桃猿隊昨天將洋投麥斯威尼下放二軍，對於外界好奇他是否準備「領機票」？總教練曾豪駒日前笑稱還沒，今天賽前也表示只是「抹消」登錄、降二軍，但聯盟稍後公布的異動，猿隊將麥斯威尼註銷，改註冊日籍投手榊原元稀。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062907.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-21 16:34", "link": "/news/story/7001/9579341"}, {"article_id": "9579336", "title": "MLB／這次不是山本由伸而是自己人 金鶯官網點名幾乎無人能敵", "summary": "金鶯隊作客道奇球場，今天3連戰第2戰從山本由伸的手中攻下3分，終場以3：2獲勝，系列賽扳平戰局；金鶯官網指出，有些人認為山本可能投出無安打比賽，畢竟他在去年9月首次面對金鶯時，只差1個出局數就締造紀錄，這次確實有一位投手幾乎無人能敵，但不是山本。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062905.jpg&M=1&s=Y&x=54&y=0&sw=1226&sh=817&exp=3600&sl=W&fw=360", "date": "2026-06-21 16:31", "link": "/news/story/6999/9579336"}, {"article_id": "9579253", "title": "世足運彩／G組晉級混戰十字路口 紐西蘭硬碰埃及生死鬥Gemini主推和局", "summary": "2026世界盃G組賽事進入白熱化，首輪四隊全數握手言和，各積1分呈現史詩級混亂。紐西蘭與埃及此役交鋒，在「贏球占得晉級先機、輸球即陷入被動」的巨大積分壓力下，此役堪稱出線分水嶺。首戰兩度領先卻遭伊朗逼", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062853.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-21 16:14", "link": "/news/story/123105/9579253"}, {"article_id": "9579252", "title": "世足運彩／紐西蘭仍遭盤口壓制 GPT看好埃及經驗占優比分2:1", "summary": "紐西蘭首戰踢成2比2，兩度領先卻守不住，士氣有亮點也有隱憂；埃及則以1比1逼平比利時，結果不算華麗，卻更像一支知道如何在高強度比賽中保住局面的球隊。兩隊目前同積1分，這場若分出勝負，G組出線形勢會立刻", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062832.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-21 16:07", "link": "/news/story/123105/9579252"}, {"article_id": "9579306", "title": "MLB／上田綺世破門、大谷翔平開轟同時來 日本球迷幸福喊好忙", "summary": "因「二寶」出生短暫缺陣後，大谷翔今天回歸主場金鶯之戰就在9局下轟出陽春砲，本季累積16發全壘打。雖然道奇最終以2比3不敵金鶯，4連勝中止，但這發「祝賀砲」仍展現他驚人的長打能力與歷史級火力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062822.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-21 16:06", "link": "/news/story/6999/9579306"}, {"article_id": "9579314", "title": "世足／踢和剛果C羅遭批太自私 葡萄牙隊友力挺老大哥：開打前就準備好面對輿論", "summary": "2026世界盃不斷爆冷，其中強權葡萄牙日前在小組賽首戰與剛果共和國踢和，陣中當家球星C羅（Cristiano Ronaldo）更是飽受外界質疑，甚至被貼上自私標籤。對此隊友達洛（Diogo Dalot）在受訪時站出來幫老大哥說話，並表示全隊早在世界盃開打前就做好面對輿論的準備。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062833.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-21 16:01", "link": "/news/story/123107/9579314"}, {"article_id": "9579250", "title": "世足運彩／南美勁旅體能亮紅燈 慎防黑馬維德角爆冷Gemini仍推烏拉圭2:1", "summary": "2026世界盃H組次輪點燃戰火，南美傳統勁旅烏拉圭將迎戰非洲新黑馬維德角。對於陣中多數主力效力於歐洲頂級球會的烏拉圭而言，跨洲奔波與季末多線作戰的體能隱憂，無疑是當前最大罩門。首輪與沙烏地阿拉伯握手言", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062821.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-21 15:59", "link": "/news/story/123105/9579250"}, {"article_id": "9579251", "title": "世足運彩／晉級壓力升高盤口仍占上風 對維德角GPT推烏拉圭不讓分勝", "summary": "首輪只拿1分的烏拉圭，面對同樣守住和局的維德角，這場已不是單純強弱對照，而是南美勁旅能否在H組提早搶回主導權的壓力測試。烏拉圭首戰1比1遭沙烏地阿拉伯逼和，維德角則以0比0逼平西班牙，四隊同積1分的局", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062806.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-21 15:52", "link": "/news/story/123105/9579251"}, {"article_id": "9579248", "title": "世足運彩／G組出線生死戰！歐洲紅魔以逸待勞強碰波斯鐵騎 Gemini看好大分", "summary": "2026年世界盃G組次輪迎來關鍵對決，由比利時迎戰伊朗。兩隊首輪皆墨守和局，此役面臨非贏不可的壓力。從備戰狀態與心理優勢來看，早已抵達並完成充分訓練的比利時顯然以逸待勞；反觀伊朗不僅面臨舟車勞頓，更因", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062791.jpg&M=1&s=Y&x=0&y=0&sw=1249&sh=833&exp=3600&sl=W&fw=360", "date": "2026-06-21 15:45", "link": "/news/story/123105/9579248"}, {"article_id": "9579247", "title": "世足運彩／對伊朗盤口暗藏冷門誘因 但比利時仍有支撐GPT推2:1或3:1", "summary": "伊朗客勝被拉到5.74，和局也高掛4.293，莊家表面給足冷門報酬，實際卻把比利時主勝壓在2.01，這不是單純放膽買下盤的格局。以世界排名第9對第20來看，比利時並未被開到過熱低賠，反而留下主勝的盤口", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062787.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-21 15:40", "link": "/news/story/123105/9579247"}, {"article_id": "9579246", "title": "世足運彩／西班牙退無可退！無敵艦隊誓展必勝決心 迎戰沙烏地Gemini推2:1", "summary": "2026世界盃H組次輪點燃戰火，奪冠熱門「無敵艦隊」西班牙首戰意外被維德角逼和，面臨極大的晉級壓力，此役對陣沙烏地阿拉伯已無退路，必勝決心與強烈戰意毋庸置疑。相較於首輪爆冷逼平烏拉圭的沙烏地阿拉伯，身", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062763.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-21 15:33", "link": "/news/story/123105/9579246"}, {"article_id": "9579276", "title": "NBA／灰狼評估交易兩大悍將 首輪28順位籤也可能成籌碼", "summary": "灰狼在休賽季交易市場上也開始有所動作，根據《HoopsHype》記者史卡托（Michael Scotto）報導，灰狼已經探詢藍道（Julius Randle）、迪文森佐（Donte DiVincenzo）以及今年首輪第28順位選秀權的交易價值，顯示球隊可能正評估進一步調整陣容。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062762.jpg&M=1&s=Y&x=0&y=7&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-21 15:31", "link": "/news/story/7002/9579276"}, {"article_id": "9579278", "title": "世足賽／千場里程碑鎌田幫日本奪勝 日媒解答進球為何「打電話」", "summary": "日本今天在世界盃足球賽以4：0擊敗突尼西亞，成為史上第1000場比賽的勝隊，目前1勝1和在「死亡之組」F組和荷蘭並列領先，晉級32強相當有利，鎌田大地開賽4分鐘破網，寫下隊史最快進球紀錄，「打電話」姿勢也創造話題。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062777.jpg&M=1&s=Y&x=0&y=20&sw=955&sh=637&exp=3600&sl=W&fw=360", "date": "2026-06-21 15:30", "link": "/news/story/123107/9579278"}, {"article_id": "9579245", "title": "世足運彩／西班牙主場壓力轉為反彈火力 對沙烏地GPT看好不讓分勝", "summary": "西班牙首戰0比0被維德角逼平，主隊身分反而讓這場面對沙烏地阿拉伯更像壓力釋放點；沙烏地1比1逼和烏拉圭後士氣確實抬頭，但排名第61對上世界第2，客場心理多半會先求穩，這正是西班牙控球與高壓最容易累積破", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062760.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-21 15:27", "link": "/news/story/123105/9579245"}, {"article_id": "9579265", "title": "NBA／自曝未替任何球隊試訓 狀元熱門迪班薩：他們知道我能做什麼", "summary": "距離備受矚目的2026年NBA選秀會只剩幾天，外界原本普遍預期可能成為狀元人選的迪班薩（AJ Dybantsa），近日卻在節目中透露一項可能影響選秀順位的重要訊息。他表示，自己雖然拜訪過多支球隊，但實際上並沒有為任何球隊進行私人試訓。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062746.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-21 15:19", "link": "/news/story/7002/9579265"}, {"article_id": "9579242", "title": "籃球／世中運錦標賽 中華女籃晉決賽寫隊史最佳", "summary": "2026年世界中學生籃球錦標賽於塞爾維亞登場，中華女籃今天在4強賽靠著張雨瞳砍下全場最高23分，順利以87比32大勝土耳...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062753.jpg&M=1&s=Y&x=0&y=25&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-21 15:19", "link": "/news/story/7003/9579242"}, {"article_id": "9579269", "title": "NBA／小人物大逆襲！太陽落選秀打出超狂紀錄 獲4年15億合約", "summary": "小人物逆襲！《ESPN》知名記者查拉尼亞（Shams Charania）透露，太陽將與上賽季打出生涯代表作的落選秀後衛格里斯佩（Collin Gillespie），簽下一紙4800萬美元（約台幣15.2億）的合約。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062759.jpg&M=1&s=Y&x=95&y=215&sw=1052&sh=638&exp=3600&sl=W&fw=360", "date": "2026-06-21 15:19", "link": "/news/story/7002/9579269"}, {"article_id": "9579254", "title": "NBA／安戴托昆波轉戰熱火傳聞升溫 活塞可能成三方交易關鍵、赫洛有望赴底特律", "summary": "安戴托昆波（Giannis Antetokounmpo）可能離開密爾瓦基公鹿的交易傳聞持續升溫，而邁阿密熱火被視為目前最積極、也最有機會完成重磅補強的球隊。根據多方消息指出，公鹿與熱火針對安戴托昆波的潛在交易已取得明顯進展，底特律活塞則可能以第三方球隊身分加入，協助完成這筆牽動聯盟版圖的三方大交易。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062725.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-21 15:10", "link": "/news/story/7002/9579254"}, {"article_id": "9579239", "title": "世足運彩／「紅魔」力拚波斯鐵騎伊朗鋼鐵防線拿3分 推比利時不讓分", "summary": "世足賽G組比利時將迎戰伊朗，兩隊皆需搶分以提升晉級希望。比利時擁有強大陣容，面對伊朗的防守反擊將成關鍵，預測比利時將不讓分。比賽時間為6月22日03:00。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062715.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-21 15:00", "link": "/news/story/123105/9579239"}, {"article_id": "9579225", "title": "拳擊／WB盃中國站林郁婷鍍銀 教練曾自強：跳量級體能需提升", "summary": "拳擊WB盃中國站今天進行的女子60公斤級決賽，台灣好手林郁婷面對哈薩克新秀格拉費耶娃，第3回合遭讀秒，最終以2比3落敗；...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062700.jpg&M=1&s=Y&x=0&y=180&sw=725&sh=483&exp=3600&sl=W&fw=360", "date": "2026-06-21 14:44", "link": "/news/story/7005/9579225"}, {"article_id": "9579205", "title": "世足賽／伊朗總教練獲告知 美國將放寬世界盃第3戰旅行限制", "summary": "世界盃伊朗代表隊總教練卡蘭諾伊（Amir Ghalenoei）今天表示，他已被告知美國將放寬全隊第3戰的旅行限制。不過，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062681.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-21 14:32", "link": "/news/story/123107/9579205"}, {"article_id": "9579068", "title": "世界盃／小組第一 淘汰賽相對有利 全美熱議能否奪冠？", "summary": "美國男足(USMNT)以2比0擊敗澳洲，寫下自1930年以來首次在世界盃分組賽取得二連勝並提前晉級，引發全美熱烈討論這支「黃金世代」能否奪冠。總教練波切蒂諾(Mauricio Pochettino)強調要保持奪冠信念，退役的瑞典傳奇足球巨星伊布拉欣莫維奇(Zlatan Ibrahimovic，球迷暱稱伊布)擔任轉播球評也給出肯定答案。但這支地主隊真的能贏得2026世界盃嗎？紐約時報旗下「運動員」(The Athletic)11名專家對此展開激辯。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062475.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-21 14:30", "link": "/news/story/123107/9579068"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9579200", "title": "世足賽／首度單場進4球！