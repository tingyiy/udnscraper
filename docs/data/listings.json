&sh=853&exp=3600"}, {"article_id": "9497655", "title": "NBA／史上第11隊！雷霆季後賽8連勝 3勁旅一路奪冠封神", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34939384.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600"}], "subsections": [{"name": "專欄", "articles": [{"article_id": "9497981", "title": "最頂級擊球品質卻換不回一轟 塔提斯真的純粹是運氣差嗎？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940085.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9498591", "title": "中職／富邦補強林岱安成效浮現 刺激戴培峰成「超級捕手」", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940808.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9498142", "title": "溫班亞瑪被逼到出肘！灰狼找到「封印」方法 馬刺真正危機來了", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940324.jpg&M=1&s=Y&x=17&y=5&sw=1239&sh=826&exp=3600&w=300"}, {"article_id": "9497668", "title": "世界盃倒數30天！巴西隊主帥動慈悲 球星內馬爾寄生大名單", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34939532.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300"}, {"article_id": "9496663", "title": "日職／職棒生涯起點不同 宋家豪將繼許銘傑後成台將第3人", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34937774.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=852&exp=3600&w=300"}, {"article_id": "9496398", "title": "唐斯撕下「軟糖」標籤 尼克先發五門齊奪東冠不是問題", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34937395.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9499145", "title": "NBA／疑似用藥過量 灰熊年度新秀第一隊前鋒克拉克驟逝得年29歲", "summary": "今年無緣季後賽的灰熊今天傳出令人遺憾的噩耗，陣中效力長達7年的前鋒克拉克（Brandon Clarke）驚傳在洛杉磯家中過世，得年僅29歲，灰熊球團、聯盟辦公室及經紀公司隨後皆證實此消息，在生涯正值壯年之際突然謝幕，令不少球迷感到唏噓。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34941465.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-13 08:24"}, {"article_id": "9499140", "title": "NBA／帶來超越籃球的勇氣 首位公開出櫃現役球員柯林斯癌逝享年47歲", "summary": "NBA歷史上首位公開出櫃的現役球員、長期擔任聯盟親善大使的柯林斯（Jason Collins），在與病魔搏鬥數月後，於今天因腦癌在家中安詳辭世，享年47歲，這名曾為運動場內外帶來變革的先驅者，用他47年的人生歲月，詮釋了超越籃球場的勇氣。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34941484.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-05-13 08:20"}, {"article_id": "9499089", "title": "NBA／湖人遭橫掃季後將重整 佩林卡、瑞迪克盼留詹姆斯、里夫斯", "summary": "隨著湖人在季後賽次輪慘遭雷霆橫掃，紫金大軍的季後賽之旅就此止步，但球隊高層的腳步卻未曾停歇，湖人營運總裁佩林卡（Rob Pelinka）與總教練瑞迪克（JJ Redick）於今天的季末訪談中同步表態，休賽季的首要任務便是爭取詹姆斯（LeBron James）與里夫斯（Austin Reaves）的回歸，延續球隊競爭核心。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_8.jpg", "date": "2026-05-13 07:39"}, {"article_id": "9497981", "title": "最頂級擊球品質卻換不回一轟 塔提斯真的純粹是運氣差嗎？", "summary": "教士隊球星塔提斯本季陷入全壘打荒，137打數未開轟，成為聯盟最令人失望球員之一。雖然擊球品質優異，強擊球率達58.8%，卻面臨不斷提高的滾地球率和降減的飛球率，可能影響長打表現。塔提斯需調整擊球模式，以尋求反彈機會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940085.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-13 07:00"}, {"article_id": "9498591", "title": "中職／富邦補強林岱安成效浮現 刺激戴培峰成「超級捕手」", "summary": "在棒球場除了先發投手外，捕手被視為最辛苦、最複雜的角色之一。除了要以蹲姿防守，還需要能夠應對各種球速與變化球的衝擊，最重要是在比賽中扮演「指揮官」的角色，好的捕手等同於場上第二個總教練，他需要防守技術、投手引導能力與領導氣質，讓投手安心專注投球，並在比賽中掌握節奏，更可能直接影響球隊勝敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940808.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-13 07:00"}, {"article_id": "9498800", "title": "高球／中信女子高球公開賽 送愛偏鄉", "summary": "日次巡總獎金最高的台、日共證賽事「二○二六中國信託女子公開賽─JLPGA巡迴特別錦標賽」明天將於東方高爾夫俱樂部登場，昨天舉行「職業業餘配對賽」共募集一千萬元善款，支持中國信託慈善基金會執行偏鄉兒童及家庭的扶助方案。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34941032.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-13 00:00"}, {"article_id": "9498642", "title": "中職／蘇智傑超前3分砲 獅本季對戰龍勝場終於開張", "summary": "中職統一7-ELEVEn獅隊今天靠著蘇智傑超前比數3分砲，胡智爲6局2責失分優質先發，終場以5比3擊敗味全龍隊，胡智爲獲...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940839.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-12 22:24"}, {"article_id": "9498592", "title": "中職／阿部雄大初登板熱投113球 後藤光尊以他過去出賽為根據", "summary": "富邦悍將隊以「育成洋將」合約簽下的阿部雄大，今天「開箱」面對中信兄弟隊演出6.1局無失分好投，幫助悍將以2：1贏球。此役在第七局球數破百情況下繼續熱投引起熱議，總教練後藤光尊表示，阿部從過去在日本社會人的比賽，球數都在110球左右，因此相信他可以投到這個球數沒有問題。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940776.jpg&M=1&s=Y&x=0&y=0&sw=1270&sh=847&exp=3600&sl=W&fw=360", "date": "2026-05-12 21:54"}, {"article_id": "9498576", "title": "中職／舉手手確認悍將PitchCom都在 光總也嚇一跳", "summary": "富邦悍將、中信兄弟隊今天發生「是誰掉了PitchCom」插曲，悍將教頭後藤光尊拿到對手PitchCom也嚇了一跳。而據悍將翻譯謝修銓還原，當時機器是沒有開的狀態，請捕手戴培峰按了沒反應，因此確認不是悍將的，實際上什麼都沒聽到。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940762.jpg&M=1&s=Y&x=0&y=0&sw=1000&sh=666&exp=3600&sl=W&fw=360", "date": "2026-05-12 21:43"}, {"article_id": "9498574", "title": "圖輯／阿部雄大一軍初登板零失分 富邦一分之差擊敗兄弟", "summary": "中華職棒今天由中信兄弟對上富邦悍將，四局下童堉誠敲出帶有兩分打點的三壘安打，富邦2：0領先，九局上兄弟有反撲攻勢，張志豪先擊出一發二壘安打，接著黃韋盛敲出一壘安打二壘跑者回本壘得下第一分，高宇杰再補上一發安打跑者攻佔一三壘，最後王威晨擊出滾地球雙殺，最後富邦悍將以2：1獲勝，這也是中信兄弟本季吞下的第20敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940757.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-12 21:43"}, {"article_id": "9498549", "title": "TPBL／馬建豪「找回自己」轟23分 夢想家22分大勝攻城獅扳平系列賽", "summary": "季後賽首戰主場失守的福爾摩沙夢想家，今天第2戰在本土球員馬建豪、蔣淯安和張宗憲聯手發揮下以83：61大勝新竹御嵿攻城獅，將5戰3勝制的系列賽扳平成1比1，代表系列賽確定會有第4戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940723.jpg&M=1&s=Y&x=0&y=0&sw=1024&sh=683&exp=3600&sl=W&fw=360", "date": "2026-05-12 21:22"}, {"article_id": "9498548", "title": "中職／兄弟29戰慘吞20敗 悍將育成洋將阿部雄大飆6.1局勵志好投", "summary": "富邦悍將隊育成洋投出奇蹟，25歲日籍投手阿部雄大一軍初登板，就繳出6.1局無失分優質先發，悍將終場以2：1擊敗中信兄弟隊，阿部取得生涯首勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940721.jpg&M=1&s=Y&x=0&y=269&sw=1024&sh=683&exp=3600&sl=W&fw=360", "date": "2026-05-12 21:21"}, {"article_id": "9498453", "title": "中職／悍將人怪好的！兄弟錯交自家PitchCom 光總揮手急忙要還", "summary": "富邦悍將、中信兄弟隊今天交手出現有趣插曲，兄弟洋投羅戈場上拾獲PitchCom，由悍將先行領回，下1球卻發現是真正失主是兄弟，急急忙忙還給對手。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940622.jpg&M=1&s=Y&x=0&y=0&sw=1000&sh=666&exp=3600&sl=W&fw=360", "date": "2026-05-12 20:13"}, {"article_id": "9498432", "title": "高球／中信公開賽配對賽助偏鄉孩童 攜手涂阿玉培育年輕潛力選手", "summary": "日次巡總獎金最高的台、日共證賽事「2026中國信託女子公開賽－JLPGA巡迴特別錦標賽」14日將於東方高爾夫俱樂部登場，中國信託商業銀行今天舉行「職業業餘配對賽」，邀請中國信託銀行貴賓客戶與32位女子高爾夫好手揮桿獻愛，共募集1000萬元善款，支持中國信託慈善基金會（簡稱「中信慈善基金會」）執行偏鄉兒童及家庭的扶助方案。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940615.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-12 20:08"}, {"article_id": "9498425", "title": "影／野獸林志傑擔任開球嘉賓 退役特展5月底登場", "summary": "中華職棒今天由中信兄弟對上富邦悍將，並邀請野獸林志傑來擔任開球嘉賓，談到個展，林志傑表示展出內容將會是他生涯實戰上一些比較有意義的球衣、鞋款跟獎項，現場也會販售一些紀念商品。他也呼籲有興趣的朋友到時可以去參觀展覽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940599.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-12 20:04"}, {"article_id": "9498327", "title": "亞運／棒球40人培訓名單 大學投手雷皓博黃玠瀚入選", "summary": "2026年名古屋亞運棒球項目40人培訓名單出爐，由總教練湯登凱領軍，國立體大兩投手雷皓博、黃玠瀚入選，上屆代表隊成員老將...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940536.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-12 19:32"}, {"article_id": "9498263", "title": "桌球／宏道基金會接機台灣男團 頒發獎勵金力挺年輕世代", "summary": "2026年國際桌球總會（ITTF）世界桌球團體錦標賽於英國倫敦落幕，我國男子桌球代表隊勇奪銅牌，追平隊史最佳成績，再度為台灣桌壇寫下亮眼一頁，宏道基金會由執行長陳士魁今天代表董事長林鴻道前往接機，並頒發獎勵金與禮盒。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940462.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-12 18:39"}, {"article_id": "9498262", "title": "影／桌球世團賽銅牌寫隊史紀錄　林昀儒：大家一起努力的結果", "summary": "中華隊在2026年倫敦世界團體桌球錦標賽勇闖男子4強，收下銅牌並連兩年站上頒獎台。由「一哥」林昀儒領軍的中華隊，10日凌晨4強戰遭遇日本隊，以0比3落敗，無緣挺進冠軍戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940433.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-12 18:37"}, {"article_id": "9498223", "title": "日職／古林睿煬二軍先發6局挨轟失7分 飆速154公里吞敗", "summary": "日職北海道日本火腿鬥士隊投手古林睿煬今天二軍先發出賽，投6局挨1轟，失掉7分責失分，單場最快球速154公里，球隊終場以5...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876247.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-12 18:24"}, {"article_id": "9498142", "title": "溫班亞瑪被逼到出肘！灰狼找到「封印」方法 馬刺真正危機來了", "summary": "馬刺灰狼第二輪，經過兩場於明尼蘇達主場的惡戰，馬刺完成突破客場討回主場優勢的基本任務，灰狼卻也在第二戰溫班亞瑪（Victor Wembanyama）因肘擊早早被驅除出場後，有驚無險地保下一場，避免主場二連敗，亦能以2比2延續系列賽的生機。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940324.jpg&M=1&s=Y&x=17&y=5&sw=1239&sh=826&exp=3600&sl=W&fw=360", "date": "2026-05-12 18:13"}, {"article_id": "9498117", "title": "NBA／湖人遭橫掃後震撼變數！里夫斯談未來去留：我不會想太多", "summary": "湖人在西區第二輪慘遭雷霆4戰橫掃後，後場主力里夫斯（Austin Reaves）的未來動向也成為外界高度關注焦點。不過在球季結束後受訪，里夫斯展現一貫低調態度，強調自己並不會過度去思考未來，更不會提前煩惱是否繼續留在湖人。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940272.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-12 17:47"}, {"article_id": "9498102", "title": "中職／3場再見勝卡位「搖滾區」有策略 張奕拉高國麟衣服是怕他濕", "summary": "富邦悍將隊本季至今3場再見勝，張奕都在贏球瞬間衝超快，成功卡位「搖滾區」，張奕對此解釋自己有策略，「因為你越晚過去越容易被噴，早點去，趕快歡呼一下就趕快跑掉。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940234.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-12 17:38"}, {"article_id": "9498054", "title": "NBA／神準八村壘落後3分放板凳？美媒解釋湖人主帥考量", "summary": "湖人隊今天在比賽尾聲落後3分，結果總教練瑞迪克（JJ Redick）將手感最火熱的八村壘放板凳，令許多球迷感到疑惑，賽後《ESPN》資深記者薛爾本（Ramona Shelburne）做出解釋。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940189.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-12 17:25"}, {"article_id": "9498050", "title": "中職／大幅縮短1年復健期回歸 張志豪：醫生說不會斷就會100%去做", "summary": "中信兄弟隊「精神領袖」張志豪今天回歸戰場，在新莊棒球場出戰富邦悍將隊，原本預估1年的復健期，他從去年9月動刀提前到此際復出，生涯遭受過許多大傷不減鬥志，「我個人想法比較極端，防護員說可以滑壘、醫生說不會斷，我就會100%去做。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940701.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-12 17:21"}]}, {"name": "棒球", "articles": [{"article_id": "9498548", "title": "中職／兄弟29戰慘吞20敗 悍將育成洋將阿部雄大飆6.1局勵志好投", "date": "2026-05-12 21:21", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940721.jpg&M=1&s=Y&x=0&y=269&sw=1024&sh=683&exp=3600&w=300"}, {"article_id": "9498592", "title": "中職／阿部雄大初登板熱投113球 後藤光尊以他過去出賽為根據", "date": "2026-05-12 21:54", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940776.jpg&M=1&s=Y&x=0&y=0&sw=1270&sh=847&exp=3600&w=300"}, {"article_id": "9498642", "title": "中職／蘇智傑超前3分砲 獅本季對戰龍勝場終於開張", "date": "2026-05-12 22:24", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940839.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&w=300"}, {"article_id": "9498576", "title": "中職／舉手手確認悍將PitchCom都在 光總也嚇一跳", "date": "2026-05-12 21:43", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940762.jpg&M=1&s=Y&x=0&y=0&sw=1000&sh=666&exp=3600&w=300"}, {"article_id": "9498574", "title": "圖輯／阿部雄大一軍初登板零失分 富邦一分之差擊敗兄弟", "date": "2026-05-12 21:43", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940757.jp