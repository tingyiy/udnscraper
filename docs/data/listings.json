e": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/17/34865828.jpg&M=1&s=Y&x=192&y=0&sw=935&sh=624&exp=3600&w=300"}, {"article_id": "9447377", "title": "勇士逆轉快艇情勢大好 爭西區老八太陽過不了柯瑞這關！", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/17/34863740.jpg&M=1&x=&y=&sw=&sh=&exp=3600&w=300"}, {"article_id": "9446213", "title": "中職／中信兄弟最爛開季 還展望季後賽嗎？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34862228.jpg&M=1&s=Y&x=0&y=36&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9443464", "title": "美媒揭大都會搶人失敗內幕 但狄亞茲球速下滑道奇虧大了？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857969.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9453644", "title": "全大運／宋佳彥射擊先包雙金 明和姊姊攜手再拚混雙", "summary": "北市大學的杭州亞運射擊選手宋佳彥，今天在114全國大專校院運動會一日進帳雙金，早上先在公開男生組10公尺空氣步槍團體賽與學弟郭穎衡、黃庭均摘下金牌，且總成績1858分打破大會紀錄；下午個人決賽再以248.1分添第二金，明天還將和姊姊宋諭婷攜手挑戰混雙金牌。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34873868.jpg&M=1&s=Y&x=0&y=0&sw=853&sh=569&exp=3600&sl=W&fw=360", "date": "2026-04-20 22:31"}, {"article_id": "9453606", "title": "全大運／放下成績執著 清大周亞瑄奪金還達亞運標", "summary": "清華大學周亞瑄在大學階段最後一戰選擇「放下對成績的執念、只跟自己比」的心態，在115年全國大專校院運動會公開女生組10公尺空氣步槍賽事中，不僅在排名賽射出629.5分，達名古屋亞運參賽標準，決賽更以250.2分摘下金牌，為大學生涯畫下美好句點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34873829.jpg&M=1&s=Y&x=0&y=0&sw=1194&sh=796&exp=3600&sl=W&fw=360", "date": "2026-04-20 22:13"}, {"article_id": "9453555", "title": "亞運／歷來最完整「一站式」中繼站 包下名古屋小學服務中華代表團", "summary": "愛知・名古屋亞運會9月登場，本屆賽事沒有興建選手村，比賽地點也較為分散，為服務我國代表團，運動部、中華奧會和國訓中心攜手，選定三地設置中繼站，其中在名古屋市區選定一間已廢校的小學「御園小學校」，運用三層樓的空間，打造出歷來最完整的「一站式」中繼站。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34873700.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 21:30"}, {"article_id": "9453528", "title": "全中運／賽前先哭再奪金 洪渝姍奇特抒壓高女100蝶四連霸", "summary": "全中運游泳今進入第三天賽程，來自台南市新豐高中「另類蝶后」洪渝姍在高女組100公尺蝶式以1分02秒11摘金，完成個人的100蝶四連霸（含一次國女組），洪渝姍在摘金後還被隊友虧，但教練黃硯歆幫她打圓場，「別人是賽後哭，但渝珊是賽前先哭，這是她獨特的抒壓方式。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34873666.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 21:04"}, {"article_id": "9453508", "title": "全中運／後壁國中軟網「南霸天」 唐子喬助校連6年稱后", "summary": "115年全中運軟式網球項目，台南市後壁國中再次展現「南霸天」氣勢，不僅包辦國中組男、女單打金牌，當中方允亨拿下隊史男單首金，唐子喬更是完成個人衛冕，並助校連續6年稱后。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34873651.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 20:50"}, {"article_id": "9453438", "title": "高球／新「一姊」吳佳晏 打下美國女子公開賽資格", "summary": "年僅22歲的「中國信託女子高爾夫之星」吳佳晏，本月好消息頻傳，先是12日在富士軟片女子公開賽勇奪生涯第二座JLPGA冠軍，世界排名上升到第100名，成台灣女子高球「一姊」，今天在2026美國女子公開賽日本區資格賽再脫穎而出，取得今年6月美國女子公開賽參賽資格。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34873600.jpg&M=1&s=Y&x=0&y=0&sw=1178&sh=785&exp=3600&sl=W&fw=360", "date": "2026-04-20 20:22"}, {"article_id": "9453326", "title": "高球／2026凱基銀行TLPGA未來賽 4月21日開打", "summary": "總獎金新台幣150萬元的「2026凱基銀行TLPGA未來賽」將於明（21）日連續三天在桃園市楊梅區揚昇高爾夫鄉村俱樂部正式開打，除了有來自海內外61位職業選手同場競技之外，13位業餘小將也將參與進行兩回合比賽。本次賽事不僅提供前兩名選手獲得「2026台灣強女子公開賽」的外卡機會，同時職業及業餘選手也將獲得世界積分，新世代女子高爾夫好手也有機會初試鋒芒，逐步累積未來打進世界級殿堂的實力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34873512.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-20 19:41"}, {"article_id": "9453235", "title": "中職／林辰勳回憶高中對決李灝宇 點不服輸勇敢拚特質", "summary": "中職味全龍捕手林辰勳今天出席記者會，回憶三級棒球國際賽經歷；林辰勳與李灝宇、林昱珉同期，聽到李灝宇升大聯盟消息，笑說很榮...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34873410.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 18:45"}, {"article_id": "9453257", "title": "亞運／場地適應問題不大 女壘力拚金牌", "summary": "愛知・名古屋亞運壘球賽事將在安城綜合公園壘球場進行，考察團今天前往比賽場地了解場地相關規劃及動線，除了比賽場地外，搭配一個熱身球場，一旁另有一個室內運動中心提供選手休息及盥洗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34873372.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 18:34"}, {"article_id": "9453046", "title": "NBA／正式宣布辭去公鹿教頭 瑞佛斯上節目淺談球隊內部問題", "summary": "最近剛辭去公鹿總教練一職的「老河流」瑞佛斯（Doc Rivers），在近期上節目談到球隊本賽季戰績欠佳的原因。他認為，問題在於自己沒能嚴格要求球員，導致有鬆懈的情況出現，至於其他細節議題，他則不願多談。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34873339.jpg&M=1&s=Y&x=191&y=34&sw=1016&sh=677&exp=3600&sl=W&fw=360", "date": "2026-04-20 18:22"}, {"article_id": "9453207", "title": "PLG／強化台南連結 獵鷹挺進季後賽", "summary": "台鋼獵鷹隊2025-26賽季主場例行賽於昨天正式告一段落，球隊本季持續以國立成功大學中正堂作為主場，這也是進駐成大後的第二個賽季。隨著主場例行賽圓滿落幕，台鋼獵鷹目前以例行賽暫居第二之姿挺進季後賽，並將帶著球迷一路相挺的力量，持續朝更高目標邁進。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34873303.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 18:05"}, {"article_id": "9453140", "title": "NBA／將溫班亞瑪名字誤念「溫班亞納」 傳奇米勒轉播頻出包惹議", "summary": "馬刺睽違7年終於在重返季後賽，這也是當家球星溫班亞瑪（Victor Wembanyama）迎來生涯首次季後賽亮相，不過場外焦點卻意外落在轉播席。名人堂球星、現任球評米勒（Reggie Miller）在比賽中多次錯誤唸出溫班亞瑪的名字，引發球迷熱議。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34873243.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-20 17:52"}, {"article_id": "9453076", "title": "青少棒／陽信銀行盃5月4日開打 龍隊林辰勳分享世界冠軍經驗", "summary": "陽信銀行盃全國青少棒錦標賽將於5月4日至12日在新北市三重、台中市舊正棒球場進行，參賽的18支縣市代表隊，今天都派出教練與小球員出席賽前記者會，味全龍隊捕手林辰勳也到場分享經驗，勉勵選手更精進自己的球技，在棒球舞台上持續發光發熱。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34873103.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 17:04"}, {"article_id": "9453055", "title": "經典賽／日本止步8強創最差成績 井端弘和請辭總教練", "summary": "日本國家代表隊「侍Japan」在世界棒球經典賽（WBC）止步8強，NPB Enterprise今天正式宣布，總教練井端弘...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34873070.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 16:57"}, {"article_id": "9452943", "title": "NBA／肯定老詹全能表現 湖人5冠名將：現在是他的魔術強森時代", "summary": "曾助湖人奪下5座總冠軍的傳奇控衛費雪（Derek Fisher），在觀看41歲湖人當家球星「老詹」詹姆斯（LeBron James）於季後賽首戰交手火箭的出色表現後，給予他極高的讚賞，並將詹姆斯比做湖人80年代傳奇球星魔術強森（Magic Johnson）。意指即使詹姆斯體能早已不在巔峰，但在球場上仍舊可以用成熟的球商和球技為球隊做出貢獻。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872904.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 16:32"}, {"article_id": "9452836", "title": "NBA／龍頭活塞到底怎麼輸的？ 總教練、球星分析原因在首節", "summary": "季後賽東區首輪G1賽事，例行賽東區龍頭活塞隊今交手第8種子魔術，卻爆冷101：112輸球，讓不少專家、球迷感到訝異。賽後，活塞總教練比克斯塔夫（J.B. Bickerstaff）以及當家球星康寧漢（Cade Cunningham）各自發表對於爆冷輸球的看法，當中的共同點是兩人認為球隊開局的落後是釀成輸球的主因。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872733.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-20 16:22"}, {"article_id": "9452672", "title": "NBA／「洛杉磯太膚淺」 字母哥放話下家非湖人另有選擇", "summary": "公鹿隊當家球星「字母哥」安戴托昆波（Giannis Antetokounmpo）的交易傳聞仍是今年自由球員市場上最熱門話題，此前洛杉磯湖人隊曾被認為是他的潛在加盟地，但根據安戴托昆波本人近期在節目上的說法，洛杉磯可能將被排除在外。相較之下，他認為，位於東岸的邁阿密熱火是較有可能的去處。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872388.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 16:11"}, {"article_id": "9452952", "title": "全中運／跟隨哥哥馬皓瑋腳步 15歲馬加樂破魔王關國女鐵餅奪金", "summary": "台南市金城國中馬加樂憑藉唯一試擲成功的44公尺59，不但在115年全中運國女鐵餅入袋金牌，還一舉打破高懸18年的大會紀錄，身為在各賽事掃蕩金牌的「紀錄收割機」，趕在畢業前終於將全中運也納進版圖。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872925.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-20 16:10"}, {"article_id": "9452897", "title": "全中運／高雄新莊高中網球高男團體摘金 寫下連7屆奪6金1銀紀錄", "summary": "115年全國中等學校運動會如火如荼競賽中，高雄市代表隊交出亮眼成績單，網球勁旅新莊高中高男團體穩扎穩打闖進決賽，最終摘金，更寫下連續7屆賽事6金1銀紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872854.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 15:52"}, {"article_id": "9452885", "title": "花式滑冰／13歲詹祥妤挑戰三周跳 穩步邁向國際舞台", "summary": "年僅13歲的詹祥妤已累積多次國際賽經驗，並準備在即將到來的全國菁英賽中挑戰技術難度。雖然心中有緊張，她的表現顯示出在競技舞台上的潛力與企圖心。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872818.jpg&M=1&s=Y&x=0&y=182&sw=960&sh=640&exp=3600&sl=W&fw=360", "date": "2026-04-20 15:51"}, {"article_id": "9452876", "title": "NBA／季後賽處女秀有馬刺傳奇見證 溫班亞瑪喊酷", "summary": "馬刺隊當家球星溫班亞瑪（Victor Wembanyama）今天季後賽處女秀就轟下35分，除改寫隊史紀錄，也助隊以111：98擊敗拓荒者隊。首度感受季後賽張力的「斑馬」提到，光是熱身時就能感受季後賽氛圍不同，也很開心看到兩位隊史傳奇球星「石佛」鄧肯（Tim Duncan）和羅賓森（David Robinson）到場支持。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872846.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-20 15:38"}, {"article_id": "9452850", "title": "中職／「龍之萌友」親子毛孩日5月登場 推出TOMBONIA聯名入場禮", "summary": "味全龍隊將於5月初在天母球場對富邦悍將隊進行3連戰，2日、3日舉辦「龍之萌友的應援時光 ─『塩』守健康！親子毛孩日」，和日本超人氣插畫TOMBONIA攜手推出系列入場贈品及商品，場邊更有豐富的活動讓家長、小朋友與萌寵們互動。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872750.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-20 15:28"}, {"article_id": "9452740", "title": "MLB／「卡仔」昨轟滿貫砲今卻傷退 響尾蛇主帥強調應無大礙", "summary": "響尾蛇台美混血明星外野手「卡仔」卡洛爾（Corbin Carroll）在昨天對藍鳥的比賽後半轟出一發超前滿貫砲，幫助球隊贏球。今天同樣面對藍鳥卻在第5局出現下背部緊繃的情況，讓球隊選擇將他換下，響尾蛇最後也以4：10吞敗。響尾蛇總教練羅夫洛（Torey Lovullo）在稍早表示傷勢並無大礙，下一場對白襪出賽不成問題。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872525.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 15:15"}, {"article_id": "9452804", "title": "中職／悍將本季首度「攻蛋」票價公布！529玖壹壹賽後開唱", "summary": "富邦悍將隊5月底進台北大巨蛋，除了5月30日 (六)、5月31日 (日) 「G!POP流行音樂節」已公布賽後嘉賓外，今日宣布5月29日（五）賽後將邀請本土天團「玖壹壹」擔任表演嘉賓，悍將大巨蛋系列戰預售票也即將於4月23日起開放亞瑟傳奇優先購票，4月28日一般售票全面開賣。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872666.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-20 15:09"}]}, {"name": "棒球", "articles": [{"article_id": "9452733", "title": "經典賽／返美每場比賽仍見台灣球迷 費爾柴德對中華隊表達感激", "date": "2026-04-20 14:31", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872503.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9452452", "title": "日職／徐若熙推算年薪排名高居第6 軟銀5人身價超過5億日圓", "date": "2026-04-20 12:15", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872035.jpg&M=1&s=Y&x=76&y=9&sw=1153&sh=769&exp=3600&w=300"}, {"article_id": "9452782", "title": "經典賽／費仔和中華隊友建立終生友誼 計畫11月訪台也要學中文", "date": "2026-04-20 14:59", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872649.jpg&M=1&s=Y&x=0&y=63&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9451265", "title": "中職／每1敗都是連敗開端 兄弟開季15戰12敗破隊史最速", "date": "2026-04-19 18:49", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/19/34870186.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&w=300"}, {"article_id": "9451123", "title": "中職／曾頌恩與家人收惡意謾罵 經紀公司將採法律行動", "date": "2026-04-19 16:26", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/19/34869865.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "MLB", "articles": [{"article_id": "9451840", "title": "MLB／再飆好投！鄧愷威2局賞3K 防禦率已降到「1字頭」", "date": "2026-04-20 06:56", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34870892.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9450737", "title": "MLB／靠史密斯賺到多1打席 大谷翔平9局敲安驚險推進連50場上壘", "date": "2026-04-19 10:54", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/19/34869