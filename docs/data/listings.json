", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042721.jpg&M=1&s=Y&x=0&y=112&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9565559"}, {"article_id": "9565977", "title": "日職／代理監督帶出口碑 巨人換帥風波反因禍得福", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043278.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9565977"}, {"article_id": "9566304", "title": "煮茶論戰／2:0扳倒土耳其 澳洲示範如何擊敗強隊", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/15/35043674.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9566304"}, {"article_id": "9565587", "title": "世足攻略／「死亡之組」日荷關鍵戰 不是一球之差就是平手", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042681.jpg&M=1&s=Y&x=22&y=0&sw=1253&sh=835&exp=3600&w=300", "link": "/news/story/122629/9565587"}, {"article_id": "9564608", "title": "馬刺慘遭史詩級逆轉不單是球員迷航 主帥強森三宗罪難辭其咎", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35041187.jpg&M=1&s=Y&x=17&y=11&sw=1263&sh=842&exp=3600&w=300", "link": "/news/story/122629/9564608"}, {"article_id": "9564449", "title": "世足攻略／內馬爾缺陣考驗巴西平局機率近五成 瑞士穩定攪局卡達難爆冷", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040924.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9564449"}]}, {"name": "最新文章", "articles": [{"article_id": "9566561", "title": "MLB／白襪再勝道奇重返分區龍頭 大谷翔平2支0終止連6場安打", "summary": "白襪隊今天在芝加哥主場對道奇隊進行3連戰最後一戰，也是兩隊本季最後一次交手，白襪第6局出現3支全壘打，終場以6：4獲勝，系列賽取得2勝1敗，重返美聯中區排名第1。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/15/35043921.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-15 08:43", "link": "/news/story/6999/9566561"}, {"article_id": "9566458", "title": "世足賽／藍色波浪寫歷史！古拉索世界盃初登場 慘輸德國仍踢進隊史首球", "summary": "德國今天揭開世界盃征程，以7比1橫掃首次參賽的古拉索而旗開得勝。這場比賽在多個層面上締造歷史，一面倒的戰局並不掩蓋加勒比...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/15/35043837.jpg&M=1&s=Y&x=0&y=0&sw=1246&sh=830&exp=3600&sl=W&fw=360", "date": "2026-06-15 07:44", "link": "/news/story/123107/9566458"}, {"article_id": "9565559", "title": "中職／歐子喬事件其實很簡單 複雜的是大人世界各種算計", "summary": "統一獅總教練林岳平呼籲媒體不要過度報導15歲的歐子喬選擇赴美繼續棒球生涯的事件，強調他有權選擇自己的路。事件的真正複雜性在於成年人的不同算計，而不是歐子喬的簡單決定。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042721.jpg&M=1&s=Y&x=0&y=112&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-15 07:00", "link": "/news/story/122629/9565559"}, {"article_id": "9565977", "title": "日職／代理監督帶出口碑 巨人換帥風波反因禍得福", "summary": "讀賣巨人隊在導致監督阿部慎之助請辭後，由橋上秀樹接任代理監督，球隊戰績驚人，交流戰獲得10勝6敗，坐上央聯第一。儘管他面臨短期任務，卻因穩定的帶領風格贏得球迷好評，讓未來監督人選的可能性引發討論。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043278.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-15 07:00", "link": "/news/story/122629/9565977"}, {"article_id": "9566470", "title": "世足賽／F組強隊交鋒 荷蘭2比2戰平日本各取得1分", "summary": "2026年6月15日凌晨4點，世界盃足球賽F組小組賽迎來焦點對決，由傳統勁旅荷蘭對陣亞洲強權日本，雙方經過90分鐘激戰，最終以2比2握手言和。荷蘭在本場賽事中兩度取得領先，但日本展現頑強韌性兩度扳平比", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/15/35043821.jpg&M=1&s=Y&x=223&y=100&sw=794&sh=530&exp=3600&sl=W&fw=360", "date": "2026-06-15 06:18", "link": "/news/story/123107/9566470"}, {"article_id": "9566431", "title": "世足賽／德國火力全開7比1大勝古拉索 小組賽首戰強勢登頂", "summary": "2026年6月15日凌晨1時，世界盃足球賽E組小組賽首輪開打，德國在主場迎戰古拉索。德國憑藉流暢的團隊配合與強大進攻火力，最終以7比1大勝古拉索。本場賽事的勝負核心在於德國中前場的高效壓迫，徹底主導比", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/15/35043775.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-15 03:46", "link": "/news/story/123107/9566431"}, {"article_id": "9566403", "title": "排球／台灣女排亞洲盃奪銀 蔡幼群、陳喬恩、林其蓉入選最佳陣容", "summary": "台灣女排今天在亞洲盃冠軍戰以0比3不敵韓國，與冠軍金盃擦肩而過，不過依舊締造隊史新猷，其中蔡幼群、陳喬恩及林其蓉入選最佳...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/15/35043853.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-15 02:51", "link": "/news/story/7005/9566403"}, {"article_id": "9566304", "title": "煮茶論戰／2:0扳倒土耳其 澳洲示範如何擊敗強隊", "summary": "世足賽開賽第三天，看到了澳洲精準的示範如何擊敗實力較強的球隊。土耳其球員身價是澳洲六倍，再以這場比賽控球率來說，土耳其占了百分之七十二，澳洲只有百分之廿八，但最後澳洲不僅沒有失球，還進了兩球帶走勝利。澳洲以高效率進攻讓控球率高的土耳其灰頭土臉，贏得一點也不僥倖。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/15/35043674.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-15 00:16", "link": "/news/story/123107/9566304"}, {"article_id": "9566294", "title": "世足賽／卡達隊長追平頭錘 9000萬獎金卻可能飛了", "summary": "卡達在世界盃小組賽對瑞士之戰傷停補時階段驚喜以一比一逼平，原本被視為卡達隊長胡赫的關鍵頭球進球，卻在賽後被國際足球總會改判為瑞士後衛穆海姆的烏龍球，胡赫高額的進球獎金可能化為烏有，形成本屆比賽有趣插曲，也讓人再次感嘆卡達的「豐厚財力」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043567.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-15 00:15", "link": "/news/story/123107/9566294"}, {"article_id": "9566290", "title": "世足賽／巴西踢平摩洛哥 教頭不滿意", "summary": "當家球星內馬爾缺陣的巴西，昨天迎接二○二六美加墨世足賽首戰，面對非洲勁旅摩洛哥，五度奪冠的「森巴軍團」第廿一分鐘先失球，靠維尼修斯十一分鐘後就進球回應，才以一比一踢和，但只拿一分的結果讓冠軍熱門隊直喊糟糕。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/15/35043666.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-15 00:12", "link": "/news/story/123107/9566290"}, {"article_id": "9566284", "title": "NBA／翻轉1999年劇本 老爸當年輸馬刺 布朗森討回來", "summary": "老布朗森曾和尼克隊打進一九九九年的ＮＢＡ總冠軍賽，如今兒子布朗森不但率尼克打進同樣階段，昨天更狂轟四十五分，率隊以九十四比九十逆轉馬刺隊，終結五十三年的冠軍等待；布朗森和目前擔任尼克助理教練的爸爸老布朗森共享冠軍，締造史上第一對父子同隊捧冠的特別紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/15/35043664.jpg&M=1&s=Y&x=16&y=0&sw=1264&sh=843&exp=3600&sl=W&fw=360", "date": "2026-06-15 00:08", "link": "/news/story/7002/9566284"}, {"article_id": "9566282", "title": "NBA／把把都逆轉 韌性尼克再捧金盃", "summary": "尼克隊等待五十三年的總冠軍，今年總算到手，昨天於總冠軍賽第五戰客場踢館成功，在「戰神」布朗森狂轟四十五分領軍下再度演出逆轉勝，以九十四比九十氣走馬刺隊，帶回一九七三年之後的第一座金盃。在場上大殺四方的布朗森，奪勝後忍不住流下男兒淚。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043557.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-15 00:05", "link": "/news/story/7002/9566282"}, {"article_id": "9566371", "title": "中職／池恩齊被懲罰性調度隔天攻守好表現 光總：搞不好他有看新聞", "summary": "富邦悍將隊游擊手池恩齊昨天遭「懲罰性調度」，總教練後藤光尊今天賽前和媒體談起他的表現時，有一番嚴厲的發言，然而池恩齊今天繼續先發上陣，攻守都有好表現，讓「光總」賽後也笑說：「搞不好他有看到賽前的新聞。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043628.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 23:43", "link": "/news/story/7001/9566371"}, {"article_id": "9566321", "title": "中職／是李東洺自己想投的！ 中斷2小時hold住局面還想續投第6局", "summary": "富邦悍將今天在新莊棒球場對戰台鋼雄鷹，比賽在雨勢中開打，打到第3局還中斷了2小時，但先發投手李東洺請纓繼續上陣，投完5局後甚至要求再投第6局，但被教練勸退，最終繳出5局無失分的表現，拿下先發8連勝，登上聯盟勝投王。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043580.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 23:20", "link": "/news/story/7001/9566321"}, {"article_id": "9566288", "title": "籃球／產學攜手人才培育 中信學院征戰ABSOLUTE 3x3全台9站", "summary": "國內ABSOLUTE 3x3籃球聯盟賽2026賽季，台中羽田娛樂有限公司與中信金融管理學院攜手，協助學生球員參與國內大型籃球運動賽事，並與國家隊成員及職業運動選手同場較勁，持續培育更多的學生籃球運動員，以及透過賽事活動的參與，建立運動產業的合作發展，與培養學生辦理運動賽事的實務經驗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043565.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 23:07", "link": "/news/story/7003/9566288"}, {"article_id": "9566209", "title": "中職／李東洺等2小時後續投仍收先發8連勝 悍將7：0完封雄鷹", "summary": "富邦悍將隊本周最後一場賽事，比賽一度因雨中斷2小時，恢復進行後悍將打線有范國宸、王苡丞相繼開轟拉開領先差距，先發投手李東洺則是在比賽暫停後繼續登板，繳出5局0失分的表現，終場富邦以7：0完封台鋼雄鷹，上半季戰績擠下台鋼回到第2，李東洺則收下先發8連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043524.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 22:50", "link": "/news/story/7001/9566209"}, {"article_id": "9566096", "title": "PLG／領航猿主場又失守遭勇士聽牌 卡總預告：會有第7戰", "summary": "例行賽主場勝率百分百的桃園璞園領航猿，季後賽卻遇臺北富邦勇士強力挑戰，總冠軍賽首戰主場全勝紀錄就破功，今天第5戰上半場又找不到準星，最終以78：87失守，不過總教練卡米諾斯自信預告，絕對會有第7戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043391.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 21:29", "link": "/news/story/7003/9566096"}, {"article_id": "9566060", "title": "排球／女排亞洲盃不敵韓國奪亞軍 締造隊史最佳", "summary": "在菲律賓舉行的女子排球亞洲盃，隊史首度挺進冠軍戰的台灣隊今天以19比25、19比25、22比25不敵韓國，以亞軍作收，仍...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043367.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 21:20", "link": "/news/story/7005/9566060"}, {"article_id": "9566047", "title": "足球／安聯小小世界盃高雄預賽熱血落幕 南台灣小將燃燒足球魂", "summary": "由台灣安聯人壽掛名贊助的「2026安聯小小世界盃」高雄區預賽在鳳山體育場激烈開踢，代表營北國中女足出賽的國一小將高惠芯，在U15組剛結束一場以2：4惜敗的激戰。儘管對手是高大的福誠足球俱樂部且都是男球員，面對結果她展現出超齡的勝負心：「雖然因為太久沒在場上跑動，對自己的表現很不滿意，但每一次的挫折都是我進步的動力。」她堅定地表示，會將不甘心轉化為下一次贏球的能量。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043343.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 20:55", "link": "/news/story/7005/9566047"}, {"article_id": "9566034", "title": "PLG／古德溫遭禁賽G6缺陣 許晉哲啟動「B計畫」", "summary": "台北富邦勇士隊今天總冠軍賽第5戰踢館成功，但主戰洋將古德溫最後43秒被吹違反運動精神犯規，累積違反運動精神犯規達到第5次，將禁賽一場加上罰款2萬，周二進行的第6戰無法出賽，讓教練許晉哲將啟動「B計畫」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35043332.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 20:41", "link": "/news/story/7003/9566034"}, {"article_id": "9565908", "title": "玉山盃／饒又語先發無失分學經驗 新北搶勝下戰碰桃園", "summary": "玉山盃青棒賽新北市今天投打發揮，終場以10比3擊敗雲林縣，先發投手饒又語3局無失分，但總教練楊孝承認為可以更好，下雨影響..."