": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35079836.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9590591"}, {"article_id": "9590550", "title": "世足攻略／西班牙將遇烏拉圭鐵血考驗 維德角黑馬奇蹟在望", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35079783.jpg&M=1&s=Y&x=0&y=39&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9590550"}, {"article_id": "9588393", "title": "中職／選秀小年！悍將是挑兩大高中游擊 還是震撼選擇火球男黃玠瀚", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076672.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9588393"}]}, {"name": "最新文章", "articles": [{"article_id": "9594405", "title": "世足賽／傷停補時關鍵絕殺！加拿大1比0險勝南非 挺進淘汰賽下一輪", "summary": "2026年世界盃足球賽於台灣時間6月29日凌晨3點迎來一場關鍵的淘汰賽，由南非對決加拿大。在這場一戰定生死的對決中，雙方展開激烈的防守大戰，最終加拿大憑藉著傷停補時階段的關鍵進球，以1比0險勝南非，成", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35085448.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-29 05:10", "link": "/news/story/123107/9594405"}, {"article_id": "9594196", "title": "世足賽／梅西狀態火燙 衛冕軍大有看頭", "summary": "世界盃足球賽首度從卅二隊擴增到四十八隊，昨天結束小組賽所有賽程，壓軸登場的衛冕軍阿根廷，當家球星「獅王」梅西雖然沒先發，但他下半場替補上場馬上展現巨星身手，第八十分鐘自由球直接破網，率領阿根廷以三比一擊敗約旦，繼續推高世界盃「進球王」障礙，並締造賽史第一位連七場進球的紀錄，阿根廷也以小組賽三戰全勝挺進卅二強淘汰賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35085285.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 00:00", "link": "/news/story/123107/9594196"}, {"article_id": "9594199", "title": "世足賽／南韓「最強陣容」無緣晉級 李在明批荒唐", "summary": "世足賽首度從卅二隊增加到四十八隊，九支亞洲球隊破紀錄與會，最終卻只有日本和澳洲晉級卅二強淘汰賽，南韓和伊朗的出線機會都在昨天破滅，南韓總統李在明形容結果「讓人錯愕且荒唐」，已指示體育團體要進行改革。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35085113.jpg&M=1&s=Y&x=0&y=0&sw=1192&sh=794&exp=3600&sl=W&fw=360", "date": "2026-06-29 00:00", "link": "/news/story/123107/9594199"}, {"article_id": "9594200", "title": "煮茶論戰／攻擊更效率 「7秒完成射門」", "summary": "首度擴增到四十八隊的世界盃小組賽全部結束，三輪循環賽下可看出攻守界線模糊化，攻擊面更務實直接，單純依賴控球或死守未來都很難在淘汰賽走遠；攻擊戰術是傳控球體系和高強度逼搶為主，防守戰術主要是收縮和密集防守策略，強弱隊間的分化相當明顯。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35085222.jpg&M=1&s=Y&x=45&y=0&sw=1235&sh=823&exp=3600&sl=W&fw=360", "date": "2026-06-29 00:00", "link": "/news/story/123107/9594200"}, {"article_id": "9594026", "title": "中職／知道戴培峰是連跑3壘包常客 光總卻吐槽「我來跑可能比他快」", "summary": "富邦悍將隊今天靠第八局4分入袋，以4：1逆轉擊敗味全龍隊，攻勢從戴培峰的保送開啟，趁申皓瑋的安打連衝三個壘包，總教練後藤光尊也知道他的「都市傳說」，笑說：「他本人應該也有在準備（跑三個壘包）。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35085035.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-28 21:31", "link": "/news/story/7001/9594026"}, {"article_id": "9594024", "title": "中職／腳傷掛保證4天能好卻休了1個月 孔念恩回歸讓後藤說安心", "summary": "孔念恩因腳傷下二軍休養，剛在前天回歸一軍陣容，今天就在面對味全龍隊之戰第八局滿壘敲二壘打建功，幫助富邦悍將隊以4：1贏球。孔念恩回顧傷情，當初跟教練掛保證4天就可以好，結果休了1個月，昨天的觸身球還剛好砸在同一位置，但他強調現在恢復狀況已經是100%，「上場就是100%！」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35085000.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-28 21:31", "link": "/news/story/7001/9594024"}, {"article_id": "9593989", "title": "中職／偉業誕生！悍將半季33勝球團史首見 孔念恩清壘二壘打獵殺龍隊", "summary": "歷經延賽、保留、延後開打，編號第151號賽事終於在今天完賽，富邦悍將隊第八局先由申皓瑋敲追平二壘打，孔念恩在滿壘局面敲出清壘二壘打，悍將終場以4：1擊敗味全龍隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084953.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-28 20:51", "link": "/news/story/7001/9593989"}, {"article_id": "9593929", "title": "排球／亞洲盃最終戰不敵卡達 中華男排第8名收尾", "summary": "中華男排今天2026男子亞洲盃（AVC Men's Cup）排名戰迎戰世界排名第23名的卡達，中華隊首局一路與對手激戰至30分才分出勝負，第二局成功扳回一城，可惜後續遭卡達掌握比賽節奏，最終以30：32、25：22、18：25、15：25落敗，以第八名結束本屆男子亞洲盃賽事。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084911.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=852&exp=3600&sl=W&fw=360", "date": "2026-06-28 19:40", "link": "/news/story/7005/9593929"}, {"article_id": "9593910", "title": "高球／JLPGA獎金新高地球達蒙明盃 盧曉晴補賽力拚后座", "summary": "JLPGA史上獎金最高的「地球達蒙明盃」，今天最終回合因天黑未能完賽，將延到明天早上補賽；台灣好手盧曉晴暫時以總桿數低於...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/2022/12/31/realtime/19800569.jpg&s=Y&x=0&y=20&sw=3000&sh=2000&exp=3600&sl=W&fw=360", "date": "2026-06-28 19:36", "link": "/news/story/7005/9593910"}, {"article_id": "9593919", "title": "中職／林泓育代打建功 桃猿保留比賽2：0斷兄弟4連勝", "summary": "中信兄弟今天在台中洲際棒球場對上樂天桃猿隊，繼續完成6月7日的保留比賽，雙方一路維持0：0平手的僵局直到第9局，猿隊40歲精神領袖「小胖」林泓育在9局上代打敲回勝利打點，最終猿隊以2：0勝出，也讓兄弟本季最長4連勝畫下句點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084907.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-28 19:28", "link": "/news/story/7001/9593919"}, {"article_id": "9593906", "title": "中職／選秀名單加1人、減1人維持200人 陳昱勛申請撤銷報名", "summary": "中華職棒選秀會明天登場，今天傳出高苑工商投手陳昱勛預計退出選秀，聯盟晚間更新選秀人數，確認陳昱勛申請撤銷報名，而經確認報名程序後，新增應屆北科附工外野手王乃文，總人數仍維持在200人。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084904.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-28 19:10", "link": "/news/story/7001/9593906"}, {"article_id": "9593867", "title": "世足賽／南韓無緣32強 總統李在明怒批荒唐促體育改革", "summary": "世界盃足球賽南韓隊今天確定無緣晉級32強，韓國總統李在明在社群媒體上發文怒批，對於這個結果感到荒唐，也點出選了沒有能力的...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084834.jpg&M=1&s=Y&x=87&y=0&sw=1193&sh=795&exp=3600&sl=W&fw=360", "date": "2026-06-28 18:16", "link": "/news/story/123107/9593867"}, {"article_id": "9593869", "title": "世足賽／32強最貴一戰！葡萄牙對克羅埃西亞最便宜門票飆破10萬台幣", "summary": "2026年世界盃32強淘汰賽明天展開，目前最貴一戰的票價也揭曉，根據票價追蹤網站Ticketdata的數據，在葡萄牙確定以小組第二晉級後，32強對上克羅埃西亞之戰，票價一路飆升，最便宜門票的平均價格已飆到3225美元（約台幣10萬3000元）。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084850.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-28 18:13", "link": "/news/story/123107/9593869"}, {"article_id": "9593848", "title": "NBA／杜倫不滿活塞報價考慮先簽後換 2.8億美元頂級續約資格成談判關鍵", "summary": "根據《The Athletic》報導，受限制自由球員杜倫（Jalen Duren）對活塞提出的初步報價並不滿意，後續可能探索先簽後換的可能性，也讓活塞今年休賽季可能面臨核心戰力續約難題。。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084789.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-28 17:55", "link": "/news/story/7002/9593848"}, {"article_id": "9593830", "title": "世足攻略／坐擁天時地利人和 看好加拿大贏南非1球出線", "summary": "32強淘汰賽明天凌晨展開，第一天只有加拿大對上南非，加拿大在六個數據上都優於南非，加上是本屆賽事東道主，看好加拿大會贏一個球左右，比數可能是1：0或2：1。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084767.jpg&M=1&s=Y&x=3&y=0&sw=1262&sh=841&exp=3600&sl=W&fw=360", "date": "2026-06-28 17:44", "link": "/news/story/122629/9593830"}, {"article_id": "9593810", "title": "MLB／優質先發笑奪第8勝 山本由伸：想看32強日本巴西之戰", "summary": "道奇王牌山本由伸客場先發對戰教士，主投6局用89球，被敲5支安打、失2分，道奇「愛山本打線」全面開火，靠著5局狂灌9分，最終以15比3痛宰對手。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084750.jpg&M=1&s=Y&x=156&y=22&sw=915&sh=610&exp=3600&sl=W&fw=360", "date": "2026-06-28 17:32", "link": "/news/story/6999/9593810"}, {"article_id": "9593795", "title": "MLB／鈴木誠也兩分砲逆轉釀酒人 大聯盟百轟只差1支", "summary": "芝加哥小熊日籍外野手鈴木誠也今天作客密爾瓦基轟出本季第12號全壘打，這讓他大聯盟生涯全壘打數累積到99支，距離百轟里程碑只差1支。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084713.jpg&M=1&s=Y&x=102&y=37&sw=1086&sh=724&exp=3600&sl=W&fw=360", "date": "2026-06-28 17:03", "link": "/news/story/6999/9593795"}, {"article_id": "9593759", "title": "中職／賴鴻誠同隊見證兩次半季10勝 李東洺9勝後換釘鞋套讓他好緊張", "summary": "中職昨天誕生史上第5位半季10勝本土投手，賴鴻誠在近兩次都同隊見證，2013年林晨樺、2026年李東洺，都因超高援護率掀起話題，賴鴻誠對此認為，當投手能給予野手安定感，在攻擊時自然更容易去掌握，「先決條件他們一定都是有能力、有技術，才可以達到這種傳奇紀錄。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https:/