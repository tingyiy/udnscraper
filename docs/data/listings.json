il": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34998424.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-31 15:09"}, {"article_id": "9536633", "title": "日職／重返一軍繳優質先發 徐若熙6局無失分飆157公里奪第2勝", "summary": "日職軟銀隊台灣投手徐若熙重返一軍，今天在交流戰出戰廣島隊，先發6局無失分，送出7次三振，最快球速157公里，靠著隊友在6局下打下3分，加上牛棚成功守住局面，徐若熙回歸首戰就繳好投，拿下本季第2勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34998402.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-05-31 14:47"}, {"article_id": "9536623", "title": "中職／好冷！後藤光尊看大巨蛋樣樣好 唯獨冷到快感冒了", "summary": "富邦悍將隊本周末在台北大巨蛋擔任主場球隊，3戰票房10萬6510人打破聯盟史上3連戰紀錄，總教練後藤光尊感謝球迷相挺，但聊到在大巨蛋出賽忍不住開玩笑說：「太冷了，會感冒。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34998376.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&sl=W&fw=360", "date": "2026-05-31 14:41"}, {"article_id": "9536604", "title": "中職／徐若熙先發6局無失分飆速157 龍隊友關注歡呼", "summary": "日職福岡軟銀鷹隊投手徐若熙今天一軍先發6局無失分，最快球速157公里，6局下隊友支援搶分，味全龍隊前隊友關注比賽跟著歡呼...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34998333.jpg&M=1&s=Y&x=0&y=4&sw=1137&sh=758&exp=3600&sl=W&fw=360", "date": "2026-05-31 14:32"}, {"article_id": "9536606", "title": "中職／林岱安近兩場一軍蹲捕都遇大局攻陷 光總：不是他的問題", "summary": "富邦悍將隊捕手林岱安近兩場一軍出賽，都碰到對手攻下大局，對於昨天遭中信兄弟隊九局攻下8分，總教練後藤光尊直言：「不是岱安的問題」，他表示，之後還會有很多先發機會，希望不要只用幾場內容去評斷。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34998332.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-31 14:32"}, {"article_id": "9536596", "title": "中職／光總出招！19歲張育豪扛先發捕手 想起春訓寫下的目標", "summary": "富邦悍將隊榜眼捕手張育豪昨天靠代打解鎖一軍初登板，如今初先發的機會也到來，今天將以19歲75天之齡擔任先發捕手，搭檔江國豪。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34998293.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-31 14:21"}, {"article_id": "9536585", "title": "NBA／溫班亞瑪史上第2年輕領軍闖總冠軍賽 超越詹皇僅次魔術強森", "summary": "馬刺本季在溫班亞瑪（Victor Wembanyama）領軍之下重返總冠軍賽，這位年僅22歲的「法國獨角獸」不只帶領球隊完成驚奇季後賽之旅，也正式寫進聯盟歷史。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34998290.jpg&M=1&s=Y&x=81&y=73&sw=1166&sh=777&exp=3600&sl=W&fw=360", "date": "2026-05-31 14:20"}, {"article_id": "9536567", "title": "日職／徐若熙回歸一軍6局無失分飆7K封鎖廣島 獲勝投資格", "summary": "福岡軟銀鷹隊台灣投手徐若熙暌違超過3周後重返一軍先發，今天在日職交流戰登板，於主場福岡巨蛋對上廣島隊，主投6局無失分，送出7次三振，最快球速飆到157公里，靠著隊友在6局下攻進分數含栗原陵矢的2分砲，取得勝投資格，前6局打完軟銀隊3：0領先。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34998271.jpg&M=1&s=Y&x=73&y=0&sw=1207&sh=805&exp=3600&sl=W&fw=360", "date": "2026-05-31 13:54"}, {"article_id": "9536550", "title": "中職／UniGirls前進遊騎兵主場 舞台工作人員直呼「超可愛」", "summary": "統一獅隊啦啦隊UniGirls持續展開「2026 TAIWAN GRAND SLAM WEEK」美國巡迴行程，昨天結束休士頓台灣日活動後，隨即搭乘長途巴士前往巡演第三站達拉斯，今天參與遊騎兵隊主場Globe Life Field舉辦的「DALLAS TAIWAN DAY」活動，持續將台灣獨特的棒球應援文化帶向美國球場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34998247.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-31 13:34"}, {"article_id": "9536542", "title": "NBA／無緣衛冕仍展風度讚賞馬刺 亞歷山大談雷霆補強：交給最偉大總管處理", "summary": "雷霆的衛冕之路在西區冠軍賽第7戰畫下句點，面對年輕馬刺的強勢挑戰，兩屆年度MVP亞歷山大（Shai Gilgeous-Alexander）雖然無緣帶隊重返總冠軍賽，但賽後仍大方給予對手高度肯定。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34998231.jpg&M=1&s=Y&x=0&y=32&sw=1203&sh=802&exp=3600&sl=W&fw=360", "date": "2026-05-31 13:34"}, {"article_id": "9536442", "title": "NBA／我們還沒結束！溫班亞瑪賽後霸氣喊話：再拿4勝", "summary": "馬刺今日在西區冠軍賽「生死戰」以111：103擊敗衛冕軍雷霆，正式挺進2026 NBA總冠軍賽。賽後，當家球星溫班亞瑪（Victor Wembanyama）激動落淚，更憑藉攻守兩端的優異表現奪下西冠MVP，他也霸氣喊話，「我們還沒結束。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34998015.jpg&M=1&s=Y&x=72&y=27&sw=1208&sh=805&exp=3600&sl=W&fw=360", "date": "2026-05-31 12:34"}, {"article_id": "9536450", "title": "中職／連兩天4萬人！悍將3連戰破10萬人成聯盟紀錄 超越林智勝引退賽", "summary": "富邦悍將隊本周末在台北大巨蛋擔任主場球隊，票房開出紅盤，今天提前在中午12點過後宣布4萬人滿場，3戰合計10萬6510人，成為今年最賣座系列賽，也寫下悍將隊史3連戰票房新猷。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34998025.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-31 12:26"}, {"article_id": "9536376", "title": "MLB／李灝宇敲安終結連12打數低潮 費爾柴德本季首秀未敲安", "summary": "美國職棒大聯盟（MLB）老虎隊台灣好手李灝宇今天先發，4打數1安打，終結連12打數無安打低潮；而昨天被守護者升上大聯盟的...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34997997.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-31 12:11"}, {"article_id": "9536368", "title": "MiLB／鄭宗哲3A敲雙安有長打 林盛恩1A先發奪本第4勝", "summary": "旅美波士頓紅襪隊野手鄭宗哲今天在小聯盟3A先發出賽，單場雙安、敲出個人本季第6支二壘打；辛辛那提紅人隊1A投手林盛恩先發...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34997988.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-31 12:08"}, {"article_id": "9536330", "title": "MLB／至少缺席4至6周！村上宗隆傷後首發聲：真的很痛", "summary": "白襪日籍重砲村上宗隆昨日在面對老虎的比賽中，因跑壘疑似拉傷腿部。今日，白襪總教練維納布（Will Venable）也證實，村上宗隆傷勢比原先預期更加嚴重，因右腿後肌二級拉傷，預計將缺席4至6周，球隊已正式將他放進10天傷兵名單。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34997842.jpg&M=1&s=Y&x=0&y=7&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-31 12:04"}, {"article_id": "9536383", "title": "NBA／SGA含哨自吹犯規？格林怒轟酸民「假摔論」：你以為NBA很簡單嗎", "summary": "勇士悍將格林（Draymond Green）近日在個人節目中，力挺近年深陷「假摔」、「買犯」爭議的雷霆一哥亞歷山大（Shai Gilgeous-Alexander），甚至怒批外界對這位「MVP二連霸」的不公平質疑，直言這種言論根本是在羞辱NBA。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34997933.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-31 12:01"}, {"article_id": "9536374", "title": "NBA／馬刺、尼克相隔27年再爭冠 連8年不同總冠軍創歷史紀錄", "summary": "隨著衛冕軍雷霆今天在西區冠軍賽第7戰遭馬刺淘汰，NBA將連續第8年誕生全新總冠軍，寫下史上最長連續不同球隊奪冠的紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34997912.jpg&M=1&s=Y&x=0&y=97&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-31 11:29"}, {"article_id": "9536323", "title": "NBA／馬刺7戰淘汰衛冕軍雷霆 溫班亞瑪奪西冠MVP激動落淚", "summary": "衛冕軍雷霆隊和馬刺隊的「天王山之戰」高潮迭起，馬刺上半場最多取得14分領先，雷霆雖靠MVP亞歷山大（Shai Gilgeous-Alexander）第二節攻下13分助隊一度反超，但馬刺靠7人得分兩位數團隊發揮下，仍以111：103扳倒衛冕軍，重返總冠軍賽，讓當家球星溫班亞瑪（Victor Wembanyama）都激動落淚。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34997861.jpg&M=1&s=Y&x=25&y=0&sw=1230&sh=820&exp=3600&sl=W&fw=360", "date": "2026-05-31 10:55"}, {"article_id": "9536250", "title": "NBA／巴恩斯成馬刺幸運符？球員生日打搶七大戰7勝0敗", "summary": "馬刺本季打出宛如魔法般的驚奇旅程，而這趟季後賽之路即將迎來最關鍵一戰。西區冠軍賽第7戰今日登場，馬刺要在客場挑戰衛冕軍雷霆，勝者將取得NBA總冠軍賽門票，敗者則正式結束賽季。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34997689.jpg&M=1&s=Y&x=201&y=28&sw=1079&sh=719&exp=3600&sl=W&fw=360", "date": "2026-05-31 10:25"}, {"article_id": "9536207", "title": "MLB／終結207打席無開轟！塔提斯炸裂近5年「最遠」全壘打", "summary": "教士球星塔提斯（Fernando Tatis Jr.）終於擺脫本季超長無轟低潮。今日面對國民之戰，塔提斯在5局上鎖定國民先發左投葛里芬（Foster Griffin）一顆1好0壞球路，轟出一發飛行距離451英呎的超大號陽春砲，不僅是他本季首轟，也正式終結長達207打席的無轟紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34997633.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-31 10:14"}, {"article_id": "9536165", "title": "法網／謝淑薇混雙也出局 台將希望僅剩梁恩碩", "summary": "先是女雙第二輪出局，我國網球「一姊」謝淑薇今天凌晨混雙第二輪也出局，今年紅土大滿貫旅程告終，加上列女雙16種子的吳芳嫺、男單唯一代表也在何承叡第二輪落馬，台將僅存希望只剩「小鋼炮」梁恩碩。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34997582.jpg&M=1&s=Y&x=23&y=85&sw=1152&sh=768&exp=3600&sl=W&fw=360", "date": "2026-05-31 09:34"}, {"article_id": "9536164", "title": "NBA／亞歷山大第二節爆發 雷霆G7克服14分落後緊追馬刺", "summary": "衛冕軍雷霆隊和馬刺隊今天西區冠軍賽第7戰上演「天王山之戰」，馬刺上半場最多取得14分領先，但雷霆第二節在年度MVP亞歷山大（Shai Gilgeous-Alexander）單節攻下13分帶動一度超前，馬刺節末回敬7：0攻勢，才帶著56：53領先進入下半場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34997560.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W