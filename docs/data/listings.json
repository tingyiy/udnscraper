 "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35066184.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 19:59", "link": "/news/story/7001/9581476"}, {"article_id": "9581471", "title": "中職／郭天信中職明星賽放哪隊有考量 曾豪駒看好能止敗", "summary": "中職明星賽將於7月登場，今天公布名單，目前所屬球隊8連敗的郭天信被放入明星隊，TEAM TAIWAN總教練高志綱分享抉擇...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35066187.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-22 19:58", "link": "/news/story/7001/9581471"}, {"article_id": "9581462", "title": "棒球／「中信60甲子緣」特展落幕 超過10萬人次進場破紀錄", "summary": "中國信託金融控股公司為慶祝成立60周年所舉辦的「中信60甲子緣」棒球特展，傳遞在比賽結束前「永不放棄」的棒球精神，5周累計觀展人次突破10萬大關，為今年夏天最熱門的體育公益展覽，展現台灣民眾對棒球的深厚情感，亦為不同世代創造難忘的棒球回憶。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35066072.jpg&M=1&s=Y&x=0&y=0&sw=1079&sh=719&exp=3600&sl=W&fw=360", "date": "2026-06-22 18:52", "link": "/news/story/7001/9581462"}, {"article_id": "9581451", "title": "全球極限體能鋼鐵大賽 10月引爆台中", "summary": "去年首度登場就引爆台中健身話題的「全球極限體能鋼鐵大賽」（Taichung Power Fitness Grand Prix），今年10月17、18日連續兩天將在台中市政府廣場及新市政公園全面開戰，今年預計邀請英國、韓國、新加坡、南非、泰國及俄羅斯等國際CrossFit菁英選手，前來挑戰百萬總獎金，台灣冠軍隊成員必定嚴陣以待，誓言捍衛主場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35066059.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=852&exp=3600&sl=W&fw=360", "date": "2026-06-22 18:39", "link": "/news/story/7005/9581451"}, {"article_id": "9581432", "title": "中職／汶汶聲明「大家不要太擔心」 針對網路猜測也有話說", "summary": "中信兄弟隊啦啦隊成員汶汶前天遇襲震驚球界，她當時參加私人棚拍活動時，被52歲許姓男子持水果刀攻擊頸部，所幸沒有生命危險，汶汶今天也發出聲明，內容提到「傷勢穩定恢復，請大家不要太過擔心」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35066037.jpg&M=1&s=Y&x=0&y=64&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 18:30", "link": "/news/story/7001/9581432"}, {"article_id": "9581405", "title": "世足賽／日本球迷帶「旭日旗」入場惹議 大陸網友反應強烈", "summary": "周六美加墨世界盃F組次輪比賽，日本對突尼西亞，結果日本以4:0獲勝，收下亞洲球隊在世界盃舞台最大比數勝仗。但球場上，有中國大陸網友反映，現場有日本球迷帶著日本軍旗「旭日旗」入場，是揭亞洲國家民眾的傷疤。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065989.png&M=1&s=Y&x=5&y=0&sw=1113&sh=742&exp=3600&sl=W&fw=360", "date": "2026-06-22 18:13", "link": "/news/story/123107/9581405"}, {"article_id": "9581364", "title": "NBA／溫班亞瑪輸球未握手惹議 「尼克神偷」痛批缺乏運動家精神", "summary": "年僅22歲的溫班亞瑪（Victor Wembanyama）在2025-26年賽季與馬刺寫下令人難忘的一年，帶領球隊在不被看好之下一路殺進總冠軍賽，成就已相當驚人。不過，隨著馬刺最終在總冠軍賽1比4敗給紐約尼克，他比賽結束後的舉動卻引發外界不少批評。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065952.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 18:07", "link": "/news/story/7002/9581364"}, {"article_id": "9581342", "title": "中職／Passion Sisters暫停近距離互動 蔡其昌也回應汶汶事件", "summary": "中信兄弟隊啦啦隊成員汶汶日前遇襲震驚球界，中華職棒會長蔡其昌今天出席明星賽開打記者會，被媒體問到未來如何防備，他表示，有關球場安檢問題，會再和球團討論，有必要就會做。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065919.jpg&M=1&s=Y&x=0&y=0&sw=1243&sh=829&exp=3600&sl=W&fw=360", "date": "2026-06-22 17:49", "link": "/news/story/7001/9581342"}, {"article_id": "9581335", "title": "NBA／享受與厄文一對一單挑 唐西奇：是最美好的感覺", "summary": "洛杉磯湖人球星唐西奇（Luka Doncic）生涯至今面對過許多頂級防守者與得分高手，但若談到一對一單挑，他心中最特別的對手，是前獨行俠隊友厄文（Kyrie Irving）。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065917.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 17:48", "link": "/news/story/7002/9581335"}, {"article_id": "9581319", "title": "NBA／溜馬首輪籤送快艇只能當局外人 祖巴茲喊話拚出最佳狀態", "summary": "在今年NBA選秀會上，溜馬沒有首輪選秀權，原因是他們去年與快艇完成交易，換來中鋒祖巴茲（Ivica Zubac），付出了今年首輪籤作為代價。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065896.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-22 17:39", "link": "/news/story/7002/9581319"}, {"article_id": "9581311", "title": "NBA／巴瑞特傳成多方交易討論焦點 表態想終身效力家鄉暴龍", "summary": "多倫多暴龍上季戰力有所提升後，季後賽首輪與騎士廝殺7場後飲恨淘汰，進入休賽季是否透過交易進一步補強陣容，也成為外界關注焦點。雖然暴龍是否會投入球星交易市場仍有待觀察，但陣中一名可能被擺上談判桌的球員，正是來自多倫多的前鋒巴瑞特（RJ Barrett）。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065895.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-22 17:37", "link": "/news/story/7002/9581311"}, {"article_id": "9581260", "title": "中職／「綱總」高志綱備戰亞冠賽 潘威倫、劉家豪進入教練團", "summary": "高志綱將在年底亞洲職棒冠軍爭霸賽成為「綱總」，今年中職明星賽先領軍TEAM TAIWAN，開始尋找潛力十足的年輕戰力，他說：「菜鳥總仔會努力看看，往好的方向走。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065783.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-22 17:11", "link": "/news/story/7001/9581260"}, {"article_id": "9581231", "title": "體操／洪源禧亞錦賽雙槓奪銅 教練看好個人全能實力", "summary": "台灣男子體操好手洪源禧在2026體操亞錦賽雙槓決賽，以難度分5.700分、執行分8.100分，總分13.800分奪銅，是...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065755.jpg&M=1&s=Y&x=0&y=542&sw=919&sh=612&exp=3600&sl=W&fw=360", "date": "2026-06-22 17:02", "link": "/news/story/7005/9581231"}, {"article_id": "9581234", "title": "全球極限體能鋼鐵大賽 7國爭霸搶百萬總獎金", "summary": "去年頗受好評的「全球極限體能鋼鐵大賽」，今年將於10月17、18日2天強勢回歸，並邀請到英國、韓國、新加坡、南非、泰國及...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065748.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 17:00", "link": "/news/story/7005/9581234"}, {"article_id": "9581228", "title": "NBA／湖人圍繞唐西奇建隊 史馬特續留機率被看好高於艾頓", "summary": "洛杉磯湖人預期將迎來一個忙碌的休賽季，其中最大問題仍是詹姆斯（LeBron James）進入自由市場前的未來動向。不過，詹姆斯並不是湖人陣中唯一可能投入市場的球員，艾頓（Deandre Ayton）與史馬特（Marcus Smart）也都握有球員選項。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065746.jpg&M=1&s=Y&x=36&y=27&sw=1153&sh=749&exp=3600&sl=W&fw=360", "date": "2026-06-22 16:56", "link": "/news/story/7002/9581228"}, {"article_id": "9581200", "title": "NBA／老鷹第8順位選秀權太誘人 鵜鶘傳願討論墨菲交易案", "summary": "亞特蘭大老鷹在2026年休賽季一開始就動作頻頻，先是以二輪選秀權向雷霆換來維金斯（Aaron Wiggins），率先啟動交易市場。如今看來，老鷹並不打算就此停手，據傳球隊正持續探索另一筆潛在交易，目標可能鎖定鵜鶘前鋒墨菲（Trey Murphy III）。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065698.jpg&M=1&s=Y&x=0&y=8&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 16:44", "link": "/news/story/7002/9581200"}, {"article_id": "9581174", "title": "世足賽／烏拉圭致命失誤 教頭坦言付出慘痛代價", "summary": "曾兩度奪下世界盃冠軍的南美強權烏拉圭，今天卻被大西洋小國維德角逼平，兩場和局讓晉級拉警報，總教練畢爾沙（Marcelo Bielsa）坦言球隊為失誤付出慘痛代價。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065662.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 16:29", "link": "/news/story/123107/9581174"}, {"article_id": "9581172", "title": "中職／明星賽兩隊球員陣容出爐 羅戈想當委內瑞拉大谷翔平", "summary": "中華職棒明星賽將於7月18、19日在台北大巨蛋登場，高志綱領軍TEAM TAIWAN，為年底亞洲職棒冠軍爭霸賽做準備，對決曾豪駒率領的TEAM STAR；高志綱表示，這次球員名單討論、想了很久，希望年輕好手能在這次明星賽激發潛能。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065700.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-22 16:28", "link": "/news/story/7001/9581172"}, {"article_id": "9580985", "title": "世足運彩／J組生死戰沙漠之狐強勢反彈 對約旦Gemini推阿爾及利亞2:1", "summary": "2026年世界盃J組小組賽迎來攸關晉級命運的關鍵戰役，首戰吞敗的約旦與阿爾及利亞將展開正面對決。從主客場心理優勢與球隊狀態切入，兩隊雖然首輪皆墨，但世界排名高達第28的阿爾及利亞，在整體大賽經驗與抗壓", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065589.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-22 16:20", "link": "/news/story/123105/9580985"}, {"article_id": "9581145", "title": "世足／連兩戰踢和陷淘汰邊緣 比利時主帥：缺乏終結的臨門一腳", "summary": "2018年世界盃季軍的強權比利時本屆賽事困難重重，日前對上埃及才以1：1踢和，今天與伊朗一戰又再次以0：0和局收場，目前僅累積2分積分，晉級出現懸念。賽後受訪時，比利時主帥賈西亞（Rudi Garcia）就點出問題，表示球隊在這場比賽讓機會錯失太多次。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065620.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 16:16", "link": "/news/story/123107/9581145"}, {"article_id": "9580986", "title": "世足運彩／約旦士氣有進球支撐但防線仍鬆動 GPT看好阿爾及利亞2:1", "summary": "約旦首戰雖以1比3敗給奧地利，至少靠Ali Olwan攻進隊史世界盃首球，士氣並非完全崩盤；阿爾及利亞則是0比3遭阿根廷完封，排名第28卻未能進球，壓力反而更沉。兩隊同為0分，這場已不是慢慢調整的比賽", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065570.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 16:14", "link": "/news/story/123105/9580986"}, {"article_id": "9581093", "title": "NBA／雷霆倒在溫班亞瑪前衛冕夢碎 勇士格林鬆口氣：不想看別隊連霸", "summary": "雷霆在2025-26年賽季挑戰二連霸失利，對勇士球星格林（Draymond Green）來說，這個結果讓他鬆了一口氣。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065522.jpg&M=1&s=Y&x=0&y=1&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 16:03", "link": "/news/story/7002/9581093"}, {"article_id": "9581089", "title": "中職／江坤宇包辦57萬9003票 第3次獲選明星賽人氣王", "summary": "中華職棒明星賽將於7月18、19日在台北大巨蛋登場，TEAM STAR對決TEAM TAIWAN，分別由曾豪駒、高志綱領軍，中信兄弟隊內野手江坤宇生涯第3次獲選人氣王。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065514.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 15:55", "link": "/news/story/7001/9581089"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9580429", "title": "世足賽／等了92年！埃及3比1逆轉紐西蘭 勇奪隊史首勝", "date": "2026-06-22 11:25", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35064373.jpg&M=1&s=Y&x=0&y=17&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9580429"}, {"article_id": "9580004", "title": "世足賽／維德角續寫黑馬驚奇 2比2逼平烏拉圭", "date": "2026-06-22 08:22", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35063771.jpg&M=1&s=Y&x=0&y=62&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9580004"}, {"article_id": "9579926", "title": "世足賽／比利時狂攻未果吞紅牌 伊朗頑抗守成零比零言和", "date": "2026-06-22 05:46", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35063581.jpg&M=1&x=&y=&sw=&sh=&exp=3600&w=300"