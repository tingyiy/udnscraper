date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/07/34833317.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300"}, {"article_id": "9419212", "title": "經典賽／台灣血脈一線牽 「費仔」用球棒為母親故鄉而戰", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/02/34822502.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9424998", "title": "日職／成績在洋砲排中段班 林安可還需加強得點圈及長打力", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830714.jpg&M=1&s=Y&x=154&y=0&sw=1080&sh=720&exp=3600&w=300"}, {"article_id": "9425072", "title": "最對味的柯瑞回來了！為勇士帶來季後賽能量和幻想", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830788.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9428749", "title": "MLB／「平常都在電視上看他投球」 岡本和真首度對決山本由伸敲長打", "summary": "藍鳥隊本周和道奇隊進行三連戰，本季赴美發展的日籍強打岡本和真，今天在第二戰面對經典賽日本隊隊友山本由伸，第三打席靠電子好球帶系統（ABS）改判，逃過三振改敲二壘打，明天將要對上「年輕時對決過」的大谷翔平。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835779.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-08 12:32"}, {"article_id": "9428740", "title": "擊劍／李讓首次全大運拚獎牌大滿貫 放眼亞錦賽頒獎台爭亞運資格", "summary": "我國擊劍新星李讓2月在亞洲青年擊劍錦標賽拿下我國首面男子銳劍團體金牌，5月將首度站上全大運舞台，今天出席全大運記者會時表示，儘管今年國內外賽程安排相當密集，仍希望在生涯首次全大運上完成自己台灣擊劍獎牌的最後一塊拼圖。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835768.jpg&M=1&s=Y&x=0&y=0&sw=954&sh=636&exp=3600&sl=W&fw=360", "date": "2026-04-08 12:30"}, {"article_id": "9428710", "title": "MLB／舊將小萊特送幸福！洋基羅沙里歐逆轉三分砲氣走運動家", "summary": "洋基今天在主場以5：3逆轉擊敗運動家，三壘手羅沙里歐貢獻2支全壘打，尤其在第8局擊出關鍵的3分砲。洋基持續以8勝2負在美聯東區獨走，貝德納成功封鎖比賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835731.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 12:26"}, {"article_id": "9428673", "title": "NBA／幫里夫斯檢查出包？獨行俠打臉湖人說法", "summary": "湖人隊後場大將里夫斯（Austin Reaves）上周碰雷霆隊時受傷，經檢查是左側腹斜肌二級拉傷，但湖人總教練瑞迪克（JJ Redick）指控幫里夫斯檢查的獨行俠隊團隊出現醫療疏失，第一次MRI檢查掃描錯誤部位，不過獨行俠今天發布聲明否認指控，強調只是一切程序都正常，掃描結果沒有任何錯誤。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835767.jpg&M=1&s=Y&x=0&y=49&sw=854&sh=569&exp=3600&sl=W&fw=360", "date": "2026-04-08 12:09"}, {"article_id": "9428669", "title": "TPBL／攻城獅「MUSE純愛俱樂部」來襲 17位慕獅女孩首次全員到齊", "summary": "新竹御嵿攻城獅球團今天和11、12日在主場舉辦年度超人氣主題周「MUSE純愛俱樂部」，再度攜手知名泳裝品牌WAVE SHINE，由「Muse Girls慕獅女孩」以絕美比基尼造型詮釋純愛氛圍，準備讓獅紫軍在春季感受甜度爆表的主場活動。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835655.jpg&M=1&s=Y&x=0&y=0&sw=1079&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-08 12:09"}, {"article_id": "9428632", "title": "全大運／NVIDIA、宏碁合力贊助 電競重回全大運舞台", "summary": "115年全國大專校院運動會將於5月2日至6日在國立中央大學盛大登場，今天也舉行全國記者會暨聖火引燃儀式，這不僅是中央大學校史第3度承辦全大運，加上今年適逢名古屋亞運年，讓不少國手都將此視為亞運會的前哨戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835571.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 12:01"}, {"article_id": "9428535", "title": "MLB／海盜王牌史肯斯5.1局無安打 走出開幕戰陰霾收二連勝", "summary": "海盜王牌史肯斯今天投出6.1局無安打，率隊以7：1擊敗教士，迎來本季第二勝。史肯斯前五局僅讓1名打者上壘，最終防禦率下降至5.25，成功走出開幕戰陰霾。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835437.jpg&M=1&s=Y&x=0&y=17&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-08 12:00"}, {"article_id": "9419212", "title": "經典賽／台灣血脈一線牽 「費仔」用球棒為母親故鄉而戰", "summary": "【撰文・鄧心瑜】 在經典賽之前，Stuart Fairchild和台灣之間的關係不算親密，美籍台裔、混血身份這些標籤新鮮卻陌生，隨著他代表中華隊參戰，逐漸被台灣球迷的熱情給收服，而他在台灣球迷眼中，逐漸從單純「具台灣血統」成為Team Taiwan實質戰力，甚至進一步成為球迷口中的「費仔」、「費寶」這樣帶有親切感的暱稱，他與這片土地之間的情感連結短時間內變得更加濃烈。 Fairchild與台灣的交集來自於母親，她12歲時離開台灣移民美國，從此未再踏上這座太平洋小島，對 Fairchild而言，台灣只是在談論家族往事時，朦朧又陌生的他鄉。然而就是這條與台灣相連的血脈，接到了來自「+886」中華職棒的聯繫，當時沒想太多，單純想為母親的家鄉效力，不敢想他的參賽引發多巨大的效應，在經典賽的表現讓全台灣球迷為他陷入瘋狂，短短一週之內贏得整個國家的人支持。 職業與現實拉扯 故事通往台灣 <", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/02/34822502.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 12:00"}, {"article_id": "9428493", "title": "MiLB／李灝宇回3A首打席敲安 鄭宗哲敲本季首支三壘打", "summary": "旅美底特律老虎隊野手李灝宇今天回到小聯盟3A出賽，首打席就敲出安打、貢獻1分打點；波士頓紅襪隊3A鄭宗哲本季首支三壘打出...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835459.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 11:36"}, {"article_id": "9428376", "title": "NBA／公鹿季中曾考慮「英雄」交易包 字母哥差點加入熱火", "summary": "公鹿考慮將安戴托昆波交易至熱火，交易包裹包括赫洛及韋爾等球員與多個選秀權。最終公鹿選擇保留字母哥，期待休賽季獲得更好報價。安戴托昆波本季出賽36場，場均27.6分。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835143.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 11:30"}, {"article_id": "9428516", "title": "TPBL／率雲豹連勝穩固龍頭 克羅馬奪單周MVP", "summary": "TPBL今天宣布第23周單周最有價值球員（MVP）得主，上周末助桃園台啤永豐雲豹隊打下主場2連勝的洋將克羅馬，以穩定又全面的表現獲選單周MVP。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835383.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-08 11:26"}, {"article_id": "9428503", "title": "MLB／鄧愷威對洛磯中繼挨轟失1分 太空人僅敲3安吞下三連敗", "summary": "太空人隊今天客場迎戰科羅拉多洛磯隊，鄧愷威本季第4度登板，7局下在球隊落後2分、壘上有人時登板，被轟出一發2分全壘打，帳上失1分，用7球完成0.2局的投球任務，最終太空人隊以1：5吞下3連敗，洛磯隊則收下3連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835385.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 11:23"}, {"article_id": "9428499", "title": "NBA／開幕戰就成傷兵 公鹿後衛波特動刀提前關機", "summary": "公鹿隊確定無緣季後賽，球隊今天宣布後衛波特（Kevin Porter Jr.）已進行右膝微創手術，賽季提前告終。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835338.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 11:22"}, {"article_id": "9428446", "title": "MLB／藍鳥捕手牽制弄傷大谷左手臂？道奇教頭：比較像被嚇到", "summary": "道奇隊二刀流巨星大谷翔平明天將先發登板，今天比賽，藍鳥隊捕手瓦倫祖拉（Brandon Valenzuela）牽制時不慎擊中大谷左手臂，道奇總教練羅伯茲（Dave Roberts）賽後受訪時說明狀況。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835272.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 11:09"}, {"article_id": "9428278", "title": "MLB／山本由伸6局失1分奪第2勝 大谷翔平1安1打點連42場上壘", "summary": "道奇隊對藍鳥隊3連戰第二場比賽，日籍強投山本由伸先發6局失1分，大谷翔平連42場上壘、敲回勝利打點，終場道奇以4：1勝出，收下5連勝，賞給藍鳥6連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835016.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 10:16"}, {"article_id": "9428253", "title": "MLB／小熊輪值拉警報 上季新人王第2霍頓動刀本季報銷", "summary": "小熊隊右投手霍頓因手肘傷勢將接受手術，確定報銷2026賽季。這名上季國聯新人王票選第二的投手，本季僅投7.1局即宣告提前結束。小熊輪值面臨重大打擊，霍頓的缺席將影響球隊表現。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34834971.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 10:11"}, {"article_id": "9428033", "title": "MiLB／看好林昱珉上大聯盟！響尾蛇投手總監：不只升上去、要待夠久", "summary": "響尾蛇小聯盟投手總監密爾茲向中央社表示，林昱珉運動天分、投球協調性在體系內數一數二，今年挑戰大聯盟是球團目標，期待他投出...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34834877.jpg&M=1&s=Y&x=280&y=54&sw=792&sh=529&exp=3600&sl=W&fw=360", "date": "2026-04-08 09:40"}, {"article_id": "9428167", "title": "NBA／角逐MVP利多！溫班亞瑪傷勢無礙", "summary": "馬刺隊當家中鋒溫班亞瑪（Victor Wembanyama）昨天戰76人隊時傷退，只留下出賽16分鐘拿17分、5籃板、3阻攻的成績單，好消息是沒有出現嚴重傷勢，明天碰拓荒者隊雖出賽成疑，不過例行賽尾聲回歸不成問題，讓溫班亞瑪能達標角逐個人獎項的最低出賽場次規定。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34834859.jpg&M=1&s=Y&x=87&y=0&sw=670&sh=477&exp=3600&sl=W&fw=360", "date": "2026-04-08 09:32"}, {"article_id": "9428093", "title": "NBA／獨撐大樑太操 詹姆斯對衛冕軍休兵", "summary": "湖人隊今天要強碰衛冕軍雷霆隊，但球隊宣布，41歲的指標球星「小皇帝」詹姆斯（LeBron James）因左腳痠痛確定缺陣，讓紫金軍團「三巨頭」全部缺席。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34834773.jpg&M=1&s=Y&x=0&y=0&sw=1249&sh=833&exp=3600&sl=W&fw=360", "date": "2026-04-08 08:50"}, {"article_id": "9428060", "title": "NBA／力挺唐納文續任總教練 公牛老闆坦言厭惡擺爛文化", "summary": "在連續4個賽季無緣季後賽後，公牛本周拋出震撼彈，解僱副總裁卡尼索瓦斯（Arturas Karnisovas）與總管艾佛斯利（Marc Eversley），老闆藍斯道夫（Michael Reinsdorf）也在今天表示，球隊接下來將積極尋找接替人選，但首要條件就是必須留下總教練唐納文（Billy Donovan）。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34834782.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 08:20"}, {"article_id": "9427576", "title": "中職／莫忘日本火腿出走教訓 南市府應修補裂痕與統一共榮", "summary": "台南市亞太國際棒球訓練中心成為統一獅新主場，因市府與球團關係出現裂痕，恐影響長期合作。類似日本火腿的出走教訓，市府應積極修補，促進雙方共榮。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/07/34834270.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 07:00"}, {"article_id": "9427523", "title": "忙到頭來一場空 湖人功虧一簣賽季真正失去了什麼？", "summary": "洛杉磯湖人隊的核心球員唐西奇確診左腿筋二級拉傷，將缺席剩餘例行賽，球隊面臨季後賽前景黯淡。隨著唐西奇受傷，湖人失去進攻引擎，加之近況不佳，讓球迷對團隊未來倍感迷茫。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/07/34834230.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 07:00"}, {"article_id": "9426854", "title": "日職／改後援全因輪值太滿 古林轉牛棚並非不合理但還有變數", "summary": "古林睿煬在日本火腿隊開季被調整為後援投手，引發球迷質疑。由於先發陣容競爭激烈，古林轉為牛棚雖合理，但其表現尚未達標。未來隨著隊伍狀態變化，位置調整仍存變數。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/07/34833317.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-08 07:00"}, {"article_id": "9427616", "title": "中職／雄鷹、獅比賽因雨裁定和局 布雷克優質先發奪MVP", "summary": "中華職業棒球大聯盟台鋼雄鷹隊今天交手統一7-ELEVEn獅隊，但雨勢不斷，比賽打到8局下半2人出局後，因雨裁定兩隊1比1...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/07/34834470.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-07 23:57"}]}, {"name": "林哲瑄專訪", "articles": [{"article_id": "9413494", "title": "林哲瑄專訪／棒球療效一輩子 過動兒踏出30年棒球生涯", "date": "2026-03-3