ail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/21/34967391.jpg&M=1&s=Y&x=0&y=0&sw=960&sh=640&exp=3600&sl=W&fw=360", "date": "2026-05-21 08:02"}, {"article_id": "9516075", "title": "NBA／稱開除基德是艱難決定 獨行俠總裁：期待厄文與佛雷格化學效應", "summary": "獨行俠在昨天拋出震撼彈，宣布與執掌兵符五個賽季的總教練基德（Jason Kidd）分道揚鑣，剛接任獨行俠總裁的尤基利（Masai Ujiri）今天首度公開談及此事，坦言這是一個完全由他個人承擔的「極度艱難決定」，但他也強調，現在的獨行俠需要重新出發。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_4.jpg", "date": "2026-05-21 07:54"}, {"article_id": "9515955", "title": "不是瑜亮！霍姆葛倫不該被拿來和溫班亞瑪比較", "summary": "當溫班亞瑪（Victor Wembanyama） 橫空出世之後，霍姆葛倫（Chet Holmgren）很快就被貼上一種很奇怪的標籤： 「那個永遠會被溫班亞瑪壓過的人。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/21/34967257.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-21 07:20"}, {"article_id": "9514832", "title": "中職／成功頂替江坤宇及張育成 兩小將成球隊游擊新希望", "summary": "中職游擊手位置迎來新希望，池恩齊與張仁瑋分別成功頂替受傷的江坤宇與張育成。兩人近期表現出色，池恩齊打擊率達2成86，張仁瑋更以3成67的成績成為中信主力游擊手，協助球隊穩住防守陣線。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34965771.jpg&M=1&s=Y&x=0&y=0&sw=800&sh=533&exp=3600&sl=W&fw=360", "date": "2026-05-21 07:00"}, {"article_id": "9515500", "title": "大聯盟指叉球使用量日增 為何左投手不用？", "summary": "指叉球在大聯盟的使用量逐年上升，但其使用率在左投手中仍然稀少，右投手的比例是其四倍。專家指出，可能原因包括傷害風險、傳統習慣及投球機制等因素。隨著需求增加，左投手或許將逐步采納這一球種。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966735.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-21 07:00"}, {"article_id": "9515817", "title": "高球／吳佳晏世界排名88 生涯新高", "summary": "中國信託商業銀行贊助的「中國信託女子高爾夫之星」吳佳晏，上周在日本女子高爾夫巡迴賽（ＪＬＰＧＡ）「Sky RKB菁英賽」拿下第二名後，世界排名攀升，最新排名來到生涯新高的第八十八位，持續位居台灣女子職業高爾夫選手之首，表現亮眼。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34967055.jpg&M=1&s=Y&x=179&y=103&sw=1031&sh=687&exp=3600&sl=W&fw=360", "date": "2026-05-21 00:00"}, {"article_id": "9515652", "title": "前所未見！雙向力場怪獸崛起 溫班亞瑪如何摧毀雷霆陣容深度優勢", "summary": "西區冠軍戰，聯盟戰績最好的兩支60+勝級球隊對決，儘管外界咸認這會是輪激戰，卻也很少人能預料到，本該帶有互相試探性質的第一戰，兩隊就打出如此精彩的頂上對決，完全不負外界「西冠即總冠」的評價，展現當代兩支最強隊伍的超凡實力，溫班亞瑪（Victor Wembanyama）史上最年輕「40分20籃板」的表現，更宛如一戰封神，讓世人彷彿看到他即將登基「當代最強球員」的不遠未來。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966926.png&M=1&s=Y&x=37&y=0&sw=1243&sh=828&exp=3600&sl=W&fw=360", "date": "2026-05-20 23:22"}, {"article_id": "9515761", "title": "中職／桃猿單場打9分超越上周5戰總和、本季新高 曾總：會越來越好", "summary": "樂天桃猿近期打擊狀況低迷，這周回到主場，首戰找回火力，單場敲出13支安打，包括李勛傑單場雙響砲灌5打點，最終以9：7擊敗中信兄弟，終止近期4連敗，單場得分超過上周5戰總和，也寫下本季單場得分新高。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34967024.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-05-20 23:14"}, {"article_id": "9515673", "title": "中職／單場雙響砲轟破打擊低潮 李勛傑：想法簡單一點", "summary": "樂天桃猿21歲強打李勛傑今天棒打中信兄弟，本季第2度演出單場雙響砲，走出近期的打擊低潮，也幫助猿隊以9：7終結4連敗。李勛傑本季累積5轟竄上全壘打榜並列第2，他生涯累積6發全壘打都是出現在桃園球場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966931.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-20 22:52"}, {"article_id": "9515616", "title": "中職／李勛傑第二度雙響砲灌5打點 桃猿9：7退兄弟止敗寫本季得分新高", "summary": "樂天桃猿隊本周回到主場尋求止敗，今天打線手感回溫，單場掃出13支安打，靠著李勛傑本季第二度單場雙響砲打下9分，寫下猿隊本季單場得分新高，最終以9：7擊落中信兄弟，終結4連敗、賞兄弟2連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966847.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-20 22:04"}, {"article_id": "9515594", "title": "中職／伍鐸好投+蔣少宏開轟 味全5：2勝台鋼收5連勝", "summary": "味全龍隊本季赴花蓮的第2場比賽，今天由伍鐸出馬，主投6.2局失1分壓制台鋼打線，還有捕手蔣少宏敲本季個人首轟，終場以5：2拿下勝利，在花蓮收下2連勝、延續近期5連勝，續坐聯盟龍頭。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966830.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-20 21:56"}, {"article_id": "9515559", "title": "國體大新校長出爐 副校長黃東治出線", "summary": "國立體育大學第12任校長出爐，遴選委員會今天召開第3次會議遴選，現任副校長黃東治在4位候選人中脫穎而出，今天學校正式公告，預計今年8月1日上任。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966800.jpg&M=1&s=Y&x=0&y=155&sw=960&sh=640&exp=3600&sl=W&fw=360", "date": "2026-05-20 21:26"}, {"article_id": "9515554", "title": "中職／阿部雄大7局好投+王苡丞雙安3打點 悍將9：2宰獅", "summary": "富邦悍將日籍投手阿部雄大來台第2場先發，今天對統一獅隊主投7局僅被敲2支安打，因蘇智傑的陽春砲失1分，悍將打線今天也展現強大火力，全場掃出11支安打，包括王苡丞雙安3打點貢獻，終場以9：2大勝獅隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966794.jpg&M=1&s=Y&x=0&y=66&sw=1024&sh=682&exp=3600&sl=W&fw=360", "date": "2026-05-20 21:22"}, {"article_id": "9515467", "title": "中職／李勛傑睽違1個月敲個人本季第4轟 僅是桃猿5月第2轟", "summary": "樂天桃猿近期陷入4連敗，今天回到主場桃園棒球場對上中信兄弟，李勛傑在4局下轟出一發3分全壘打，是他個人本季第4轟，也是猿隊本季第12轟、5月團隊第2轟。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966673.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-05-20 20:20"}, {"article_id": "9515313", "title": "中職／張趙紘升一軍擔任DH或代打 曾總告訴他「你就是砲！」", "summary": "樂天桃猿開季至今打擊不振，前天將何品室融降二軍，並拉上20歲強打新秀張趙紘，期待能強化球隊火力，被設定為指定打擊或代打角色，張趙紘透露，這次被叫上一軍，總教練曾豪駒告訴他，「你就是一個砲！」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966484.jpg&M=1&s=Y&x=1&y=107&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-20 18:57"}, {"article_id": "9515299", "title": "高球／世界排名上升11名 吳佳晏寫新高", "summary": "中國信託商業銀行贊助的「中國信託女子高爾夫之星」吳佳晏，上周於JLPGA「Sky RKB菁英賽」拿下第二名後世界排名攀升，最新公布的世界排名從原本99名提升11位來到第88位，持續位居臺灣女子職業高爾夫選手之首，表現相當亮眼。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966467.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&sl=W&fw=360", "date": "2026-05-20 18:47"}, {"article_id": "9515272", "title": "中職／黎克手肘不適讓游竣宥迎生涯初先發 王建民：他滿有鬥志", "summary": "中信兄弟連續兩戰推出本土投手登板迎生涯初先發，周日派出24歲的伍立辰，今天面對樂天桃猿隊則是讓22歲菜鳥左投游竣宥登板，投手教練王建民解釋，原訂今天要先發的洋投黎克手肘不適，將安排明天進行檢查。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966480.jpg&M=1&s=Y&x=0&y=1&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-20 18:35"}, {"article_id": "9515251", "title": "中職／被張政禹盜本壘挨罵 林子崴：檢討自己2好球沒解決打者", "summary": "樂天桃猿左投林子崴周日中繼登板面對味全龍隊，7局下在2出局後製造一、三壘有人的局面，接著被張政禹盜本壘成功，他也因此受到不少私訊謾罵，林子崴事後自我反省，「應該檢討自己前兩打席2好球沒有解決打者。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966425.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-05-20 18:21"}, {"article_id": "9515186", "title": "中職／盜本壘除了腳程還要勇氣 猿補手嚴宏鈞稱張政禹「夠大膽」", "summary": "味全龍隊內野手張政禹在周日對上樂天桃猿之戰，7局下在投捕都還未能反應過來之際，從三壘「盜本壘」攻下分數，猿隊總教練曾豪駒、捕手嚴宏鈞今天還原當下狀況，都稱讚張政禹夠大膽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955829.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-20 17:59"}, {"article_id": "9515123", "title": "王貞治青棒賽／張乙安開轟引爆單局8分 新北晉冠軍戰", "summary": "王貞治青棒賽今天4強戰新北市隊團隊敲出2轟，其中包含張乙安在第5局點燃攻勢的2分砲，單局攻下8分，以11比1提前擊倒台東...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966541.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-20 17:49"}, {"article_id": "9515105", "title": "馬國羽賽／王子維首勝中國翁泓陽 男單闖頭關", "summary": "BWF超級500系列的馬來西亞羽球大師賽，台灣「羽球王子」王子維今天在男單首輪以21比17、19比21、21比18擊敗中...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966245.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-20 17:42"}, {"article_id": "9515031", "title": "中職／遭蚊子大軍攻擊？比基尼背部照慘況曝光 瑟七：可能會薯條", "summary": "統一獅啦啦隊女孩瑟七近日發布比基尼背部照，卻驚見全身超過10處蚊子叮咬痕跡，特別是腰部成為「重災區」。此貼文引發粉絲熱烈關心與留言。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966107.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-20 17:19"}, {"article_id": "9515075", "title": "全障運／北市邱文昇、柯茗碩合體 再度拿下保齡球視障雙人賽A組冠軍", "summary": "代表台北市的邱文昇與柯茗碩2人，上屆全國身心障礙國民運動會就在視障雙人賽A組拿下金牌，本屆再度「雙劍合璧」，各自揮別首日賽事狀況不盡理想的小低潮，今天以6局1873分完成2連霸，朝開「五金行」目標繼續邁進。", "thumbnail": "https://pgw.udn.com.tw