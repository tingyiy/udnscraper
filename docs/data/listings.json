/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34862228.jpg&M=1&s=Y&x=0&y=36&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9443464", "title": "美媒揭大都會搶人失敗內幕 但狄亞茲球速下滑道奇虧大了？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857969.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9452943", "title": "NBA／肯定老詹全能表現 湖人5冠名將：現在是他的魔術強森時代", "summary": "曾助湖人奪下5座總冠軍的傳奇控衛費雪（Derek Fisher），在觀看41歲湖人當家球星「老詹」詹姆斯（LeBron James）於季後賽首戰交手火箭的出色表現後，給予他極高的讚賞，並將詹姆斯比做湖人80年代傳奇球星魔術強森（Magic Johnson）。意指即使詹姆斯體能早已不在巔峰，但在球場上仍舊可以用成熟的球商和球技為球隊做出貢獻。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872904.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 16:32"}, {"article_id": "9452836", "title": "NBA／龍頭活塞到底怎麼輸的？ 總教練、球星分析原因在首節", "summary": "季後賽東區首輪G1賽事，例行賽東區龍頭活塞隊今交手第8種子魔術，卻爆冷101：112輸球，讓不少專家、球迷感到訝異。賽後，活塞總教練比克斯塔夫（J.B. Bickerstaff）以及當家球星康寧漢（Cade Cunningham）各自發表對於爆冷輸球的看法，當中的共同點是兩人認為球隊開局的落後是釀成輸球的主因。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872733.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-20 16:22"}, {"article_id": "9452672", "title": "NBA／「洛杉磯太膚淺」 字母哥放話下家非湖人另有選擇", "summary": "公鹿隊當家球星「字母哥」安戴托昆波（Giannis Antetokounmpo）的交易傳聞仍是今年自由球員市場上最熱門話題，此前洛杉磯湖人隊曾被認為是他的潛在加盟地，但根據安戴托昆波本人近期在節目上的說法，洛杉磯可能將被排除在外。相較之下，他認為，位於東岸的邁阿密熱火是較有可能的去處。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872388.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 16:11"}, {"article_id": "9452952", "title": "全中運／跟隨哥哥馬皓瑋腳步 15歲馬加樂破魔王關國女鐵餅奪金", "summary": "台南市金城國中馬加樂憑藉唯一試擲成功的44公尺59，不但在115年全中運國女鐵餅入袋金牌，還一舉打破高懸18年的大會紀錄，身為在各賽事掃蕩金牌的「紀錄收割機」，趕在畢業前終於將全中運也納進版圖。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872925.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-20 16:10"}, {"article_id": "9452885", "title": "花式滑冰／13歲詹祥妤挑戰三周跳 穩步邁向國際舞台", "summary": "年僅13歲的詹祥妤已累積多次國際賽經驗，並準備在即將到來的全國菁英賽中挑戰技術難度。雖然心中有緊張，她的表現顯示出在競技舞台上的潛力與企圖心。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872818.jpg&M=1&s=Y&x=0&y=182&sw=960&sh=640&exp=3600&sl=W&fw=360", "date": "2026-04-20 15:51"}, {"article_id": "9452876", "title": "NBA／季後賽處女秀有馬刺傳奇見證 溫班亞瑪喊酷", "summary": "馬刺隊當家球星溫班亞瑪（Victor Wembanyama）今天季後賽處女秀就轟下35分，除改寫隊史紀錄，也助隊以111：98擊敗拓荒者隊。首度感受季後賽張力的「斑馬」提到，光是熱身時就能感受季後賽氛圍不同，也很開心看到兩位隊史傳奇球星「石佛」鄧肯（Tim Duncan）和羅賓森（David Robinson）到場支持。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872846.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-20 15:38"}, {"article_id": "9452850", "title": "中職／「龍之萌友」親子毛孩日5月登場 推出TOMBONIA聯名入場禮", "summary": "味全龍隊將於5月初在天母球場對富邦悍將隊進行3連戰，2日、3日舉辦「龍之萌友的應援時光 ─『塩』守健康！親子毛孩日」，和日本超人氣插畫TOMBONIA攜手推出系列入場贈品及商品，場邊更有豐富的活動讓家長、小朋友與萌寵們互動。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872750.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-20 15:28"}, {"article_id": "9452740", "title": "MLB／「卡仔」昨轟滿貫砲今卻傷退 響尾蛇主帥強調應無大礙", "summary": "響尾蛇台美混血明星外野手「卡仔」卡洛爾（Corbin Carroll）在昨天對藍鳥的比賽後半轟出一發超前滿貫砲，幫助球隊贏球。今天同樣面對藍鳥卻在第5局出現下背部緊繃的情況，讓球隊選擇將他換下，響尾蛇最後也以4：10吞敗。響尾蛇總教練羅夫洛（Torey Lovullo）在稍早表示傷勢並無大礙，下一場對白襪出賽不成問題。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872525.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 15:15"}, {"article_id": "9452804", "title": "中職／悍將本季首度「攻蛋」票價公布！529玖壹壹賽後開唱", "summary": "富邦悍將隊5月底進台北大巨蛋，除了5月30日 (六)、5月31日 (日) 「G!POP流行音樂節」已公布賽後嘉賓外，今日宣布5月29日（五）賽後將邀請本土天團「玖壹壹」擔任表演嘉賓，悍將大巨蛋系列戰預售票也即將於4月23日起開放亞瑟傳奇優先購票，4月28日一般售票全面開賣。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872666.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-20 15:09"}, {"article_id": "9452782", "title": "經典賽／費仔和中華隊友建立終生友誼 計畫11月訪台也要學中文", "summary": "台美混血球員費爾柴德（Stuart Fairchild）接受經典賽官網專訪，今天在首頁登出大篇幅報導，這位擁有5年大聯盟資歷的外野手說：「中華隊完全擁抱我，對此我感激不盡。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872649.jpg&M=1&s=Y&x=0&y=63&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 14:59"}, {"article_id": "9452733", "title": "經典賽／返美每場比賽仍見台灣球迷 費爾柴德對中華隊表達感激", "summary": "第6屆世界棒球經典賽已經結束1個多月，官網今天推出台美混血球員費爾柴德（Stuart Fairchild）的專訪，從他本來擔心加入中華隊，到台灣球迷瘋狂支持，都有非常詳盡的報導，這位30歲好手說：「台灣人民對棒球的影響和關心，我在經典賽前完全不知。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872503.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 14:31"}, {"article_id": "9452728", "title": "全障運5月登場 新北推七大服務讓運動無礙", "summary": "2026年全國身心障礙國民運動會將從5月23日至26日在新北市登場，新北市長侯友宜今天主持「賽會有服務」開箱體驗，新北針對選手提供包含器材損壞、身體恢復、交通接駁等，打造「服務型賽會」，也邀請民眾一起來參與這次全國盛會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872491.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-20 14:29"}, {"article_id": "9452698", "title": "棒球／亞運副場地岡崎球場 內野黑土、界外區人工草皮", "summary": "愛知・名古屋亞運將在9月登場，棒球賽事將分在兩個戶外球場進行，主球場為豐橋市民棒球場，今天亞運考察團先至副球場岡崎市民球場進行視察，擔任賽會技術代表的葉志仙指出，場地基本上沒有問題，就是希望能選手村離球場的路程不要太長。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872439.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 14:08"}, {"article_id": "9451916", "title": "NBA／綠衫軍雙槍首戰飆分寫紀錄 泰托姆敬重76人：他們不像傳統第7種子", "summary": "東區季後賽首輪，後勢看漲的波士頓塞爾蒂克以壓倒性勝利痛宰費城76人，最終大勝32分之多，輕鬆在系列賽首戰奪勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872332.jpg&M=1&s=Y&x=73&y=41&sw=1207&sh=804&exp=3600&sl=W&fw=360", "date": "2026-04-20 14:00"}, {"article_id": "9452655", "title": "台灣體壇美少女學霸姊妹 國際花式滑輪溜冰公開賽再創佳績", "summary": "2026年台灣國際花式溜冰公開賽圓滿落幕，姊妹花黃海琍獲得自由型青女組第四名，妹妹黃敏琍在少女組中贏得第二名。她們展示出超凡韌性及潛力，將為即將到來的世錦賽繼續努力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872339.jpg&M=1&s=Y&x=0&y=212&sw=960&sh=640&exp=3600&sl=W&fw=360", "date": "2026-04-20 13:59"}, {"article_id": "9452241", "title": "NBA／曾遭斑馬戲稱「罰球很多」 拓荒者一哥回應：沒太在意", "summary": "今年NBA全明星賽期間，馬刺隊球星「斑馬」溫班亞瑪（Victor Wembanyama）曾對拓荒者隊明星前鋒阿夫迪賈（Deni Avdija）的買犯能力發表了一番尖銳評論。雖然有些人可能認為這是在暗諷，但阿夫迪賈似乎對此毫不在意。在今日馬刺交手拓荒者的首輪季後賽G1前，這位明星前鋒回應了溫班亞瑪的評論表示絲毫不在意，並強調他現在只專注在比賽本身。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871661.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=852&exp=3600&sl=W&fw=360", "date": "2026-04-20 13:35"}, {"article_id": "9452581", "title": "MLB／慘！道奇守護神投0局狂失3分 總教練分析可能「太久沒登板」", "summary": "休賽季獲得3年6900萬美元（約新台幣22億元）大合同的道奇明星終結者狄亞茲（Edwin Diaz），睽違8天再度於今日登板，在面對洛磯比賽第8局登板救援，但他卻1個局數都沒拿就被敲3安狂失3分，賽後防禦率更飆到雙位數。道奇總教練羅伯茲（Dave Roberts）賽後總結，狄亞茲可能因為太久沒上場，所以控球、球速都有些生疏。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872205.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 13:34"}, {"article_id": "9452605", "title": "MiLB／林維恩先發5局8K勇奪2A首勝 表弟柯敬賢1A開轟", "summary": "旅美運動家隊左投林維恩今天小聯盟2A登板，先發飆出8次三振、無失分，奪下2A生涯首勝；洛杉磯道奇隊1A野手柯敬賢維持手感...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872281.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-20 13:32"}, {"article_id": "9452556", "title": "全中運／花蓮洪災後剩1支標槍練習 光復國中田佳恩拚出金牌", "summary": "花蓮光復國中選手田佳恩在全中運男子標槍項目奪得金牌，這面金牌得來不易，因去年光復洪災學校操場被淹沒，標槍剩1支得輪流練習...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872246.jpg&M=1&s=Y&x=0&y=320&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-20 13:22"}, {"article_id": "9452104", "title": "NBA／76人不妙！「大帝」安比德可能缺席整個首輪系列賽", "summary": "根據美媒ESPN記者塞達諾（Jorge Sedano）報導，費城76人隊明星中鋒「大帝」安比德（Joel Embiid）日前因闌尾切除手術缺席附加賽，目前仍尚未恢復籃球訓練。因此記者認為，他很可能將缺席整個76人對塞爾蒂克的東區季後賽首輪系列賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871415.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 13:18"}, {"article_id": "9452337", "title": "MLB／大聯盟首秀貢獻2安1打點 「台灣之友」瓦德：感覺真的很棒", "summary": "道奇隊在日前宣布將3A好手瓦德（Ryan Ward）拉上大聯盟，他在今天對洛磯比賽迎來在大聯盟的首次出賽，他也不負眾望交出火燙表現，全場5打數貢獻2安和1分打點。賽後，瓦德也難掩興奮表示在大聯盟出賽的感覺真的很棒。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871808.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 13:11"}, {"article_id": "9452506", "title": "PLG／音樂結合籃球 洋基工程辦嘻哈主題周", "summary": "PLG新球隊洋基工程隊本周4月25日、26日在新竹市立體育館舉辦「洋基嘻哈時代」主題周，兩日賽事分別由晃誼科技與大亞集團冠名支持，攜手結合籃球、音樂與街頭文化元素，規劃多項主題活動與演出內容，邀請球迷一同進場感受方舟主場的嘻哈魅力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872114.jpg&M=1&s=Y&x=0&y=0&sw=1076&sh=717&exp=3600&sl=W&fw=360", "date": "2026-04-20 12:35"}, {"article_id": "9452484", "title": "亞運／射箭場地射向面光 從國內找場地提前適應", "summary": "2026年愛知・名古屋亞運會射箭賽事將在岡崎中央公園綜合多功能廣場進行，考察團今天前往比賽場地進行視察，亞運射箭隊總教練廖健男指出，根據去年來參與模擬賽的經驗，因射向面東邊，選手需要再適應面太陽的環境。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872076.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 12:27"}, {"article_id": "9452452", "title": "日職／徐若熙推算年薪排名高居第6 軟銀5人身價超過5億日圓", "summary": "日本職棒軟銀鷹隊以3年15億日圓（約台幣3億元）合約簽下徐若熙，本季年薪數字並未正式公布，但從日本相關網站的資訊看來，他的身價在所有日職球員排名高居第6，確實相當頂級。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872035.jpg&M=1&s=Y&x=76&y=9&sw=1153&sh=769&exp=3600&sl=W&fw=360", "date": "2026-04-20 12:15"}]}, {"name": "棒球", "articles": [{"article_id": "9452733", "title": "經典賽／返美每場比賽仍見台灣球迷 費爾柴德對中華隊表達感激", "date": "2026-04-20 14:31", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872503.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9452452", "title": "日職／徐若熙推算年薪排名