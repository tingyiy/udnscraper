=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9488776", "title": "球員投票「最沒料教練」第四名 勇士還需要柯爾嗎？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/07/34926618.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300"}, {"article_id": "9489114", "title": "同樣日職明星到美國 今井達也為何水土不服？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/07/34926973.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9487893", "title": "雷霆首戰從從容容游刃有餘 湖人「小輸」背後的恐怖絕望感", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/07/34925288.jpg&M=1&s=Y&x=32&y=68&sw=1210&sh=806&exp=3600&w=300"}, {"article_id": "9486000", "title": "活塞贏G1防守強度仍不及暴龍 騎士有對位優勢看好6戰晉級東冠", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/06/34922484.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9493476", "title": "NBA／忍痛錯失聽牌機會 「活塞一哥」解釋末節崩盤原因", "summary": "在今日活塞騎士G3之戰，上半場打完活塞雖落後雙位數，但易籃後靠著當家主控兼球隊一哥康寧漢（Cade Cunningham）持續輸出，一度在決勝節幫助活塞追到1分差；但騎士主控哈登（James Harden）卻在關鍵時刻接管戰局，連拿7分包含一記致勝三分彈，終場騎士便以116：109擊退騎士。談到在第3戰錯失聽牌機會，康寧漢在賽後分享自己目前的心境，以及比賽最後兩節球隊如何作出調整。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933554.jpg&M=1&s=Y&x=123&y=0&sw=972&sh=656&exp=3600&sl=W&fw=360", "date": "2026-05-10 14:52"}, {"article_id": "9493489", "title": "籃球／全台最大2026紐崔萊三對三籃球挑戰賽 449隊台中熱血開打", "summary": "由紐崔萊獨家冠名贊助，全台規模最大的「2026紐崔萊三對三籃球挑戰賽」，9日在國立中興大學籃球場熱血揭開序幕，今年中區預賽吸引國中、高中、大專及社會組共計449隊、1712名選手踴躍報名參賽，場面盛大，展現台灣籃球運動的蓬勃發展與青春能量。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933570.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-10 14:49"}, {"article_id": "9493479", "title": "NBA／飛人卡特代表籃網抽狀元！14％機率拚翻身 樂透代表名單一次看", "summary": "2026年NBA選秀會樂透抽籤大會將於台灣時間11日凌晨3點在芝加哥登場，14支參與樂透抽籤的球隊也陸續公布代表人選。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933557.jpg&M=1&s=Y&x=0&y=22&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-10 14:41"}, {"article_id": "9493484", "title": "TPBL／助雲豹打下龍頭 克羅馬獲年度外援肯定", "summary": "TPBL今天公布年度外援，由桃園永豐雲豹隊克羅馬（Lasannah Kromah）獲選，他在媒體與球迷綜合加權評選中以4成51總占比居冠，擊敗新竹御嵿攻城獅隊洋將德魯與新北中信特攻隊的馬可，成功拿下年度外援殊榮。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933562.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-05-10 14:37"}, {"article_id": "9493435", "title": "NBA／批評巴克利言論慘遭炎上！格林：我非常樂意公開道歉", "summary": "勇士王朝元老級人物之一的「嘴綠」格林（Draymond Green）又因爭議言論惹上麻煩。此前在ESPN一檔節目中，格林針對NBA傳奇球星巴克利（Charles Barkley）批評「勇士王朝已終結」論述做出回擊。然而，當時格林反駁巴克利的說辭，如今卻遭外界「炎上」，並在網路引起軒然大波。格林在事後發表道歉聲明，並試圖澄清他並沒有任何不敬之意。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933488.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-10 14:08"}, {"article_id": "9493456", "title": "NBA／史上第6支！衛冕軍雷霆前7戰全勝 過往3隊最終順利衛冕", "summary": "衛冕軍奧克拉荷馬雷霆今天持續季後賽不敗之姿，全隊在米契爾（Ajay Mitchell）24分領軍下，今天在系列賽第3戰以131比108擊敗洛杉磯湖人，距西冠門票只差最後1勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933521.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-10 14:06"}, {"article_id": "9493432", "title": "MiLB／柯敬賢1A首度雙響砲 潘文輝中繼勝、林盛恩先發敗", "summary": "美職道奇隊1A的柯敬賢今天在對天使隊1A之戰，不僅單場4安打，更締造生涯首次雙響砲；另一場費城人1A與紅人1A交手，台灣...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933517.jpg&M=1&s=Y&x=0&y=0&sw=975&sh=650&exp=3600&sl=W&fw=360", "date": "2026-05-10 14:00"}, {"article_id": "9493329", "title": "世足賽／倒數一個月 政局動盪加門票天價蒙陰影", "summary": "2026年世界盃於11日進入倒數一個月。然而隨著票價飆漲、川普領導下的美國政治局勢緊繃，以及伊朗戰爭持續，各界的期待已轉...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933511.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-10 13:54"}, {"article_id": "9493422", "title": "NBA／雷霆又養出超級後衛？米契爾強勢崛起 300萬美元驚人投報率", "summary": "為了不想被亞歷山大（Shai Gilgeous-Alexander）予取予求，湖人在防守端特別針對性地執行包夾，確實也在系列賽3戰將他的場均得分壓在僅有21分，較例行賽整整少了10分，投籃和罰球次數也大幅降低，然而放大到整個戰局，卻無助於球隊平均輸分近20分的挫敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933485.jpg&M=1&s=Y&x=130&y=17&sw=1074&sh=716&exp=3600&sl=W&fw=360", "date": "2026-05-10 13:38"}, {"article_id": "9493425", "title": "網球／球后怎麼了？莎芭蓮卡羅馬賽第三輪就出局", "summary": "白俄羅斯「世界球后」莎芭蓮卡（Aryna Sabalenka）今年紅土賽季起步不順，馬德里女網賽8強提前落馬，在羅馬女網賽更是第三輪就意外敗給世界排名26的羅馬尼亞對手柯絲塔亞（Sorana Cirstea），決勝盤喊出傷停治療的球后坦言，身體狀況影響了實際表現。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933500.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-10 13:34"}, {"article_id": "9493330", "title": "MLB／大谷翔平連9戰未開轟 史奈爾復出首戰不敵勇士", "summary": "道奇隊33歲左投史奈爾（Blake Snell）本季初登板，今天在主場先發3局失5分，加上打線受到封鎖，全場6支安打只有勇士隊的一半，最後以2：7落敗，終止2連勝，兩隊在3連戰前兩戰扯平。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933351.jpg&M=1&s=Y&x=83&y=24&sw=1088&sh=725&exp=3600&sl=W&fw=360", "date": "2026-05-10 12:13"}, {"article_id": "9492481", "title": "NBA選秀機制將變！歷史會說話：神抽力壓機率 坦克未必是贏家", "summary": "NBA聯盟主席席佛（Adam Silver）為了改善近幾年擺爛求籤的風氣，已提出新版的選秀改革方案，若獲得各球隊同意，有可能會在2027年實施，而今年的NBA選秀機制將成為自2019年調整以來的末代選秀，在下週一即將揭曉的選秀抽籤前，我們可以回顧一下過去七年，有哪些值得參考的選秀密碼：", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34932195.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-10 12:04"}, {"article_id": "9493269", "title": "NBA／談里夫斯G2找裁判「開會」事件 聯盟副總裁今正式回應", "summary": "在雷霆G2以125：107戰勝湖人的比賽中，由於裁判在過程中做出多次爭議吹判，導致湖人隊新星「村曼巴」里夫斯（Austin Reaves）在賽後號召隊友向裁判開會，並進行激烈溝通，該事件隨即在網路引起熱議和討論。而NBA副總裁麥卡琴（Monty McCutchen）也在稍早回應此事，並給出個人見解。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933248.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-10 11:59"}, {"article_id": "9493186", "title": "NBA／回應「季後賽軟手」質疑聲浪 哈登強調：全力贏得比賽才重要", "summary": "騎士36歲老將後衛「大鬍子」哈登（James Harden）在先前對活塞G2表現差強人意，直至今天G3他才有回溫跡象，他全場攻下19分7助攻幫助騎士最終116：109擊敗活塞，驚險逃過「被聽牌」命運，哈登也在賽後採訪時，談到了外界稱他手部有傷的傳聞，以及回應那些過去批評他「在季後賽總是軟手」的言論。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933113.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-10 11:41"}, {"article_id": "9493233", "title": "MLB／釀酒人後援艾許比只投25局拿到7勝 賈吉、村上繼續並列全壘打王", "summary": "釀酒人隊今天在主場打到延長10局以4：3險勝洋基隊，後援投手艾許比（Aaron Ashby）投兩局失1分，開季7連勝，暫居大聯盟勝投王。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933196.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-10 11:16"}, {"article_id": "9493225", "title": "NBA／又是下半場被逆轉！湖人主場慘輸23分 雷霆3連勝聽牌", "summary": "湖人隊今天回到主場迎接第三戰，但和第二戰劇本相似，上半場打完「紫金軍團」都是領先一方，但第三節優勢盡失，遭衛冕軍雷霆隊逆轉且一口氣拉開比數，最終湖人在洛杉磯以108：131吞敗，西區第二輪系列賽陷入0：3落後的絕對劣勢。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933177.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-10 11:14"}, {"article_id": "9493168", "title": "MLB／李灝宇連4戰掛零掉到1成59 惠特場內全壘打讓老虎吞5連敗", "summary": "老虎隊作客堪薩斯市，今天對皇家隊進行3連戰第2戰，台灣好手李灝宇未排進先發打線，8局上代打沒有表現，老虎終場1：5落敗，本季第2次吞下5連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933125.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-10 10:37"}, {"article_id": "9493102", "title": "NBA／不是詹皇、里夫斯！雷霆主帥談團隊防守首要針對目標", "summary": "湖人、雷霆次輪賽事移至洛杉磯主場舉行，目前雷霆系列賽取得2：0領先優勢。在稍早G3開打前，雷霆隊總教練戴格諾（Mark Daigneault）在記者會上明確表示，他們團隊防守的首要限制目標不是湖人隊中巨星「詹皇」詹姆斯（LeBron James）、里夫斯（Austin Reaves）等人，而是湖人中鋒艾頓（Deandre Ayton）。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933012.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-05-10 10:27"}, {"article_id": "9492996", "title": "NBA／騎士擋下活塞大反撲成功續命 哈登：重點是保持冷靜", "summary": "克里夫蘭騎士憑藉米契爾（Donovan Mitchell）狂砍35分，以及哈登（James Harden）終場前的精彩表現，今天以116比109擊敗底特律活塞，在NBA東區準決賽第3戰搶下關鍵勝利。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933205.jpg&M=1&s=Y&x=182&y=0&sw=1098&sh=732&exp=3600&sl=W&fw=360", "date": "2026-05-10 10:00"}, {"article_id": "9493067", "title": "NBA／甩低潮！哈登關鍵三分彈澆熄活塞反撲 騎士G3開胡", "summary": "系列賽前兩戰表現平平，「大鬍子」哈登（James Harden）今天東區第二輪第3戰展現球星價值，最後90秒完成3記關鍵進球，包括終場前25秒的後撤步三分球，為騎士隊甩開龍頭活塞隊緊追，最終以116：109守護主場，系列賽追到1：2。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34932931.jpg&M=1&s=Y&x=124&y=58&sw=1119&sh=746&exp=3600&sl=W&fw=360", "date": "2026-05-10 09:40"}, {"article_id": "9493066", "title": "MLB／男孩斷了一隻手臂也要丟回全壘打球 下一秒變委屈哭臉", "summary": "即使是斷了一隻手的小男孩，也無法阻止丟球的慾望。馬林魚隊主場今天迎戰國民之戰場邊出現有趣一幕，一位坐在外野上層看台的父親興奮接到全壘打，隨後將球給了兒子，而這位一手還打著石膏的男孩，拿到球的第一反應竟是丟回場內，當鏡頭下一秒再照到他時已是一張委屈巴巴的哭臉。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34932926.jpg&M=1&s=Y&x=0&y=52&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-10 09:39"}, {"article_id": "9493065", "title": "NBA／跌破眼鏡？柯爾和勇士再續約兩年 邁入第13個執教賽季", "summary": "經過三周的討論商議，勇士隊決定和柯爾（Steve Kerr）再續前緣，這位60歲教頭答應球團的兩年合約，第13個總教練執教賽季仍在勇士開啟。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34932884.jpg&M=1&s=Y&x=141&y=9&sw=1065&sh=710&exp=3600&sl=W&fw=360", "date": "2026-05-10 09:39"}, {"article_id": "9493021", "title": "MLB／鄧愷威當太空人投手工具人 11日再扛先發出戰紅人", "summary": "台灣投手鄧愷威當太空人隊的投手工具人，明天將演出本季第二度先發，於台灣時間凌晨1點40分出戰紅人隊，對手則由左投亞柏特（Andrew Abbott）先發。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34932822.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-05-10 08:59"}, {"article_id": "9493015", "title": "桌球世團賽／4強賽不敵日本 中華男團奪銅追平最佳", "summary": "勇闖2026年倫敦世界團體桌球錦標賽男子4強的中華隊，今天凌晨對決日本，領銜的「一哥」林昀儒碰世界排名第3的老對手張本智和先搶下首局，可惜錯過一次局點機會，最終在