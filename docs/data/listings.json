il": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985587.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-27 10:40"}, {"article_id": "9528140", "title": "日媒狂拋「川普挺高市」劇本 川習會後大內宣焦慮現形", "summary": "川習會曲終人散，讀賣新聞與金融時報頻爆「內幕」，包括讀賣新聞引述「日本政府消息人士」，稱中國大陸國家主席習近平在川習會上點名批評日本首相高市早苗與我國總統賴清德。川普並未附和中方說法，反而替高市辯護。金融時報更指出習近平在川普面前激動批評高市，遭北京外交部發言人毛寧一句「報道（導）與中方掌握的情況不符」否認。耐人尋味的是，美方乃至於川普本人迄今保持沉默。內幕報導的背後，其實還有內情。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/26/34984324.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 10:30"}, {"article_id": "9528130", "title": "川普10%全球關稅不退場？美貿易代表：7月到期後可能重新起徵", "summary": "美國貿易代表葛里爾（Jamieson Greer）周二（26日）表示，美國總統川普實施的10%全球關稅在7月到期後，仍可能再次起徵。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985509.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 10:30"}, {"article_id": "9528017", "title": "三星工會投票通過薪酬協議 全球晶片供應鏈驚險避開大亂", "summary": "三星電子公司最大工會已表決通過暫定的薪酬協議，晶片部門員工將可平均獲得約34萬美元獎金（約台幣1,070萬元），避免了一場可能擾亂全球晶片供應的罷工行動。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985335.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 09:57"}, {"article_id": "9528011", "title": "面臨中國後發先至壓力！NASA拚2032年前建半永久月面基地 專家潑冷水", "summary": "美國太空總署（NASA）26日公布月面基地建設計畫部分內容，包括機器登月器、跳躍式無人機與載具細節。亞馬遜創辦人貝佐斯旗下的藍色起源（Blue Origin）也是獲選參與建造的多家公司之一。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985324.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-05-27 09:55"}, {"article_id": "9527982", "title": "三星電子薪資協商拍板！工會73.7%贊成率通過暫定協議", "summary": "韓聯社27日報導，三星電子工會會員針對勞資雙方敲定的薪資協商暫定協議案進行投票，最終以超過70%的贊成率通過。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985288.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 09:48"}, {"article_id": "9527911", "title": "印度高溫47.6熱死人 雞蛋落地熟了", "summary": "印度氣溫連日飆高，北方邦和馬哈拉什特拉邦25日最高測得攝氏47.6度，生雞蛋打在地上，3分鐘就會轉熟，印度南部、東南部已...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985275.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 09:46"}, {"article_id": "9527947", "title": "告別曼城！傳奇教頭瓜迪奧拉十年謝幕，為足壇留下哪些遺產？", "summary": "執教英格蘭足球超級聯賽（Premier League，以下簡稱英超）俱樂部曼城（Manchester City）長達10年的西班牙名帥瓜迪奧拉（Pep Guardiola），在英超2025-26賽季最後一輪比賽前宣布，他將在本賽季結束後卸下曼城教鞭。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/26/34983889.jpg&M=1&s=Y&x=0&y=40&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 09:35"}, {"article_id": "9527943", "title": "當啦啦隊成為本體？從草根應援到大女團時代的韓國職棒歌舞進化", "summary": "1998年，韓國職棒的球場應援也跟中華職棒一樣處在敲鑼打鼓、人聲應援的階段，但韓職的女子啦啦隊建置時間較早，在1998年的雙鈴突擊者隊時期就已經有了。不過最開始的韓職啦啦隊，是身著傳統儀隊制服、手持彩球、大跳康康舞，偏向競技啦啦隊的樣貌。以競技應援為主，講究團隊精神，比較像是球場的背景，沒有個人風格和偶像特色。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/26/34983942.jpg&M=1&s=Y&x=0&y=38&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 09:34"}, {"article_id": "9527940", "title": "家庭主婦重返職場有多難？日本稅制「年收三道牆」如何影響女性職涯選擇", "summary": "在〈日本女性權益很低落？制度設計如何讓家庭主婦成為「理性」選擇〉這篇文章中，我曾指出日本社會中「成為家庭主婦」之所以能被視為一種理性的選擇，並非單純源於個人偏好或文化價值，而是與制度設計密切相關。有讀者進一步提問：所謂「稅制、社會保險與配偶制度的實質獎勵」究竟是如何運作的？若要理解這一點，與其從抽象制度的解說入手，不如先從一個具體情境開始體驗日本女性的生涯選擇。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34972983.jpg&M=1&s=Y&x=131&y=181&sw=1149&sh=767&exp=3600&sl=W&fw=360", "date": "2026-05-27 09:32"}, {"article_id": "9527870", "title": "北約真要被「放生」？德媒曝美國恐撤出核潛 轟炸機戰機驅逐艦全縮水", "summary": "德國媒體《明鏡》（Spiegel）報導，美國預計將減少危機期間供北約（NATO）盟友使用的轟炸機、戰鬥機與軍艦。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985127.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 08:52"}, {"article_id": "9526304", "title": "吃光才問？奧客怒轟餐點含甲殼類沒說 店員反擊：看不出你會過敏", "summary": "餐飲業或其他必須面對客人的服務業人員，需時常面臨各種突發狀況，有時連「食物過敏」都能成為奧客刁難的藉口。一名住在西日本、從事外食餐飲服務業的30歲左右男性，在網路論壇上分享了他遇上奧客的無奈經歷。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/26/34983918.png&M=1&s=Y&x=0&y=0&sw=1076&sh=717&exp=3600&sl=W&fw=360", "date": "2026-05-27 08:45"}, {"article_id": "9527859", "title": "記憶體好旺！SK海力士「市值衝破1兆美元」跟進美光與三星 還有一大利多", "summary": "SK海力士股價今天盤初一度大漲11%，帶動公司市值突破1兆美元，顯示投資人對該公司做為AI先進記憶體供應龍頭地位的信心。這也使得南韓成為亞洲國家中，唯一擁有兩家「1兆美元市值」企業的國家。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985110.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 08:41"}, {"article_id": "9527855", "title": "川普速報／美進口中國貨降稅啟動 攻伊朗星鏈發戰爭財", "summary": "編按：美國總統川普上任以來，掀起全球「川普風暴」。聯合報數位版即日起每周一至周五，由資深編譯搭配AI協作，一早為讀者編按精選川普最新發言，快速整理對全球經貿政策與國際局勢的影響。\n\n．川普的對中與對伊朗談判進入「細算得失」階段。美中關稅方面，華府準備啟動公開徵詢意見程序，決定哪些中國商品可納入降稅或免稅清單，但美國貿易代表葛里爾同時強調，美方仍會保留對中國關稅，且稅率可能長期高於其他國家。伊朗方面，德黑蘭想透過談判換取經濟紓困，卻不願在核計畫上讓步到足以讓川普宣稱勝利。路透披露，SpaceX在伊朗戰爭期間調高Starlink費用，五角大廈雖惱怒最後仍埋單，凸顯美軍戰時通訊愈依賴私人企業，議價空間就愈受限制。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985102.png&M=1&s=Y&x=0&y=0&sw=930&sh=620&exp=3600&sl=W&fw=360", "date": "2026-05-27 08:38"}, {"article_id": "9527822", "title": "女子1小時拒絕75次！韓國法院仍判性侵脫罪：受害人未積極抵抗", "summary": "韓國法院判決一名女性明確拒絕性行為75次仍然無罪，理由是受害者未「積極抵抗」。人權團體批評此判決無視女性性自主權，已向憲法裁判所提起審查，要求重新檢討性暴力基準。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985088.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 08:26"}, {"article_id": "9527818", "title": "油價重返100美元！分析師警告：全球能源市場恐已回不了頭", "summary": "美軍再度空襲伊朗目標後，市場對美伊和談的期待再度受挫，國際油價周二重返每桶100美元。分析人士警告，即使未來達成和平協議，全球能源市場恐怕也已跨過「難以逆轉的臨界點」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985052.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 08:06"}, {"article_id": "9527813", "title": "影／美國華盛頓州造紙廠化學槽突發內爆！已有人員死亡 現場照片曝光", "summary": "美國華盛頓州朗維尤（Longview）一家造紙廠26日發生化學槽破裂事故，緊急救援人員目前正確認死亡人數。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985046.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 08:02"}, {"article_id": "9527812", "title": "線上會議成新職災？日顧問一針見血「問題在爛會議」", "summary": "拜現代科技之「賜」，職場形態與以前大不相同，最常被討論的是下班以後回覆主管工作訊息，算不算加班。其實在疫情以後，出現新的職災，不只基層員工、主管也受害，那就是會議通膨。日本人氣企業顧問橫山信弘說，線上會議的便利性讓會議數量無限膨脹。但是，科技真的有錯嗎？", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/26/34981705.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 08:00"}, {"article_id": "9527800", "title": "聯電ADR狂飆15% 日月光也漲近12% 台積電隨費半走揚", "summary": "台股ADR周二（27日） 大多上漲，台積電ADR收盤上漲1.93%，報每股412.32美元，收盤最新價格換算並折合新台幣後為每股2,592.75，較台北交易股票溢價率14.22%。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985027.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-27 07:37"}, {"article_id": "9527788", "title": "美伊達協議？Piper Sandler潑冷水：荷莫茲海峽恐再封數月 油價飆新高", "summary": "Piper Sandler並不相信美伊即將達成協議的說法，該投資銀行向客戶表示，荷莫茲海峽短期內依然將關閉，油價將再創下新高。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985020.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 07:16"}, {"article_id": "9527786", "title": "美股收盤／標普500、那指又創新高 美光市值破兆帶動費半狂飆逾5%", "summary": "美股標普500指數和那斯達克指數周二（26日）收漲並創歷史新高，費城半導體指數同樣創新高且大漲超過5%，AI帶來的樂觀情緒抵銷市場對中東和平談判的擔憂，儘管美伊爆發衝突令停火面臨考驗，但投資人仍看好雙方接近達成協議重啟荷莫茲海峽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985017.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 07:10"}, {"article_id": "9527772", "title": "華盛頓州紙漿廠化學槽內爆 至少10傷、死亡人數不明", "summary": "美國華盛頓州今天傳出一座紙漿廠的化學品儲槽內爆並破裂，當局證實至少10人受傷，包括一名趕赴現場救災的消防隊員。當局暫未透...", "thumbnail": "https: