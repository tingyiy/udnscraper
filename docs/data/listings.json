ttps://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34991914.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&sl=W&fw=360", "date": "2026-05-29 02:18"}, {"article_id": "9532273", "title": "南韓7月可能升息1碼", "summary": "南韓央行28日維持利率不變，但首次主持政策會議的新任總裁申鉉松，在會議後的記者會上盡顯鷹姿，他說，考量到金融穩定疑慮加劇，加上中東危機引發的通膨壓力，確有必要調高利率。彭博經濟研究預計該央行最快將在7月升息1碼。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_7.jpg", "date": "2026-05-29 02:17"}, {"article_id": "9532275", "title": "川普擬注資民營無人機業", "summary": "川普政府傳出正與幾家美國無人機業者洽談資金合作協議，要協助提升國內的無人機製造能力並降低成本。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_6.jpg", "date": "2026-05-29 02:17"}, {"article_id": "9532298", "title": "Meta AI機器人推付費訂閱制 訂每月7.99、19.99美元兩種方案", "summary": "Meta首度向消費者銷售Meta AI聊天機器人訂閱服務，是該公司建立人工智慧（AI）商業模式的一大步，有助抵銷在AI領域投入的數千億美元成本。該公司執行長祖克柏也說，若建置過多運算資源，可能進入雲端運算市場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992174.png&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-05-29 02:16"}, {"article_id": "9532300", "title": "財測看出端倪 惠普仍在應對記憶體漲價挑戰", "summary": "惠普（HP）上季營收獲利均超越市場預期，但其財測顯示，本季仍在應對記憶體晶片價格大幅上漲帶來的挑戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_0.jpg", "date": "2026-05-29 02:15"}, {"article_id": "9532302", "title": "亞馬遜晶片奪單60億美元", "summary": "軟體公司Snowflake和亞馬遜（Amazon）旗下網路服務事業AWS簽約，成為亞馬遜最新的晶片客戶，以因應AI代理持續擴張所帶來的運算硬體需求。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_5.jpg", "date": "2026-05-29 02:14"}, {"article_id": "9532305", "title": "法國新創Mistral AI 擬設計自研晶片", "summary": "法國Mistral AI公司正探索設計自家人工智慧（AI）晶片，將來可能發展自研晶片，還打算朝應用實體AI技術的先進製造領域擴張，已和空中巴士、寶馬汽車（BMW）等新客戶敲定協議。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_6.jpg", "date": "2026-05-29 02:12"}, {"article_id": "9532407", "title": "亞太軍備 英智庫憂：美中核風險升級 兩國軍方無「護欄」", "summary": "二○二六年香格里拉對話將於廿九日至卅一日在新加坡舉行。主辦單位、英國防務研究機構「國際戰略研究所」（ＩＩＳＳ）廿八日發布戰略評估指出，美中若因台灣爆發衝突，恐將面臨核升級風險，雙方軍隊可能鎖定彼此的指揮與通訊樞紐，展開大規模軍事行動。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992151.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 01:28"}, {"article_id": "9532265", "title": "中東情勢丕變 油價漲幅收斂", "summary": "兩名美國官員告訴新聞媒體Axios，美伊談判代表已就一份為期60天的合作備忘錄（MOU）建立協議，將是自這場戰爭爆發以來最重大的外交突破，但川普尚未給予最終批准。消息一出，油價漲幅一度從漲2%收斂至僅漲0.2%，隨後又震盪走高，漲約1%。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846493.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 01:13"}, {"article_id": "9532266", "title": "川普威脅阿曼 施壓古巴", "summary": "美國總統川普27日被問及有關阿曼與伊朗擬共同管理荷莫茲海峽的報導時，語出驚人威脅，若阿曼參與，美國可能「炸掉」阿曼。另據美國媒體Axios報導，川普政府正加速施壓古巴，準備因應古巴極權政府最快夏季垮台的情境。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_4.jpg", "date": "2026-05-29 01:09"}, {"article_id": "9532271", "title": "美通膨增溫 Fed估按兵不動", "summary": "美國通膨持續升溫，個人消費支出（PCE）通膨指數較去年同期上升3.8%，是2023年5月以來最大升幅，且美國第1季國內生產毛額（GDP）遭下修，未如初估值強勁，反映油價上漲的不利影響，但尚未重創經濟。經濟學者預料聯準會（Fed）6月將按兵不動，繼續觀望中東戰爭及經濟情勢的後續變化。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992178.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 00:10"}, {"article_id": "9532252", "title": "擺脫對美依賴 加拿大買瑞典預警機不買波音", "summary": "加拿大總理卡尼廿七日宣布，將向瑞典紳寶集團（Saab）採購預警機，而非美國波音。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34991931.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 00:00"}, {"article_id": "9532251", "title": "劍指中國？日菲峰會關係升級 邁向「準同盟」關係", "summary": "正在國是訪日的菲律賓總統馬可仕廿八日和東道主日本首相高市早苗舉行峰會。高市在會後共同記者會中說，日菲關係將升級至「全面戰略夥伴關係」；兩國並將正式啟動旨在共享安全相關機密情資的軍事情報保護協定（ＧＳＯＭＩＡ）談判。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34991883.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&sl=W&fw=360", "date": "2026-05-29 00:00"}, {"article_id": "9532250", "title": "智庫：美對伊戰爭 導致關鍵武器庫存、軍費預算都受衝擊", "summary": "根據美國智庫戰略與國際研究中心（ＣＳＩＳ）最新報告，美國二月底對伊朗開戰後，美軍大量消耗三種關鍵武器系統。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34991922.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 00:00"}, {"article_id": "9532249", "title": "48小時內2度交火...美空襲伊無人機設施 伊炸美基地報復", "summary": "美伊邊打邊談，自廿五日以來的四十八小時內兩度交火。美軍廿八日凌晨空襲伊朗南部港市阿巴斯一帶後，伊朗伊斯蘭革命衛隊（ＩＲＧＣ）也對科威特一座美國空軍基地發動報復攻擊。該港也是伊朗在波斯灣及荷莫茲海峽（下稱海峽）的重要海軍基地。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34991917.jpg&M=1&s=Y&x=0&y=0&sw=1082&sh=721&exp=3600&sl=W&fw=360", "date": "2026-05-29 00:00"}, {"article_id": "9532247", "title": "不滿荷莫茲海峽擬收過路費 川普警告阿曼：站隊伊朗就等著挨炸", "summary": "美國總統川普廿七日警告中東國家阿曼別在控制荷莫茲海峽（下稱海峽）上與伊朗站在一起，否則將被美軍「炸掉」；他同日提到，自己不放心中國大陸或俄羅斯取得伊朗濃縮鈾。一旁的美國國務卿魯比歐也說，接下來幾小時至幾天內，「我們就能看出（美伊終戰協議）是否有所進展」。巴基斯坦外長達爾預定廿九日訪美，與魯比歐會面。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34991881.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=851&exp=3600&sl=W&fw=360", "date": "2026-05-29 00:00"}, {"article_id": "9532286", "title": "英國生育率下探1930年代來新低 但仍是台灣的兩倍...", "summary": "根據最新數據，英國總生育率已降至每名女性一生平均生育1.39名子女，寫1930年代有紀錄以來新低，不過，仍比台灣的0.695多一倍，這也凸顯台灣的人口危機有多嚴峻。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34991919.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-28 23:22"}]}, {"name": "中東戰火連綿", "articles": [{"article_id": "9532244", "title": "美媒：美伊達成終戰諒解備忘錄協議 但川普需幾天考慮", "date": "2026-05-28 23:07", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34991879.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9532247", "title": "不滿荷莫茲海峽擬收過路費 川普警告阿曼：站隊伊朗就等著挨炸", "date": "2026-05-29 00:00", "thumbnail": "https://pgw.udn.com.tw/gw/