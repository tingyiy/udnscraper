date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34837873.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9419212", "title": "經典賽／台灣血脈一線牽 「費仔」用球棒為母親故鄉而戰", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/02/34822502.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9427576", "title": "中職／莫忘日本火腿出走教訓 南市府應修補裂痕與統一共榮", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/07/34834270.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9435800", "title": "中職／岳政華傷癒歸隊仍在熱機 平野惠一： 希望他盡快回前段棒次", "summary": "中信兄弟岳政華今年春訓後段拉傷腳，沒能趕上開季，直到昨天歸隊被登錄一軍，且直接先發上陣，首打席就敲出安打，但之後三打席都遭到三振，岳政華坦言，是自己好球帶設定沒做好。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846370.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-11 17:50"}, {"article_id": "9435690", "title": "無人機足球接軌國際 台灣首座FIDA標準場地啟用", "summary": "中華無人機競技運動協會與華興中學今天正式合作，啟用全國首座FIDA40 Class無人機足球標準賽制場地，期待未來培養出...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846357.jpg&M=1&s=Y&x=74&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-11 17:35"}, {"article_id": "9435782", "title": "影／林志傑引退檸檬直呼不想今天到來 韓援三本柱齊喊「球給志傑」", "summary": "台北富邦勇士今明兩天在台北小巨蛋舉行林志傑引退主題周活動，在首日賽事中就帶給球迷絕佳聲光體驗，包括今天賽前Fubon Angels也帶來精彩表現，在賽前受訪時包括檸檬、秀秀子、慈妹以及韓援三本柱李雅英、南珉貞、李晧禎也分別談到對林志傑的印象，其中從台啤「態度」時期就開始關注林志傑的檸檬就表示，很不希望今天的到來。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846348.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-11 17:29"}, {"article_id": "9435755", "title": "中職／黎克先發壓制力不足調往中繼 平野惠一：強化牛棚", "summary": "中信兄弟新洋投黎克開季連兩場先發投不滿五局，防禦率破10，本周被調往中繼，兄弟總教練平野惠一證實，目前就會先將他安排在中繼，強化球隊牛棚戰力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846310.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=852&exp=3600&sl=W&fw=360", "date": "2026-04-11 17:08"}, {"article_id": "9435726", "title": "MLB／孟西「三響砲」締多項紀錄！羅伯茲讚：相信自己", "summary": "洛杉磯道奇今天在主場迎戰德州遊騎兵，靠著孟西（Max Muncy）單場3發全壘打、包括9局下兩出局時的再見陽春砲，終場以8比7逆轉勝出，為球隊搶下系列賽首勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846292.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-11 17:07"}, {"article_id": "9435731", "title": "PLG／引退賽一定讓「野獸」跑起來 許晉哲分析林志傑超人氣主因", "summary": "台北富邦勇士今天在台北小巨蛋舉行「野獸」林志傑引退主題周，兩日賽事將吸引近2萬7000萬名球迷進場，富邦勇士總教練許晉哲在今天賽前表示，將會盡量讓林志傑在這兩場比賽中以最好表現呈現給觀眾，一定會讓「野獸」跑起來。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846295.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-11 16:45"}, {"article_id": "9435728", "title": "韓職／王彥程繳6局失1分優質先發 牛棚放火無緣第三勝", "summary": "韓職韓華鷹隊台灣左投王彥程，今天在主場對戰起亞虎隊力拚三連勝，繳出6局失1分的優質先發表現，在球隊4：1領先時退場，但牛棚放火搞砸他的勝投，韓華隊終場也以5：6遭逆轉吞敗，王彥程無關勝敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846296.jpg&M=1&s=Y&x=0&y=78&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-11 16:43"}, {"article_id": "9435719", "title": "韓職／王彥程好投但勝投被牛棚搞飛！韓媒盛讚：台灣王子", "summary": "韓職韓華鷹隊台灣左投王彥程今天面對起亞虎隊，再度繳出優質先發，主投6局只失1分，好表現被韓媒封為「台灣王子」。不過韓華牛棚8局上放火，終場起亞虎以6：5逆轉勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846276.jpg&M=1&s=Y&x=217&y=57&sw=1063&sh=755&exp=3600&sl=W&fw=360", "date": "2026-04-11 16:40"}, {"article_id": "9435696", "title": "NBA／擺爛爵士竟狂勝灰熊 板凳暴徒攜手締造史詩級大三元", "summary": "爵士在主場以147比101大勝灰熊，不僅寫下本季少見的大比分勝利，同時也誕生一項前所未見的NBA歷史紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846234.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-11 16:20"}, {"article_id": "9435681", "title": "NBA／湖人優勢到手卻成箭靶？瑞迪克嘆：大家都想打我們", "summary": "隨著湖人今天以101比73擊敗太陽，加上火箭敗給灰狼後，湖人將在季後賽第一輪擁有主場優勢。對此，湖人總教練瑞迪克（JJ Redick）對球隊處境相當清楚，直言外界普遍將湖人視為理想對手。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846222.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-11 16:16"}, {"article_id": "9435668", "title": "MLB／三響砲登道奇隊史全壘打第6 孟西：我沒辦法像大谷投10K", "summary": "道奇隊今天舉辦「大谷翔平搖頭娃娃日」，不過風采全被隊友孟西（Max Muncy）搶去，上演單場三響砲，包含再見全壘打。孟西賽後受訪時笑說：「我還沒辦法單場10K。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846201.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-11 15:45"}, {"article_id": "9435649", "title": "NBA／雙強主力關機輪休17人！金塊豪取11連勝 創約柯奇時代最佳", "summary": "金塊與衛冕冠軍雷霆之戰上演「輪休大對決」，雷霆輪休亞歷山大（Shai Gilgeous-Alexander）等10位球員，金塊則是輪休約柯奇（Nikola Jokic）與穆雷（Jamal Murray）等7位球員，雙方合計17人缺席。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846153.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-11 15:21"}, {"article_id": "9435633", "title": "韓職／王彥程6局失1分連兩戰優質先發 有望收下三連勝", "summary": "效力於韓職韓華鷹隊的台灣左投王彥程，本季第三場先發，今天在主場對上起亞虎隊，主投6局失1分，用85球，被敲出6支安打，送出5次三振，沒有保送，退場時韓華4：1領先，王彥程有望收下本季第3勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846136.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-11 15:01"}, {"article_id": "9435613", "title": "MLB／感動重返花旗球場！麥尼爾情感湧現一度「哽咽」", "summary": "運動家內野手麥尼爾（Jeff McNeil）今日首度以客隊身分重返花旗球場，面對效力多年的老東家大都會，在全場36,349名球迷起立致敬下，他一度情緒湧上心頭，坦言「差點哽咽」，最終也幫助球隊以4：0完封大都會，為這個特別夜晚畫下句點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846090.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-11 14:59"}, {"article_id": "9435618", "title": "中職／裁判誤判網友「出征」成晉社群 球迷回嗆：不要來敗人品啦", "summary": "中華職棒昨天出現誤判，有現場球迷拍攝到，樂天桃猿隊外野手成晉處理飛球，球疑似先落地才放進手套，結果裁判判定接殺出局，由於中信兄弟隊未提出挑戰，形成出局數。沒想到有許多不理性球迷出征成晉，也有不少球迷反嗆回去。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846103.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-11 14:54"}, {"article_id": "9435582", "title": "NBA／詹姆斯生涯助攻數創里程碑 湖人連勝搶下首輪主場優勢", "summary": "美國職籃洛杉磯湖人球星詹姆斯（LeBron James），今天晚間主場出戰鳳凰城太陽時，憑著第1節的第2次助攻，順利成為...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846092.jpg&M=1&s=Y&x=267&y=12&sw=1013&sh=675&exp=3600&sl=W&fw=360", "date": "2026-04-11 14:50"}, {"article_id": "9435594", "title": "NBA／杜蘭特超越馬龍創史上第一紀錄 火箭終結8連勝失主場優勢", "summary": "灰狼與火箭兩支確定進入季後賽的西區勁旅正面交鋒，雙方上演一場激烈對攻戰，最終靠著愛德華（Anthony Edwards）在關鍵時刻的致命三分球，灰狼以136比132力退火箭，一舉終止對手8連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846059.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-11 14:46"}, {"article_id": "9435537", "title": "NBA／馬傑森後又一個體壇網路梗消失！勇士波傑姆斯基生涯首次30分", "summary": "勇士隊今天以118：124輸給西區墊底的國王隊，這場看似無關緊要的比賽，卻成為許多球迷心中難忘的回憶，因為波傑姆斯基（Brandin Podziemski）生涯首度得分達30分，又一個知名網路梗被消滅。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34845904.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-11 13:38"}, {"article_id": "9435515", "title": "MLB／今井達也0.1局5四死球寫旅美最慘 日網友：根本藤浪再現", "summary": "休士頓太空人日籍投手今井達也前一戰拿下大聯盟首勝，今天客場對戰西雅圖水手冀望乘勝追擊，不料卻在首局陷入嚴重控球失準的巨大麻煩，僅投0.1局就用掉37球退場，單局狂送5次四死球包含暴投一共失掉3分。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34845835.jpg&M=1&s=Y&x=72&y=15&sw=881&sh=587&exp=3600&sl=W&fw=360", "date": "2026-04-11 13:30"}, {"article_id": "9435498", "title": "MLB／大谷搖頭娃娃之夜只刷到1安 孟西三響砲+再見轟挺道奇率先10勝", "summary": "大谷翔平的搖頭娃娃之夜，今天4打數敲1安打、另有1次故意四壞保送，推進連44場上壘，獨占日本球員紀錄，但在今天只是公務員般的存在，道奇打線有其他更耀眼的人，孟西（Max Muncy）單場三響砲，包括9局下的再見陽春砲，幫助道奇以8：7擊敗遊騎兵隊，成為大聯盟本季第一支10勝球隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34845819.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-11 13:07"}, {"article_id": "9435451", "title": "MLB／否認「鎖喉衝突」！麥尼爾仍盛讚林多：史上最好游擊手之一", "summary": "運動家內野手麥尼爾（Jeff McNeil）今日首度以客隊身分面對前東家大都會。針對過去傳出與前隊友林多（Francisco Lindor）的衝突事件，麥尼爾也在賽前親自出面澄清，否認外界所描述的激烈對立。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34845735.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-11 12:58"}, {"article_id": "9435399", "title": "NBA／回擊「罰球製造機」標籤！SGA：為了成為最強會做任何事", "summary": "雷霆當家球星「SGA」亞歷山大（Shai Gilgeous-Alexander）本季持續打出MVP等級表現，不僅帶領球隊連續第三年拿下西區第1種子，近期更正面回應外界對其「罰球製造機」的質疑。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34845677.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-11 12:19"}, {"article_id": "9435357", "title": "MLB／李政厚本季首轟終於出爐！韓媒讚：一成打者大爆發", "summary": "舊金山巨人隊韓籍外野手李政厚開季陷入大低潮，開季前13場比賽0轟，今天在金鶯隊主場終於扛出本季首轟，幫助巨人以6：3擊敗金鶯。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34845616.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-11 12:00"}, {"article_id": "9435368", "title": "NBA／26分鐘就飆40分達65場門檻 溫班亞瑪：像完成既定任務", "summary": "馬刺溫班亞瑪（Victor Wembanyama）在今天與獨行俠之戰，僅上場26分鐘就拿下40分、13籃板、5助攻的全能數據，幫助馬刺以139：120輕取獨行俠，並在本場比賽後達到出賽65場的競爭個人獎項最低門檻。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34845644.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-11 11:58"}]}, {"name": "棒球", "articles": [{"article_id": "9435755", "title": "中職／黎克先發壓制力不足調往中繼 平野惠一：強化牛棚", "date": "2026-04-11 17:08", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846310.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=852&exp=3600&w=300"}, {"article_id": "9435618", "title": "中職／裁判誤判網友「出征」成晉社群 球迷回嗆：不要來敗人品啦", "date": "2026-04-11 14:54", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/11/34846103.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9435719", "title": "韓職／王彥程好投但勝投被