w/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35066229.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9581615"}, {"article_id": "9581639", "title": "愛德華孤掌難鳴需要二號球星？灰狼或許不要冒險交易會更好", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35066281.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9581639"}, {"article_id": "9580863", "title": "世足攻略／阿根廷爭龍頭 梅西挑戰進球王紀錄", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065236.jpg&M=1&s=Y&x=0&y=0&sw=1247&sh=831&exp=3600&w=300", "link": "/news/story/122629/9580863"}, {"article_id": "9579234", "title": "中職／天花板高很多時候只是想像！葉君璋評選秀大物一針見血", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062720.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9579234"}]}, {"name": "最新文章", "articles": [{"article_id": "9584392", "title": "世足賽／刷新歷史…梅西累計18球 登基世足進球王", "summary": "世界盃足球賽小組賽昨天上演歷史性一幕，衛冕軍阿根廷對決奧地利之戰，當家球星梅西在開賽之初意外射失禁區罰球，但他隨後展現強大心理素質「梅開二度」，率領阿根廷二比○獲勝，不僅奪下二連勝提前挺進卅二強淘汰賽，生涯在世足賽累積十八顆進球，更超越德國傳奇前鋒克洛澤，獨居史上進球王寶座。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070672.jpg&M=1&s=Y&x=44&y=0&sw=1135&sh=756&exp=3600&sl=W&fw=360", "date": "2026-06-24 00:02", "link": "/news/story/123107/9584392"}, {"article_id": "9584391", "title": "世足賽／姆巴佩、梅西、哈蘭德 卡位金靴", "summary": "今年世足賽三大射手梅西、姆巴佩、哈蘭德昨天再度上演進球大戰，都繳出「梅開二度」的成績單，也讓今年金靴獎的競爭提前進入白熱化階段，是否有人能打破單屆個人最多十三球紀錄，成為各界討論焦點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35070269.jpg&M=2&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 00:01", "link": "/news/story/123107/9584391"}, {"article_id": "9584397", "title": "世足賽／哈蘭德快攻奏效 挪威晉級", "summary": "挪威暌違廿八年重返世足賽舞台，熱情球迷將「維京戰船」的慶祝儀式划進北美，挪威當家球星哈蘭德昨天「梅開二度」，以三比二擊敗塞內加爾後，全隊連同教練團更坐在球場草地上做出划船慶祝動作，慶祝以二連勝之姿提前晉級卅二強淘汰賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070663.jpg&M=1&s=Y&x=0&y=54&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 00:01", "link": "/news/story/123107/9584397"}, {"article_id": "9584147", "title": "中職／兄弟近5戰4勝拉尾盤 上半季猿象爐主之爭還有得瞧", "summary": "中信兄弟隊鄰近上半季尾聲拉尾盤，今天狂敲15支安打，進攻8局有6局得分，終場以6：3擊敗富邦悍將隊。兄弟近5戰4勝，加上樂天桃猿隊吞下5連敗，雙方勝差縮小到1.5場，誰是上半季爐主還有得瞧。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35070081.jpg&M=1&s=Y&x=0&y=0&sw=1111&sh=741&exp=3600&sl=W&fw=360", "date": "2026-06-23 21:46", "link": "/news/story/7001/9584147"}, {"article_id": "9584095", "title": "中職／桃猿「開箱」日籍洋投中大獎也沒用 打線0分吞本季最長5連敗", "summary": "樂天桃猿隊「開箱」二軍核爆的日籍洋投榊原元稀，飆出令人刮目相看的6局失1分好投，然而打線0分支援，終場以0：1不敵統一隊，猿隊吞下本季最長的5連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069997.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 21:12", "link": "/news/story/7001/9584095"}, {"article_id": "9584025", "title": "世足賽／紅魔鬼世足之路顛簸 比利時媒體化身數學老師算晉級", "summary": "比利時在今年世界盃的首勝仍未開張，連帶使得球迷開始擔心晉級之路。比利時媒體化身數學老師，逐一分析接下來晉級淘汰賽或是小組...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065620.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 20:47", "link": "/news/story/123107/9584025"}, {"article_id": "9583913", "title": "世足賽／多元族裔改寫世足樣貌 1/4球員非本土出生親兄弟鬩牆", "summary": "瑞典球員阿亞瑞世界盃首秀開賽7分鐘就進球，但是出於對父親祖國突尼西亞的尊重，他舉起雙手帶著歉意，而非熱烈慶祝", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/15/35045613.jpg&M=1&s=Y&x=0&y=30&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 20:36", "link": "/news/story/123107/9583913"}, {"article_id": "9583818", "title": "中職／郭李建夫發掘潛力 開南大學陳趙羿勳轉投手從抗拒到自信", "summary": "開南大學陳趙羿勳野手轉投手雖曾抗拒，但總教練郭李建夫看見他的潛力、耐心調教，陳趙羿勳也慢慢投出心得，目前最快球速可投到1...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069915.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-23 20:17", "link": "/news/story/7001/9583818"}, {"article_id": "9583875", "title": "紅葉少棒隊朝威廉波特邁進 北市台東縣同鄉會宴請小將喊加油", "summary": "台東縣紅葉國小少棒隊曾經創下台灣棒球史上一頁傳奇，今年又再度勇奪全國少棒冠軍，月底將前往南韓挑戰亞太盃、搶奪前進威廉波特門票，北市台東縣同鄉會行前特別舉辦餐會為選手加油，校方也期盼再次重現50多年前金龍少棒連拿17屆的冠軍榮耀。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069791.jpg&M=1&s=Y&x=1&y=111&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 19:23", "link": "/news/story/7001/9583875"}, {"article_id": "9583725", "title": "中職／南華大學廖永詮能飆速也能開轟 運動能力突出拚選秀", "summary": "南華大學廖永詮具備投打二刀實力，投球最速可達153公里，大學階段累積8轟，運動能力突出，將以外野手身分挑戰中職選秀，他表...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069630.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 18:15", "link": "/news/story/7001/9583725"}, {"article_id": "9583762", "title": "世足賽／挪威晉級32強全民歡慶 放假議題引發討論", "summary": "挪威在世界盃足球賽以3比2擊敗塞內加爾，提前晉級32強，舉國歡騰。但當地民眾徹夜未眠換來的喜悅，也讓「往後若遇深夜賽事，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069618.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 18:14", "link": "/news/story/123107/9583762"}, {"article_id": "9583700", "title": "世足運彩／三獅軍團凶猛進攻迦納鐵桶以對 主推英格蘭讓1分", "summary": "英格蘭將在世界盃小組賽對陣迦納，首戰以4：2擊敗克羅埃西亞，賽前球星薩卡傷勢恢復。迦納首戰1：0險勝巴拿馬，但防線易被擊破。勝者將鎖定32強席位，英格蘭被視為奪冠熱門。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069445.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-23 17:42", "link": "/news/story/123105/9583700"}, {"article_id": "9583568", "title": "世足運彩／葡萄牙跟西班牙一樣要解悶 C羅心態要調整可以大勝烏茲別克推大分", "summary": "葡萄牙在世足賽首輪遭民主剛果逼和，C羅心態需調整，以迎接今晚對烏茲別克的比賽。烏茲別克以年輕球員為主，首次參賽表現不俗，葡萄牙則期待大勝以振作士氣。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069283.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 17:10", "link": "/news/story/123105/9583568"}, {"article_id": "9583610", "title": "NBA／熱火留得住維金斯和鮑威爾？美媒分析詹皇回鍋可能性", "summary": "熱火隊今天發動大交易，換來｢字母哥｣安戴托昆波（Giannis Antetokounmpo），雖引進超級巨星，但陣容深度也大幅削減，《邁阿密先驅報》記者傑克森（Barry Jackson）撰文提到，41歲巨星詹姆斯（LeBron James）重返邁阿密的可能性。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069336.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 17:09", "link": "/news/story/7002/9583610"}, {"article_id": "9583584", "title": "日職／徐若熙表訂24日出戰歐力士沒了 軟銀投教：不是可以登板的狀態", "summary": "效力軟銀鷹隊台灣投手徐若熙，原訂24日先發出戰歐力士隊，近日傳出狀態出現疑問，投手教練倉野信次今天透露，徐若熙目前「不是可以馬上投球的狀態」，下一步安排將等待檢查結果。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069296.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 16:57", "link": "/news/story/7001/9583584"}, {"article_id": "9583580", "title": "射擊／黃金計畫修改條文 李孟遠禁賽結束可再申請", "summary": "巴黎奧運射下我國首面射擊奧運獎牌的定向飛靶好手李孟遠，去年7月在義大利世界盃後的藥檢被驗出微量禁藥成分，經中華運動禁藥防制基金會調查後最終禁賽5個月，今年1月已解禁，國訓中心今天舉行董事會上確認修改原本條文，選手走完禁賽流程仍能申請黃金計畫，「李孟遠條款」將擇日公告並公知協會與選手。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069302.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 16:56", "link": "/news/story/7005/9583580"}, {"article_id": "9583392", "title": "日職／林安可二軍敲陽春砲 近4場出賽敲4轟", "summary": "日職埼玉西武獅隊野手林安可二軍出賽維持好手感，今天單場2安包括1發陽春砲，為二軍本季第6轟，貢獻1分打點，近4場出賽敲出...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34877141.jpg&M=1&s=Y&x=0&y=229&sw=1265&sh=843&exp=3600&sl=W&fw=360", "date": "2026-06-23 16:52", "link": "/news/story/7001/9583392"}, {"article_id": "9583305", "title": "世足運彩／哥倫比亞連勝氣勢壓過民主剛果 盤口偏冷GPT推大分", "summary": "哥倫比亞首戰3比1拿下烏茲別克，加上近5場全勝，場均積分維持滿檔，整隊士氣明顯站在高點；民主剛果1比1逼和葡萄牙固然提振信心，但那場更多來自防守紀律與反擊效率，若被迫拉高節奏，後場承壓會更早出現。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069241.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 16:46", "link": "/news/story/123105/9583305"}, {"article_id": "9583304", "title": "世足運彩／爆冷盤口暗藏玄機！無懼剛果反擊Gemini看好哥倫比亞3:1或2:1", "summary": "2026世界盃K組次輪迎來焦點對決，世界排名第13的強權哥倫比亞迎戰第46的民主剛果。然而，國際不讓分平均賠率卻開出奇特的「冷門盤口」：哥倫比亞勝賠高達4.84，甚至高於民主剛果的4.21與和局的3.", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069223.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 16:42", "link": "/news/story/123105/9583304"}, {"article_id": "9583303", "title": "世足運彩／克羅埃西亞體能疑慮壓不住盤口優勢 巴拿馬防線受壓GPT看好大分", "summary": "克羅埃西亞首戰對英格蘭進2球卻失4球，這支排名第11的強隊最先暴露的不是技術落差，而是連續高強度賽程下回防腿力不足。多名主力長期扛著俱樂部與國家隊雙線消耗，面對巴拿馬這種衝刺、對抗比例高的球隊，體能隱", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069131.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-23 16:22", "link": "/news/story/123105/9583303"}, {"article_id": "9583302", "title": "世足運彩／生死邊緣搶分大戰！格子軍團對巴拿馬火力全開Gemini 推克羅埃西亞3:1或2:1", "summary": "2026年美加墨世界盃L組次輪上演生死決戰，首戰吞敗的巴拿馬與克羅埃西亞此刻雙雙落入積分榜墊底的深淵，此役正面交鋒已無任何退路。面臨分組晉級的巨大壓力，兩隊都抱持著「非贏不可」的必勝決心。對於尋求隊史", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069104.jpg&M=1&s=Y&x=0&y=0&sw=1225&sh=817&exp=3600&sl=W&fw=360", "date": "2026-06-23 16:14", "link": "/news/story/123105/9583302"}, {"article_id": "9583422", "title": "足球／198隊脫穎而出 小學生賽決賽台中開戰", "summary": "歷經3個月全台激戰，「114學年度小學生足球賽」共有198支隊伍脫穎而出，取得全國決賽參賽資格，6月27日到7月5日將在台中朝馬足球場展開最終對決，屆時也將有部分場次直播服務，讓無法到場的家長、親友也能透過轉播共襄盛舉。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069007.jpg&M=1&s=Y&x=0&y=0&sw=852&sh=568&exp=3600&sl=W&fw=360", "date": "2026-06-23 15:46", "link": "/news/story/7005/9583422"}, {"article_id": "9583295", "title": "世足運彩／凱恩猛烈砲火對決迦納 分組龍頭之爭Gemini看好英格蘭3：1", "summary": "英格蘭在2026世界盃首戰以4比2大勝克羅埃西亞，前鋒哈利簡尼梅開二度展現驚人宰制力，全隊士氣如日中天；而非洲雄星迦納同樣在首戰以1比0力克巴拿馬，帶著高昂鬥志迎