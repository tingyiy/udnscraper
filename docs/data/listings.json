gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/06/34922484.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9486031", "title": "中職／打線變準一成戰隊 中信上半季剩下時間就是調打擊", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/06/34922520.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9485547", "title": "尼克盡顯東區霸王本色 76人藏與不藏安比德很頭大", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/06/34921740.jpg&M=1&s=Y&x=255&y=70&sw=854&sh=570&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9490122", "title": "MLB／洋基19戰16勝與勇士並列第1 布恩談火星人傷退：是好孩子", "summary": "洋基隊今天啟用牛棚車輪戰，仍以9：2大勝遊騎兵隊，近19戰16勝。洋基目前26勝12敗與勇士隊並列全大聯盟第一，但光芒隊近14戰13勝，以0.5場勝差緊追在後。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928654.jpg&M=1&s=Y&x=163&y=128&sw=958&sh=639&exp=3600&sl=W&fw=360", "date": "2026-05-08 12:54"}, {"article_id": "9490171", "title": "MLB／大都會老將金布洛爾挨逆轉滿貫砲：我認為先三振了", "summary": "大都會今日作客洛磯主場，原在前段比賽取得2：0領先，後援投手金布洛爾（Craig Kimbrel）卻在第8局慘遭麥卡錫（Jake McCarthy）滿貫砲重擊，最終以2：6慘遭逆轉，無緣完成系列賽橫掃。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928707.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-08 12:44"}, {"article_id": "9490178", "title": "NBA／里夫斯復活飆31分無用 湖人下半場被雷霆打爆吞2連敗", "summary": "西區季後賽第二輪雷霆隊與湖人隊今天進行第二戰，儘管上半場雙方一路拉鋸，但雷霆在第三節靠著多點開花的攻勢單節灌進36分，將領先差距擴大到雙位數，加上末節外線手感甦醒，最終雷霆就以125：107擊敗湖人，將帶著2：0優勢前往洛杉磯作客。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928743.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-08 12:27"}, {"article_id": "9490121", "title": "NBA／哈登季後賽又「軟手」 米契爾：一點都不擔心", "summary": "騎士隊「大鬍子」哈登（James Harden）今年季後賽第二輪狀態低迷，在與活塞隊系列賽的前兩場比賽都未能打出水準，包括今天的第二戰單場只有10分進帳，其中下半場僅有2次出手機會，昔日聯盟頭號得分手的風采盡失，不過搭檔米契爾（Donovan Mitchell）也強調一點都不擔心他的狀況。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928656.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-08 12:04"}, {"article_id": "9490050", "title": "NBA／「一同退休」藍圖恐破局？名記透露格林續約意願剩5成", "summary": "勇士老將格林（Draymond Green）今夏動向持續受到關注。根據《ClutchPoints》記者席格爾（Brett Siegel）透露，雖然勇士總教練柯爾（Steve Kerr）仍希望格林留隊，但目前雙方續約前景僅有「50／50」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928500.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-08 11:57"}, {"article_id": "9490055", "title": "MiLB／剛入選百大新秀 林維恩6局狂飆10K創旅美後新高", "summary": "運動家隊2A台灣左投林維恩先發6局狂飆10K，幫助球隊以6：2擊敗教士隊2A，林維恩收下本季第2勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928519.jpg&M=1&s=Y&x=0&y=453&sw=1024&sh=683&exp=3600&sl=W&fw=360", "date": "2026-05-08 11:45"}, {"article_id": "9490001", "title": "MLB／不甩「反派化」爭議！道奇捕手拉辛：不會改變比賽方式", "summary": "道奇25歲捕手拉辛（Dalton Rushing）儘管本季表現亮眼，但場上火爆作風與多起爭議事件，也讓他逐漸被外界貼上「反派」標籤。對此，拉辛近日首度正面回應外界討論。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928407.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-08 11:32"}, {"article_id": "9489650", "title": "世足賽／嫌FIFA門票太貴 連川普都不願花上千美元看比賽", "summary": "國際足球總會（FIFA）最近因為票價過高而飽受壓力，美國總統川普在今天刊出的訪問中表示，世界盃足球賽美國隊第一場分組賽，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928383.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-08 11:21"}, {"article_id": "9489984", "title": "MLB／今永昇太稱瑞格利有神秘力量 6局10K率隊奪主場15連勝", "summary": "小熊隊日籍左投今永昇太，今天對紅人隊先發6局失1分，飆出10次三振，本季第5度繳出優質先發，防禦率2.28，幫助球隊以8：3拿下勝利，在主場瑞格利球場（Wrigley Field）收下15連勝，寫下隊史近百年來的新高。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928417.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-08 11:15"}, {"article_id": "9489906", "title": "NBA／教練盛讚康寧漢就是殺手！ 哈里斯連7場20分平生涯紀錄", "summary": "東區龍頭活塞持續在季後賽展現驚人氣勢，繼首輪從1：3落後逆轉魔術後，今日再以107：97擊敗騎士，系列賽取得2：0領先。賽後，總教練比克斯塔夫（JB Bickerstaff）更毫不掩飾對康寧漢（Cade Cunningham）的讚賞。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928296.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-08 11:14"}, {"article_id": "9489792", "title": "桌球世團賽／中華男團完成世代交替 銅牌起跳抗日拚破隊史", "summary": "在英國倫敦舉行的世界桌球團體錦標賽台灣男團今天靠24歲選手林昀儒獨攬2點，以3比2擊敗瑞典晉級4強。林昀儒說，沒想過登上...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928297.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-08 11:04"}, {"article_id": "9489944", "title": "MLB／不用150公里速球也壓制 今永昇太談唯一失分：想試東西", "summary": "小熊隊日籍左投今永昇太今天面對紅人隊，主投6局狂飆10K，只失1分，防禦率下降至2.28。小熊以8：3贏球，收下9連勝、主場15連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928304.jpg&M=1&s=Y&x=374&y=27&sw=906&sh=604&exp=3600&sl=W&fw=360", "date": "2026-05-08 11:04"}, {"article_id": "9489819", "title": "NBA／2連勝尼克拉警報 側翼大將阿努諾比腿筋拉傷出賽成疑", "summary": "尼克隊在東區季後賽次輪勢如破竹，雖然目前對戰76人隊已取得2：0領先，但陣中全能前鋒阿努諾比（OG Anunoby）的傷情卻為晉級之路蒙上陰影，根據報導，阿努諾比經診斷為右腿筋拉傷，目前狀態列入每日觀察名單，能否趕上第三戰仍是未知數。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928117.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-08 10:28"}, {"article_id": "9489816", "title": "MLB／紅人捕手低級失誤自開本壘大門 教頭：我們當時都在大喊", "summary": "紅人隊今天以3：8輸給小熊隊，吞下7連敗，捕手史蒂文森（Tyler Stephenson）第4局不在狀況內的失誤，最終變成小熊的7分大局，紅人教頭法蘭柯納（Terry Francona）賽後指出，史蒂文森當時因打者、跑者影響到視線，才會導致這次疏失。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928111.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-08 10:25"}, {"article_id": "9489800", "title": "NBA／41歲防守悍將塔克正式宣布退休 眾球星獻上祝福", "summary": "現年41歲的防守悍將塔克（PJ Tucker）今天宣布退休，結束20年職業生涯，眾多NBA球星第一時間在社群平台獻上祝福。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928098.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-08 10:25"}, {"article_id": "9489763", "title": "桌球世團賽／觸發潛規則！日本25歲女將向桌球阿嬤鞠躬致歉", "summary": "2026世界桌球團體賽女團8強戰，日本以3比0擊敗盧森堡，日本25歲好手早田希娜因違反球場潛規則，賽後向盧森堡62歲選手倪夏蓮90度鞠躬致歉。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928018.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-08 10:03"}, {"article_id": "9489719", "title": "NBA／康寧漢末節12分接管戰局 活塞再退騎士系列賽2連勝", "summary": "在系列賽首戰於主場搶先開胡後，活塞今天繼續在主場力拚連勝，在前三節一路領先的情況下，儘管第四節一度遭到騎士逆轉戰局，但關鍵時刻一哥康寧漢（Cade Cunningham）挺身接管戰局，個人單節進帳12分，最終活塞就以107：97擊敗騎士，系列賽收下2連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34927946.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-08 09:47"}, {"article_id": "9489648", "title": "日職／徐若熙有明確問題需解決 軟銀投教：有必要在二軍出賽", "summary": "台灣強投徐若熙連兩場登板核爆，被降下二軍調整，球團未設歸期，軟銀投手教練倉野信次談到接下來的安排，徐若熙必須先在二軍比賽，證明自己所面臨的問題已經解決，並未排除可能會花較長時間，不一定會在10天後就重新登錄一軍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34927839.jpg&M=1&s=Y&x=126&y=24&sw=769&sh=513&exp=3600&sl=W&fw=360", "date": "2026-05-08 09:07"}, {"article_id": "9489640", "title": "NBA／黃蜂單季進步25勝創隊史紀錄 主帥李獲續約盼終結季後賽荒", "summary": "黃蜂在過去一個賽季寫下令人驚豔的翻身驚奇，而在這場蛻變的背後，總教練李（Charles Lee）居功厥偉，黃蜂球團於今天正式宣布，已與李簽下一份延長合約，肯定他帶隊單季拿下44勝，較前一季大幅進步25勝的優異執教表現。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34927842.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-08 09:05"}, {"article_id": "9489554", "title": "桌球世團賽／對瑞典連拿6局助隊晉級4強 林昀儒：努力打進決賽", "summary": "我國桌球一哥林昀儒今天在2026世界桌球團體賽8強賽領軍出擊，面對強敵瑞典，林昀儒除了在第一點直落三擊敗男單排名第2名的「六角戰士」摩賈德（Truls Moregard）外，更在第五點再度直落三拍退凱爾伯格（Anton Kallberg）成功關門，一人連拿6局的表現帶領中華隊挺進4強，確定銅牌保底。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34928072.jpg&M=1&s=Y&x=0&