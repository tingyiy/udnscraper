thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35031035.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 17:02", "link": "/news/story/123105/9557624"}, {"article_id": "9557623", "title": "世足運彩／南韓世界排名占優卻讓不動捷克 GPT看好「捷克受讓不敗」", "summary": "南韓世足排名高於捷克，但賠率顯示兩隊實力接近。投注建議支持捷克受讓不敗，並預測小於2.5球，可能結果為1比1或捷克1比0小勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030995.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-10 17:02", "link": "/news/story/123105/9557623"}, {"article_id": "9557784", "title": "世足運彩／晉級關鍵戰莊家不怕捷克贏球 推薦投注「南韓不敗」更有利", "summary": "南韓將在世界盃小組賽中迎戰捷克，此役對雙方晉級至關重要。南韓球星孫興慜的表現將是突破捷克防線的關鍵，而捷克則依賴紹切克和希克的默契配合。專家建議投注南韓不敗，預估最終比分為2：0。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35031373.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 17:02", "link": "/news/story/123105/9557784"}, {"article_id": "9558228", "title": "籃球／興富發建設深入宜蘭偏鄉 送暖四季國小籃球隊共築夢想", "summary": "興富發建設股份有限公司秉持著企業社會責任與回饋社會的初衷，今天在中華文化教育暨體育交流促進會帶領下，偕同小學體總團隊深入宜蘭縣偏鄉，為成績斐然卻資源匱乏的四季國小籃球隊這群熱愛籃球的泰雅族孩子送上最實質的溫暖與支持。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35031307.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 16:51", "link": "/news/story/7003/9558228"}, {"article_id": "9558224", "title": "日職／孫易磊本季初先發拚生涯首勝 明主場對決橫濱王牌東克樹", "summary": "日職火腿隊明天將在交流戰於北海道主場Es Con Field迎戰橫濱DeNA隊，雙方先發投手公告，21歲台灣投手孫易磊將迎接本季首場一軍先發，對上橫濱隊王牌左投東克樹，力拚生涯首勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35031380.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-10 16:50", "link": "/news/story/7001/9558224"}, {"article_id": "9558175", "title": "NBA／美記者看好湖人留住詹姆斯 直言續留機率「超過五成」", "summary": "傳奇球星詹姆斯的去向備受關注，ESPN記者溫德霍斯特預測湖人留住他的機率為51%。他指出勇士有潛力吸引詹姆斯，但認為昇回騎士的可能性不高，因為詹姆斯不可能接受低薪。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35031228.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 16:40", "link": "/news/story/7002/9558175"}, {"article_id": "9558133", "title": "日職／林安可單場2支二壘打 二軍連2天敲長打", "summary": "日本職棒埼玉西武獅隊台灣野手林安可近期在二軍展現長打火力，繼昨天開轟後，今天又是2支二壘安打，不過西武隊最終以3比6敗給...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/03/31/34815827.jpg&M=1&s=Y&x=0&y=2&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 16:36", "link": "/news/story/7001/9558133"}, {"article_id": "9557618", "title": "世足運彩／開幕戰南非有搶積分壓力 GPT推薦「墨西哥不讓分勝」", "summary": "墨西哥面對南非的世足首輪賽事將決定小組出線命運，莊家對墨西哥不讓分勝較為看好，赔率顯示和局可能性亦高。歷史交手中，南非曾逼平墨西哥，今屆比賽依然存在變數。投注方向以墨西哥不讓分勝為主，較保守可搭配墨西哥勝或和的雙重機會，參考比分看墨西哥2比0或2比1勝出。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35031107.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 16:21", "link": "/news/story/123105/9557618"}, {"article_id": "9557617", "title": "世足運彩／A組首戰東道主有高原優勢 Gemini 推薦鎖定「墨西哥獨贏」", "summary": "2026年世界盃A組首戰，東道主墨西哥迎戰南非，助力高原環境，預測墨西哥不讓分勝出。歷史交鋒中，墨西哥優勢明顯，投注策略建議鎖定「墨西哥獨贏」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35031161.jpg&M=1&s=Y&x=0&y=0&sw=1258&sh=839&exp=3600&sl=W&fw=360", "date": "2026-06-10 16:21", "link": "/news/story/123105/9557617"}, {"article_id": "9557783", "title": "世足運彩／重演2010開幕戰墨西哥換當主人 氣勢壓南非仍小心為上主推小分", "summary": "在2010年世界盃的開幕戰重演中，墨西哥將以東道主身份迎戰南非。專家預測兩隊上半場將採取保守策略，進球數料不會太多，後半場墨西哥有望掌握主動。主推簽盤為2.5小分。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030647.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 16:21", "link": "/news/story/123105/9557783"}, {"article_id": "9558072", "title": "MLB／菅野智之5局失3分洛磯贏小熊 6勝與大谷、山本並列日投之最", "summary": "洛磯投手菅野智之今日先發5局失3分，奪下本季第6勝，與大谷翔平及山本由伸並列日本勝投王。洛磯強力打線前三局攻下7分，最終以7：3擊敗小熊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35031021.jpg&M=1&s=Y&x=0&y=6&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 16:05", "link": "/news/story/6999/9558072"}, {"article_id": "9558052", "title": "MLB／李政厚連17場安打寫紀錄 巨人新秀大讚：現在世界上最好的打者", "summary": "巨人隊韓籍球星李政厚今天對上國民隊，單場再繳出5支2、2打點表現，連續17場比賽敲安打，正式超越2013年紅人隊秋信守及2023年教士隊金河成，寫下大聯盟南韓球員新紀錄，目前打擊率3成35則在大聯盟排名第二，一步步進逼打擊王。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030997.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 15:44", "link": "/news/story/6999/9558052"}, {"article_id": "9557982", "title": "MLB／李政厚推進連17場敲安 打擊率3成35瞄準打擊王", "summary": "巨人外野手李政厚今以17場連續安打創下韓國大聯盟紀錄，打擊率3成35位居第二。雖然球隊最終以3：6不敵國民，李政厚仍貢獻2安打和2分打點，表現搶眼。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030895.jpg&M=1&s=Y&x=0&y=8&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-10 15:27", "link": "/news/story/6999/9557982"}, {"article_id": "9557960", "title": "澳洲羽賽／薑是老的辣！周天成3局逆轉王柏崴", "summary": "世界排名第6的我國「一哥」周天成，上周在BWF超級1000的印尼公開賽打進最終4強，本周轉戰BWF超級500的澳洲公開賽排上頭號種子，今天首輪碰到世界排名43的同胞王柏崴，首局只拿12分，不過後兩局扳回顏面，贏得1小時20分鐘馬拉松大賽勝利，小天殺球拿下最後一分後也忍不度丟下球拍、仰躺在地，最後將球發到觀眾席，慶祝這場激戰勝利。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030870.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 15:17", "link": "/news/story/7005/9557960"}, {"article_id": "9557859", "title": "MLB／道奇年輕捕手再次惹事 拉辛爭議故意滑壘引球迷怒火", "summary": "道奇捕手拉辛在對海盜的比賽中因刻意滑壘干擾對手而遭判妨礙守備出局，並引發球迷怒噓。這並非他首次因類似行為引發爭議，過去更曾有過其它負面表現。儘管如此，拉辛本季表現亮眼，打擊率達2成86。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030730.jpg&M=1&s=Y&x=0&y=34&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 14:46", "link": "/news/story/6999/9557859"}, {"article_id": "9557013", "title": "NBA／尼克G3吞敗引爆球迷衝突 群毆、襲警共21人被捕", "summary": "紐約尼克隊(New York Nicks)8日晚在NBA總決賽第三戰中，以111比115的微弱分差敗給聖安東尼奧馬刺隊(San Antonio Spurs)，隨即引發了部分狂熱球迷的失控行為。在曼哈頓布萊恩公園(Bryant Park)參與戶外觀賽派對的群眾也與警方爆發激烈衝突，導致多名警員受傷，21人當場被逮捕。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35029280.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 14:46", "link": "/news/story/7002/9557013"}, {"article_id": "9557839", "title": "MLB／鄧愷威丟7分本季最艱苦一戰吞敗 教頭：不是最佳狀態", "summary": "美國職棒台灣投手鄧愷威今天出戰天使，遭遇本季最艱苦一戰。總教練艾斯帕達表示，儘管「不是他最佳狀態」，仍肯定鄧愷威多撐2局...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030710.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-10 14:35", "link": "/news/story/6999/9557839"}, {"article_id": "9556942", "title": "世足賽／逾1/4參賽國民眾遭美嚴限入境 球迷怒：不是我們的世界盃", "summary": "美加墨世界盃11日揭幕，但川普政府的限制入境政策，已剝奪多國球迷親身到美國觀戰的機會，引發批評。有球迷怒言：「這屆世界盃不是我們的。」亦有球迷認為，一個不願接待參賽球隊球迷的國家，根本沒有資格辦世界盃。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030780.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 14:35", "link": "/news/story/123107/9556942"}, {"article_id": "9557829", "title": "NBA／總決賽成肉搏大戰 卡瑟爾誓言明天帶著勝利離開紐約", "summary": "NBA總冠軍賽戰火全面升級，馬刺隊在系列賽G3歷經一番苦戰，最終以115：111險勝尼克隊，雖然在系列賽仍以1：2落後，但雙方球員在場上拳拳到肉的身體對抗，已讓今年的總決賽徹底淪為高強度的肉搏戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030698.jpg&M=1&s=Y&x=0&y=34&sw=907&sh=604&exp=3600&sl=W&fw=360", "date": "2026-06-10 14:24", "link": "/news/story/7002/9557829"}, {"article_id": "9557824", "title": "中職／又沒比賽看了！ 今晚桃園獅猿戰因雨延賽", "summary": "受到梅雨滯留鋒面及西南氣流影響，本周台灣各地雨不停，今天原訂在桃園棒球場進行的樂天桃猿與統一獅隊之戰，也受到雨勢影響，聯盟宣布延賽，將延至6月23日18：35原場地進行補賽，本周還沒有賽事能順利開打。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030717.jpg&M=1&s=Y&x=0&y=0&sw=1260&sh=840&exp=3600&sl=W&fw=360", "date": "2026-06-10 14:23", "link": "/news/story/7001/9557824"}, {"article_id": "9557745", "title": "MLB／道奇捕手史密斯持續休戰中 主帥羅伯茲證實不排除進傷兵", "summary": "道奇捕手史密斯因頸部僵硬連續三場未先發，主教練羅伯茲表示他進入傷兵名單的可能性增加，預計不會出戰下一場比賽。拉辛已連續擔任捕手，渴望把握這次機會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030532.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 14:08", "link": "/news/story/6999/9557745"}, {"article_id": "9557722", "title": "世足賽／梅西傷癒復出替補破門 衛冕軍阿根廷吃下定心丸", "summary": "2026年世足賽即將在美加墨點燃戰火，力拚衛冕的「藍白軍團」阿根廷隊迎來好消息，日前因左大腿後側肌群過載缺陣16天的當家球星梅西（Lionel Messi），今天對陣冰島熱身賽重返球場，並於下半場替補登場頂替西蒙尼（Giuliano Simeone），隨後在比賽第72分鐘成功罰進點球，幫助阿根廷以3：0大勝冰島。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030491.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 13:49", "link": "/news/story/123107/9557722"}, {"article_id": "9557702", "title": "世足賽／銀彈準備好！旅遊平台上架美國區門票 最便宜快8萬", "summary": "2026美加墨FIFA世界盃即將開踢，全球旅遊體驗平台KKday目前上架世界盃5場美國賽區門票，售價從7萬7千台幣起，最貴場次的單人門票高達17萬台幣，想「朝聖」必須有充足銀彈。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030469.png&M=1&s=Y&x=0&y=0&sw=995&sh=663&exp=3600&sl=W&fw=360", "date": "2026-06-10 13:38", "link": "/news/story/123107/9557702"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9557722", "title": "世足賽／梅西傷癒復出替補破門 衛冕軍阿根廷吃下定心丸", "date": "2026-06-10 13:49", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030491.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9557722"}, {"article_id": "9557510", "title": "拜仁之王破詛咒！英格蘭隊長凱恩的世足之路", "date": "2026-06-10 12:27", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030190.jpg&M=1&s=Y&x=0&y=32&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9557510"}, {"article_id": "9556942", "title": "世足賽／逾1/4參賽國民眾遭美嚴限入境 球迷怒：不是我們的世界盃", "date": "2026-06-10 14:35", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030780.jpg&M=1&s=Y&x=