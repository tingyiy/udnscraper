/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34943537.jpg&M=1&s=Y&x=0&y=69&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9500368", "title": "大谷翔平2026的極端悖論：投球0.97ERA背後的打擊節奏失序", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34943893.jpg&M=1&x=&y=&sw=&sh=&exp=3600&w=300"}, {"article_id": "9500521", "title": "海盜「不一樣了」！史肯斯領軍三王牌投出國聯最佳輪值成績", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34943951.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9481204", "title": "中職／躋身200盜殿堂 樂天桃猿陳晨威突破框架追逐偉大", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/01/34817067.jpg&M=1&s=Y&x=425&y=1&sw=480&sh=320&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9505852", "title": "TPBL／國王從不被看好到季後賽搶先聽牌 洪志善：很多事情要去證明", "summary": "新北國王今天在季後賽首輪第3戰，於主力後衛李愷諺缺陣的情況下，最終以2分差距險勝桃園台啤永豐雲豹，系列賽取得2：1聽牌，對於球隊從開季就不被看好，到如今距離總冠軍賽只差最後1勝，總教練洪志善直言，很多東西都是要去證明，尤其愈不被看好，就愈要做給別人看。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951849.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 22:43"}, {"article_id": "9505838", "title": "中職／進職棒後才慢慢學會代打 劉俊緯：球過來就勇敢揮棒", "summary": "味全龍隊劉俊緯近期多以代打角色出賽，今天面對樂天桃猿隊，8局下滿壘時被換上場，抓賴胤豪投出的第1球掃出2分打點二壘打，一棒當英雄，幫助球隊以3：1打下勝利，劉俊緯說：「上去就是積極進攻，好球帶設定好，球過來就要勇敢去揮棒。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951834.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 22:36"}, {"article_id": "9505823", "title": "中職／劉俊緯滿壘代打建功 葉總：他只要上場就能讓球隊「火起來」", "summary": "味全龍隊今天在主場迎戰樂天桃猿隊，8局下劉俊緯在滿壘時上場代打，揮出2分打點二壘打敲回致勝一擊，幫助球隊以3：1打下勝利，終止近期3連敗，也保住聯盟龍頭，總教練葉君璋大讚，他有一種讓球隊「火起來」的特質。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951811.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 22:16"}, {"article_id": "9505822", "title": "高球／中國信託女子公開賽第二輪 俞涵軒衝上並列第4名", "summary": "中國信託商業銀行主辦、TLPGA與JLPGA共同認證的「2026 中國信託女子公開賽 – JLPGA巡迴特別錦標賽」，今天在東方高爾夫俱樂部進行第二輪賽程，以並列領先出發的石昱莉，順利以單輪72桿、兩輪低於標準桿三桿的141桿暫時排名第一，「中國信託女子高爾夫之星」俞涵軒也在本輪大有斬獲，低於標準桿一桿的71桿，兩輪總桿數145桿暫時並列第四名。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951809.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 22:16"}, {"article_id": "9505810", "title": "中職／終於10勝了！兄弟歷時32場達陣 慢吞吞平隊史最慢紀錄", "summary": "中信兄弟隊花了32場，終於拿到本季第10勝，今天由老將陳俊秀的兩分砲當起爆劑，終場以7：4擊敗統一獅隊，終止近期的3連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951798.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 22:09"}, {"article_id": "9505802", "title": "TPBL／杰倫31分加致勝罰球 國王驚濤駭浪中險勝雲豹聽牌", "summary": "新北國王今天在系列賽第三戰將主場移師到台北和平籃球館，不過卻發生主力後衛李愷諺因熱身時腳部不適突發缺陣，逼得球隊陣前換將，然而陷入變陣劣勢的國王，克服上半場禁區大將沃許本陷入犯規麻煩的危機，靠著洋將杰倫轟下全場最高31分、包含讀秒階段的致勝兩罰，外加林彥廷奇兵演出拿下19分，最終以104：102驚險戰勝桃園...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951793.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 22:05"}, {"article_id": "9505787", "title": "中職／去年落後11場→今年落後1場 魔力藍看悍將哪裡不一樣", "summary": "去年上半季打完前30場，富邦悍將隊與龍頭勝差已經達到11場，早早退出爭冠行列，今年展現不同以往的競爭力，洋投魔力藍談團隊此刻氣氛，他說：「我們都相信自己會贏。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951783.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 21:55"}, {"article_id": "9505768", "title": "中職／劉峻緯關鍵代打當英雄 龍隊3：1打退桃猿止敗", "summary": "味全龍隊吞下3連敗後回到主場，今天對戰樂天桃猿隊，先打下領先卻被追平，直到8局下靠著劉俊緯代打建功，滿壘時揮出2分打點二壘打，替龍隊以3：1敲回勝利，成功止敗，並保住聯盟龍頭位置。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951768.jpg&M=1&s=Y&x=0&y=43&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 21:42"}, {"article_id": "9505767", "title": "中職／悍將打完30場只落後龍頭1場 球團史僅次2020下半季", "summary": "富邦悍將隊今天以3：1擊敗台鋼雄鷹隊，在上半季前30場取得17勝13敗佳績，落後龍頭味全龍隊僅1場勝差，這是球團史在半季打完30場時落後的第二小差距，僅次於2020年下半季。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951758.png&M=1&s=Y&x=21&y=1&sw=1079&sh=719&exp=3600&sl=W&fw=360", "date": "2026-05-15 21:42"}, {"article_id": "9505721", "title": "中職／悍將爭冠來真的！上半季跑完半程仍在領先集團 狂拉4連勝", "summary": "中職上半季賽場跑完半圈，富邦悍將隊仍在領先集團，今天由洋投魔力藍7局僅失1分、狂賞10K好投帶領，以3：1險勝台鋼雄鷹隊。悍將在這波本季最長的4連勝衝刺之下，上半季前30場打完握有17勝13敗佳績。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951665.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 21:12"}, {"article_id": "9505688", "title": "韓職／王彥程5局飆8K壓制聯盟龍頭KT巫師 收下本季第4勝", "summary": "韓華鷹隊25歲台灣左投王彥程今天客場登板，出戰聯盟戰績第一的KT巫師隊，先發5局失2分，送出生涯單場新高的8次三振，最快球速也飆到150公里，在球隊領先時退場，最終韓華鷹隊以5：3勝出，王彥程收下本季第4勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951643.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 20:56"}, {"article_id": "9505632", "title": "中職／宋柏翰上周敲生涯首轟 哥哥宋嘉翔卻問「怎麼只打1支安打？」", "summary": "台鋼雄鷹20歲新秀宋柏翰上周寫下「生涯首安＝首轟」的成就，他的哥哥、樂天桃猿隊捕手宋嘉翔當天也在比賽中就得知消息，直呼不會意外，宋嘉翔也透露，賽後有傳訊息給弟弟，「我跟他說，你怎麼只打1支安打而已？」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951586.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 20:10"}, {"article_id": "9505623", "title": "中職／范國宸前5局已雙安卻提早退場 球團說明：手指挫傷治療", "summary": "富邦悍將隊長范國宸今天前兩打席已經雙安，六局上並未繼續上場守備，球團表示，范國宸手指挫傷，先行退場治療。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951585.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 19:58"}, {"article_id": "9505615", "title": "韓職／王彥程5局失2分飆速150公里 單場8K寫生涯新高", "summary": "韓職韓華鷹隊台灣左投王彥程本季第9場登板，今天客場出賽，首度對戰KT巫師隊，與高永表同場先發，王彥程主投5局失2分送出8次三振，退場時韓華3：2領先，成勝投候選人。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951569.jpg&M=1&s=Y&x=0&y=28&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 19:51"}, {"article_id": "9505596", "title": "泰國羽賽／兩度遭化解賽末點 周天成三局險勝全奕陳晉級4強", "summary": "BWF超級500的泰國羽球公開賽今天進行到8強賽事，其中我國一哥周天成在男單8強賽遭遇南韓好手全奕陳，上演雙方生涯第4度對壘，最終周天成以21：18、21：23、21：14險勝，相隔一年挺進到4強賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951538.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 19:33"}, {"article_id": "9505564", "title": "中職／「想要像洋將那樣⋯⋯」 曾家輝投1休5才知洋投的厲害", "summary": "樂天桃猿隊先發投手曾家輝昨天首度「投1休5」登板，面對台鋼雄鷹隊先發4局失2分，僅用70球退場，無關勝敗，他形容是「滿新鮮的體驗」，實際嘗試過後更能理解「洋將真的非常厲害」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951495.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 19:15"}, {"article_id": "9505520", "title": "中職／張育豪不會太快「開箱」 後藤光尊：除非球隊有較大問題", "summary": "富邦悍將隊今天選手異動降下張進德、升上劉俊豪，一軍剩下兩位捕手，去年選秀榜眼張育豪今天再度來到新莊棒球場「補習」，總教練後藤光尊表示，他是背號兩位數的選手，當然有機會註冊，「但除非球隊有比較大的問題，不然不會那麼快用到。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951435.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 18:52"}, {"article_id": "9505494", "title": "中職／吉力吉撈最快5月底一軍復出 龍隊先註冊20歲捕手當備案", "summary": "味全龍隊目前一軍僅蔣少宏、林辰勳兩名純捕手，昨天新註冊20歲的黃贊維當「備案」，總教練葉君璋透露，怕如果一軍捕手不小心受傷，還是要有人準備，因此先將黃贊維登錄來預防。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951422.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 18:34"}, {"article_id": "9505471", "title": "中職／林子偉請假2天明歸隊 桃猿PitchCom預計下周到貨", "summary": "樂天桃猿隊本周展開客場5連戰，昨天結束在澄清湖棒球場對戰台鋼雄鷹的賽事，今天北上天母棒球場面對味全龍隊，但連續兩天不見林子偉蹤影，總教練曾豪駒透露，林子偉因家裡有事請假，預計明天就會歸隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951383.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 18:18"}, {"article_id": "9505470", "title": "中職／史上前兩大地獄開局都有他 李東洺經歷過更知擋住氣勢有多難", "summary": "中職史上第一大和第二大的地獄開局，富邦悍將隊投手李東洺都有份，中信兄弟隊鄭浩均前一場登板的核爆，李東洺自己也曾經歷過，而那一場挫敗對他來說已是過眼雲煙，「職業球員，一整年有很多比賽，那場比賽就是過去了，重點是怎樣表現更好。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951379.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&sl=W&fw=360", "date": "2026-05-15 18:18"}, {"article_id": "9505426", "title": "中職／悍將聯盟第一打線如何誕生？後藤給名單、2位打教排棒次", "summary": "富邦悍將隊近期已經處於前段班的火力，在上一場18安、17分進補後，更是進一步躍升全聯盟第一，悍將本季打線安排亮點不少，究竟是由誰主導？總教練後藤光尊指出，自己會決定今天哪些人上，棒次則由打擊教練討論，但如果打擊教練有自己的想法，也可能在...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951341.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 17:53"}, {"article_id": "9505334", "title": "MLB／史瓦柏致勝轟讓費城人贏球 7戰7轟穩坐全壘打王", "summary": "費城人靠史瓦柏在第8局的致勝2分砲，以3：1險勝紅襪，贏得系列賽。史瓦柏本季第18轟讓他在全壘打王的寶座上穩坐不墜，近7場比賽已轟出7支全壘打。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951177.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 17:05"}, {"article_id": "9505281", "title": "世足賽／央視拿下中國大陸轉播權 傳砍價逾6成", "summary": "中國體育平台「直播吧」今天報導，官媒中央電視台已經獲得2026年美加墨世界盃足球賽的中國大陸地區轉播權。社群盛傳，央視最...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951174.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 16:57"}, {"article_id": "9505212", "title": "NBA／聽牌騎士爆腸病毒危機 主帥亞特金森健康也出問題", "summary": "騎士隊在季後賽第二輪以3：2取得聽牌，卻面臨腸胃病毒疫情影響，多名球員健康亮紅燈。主教練亞特金森也出現上呼吸道感染症狀，隊內情況令人擔憂。明天回到主場將面對系列賽關鍵戰役。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951003.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-15 16:09"}]}, {"name": "棒球", "articles": [{"article_id": "9505810", "title": "中職／終於10勝了！兄弟歷時32場達陣 慢吞吞平隊史最慢紀錄", "date": "2026-05-15 22:09", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/15/34951798.jpg&M=1&s=Y&x=0&y=