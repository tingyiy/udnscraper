", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/13/34851372.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9444363", "title": "中職／林岳平讚林泓弦攻守俱佳「相當穩健」 捕手輪流上場不連三", "summary": "統一獅隊今年開季大量啟用「幼獅」，其中20歲內野手林泓弦今天對上樂天桃猿隊，繳出攻守俱佳的表現，敲回2分打點，讓總教練「大餅」林岳平也給予肯定，稱他已成為「相當穩健的選手」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34859234.jpg&M=1&s=Y&x=0&y=0&sw=852&sh=568&exp=3600&sl=W&fw=360", "date": "2026-04-15 22:29"}, {"article_id": "9444339", "title": "中職／連兩戰至少7局好投 布雷克：今年直球控球狀況特別好", "summary": "統一獅隊布雷克今天先發出戰樂天桃猿，先發7局失1分拿下本季首勝，近期連兩場出賽都投出至少7局僅失1分的優質先發，布雷克透露，今年開季感覺直球的控球狀況確實特別好。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34859202.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 22:09"}, {"article_id": "9444322", "title": "圖輯／中職布雷克7局好投 助統一獅5：1擊敗樂天桃猿 中止3連敗", "summary": "樂天桃猿隊今天在桃園主場出戰來訪的統一獅隊，雙方先發皆推出洋投先發，樂天桃猿派出摩爾曼先發對上統一獅隊的布雷克。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34859185.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 21:51"}, {"article_id": "9444305", "title": "中職／布雷克7局失1分 獅隊5：1宰猿隊終止三連敗", "summary": "統一獅隊今天作客桃園棒球場對上樂天桃猿，打線靠著8支安打的串連，5局起連三局攻下分數，加上洋投布雷克先發7局失1分壓制猿隊打線，終場獅隊以5：1勝出，終止近期三連敗，猿隊則在主場吞下二連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34859117.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 21:37"}, {"article_id": "9444306", "title": "中職／王維中6.2局無失分奪久違勝投 兄弟開季12戰吞10敗平隊史最慘", "summary": "台鋼雄鷹今天在台中洲際棒球場以4：0完封中信兄弟，拿下4連勝續坐聯盟龍頭，王維中先發6.2局無失分，睽違近2年再繳優質先發，拿下轉隊後首勝；中信兄弟則是成為本季首支吞下10敗的隊伍，開季前12戰吞10敗追平隊史紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34859204.jpg&M=1&s=Y&x=0&y=19&sw=911&sh=608&exp=3600&sl=W&fw=360", "date": "2026-04-15 21:37"}, {"article_id": "9444195", "title": "圖輯／中職摩爾曼對上布雷克 5局結束樂天桃猿0：4落後統一獅", "summary": "樂天桃猿隊今天在桃園主場出戰來訪的統一獅隊，雙方先發皆推出洋投先發，樂天桃猿派出摩爾曼先發對上統一獅隊的布雷克。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858966.jpg&M=1&s=Y&x=0&y=0&sw=852&sh=568&exp=3600&sl=W&fw=360", "date": "2026-04-15 20:30"}, {"article_id": "9444186", "title": "日職／林安可4打數無安打 宋家豪1球抓2出局數奪本季第2勝", "summary": "日職西武獅隊今天客場對戰歐力士隊，林安可擔任先發第3棒、指定打擊，4打數沒有敲出安打，終場西武隊以1：3落敗。另一場樂天金鷲隊與軟銀鷹隊之戰，宋家豪只用1球抓下2個出局數化解危機，靠著隊友村林一輝敲致勝轟，拿下本季第2勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858963.jpg&M=1&s=Y&x=166&y=0&sw=1077&sh=718&exp=3600&sl=W&fw=360", "date": "2026-04-15 20:26"}, {"article_id": "9444024", "title": "中職／廖任磊赴美訓練球速增 當年差點改拚美國職籃", "summary": "富邦悍將投手廖任磊本季最快球速已飆至154公里，他歸功於季前赴美訓練，讓發力更有效率；此外，擁有201公分身高的他也自曝...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858762.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 19:01"}, {"article_id": "9444001", "title": "中職／悶17打席後猛打賞被陳晨威虧「偷安打」 何品室融：分我幾支啦", "summary": "樂天桃猿20歲新秀何品室融揮別開季前17打數0安打的狀況，12日對上中信兄弟不僅首打席就擊出首安，且繳出單場3安猛打賞的表現，何品室融坦言「心態上稍微比較舒服一點」，但仍絲毫不敢放鬆，「每一場都要把能做的事情做好。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858702.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 18:38"}, {"article_id": "9443910", "title": "中職／張育成重返悍將先發 疲勞缺陣與經典賽有關", "summary": "中華職棒富邦悍將隊強打張育成昨天缺陣，加上賽前未現身戶外練習引起關注。今天他回到先發打線，也親自解釋缺陣「就是單純疲勞」...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858526.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 18:05"}, {"article_id": "9443876", "title": "中職／江少慶二軍1.1局失5分餅總說「無妨」 林子崴首戰投到144公里", "summary": "統一獅隊投手江少慶持續為重返一軍做準備，自本月起開始在二軍出賽，今天第二場登板，對上台鋼雄鷹二軍，在設定的用球數之下，僅投1.1局失5分（4分自責分）退場，對於這樣的結果，獅隊總教練林岳平淡回兩個字「無妨」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858440.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 17:49"}, {"article_id": "9443792", "title": "中職／鄭浩均被打爆與捕手有關？平野惠一稱Pitchcom出現延遲問題", "summary": "中信兄弟先發鄭浩均在對台鋼雄鷹比賽中表現不佳，投3.1局失8分。總教練平野惠一表示，PitchCom設備延遲影響投捕節奏，致使鄭浩均專注度下降，情緒急躁。未來將改善設備應變機制。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858331.jpg&M=1&s=Y&x=0&y=23&sw=1087&sh=725&exp=3600&sl=W&fw=360", "date": "2026-04-15 17:37"}, {"article_id": "9443718", "title": "MLB／老虎一分險勝皇家 簡森479次救援成功登史上第三", "summary": "老虎在8局逆轉擊敗皇家，簡森成功收下本季第3次救援，累積479次救援成功成為歷史第三。賽後，他表示為隊友的勝利感到驕傲，並強調持續保持高水平表現。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858255.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 17:24"}, {"article_id": "9443769", "title": "中職／準備歸隊前再傳傷勢 林靖凱在家跌倒撞到頭", "summary": "統一獅隊內野手林靖凱近年受傷勢所苦，開季已在二軍開始出賽，依照原訂進度，原本有機會在近期回歸一軍，但近期在二軍連兩戰缺席，獅隊總教練「大餅」林岳平透露，他在家中跌倒造成頭部及嘴唇有外傷，歸隊進度將在復原後重新評估。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858304.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 17:20"}, {"article_id": "9443758", "title": "NBA／未來之星邀請賽6月登場 林書豪現身新加坡", "summary": "NBA今天宣布，第二屆NBA未來之星邀請賽將於6月22到28日在新加坡華僑銀行室內體育館進行，這項高中籃球錦標賽將匯聚來自亞太地區的男女籃球隊，台灣球迷熟悉的「哈佛小子」林書豪將與WNBA總冠軍成員傑克森（Lauren Jackson）將親臨活動現場，在整個活動周與參賽選手互動。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858287.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&sl=W&fw=360", "date": "2026-04-15 17:14"}, {"article_id": "9443702", "title": "亞沙運／走出跳高失憶症 葉柏廷期待「驚喜」", "summary": "兩年前在全大運飛過2公尺30橫桿，葉柏廷成為全國跳高男子紀錄保持人，但先是受傷，再出現「跳高失憶症」，今年比賽盼慢慢抓回感覺，期待本月22日在三亞舉辦的亞洲沙灘運動會能有新的刺激。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858221.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 16:53"}, {"article_id": "9443695", "title": "中職／江少慶控球大走鐘！1.1局狂失5分、防禦率破10", "summary": "統一獅隊江少慶今天迎來第2場復健賽，面對台鋼雄鷹隊二軍大走鐘，1.1局投出4次四壞保送，失掉5分，防禦率暴漲至10.80，最快球速151公里。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858212.jpg&M=1&s=Y&x=148&y=41&sw=699&sh=466&exp=3600&sl=W&fw=360", "date": "2026-04-15 16:53"}, {"article_id": "9443630", "title": "韓職／自曝遭言語暴力、躲在廁所哭 韓啦啦隊鄭嘉睿：暫停工作接受治療", "summary": "前韓國職棒起亞虎隊啦啦隊長鄭嘉睿，今天在社群平台發文透露，曾在工作時遭受辱罵與言語暴力，比賽前一直躲在廁所裡哭。目前正接受治療，將減少與粉絲見面機會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858124.jpg&M=1&s=Y&x=0&y=193&sw=961&sh=640&exp=3600&sl=W&fw=360", "date": "2026-04-15 16:29"}, {"article_id": "9443589", "title": "亞沙運／暌違10年舉辦 中華代表團71位選手出征三亞", "summary": "亞洲沙灘運動會暌違10年終於重啟，第6屆亞沙運將於4月22日至30日在中國三亞市舉行，中華代表團共派出71位選手參加10種運動，今天運動部部長李洋為代表團授旗，並致贈20萬元加菜金，祝福選手健康、順利完賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858023.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=852&exp=3600&sl=W&fw=360", "date": "2026-04-15 16:10"}, {"article_id": "9443557", "title": "MLB／6連敗釀酒人又傳壞消息 看板球星葉力奇將休一個月", "summary": "釀酒人當家球星葉力奇因內收肌拉傷被放入傷兵名單，預計缺席一個月。球隊近期已遭遇六連敗，失去進攻主力將對戰績造成進一步影響。葉力奇開季表現良好，打擊率達3成14。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858005.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 16:06"}, {"article_id": "9443511", "title": "社區運動俱樂部說明會全台展開 近800單位搶進響應全民運動政策", "summary": "運動部推動「社區運動俱樂部實施計畫」，全台近800單位參與，顯示基層對運動發展的期待。說明會已在多地舉行，並提供實務案例解析，鼓勵學校與民間合作，促進社區運動常態化。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857899.jpg&M=1&s=Y&x=0&y=64&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 15:50"}, {"article_id": "9443497", "title": "MLB／手套有「藍色力量」？山本由伸：用起來特別順手", "summary": "山本由伸今天面對大都會隊，繳出7.2局只失1分好投，賽後被問到換回藍色手套的原因，山本直言，「手套對投球其實很重要。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857