nail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042004.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600", "link": "/news/story/6999/9565148"}], "subsections": [{"name": "專欄", "articles": [{"article_id": "9564608", "title": "馬刺慘遭史詩級逆轉不單是球員迷航 主帥強森三宗罪難辭其咎", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35041187.jpg&M=1&s=Y&x=17&y=11&sw=1263&sh=842&exp=3600&w=300", "link": "/news/story/122629/9564608"}, {"article_id": "9564449", "title": "世足攻略／內馬爾缺陣考驗巴西平局機率近五成 瑞士穩定攪局卡達難爆冷", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040924.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9564449"}, {"article_id": "9563581", "title": "煮茶論戰／世足首戰就發3紅牌 後面還會更多", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35039525.jpg&M=1&s=Y&x=0&y=0&sw=1275&sh=850&exp=3600&w=300", "link": "/news/story/123107/9563581"}, {"article_id": "9563228", "title": "尼克示範如何把溫班亞瑪拉出禁區 馬刺必須面對的攻防課題", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35038965.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/122629/9563228"}, {"article_id": "9562529", "title": "世足攻略／美國碰「南美滾泥土」防爆冷 加拿大少戴維斯戰波赫怕逼和", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35037670.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9562529"}, {"article_id": "9562359", "title": "破除西媒稱梅西是藏鏡人陷阱 阿根廷主帥要捍衛頭上冠冕", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35037373.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9562359"}]}, {"name": "最新文章", "articles": [{"article_id": "9565556", "title": "NBA／22歲首次爭冠遭受震撼教育 溫班亞瑪：不逃避失敗痛苦化前進動力", "summary": "馬刺在NBA總冠軍賽第5戰以90比94不敵紐約尼克，系列賽以1比4落敗，無緣在本季完成奪冠夢。尼克則睽違53年再度捧起歐布萊恩金盃，拿下隊史第3座總冠軍。對年僅22歲的馬刺當家少主溫班亞瑪（Victor Wembanyama）而言，生涯初次打季後賽就是一路闖到總冠軍賽，堪稱是生涯至今最重要的一堂課。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042644.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 13:23", "link": "/news/story/7002/9565556"}, {"article_id": "9565564", "title": "杜元坤、黃明山獲聘橄欖球協會榮譽理事長　攜手推動台灣橄欖球永續發展", "summary": "中華民國橄欖球協會聘任杜元坤及黃明山為榮譽理事長，表彰其對台灣橄欖球運動的重大貢獻。未來將攜手推動基層培育及競技發展，促進台灣橄欖球的永續成長。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042665.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 13:22", "link": "/news/story/7005/9565564"}, {"article_id": "9565535", "title": "世足運彩／約克雷斯強襲應能拆掉突尼西亞！「鋼鐵大巴」 推薦瑞典不讓分勝、正比2：0", "summary": "瑞典對突尼西亞的世界盃小組賽即將於6月15日舉行，瑞典主教練波特的流暢進攻面對突尼西亞的堅固防守。盤口分析顯示瑞典讓0.5球，預測瑞典將以2-0戰勝對手，確保晉級希望。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042632.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-14 13:09", "link": "/news/story/123105/9565535"}, {"article_id": "9565492", "title": "世足賽／日本強碰荷蘭 菅原由勢無懼傷兵潮：會像過往一樣創造歷史", "summary": "2026美加墨世足已如火如荼開打中，日本將在明日清晨F組小組賽強碰荷蘭，在今日上午的球隊訓練後，效力德甲的日本隊後衛菅原由勢，在稍早採訪中談到了球隊求勝的強烈心態，儘管少了三名核心大將三笘薰、南野拓實以及遠藤航，但過去經常創造奇蹟的「藍武士」，仍然有望擊敗這支歐陸強權。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042500.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 12:50", "link": "/news/story/123107/9565492"}, {"article_id": "9565419", "title": "LPGA／陶氏錦標賽團體賽第3天 徐薇淩攜德國搭檔並列24名", "summary": "LPGA陶氏錦標賽（Dow Championship），台灣好手徐薇淩和德國搭檔克勞特在第3回合，合力抓3博蒂、吞4柏忌...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042545.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 12:48", "link": "/news/story/7005/9565419"}, {"article_id": "9565496", "title": "世足賽／蘇格蘭1：0險勝海地 重返世界盃首戰告捷", "summary": "蘇格蘭今天靠著隊長麥金（John McGinn）全場唯一進球，以1比0擊敗海地，拿下1990年來在世界盃的首場勝利，並暫...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042544.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 12:46", "link": "/news/story/123107/9565496"}, {"article_id": "9565512", "title": "世足運彩／「死亡之組」日、荷首戰只會保守和局機率大 主推2.5小分與正比1：1", "summary": "荷蘭與日本在世足死亡之組首戰即將上演，雙方防守強勁但攻擊力不足，和局機率大。專家預測本場比賽將以1:1收場，並建議投注「2.5小分」和「不讓分和局」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042532.jpg&M=1&s=Y&x=0&y=0&sw=1236&sh=824&exp=3600&sl=W&fw=360", "date": "2026-06-14 12:44", "link": "/news/story/123105/9565512"}, {"article_id": "9565485", "title": "世足運彩／厄瓜多主拚防守 象牙海岸靠轉會籍戰力升級 推薦倒打高賠「不讓分勝」", "summary": "世界盃小組賽E組，厄瓜多以強勁防守迎戰象牙海岸。厄瓜多防守堅韌，歷經南美資格賽僅失1球；象牙海岸則引入雙重國籍新血，狀態火熱。專家建議選擇象牙海岸受讓一球，甚至可考慮不讓分勝的高賠率選項。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042503.jpg&M=1&s=Y&x=0&y=0&sw=1275&sh=850&exp=3600&sl=W&fw=360", "date": "2026-06-14 12:31", "link": "/news/story/123105/9565485"}, {"article_id": "9565481", "title": "NBA／封王戰飆45分比肩喬丹 「關鍵之王」布朗森狂寫多項紀錄", "summary": "尼克球迷終於等到這一刻！尼克在總冠軍賽第5戰以94比90又一次逆轉擊敗馬刺，系列賽以4比1封王，拿下隊史自1973年後首座總冠軍，也讓紐約等待超過半世紀的冠軍荒正式畫下句點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042483.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 12:21", "link": "/news/story/7002/9565481"}, {"article_id": "9565336", "title": "世足運彩／德國洗刷過去2屆恥辱要強攻 古拉索不管比數只會拚進球看好3.5大分", "summary": "德國隊在世界盃首戰對古拉索，將全力求勝以洗刷過去兩屆的恥辱。雖然古拉索希望能打進隊史首球，但德國有意以大比分開局，讓分盤高達3至5球。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042478.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 12:19", "link": "/news/story/123105/9565336"}, {"article_id": "9565432", "title": "NBA／188公分戰神奪FMVP 布朗森奪冠落下英雄淚", "summary": "身高只有188公分的布朗森（Jalen Brunson），今年總冠軍賽率尼克隊粉碎一切質疑，今天第5戰他更狂轟45分，其中29分集中在下半場，率隊扭轉最多16分落後，在客場以94：90擊敗馬刺隊，奪下等待53年的隊史第3冠，讓獲得總冠軍賽MVP的他忍不住流下英雄淚。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042462.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 11:52", "link": "/news/story/7002/9565432"}, {"article_id": "9565373", "title": "世足賽／第94分鐘驚天頭槌踢平強權瑞士 卡達主帥：意義重大", "summary": "隊史第二度參與世足會內賽的卡達，今日在美國舊金山遭遇世界排名13的歐洲強權瑞士，雖在開賽被瑞士先攻進1球，但卡達隨即祭出高壓防守切斷對手攻勢，並在傷停補時第94分鐘由35歲老將胡赫（Boualem Khoukhi）頭槌破網，最終1：1逼平瑞士，拿下隊史頗具歷史意義的第1個積分，卡達總教練在賽後採訪也強調，能夠從瑞士手中拿下1分對他們而言意義重大。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042375.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 11:45", "link": "/news/story/123107/9565373"}, {"article_id": "9565390", "title": "NBA／戰神布朗森狂轟45分 尼克G5逆轉馬刺自1973年後奪隊史第3冠", "summary": "NBA總冠軍賽第5戰今天回到馬刺隊主場進行，退無可退的馬刺最多取得16分領先，但尼克隊在當家球星布朗森（Jalen Brunson）領軍下再度上演瘋狂逆轉勝，布朗森全場狂轟45分，率隊第四節尾聲逆轉，最終以94：90搶下勝利，終結超過50年的等待，捧回1973年後的再一座金盃。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042407.jpg&M=1&s=Y&x=0&y=0&sw=1024&sh=683&exp=3600&sl=W&fw=360", "date": "2026-06-14 11:33", "link": "/news/story/7002/9565390"}, {"article_id": "9564630", "title": "NBA／G5又是逆轉秀！布朗森45分封神戰 尼克94：90終結53年等待奪冠", "summary": "隨著系列賽即將回到聖安東尼奧進行G5，馬刺將全力避免遭到淘汰，而尼克距離隊史自1973年以來首座總冠軍僅差1勝，不過從布朗森到唐斯，尼克全隊目前都展現出相同態度：29分大逆轉已經成為過去式，眼前唯一的目標，就是再拿下一場勝利，將總冠軍帶回紐約。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042086.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 11:29", "link": "/news/story/7002/9564630"}, {"article_id": "9565329", "title": "NBA／溫班亞瑪「法國神墊」布朗森引熱議 美媒怒批：該吹惡意犯規", "summary": "NBA總冠軍賽第5戰再度引發爭議，布朗森在外線命中三分球後落地踩到溫班亞瑪的腳，疑似扭傷腳踝卻未獲判罰。媒體與專家普遍認為應判定為惡意犯規，可能導致溫班亞瑪面臨禁賽懲處，這一判罰引發廣泛討論和批評。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042267.jpg&M=1&s=Y&x=32&y=6&sw=1248&sh=827&exp=3600&sl=W&fw=360", "date": "2026-06-14 10:57", "link": "/news/story/7002/9565329"}, {"article_id": "9565308", "title": "世足賽／不滿意巴西首戰僅逼平 總教練：輸掉很多對抗和控球", "summary": "缺少頭號巨星內馬爾（Neymar）坐鎮的「森巴軍團」，今日在世界盃C組首戰碰頭上屆4強得主摩洛哥，在比賽第21分鐘先是被摩洛哥攻破大門，好在維尼修斯（Vinicius Jr.）在隨後補上一記內切射門，將比分扳平。下半場雙方皆未能越雷池一步，終場以1：1踢平。賽後巴西選手、教練也談到開局球隊表現不佳，以致他們遲遲未能找到節奏。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042237.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 10:47", "link": "/news/story/123107/9565308"}, {"article_id": "9565289", "title": "NBA／溫班亞瑪遭尼克球迷丟雞蛋 巴克利怒轟：這些人是真正懦夫", "summary": "NBA總冠軍賽第4戰後，尼克球迷朝馬刺球星溫班亞瑪丟雞蛋，引發巴克利強烈譴責，稱該行為懦弱。溫班亞瑪坦言未受到影響，並強調這類行為不當。隨著賽事升溫，球迷失序行為成為焦點，NBA需加強場外安全維護。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042231.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 10:36", "link": "/news/story/7002/9565289"}, {"article_id": "9565256", "title": "滑板世界盃羅馬站 13歲林逸凡首進前10有利亞運", "summary": "在義大利舉行的滑板世界盃羅馬站，台灣13歲小將林逸凡今天在16強以81.80高分，居分組第3，可惜總排名第10，未能闖進...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042181.jpg&M=1&s=Y&x=0&y=238&sw=960&sh=640&exp=3600&sl=W&fw=360", "date": "2026-06-14 10:28", "link": "/news/story/7005/9565256"}, {"article_id": "9565215", "title": "NBA／斑馬上半場搧5火鍋 馬刺G5上半場領先5分", "summary": "NBA總冠軍賽第5戰今天回到馬刺隊主場進行，馬刺首節雖取得23：13領先，但第4戰上演落後29分瘋狂逆轉的尼克，第二節在當家球星布朗森（Jalen Brunson）領軍下追分，半場打完差距縮小到37：42。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042101.jpg&M=1&s=Y&x=0&y=94&sw=853&sh=569&exp=3600&sl=W&fw=360", "date": "2026-06-14 09:55", "link": "/news/story/7002/9565215"}, {"article_id": "9565208", "title": "MLB／白襪球迷昨贏到喊「想看翔平」 大谷1轟、3BB「款待」對手", "summary": "白襪隊昨天以8：2大勝大谷翔平缺陣的道奇隊，球迷高喊「\"We want Shohei! We want Shohei!\"」呼喚大谷翔平，今天回歸打線的他，首局首打席就以全壘打「款待」白襪球迷。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042103.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 09:50", "link": "/news/story/6999/9565208"}, {"article_id": "9565116", "title": "NBA／尼克熱潮壓倒世界盃 紐約市民目光聚焦53年來首冠", "summary": "世界盃足球賽嘉年華氣氛今天席捲紐約，但完全敵不過紐約民眾更關心尼克隊爭奪NBA總冠軍的狂熱，足球盛事的聲勢因而相形失色", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042078.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 09:48", "link": "/news/story/7002/9565116"}, {"article_id": "9565206", "title": "MLB／山本由伸無安打比賽又在第9局破功 「棒球真的好難」", "summary": "道奇隊日籍強投山本由伸又一次與偉大紀錄擦身而過，今天面對白襪隊演出23上23下後，先因游擊手貝茲（Mookie Betts）接球失誤，挑戰完全比賽在7.2局夢碎，第9局被敲此役第1支安打，為首位打者彼得斯（Tristan Peters）的陽春砲，無安打比賽的挑戰也畫下句點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042091.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 09:47", "link": "/news/story/6999/9565206"}, {"article_id": "9565205", "title": "MLB／貝茲失誤搞砸完全比賽扛責 山本、魯辛都緩頰「不好處理」", "summary": "道奇隊日籍強投山本由伸前7.2局仍維持完全比賽局面，一顆朝游擊手貝茲（Mookie Betts）而去的滾地球，在下一幕出現令人錯愕的瞬間，一記失誤讓完全比賽夢碎，貝茲扛責：「沒能處理好平常應該處理起來的滾地球，我沒有任何藉口。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042092.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 09:47", "link": "/news/story/6999/9565205"}, {"article_id": "9565148", "title": "MLB／李灝宇隔11天重返大聯盟！ 與「費仔」同場先發都敲安", "summary": "台灣內野手李灝宇相隔11天回到大聯盟！今天在對上守護者之戰擔任先發第9棒、三壘手，2打數敲出1支安打；另一名經典賽國手「費仔」費爾柴德（Stuart Fairchild）同場出賽則有雙安表現。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042004.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 09:00", "link": "/news/story/6999/9565148"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9565492", "title": "世足賽／日本強碰荷蘭 菅原由勢無懼傷兵潮：會像過往一樣創造歷史", "date": "