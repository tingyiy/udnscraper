", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054128.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9573408"}, {"article_id": "9573349", "title": "煮茶論戰／梅西「戴帽」寶刀未老 背後有3大關鍵", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/17/35054050.jpg&M=1&s=Y&x=0&y=22&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9573349"}, {"article_id": "9572592", "title": "世足攻略／英格蘭正常發揮應可勝老邁格子軍 葡萄牙就怕慢熱輕敵被爆冷", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/17/35052981.jpg&M=1&s=Y&x=0&y=0&sw=1253&sh=835&exp=3600&w=300", "link": "/news/story/122629/9572592"}, {"article_id": "9572114", "title": "讓西班牙27次射門成泡影 維德角40歲門將用生命寫「小卒也能成英雄」", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/17/35052448.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9572114"}, {"article_id": "9570610", "title": "中職／測試會挖掘大量珍珠 朱育賢是最閃耀的一顆星", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/16/35050121.jpg&M=1&s=Y&x=0&y=131&sw=745&sh=497&exp=3600&w=300", "link": "/news/story/122629/9570610"}, {"article_id": "9570558", "title": "從百敗大爛隊變美中勁旅 白襪一年完成重建不是只靠村上宗隆", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/16/35050009.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9570558"}]}, {"name": "最新文章", "articles": [{"article_id": "9574043", "title": "NBA／勇士總管談選秀「我要全部」 冠軍前鋒第11順位呼聲高", "summary": "勇士隊現有陣容年紀過大，今年選秀握有首輪第11順位，將是陣容年輕化關鍵。勇士總管鄧利維（Mike Dunleavy）坦言球隊任何類型球員都缺，密西根大學前鋒倫德伯格（Yaxel Lendeborg）傳出備受勇士內部關注。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35055155.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-18 11:01", "link": "/news/story/7002/9574043"}, {"article_id": "9573953", "title": "NBA／太陽球星布克要換球衣背號 下季改穿「15」致敬父親", "summary": "太陽球星布克宣布下賽季將改穿15號球衣，以致敬父親及延續在國家隊的傳承。這一變更標誌著他從啟用多年的1號球衣轉變，並有望成為太陽隊歷史上第16位穿著此號碼的球員。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054993.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 10:54", "link": "/news/story/7002/9573953"}, {"article_id": "9573798", "title": "MLB／「卡仔」滿貫砲重創天使 助攻隊友羅德里奎茲生涯百勝", "summary": "卡洛爾轟出滿貫砲助響尾蛇8：1戰勝天使，鎖定系列賽勝利。此役中，卡洛爾貢獻4分打點，並協助隊友羅德里奎茲達成職業生涯第100勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054708.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 10:27", "link": "/news/story/6999/9573798"}, {"article_id": "9573940", "title": "MLB／鄧愷威先發地位暫時不動 22日對決守護者期待甩掉3連敗", "summary": "太空人隊今天以4：2擊敗老虎隊，3連戰取得2勝1敗，後天繼續在休士頓主場迎戰守護者隊，台灣投手鄧愷威將在22日登板先發，期待甩掉最近3連敗陰霾。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054979.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 10:23", "link": "/news/story/6999/9573940"}, {"article_id": "9573895", "title": "NBA／童年時熬夜為看喬丹打球 史普利特接掌公牛教鞭盼重返榮耀", "summary": "公牛在今天召開新任總教練加盟記者會，宣布由前馬刺冠軍中鋒史普利特（Tiago Splitter）正式接掌教鞭，這位來自巴西的主帥透露，自己從小就是經常偷偷熬夜看喬丹（Michael Jordan）打球長大的公牛迷，如今承接這份榮耀，他強調將帶入高標準的球隊文化，率領風城軍團走出連4季無緣季後賽的低谷。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054880.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 10:11", "link": "/news/story/7002/9573895"}, {"article_id": "9573862", "title": "NBA／若詹姆斯離開湖人？勇士記者：提中產合約、派柯瑞招募", "summary": "詹姆斯（LeBron James）是否會離開湖人隊，加入勇士隊與柯瑞（Stephen Curry）聯手，是今年NBA休賽季最大焦點，但勇士隨隊記者史萊特（Anthony Slater）認為詹姆斯高機率重返湖人，若他進入自由球員市場，勇士也只會開出1510萬美元的中產特例合約。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054842.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 10:05", "link": "/news/story/7002/9573862"}, {"article_id": "9573689", "title": "世足賽／帽子戲法仍被討厭！梅黑曝原因：全隊都在服務梅西", "summary": "梅西（Lionel Andrés Messi）在今年世界盃對上阿爾及利亞時上演帽子戲法，阿根廷下一場世界盃小組賽將於台灣時間6月23日凌晨1點對陣奧地利。一名網友發文，稱梅西雖然很厲害，但他並不喜歡整個球隊都在服務他的踢法，而更喜歡如德國、義大利或日本隊這種各司其職的球風。對此，引來網友們熱烈討論，有球迷反駁梅西無論是射門、傳球還是創造能力都十分優秀，不應該說是球隊在服務他，而是他在服務球隊更為準確。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054990.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 09:56", "link": "/news/story/123107/9573689"}, {"article_id": "9573786", "title": "NBA／詹皇續留湖人機率大增 冠軍搭檔「愛神」有望加盟紫金大軍", "summary": "自由球員市場即將開啟，傳出詹姆斯（LeBron James）很有可能續留湖人隊，昔日騎士隊奪冠拍檔「愛神」勒夫（Kevin Love）也有望加入紫金軍團。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054681.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 09:41", "link": "/news/story/7002/9573786"}, {"article_id": "9573777", "title": "NBA／尼克暌違53年封王遊行降臨 紐約動員萬名警力寫歷史紀錄", "summary": "尼克在今年總冠軍賽擊敗馬刺，奪下隊史暌違53年的NBA總冠軍，讓整座紐約市陷入瘋狂，紐約市預計於美國時間4日在曼哈頓隆重舉行傳統的「英雄谷」封王大遊行，紐約市警察局今天宣布，將部署高達1萬名警力進駐維安，寫下紐約史上計畫性活動動員警力的最高紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054675.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 09:33", "link": "/news/story/7002/9573777"}, {"article_id": "9573748", "title": "世足賽／20歲小將傷停進球 迦納絕殺巴拿馬", "summary": "迦納和巴拿馬今天比數一直掛零，直到傷停補時迦納才打破僵局，靠伊倫基（Caleb Yirenkyi）傷停補時的巧射破網「絕殺」巴拿馬，驚險搶下3分積分。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054624.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 09:18", "link": "/news/story/123107/9573748"}, {"article_id": "9573715", "title": "MLB／羅伯茲不在意大谷連兩戰失4分 為何派翔平代打也給了答案", "summary": "大谷翔平今天對光芒隊先發6局失4分，幫助道奇隊5：4獲勝，在洛杉磯主場完成3連戰橫掃；大谷雖獲本季第7勝，但最近兩場先發都失4分，道奇總教練羅伯茲（Dave Roberts）很有信心說：「我並沒有太在意。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054592.jpg&M=1&s=Y&x=322&y=286&sw=850&sh=567&exp=3600&sl=W&fw=360", "date": "2026-06-18 09:00", "link": "/news/story/6999/9573715"}, {"article_id": "9573709", "title": "世足賽／凱恩成英格蘭進球王 一紀錄並肩貝克漢", "summary": "英格蘭隊長凱恩（Harry Kane）第三度出征世界盃，今天首戰碰強敵克羅埃西亞就「梅開二度」，除率隊以4：2踢下首勝，個人世界盃進球數累積到第10顆，已經追平前輩李納克（Gary Lineker）1986年到1990年紀錄，再一球就能獨居隊史世界盃進球王。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054576.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-18 08:57", "link": "/news/story/123107/9573709"}, {"article_id": "9573673", "title": "世足賽／南非中場遭禁賽3場、梅西踩人卻沒事 主帥砲轟VAR裁判雙標", "summary": "南非在今年世足賽首戰與地主墨西哥展開慘烈激戰，該場比賽裁判不僅送出3張紅牌，創下開幕戰新紀錄，老將茲瓦內（Themba Zwane）還因此遭到禁賽3場重罰，對此南非隊總教練布魯斯（Hugo Broos）在今天大表不滿，公開質疑FIFA與影像輔助裁判（VAR）存在「雙重標準」，直言阿根廷巨星梅西（Lionel Messi）逃過判罰，兩者待遇天差地遠。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054507.jpg&M=1&s=Y&x=0&y=0&sw=1274&sh=850&exp=3600&sl=W&fw=360", "date": "2026-06-18 08:32", "link": "/news/story/123107/9573673"}, {"article_id": "9573651", "title": "MLB／大谷手指破皮流血奮勇奪勝 臨時代打也沒有特別緊張", "summary": "大谷翔平今天對光芒隊先發6局失4分，奪下本季第7勝，但他最近左膝發炎，右手中指也起水泡，引發媒體和球迷關注，他說：「並未對投球造成很大影響。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054960.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 08:19", "link": "/news/story/6999/9573651"}, {"article_id": "9573649", "title": "世足賽／失望上半場平手狀態 凱恩曝教頭一席話成擊退格子軍關鍵", "summary": "身為本屆世界盃冠軍熱門之一，「三獅軍團」英格蘭有好的起步，今天首戰在隊長凱恩（Harry Kane）連進兩球領軍下以4：2擊敗連兩屆闖進4強的克羅埃西亞，凱恩透露總教練圖赫爾（Thomas Tuchel）中場休息的一番話提振士氣，讓團隊下半場充滿能量，成甩開克羅埃西亞關鍵。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054487.jpg&M=1&s=Y&x=0&y=0&sw=1256&sh=838&exp=3600&sl=W&fw=360", "date": "2026-06-18 08:18", "link": "/news/story/123107/9573649"}, {"article_id": "9573627", "title": "世足賽／零封西班牙爆紅獲千萬粉絲 維德角門將之母獲美簽一圓觀賽夢", "summary": "維德角門將沃齊尼亞（Vozinha），靠著日前在與西班牙之戰全場7度撲救成功，幫助維德角以0：0逼平奪冠熱門西班牙，一夕爆紅，不僅社群追蹤人數從賽前的5萬人到如今已突破1200萬，其母親也在美國國務院的幫助下獲得美國簽證，將能如願到場為兒子加油打氣。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054450.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 07:58", "link": "/news/story/123107/9573627"}, {"article_id": "9573613", "title": "世足賽／走出硫酸襲擊險失明與綁女陰霾 維薩頂進剛果足球新歷史", "summary": "當足球在休士頓的夜空中劃出一道弧線，剛果前鋒維薩（Yoane Wissa）高高躍起，在上半場傷停補時階段，頂碎了葡萄牙的領先美夢，也徹底掀翻了剛果足球半個世紀的沉悶，這記頭錘是剛果在世足賽正賽舞台的歷史性首顆進球，背後更是維薩與生命激烈拉扯的精彩人生。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054428.jpg&M=1&s=Y&x=121&y=189&sw=1073&sh=716&exp=3600&sl=W&fw=360", "date": "2026-06-18 07:40", "link": "/news/story/123107/9573613"}, {"article_id": "9573598", "title": "MLB／李灝宇對太空人3支0、吞2K 終止連4戰安打紀錄", "summary": "老虎隊作客休士頓，今天對太空人隊進行3連戰最後一戰，旅美好手李灝宇3次打數掛零，吞下兩次三振，終止連續4場比賽安打紀錄，老虎全場只有3支安打，終場以2：4落敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054412.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 07:22", "link": "/news/story/6999/9573598"}, {"article_id": "9573587", "title": "世足賽／從「薩伊」到剛果的52年等待 維薩頂進隊史首進球：巨大驕傲", "summary": "前一次在世足賽舞台亮相，帶著0勝3敗、未進球紀錄敗興而歸的剛果民主共和國，暌違52年再戰世足賽會內賽，首戰就遭遇強敵葡萄牙，並且靠著前鋒維薩（Yoane Wissa）在上半場傷停補時階段頂進隊史歷史性的第一記進球逼平葡萄牙，拿下在世足賽的首個積分，賽後維薩也強調，全隊在這場比賽中展現了勇氣與韌性。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054397.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 07:03", "link": "/news/story/123107/9573587"}, {"article_id": "9573408", "title": "中職／鍾允華離新人王最近 但兩名自培新秀也值得肯定", "summary": "中職上半季即將結束，鍾允華成為最佳新人的熱門人選，防禦率僅1.96，已累積14次救援成功。樂天的劉子杰與味全的王伯洋也展現優異表現，值得關注。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054128.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 07:00", "link": "/news/story/122629/9573408"}, {"article_id": "9573579", "title": "MLB／弗里曼致勝兩分砲 大谷翔平6局失4分奪第7勝與5連勝", "summary": "大谷翔平今天登板先發，對光芒隊先發6局失4分，道奇隊6局下靠弗里曼（Freddie Freeman）轟出兩分砲逆轉戰局，終場以5：4獲勝，在主場完成3連戰橫掃，大谷奪下本季第7勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054394.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 06:53", "link": "/news/story/6999/9573579"}, {"article_id": "9573578", "title": "NBA／川普送出邀請 尼克隊受邀訪問白宮", "summary": "紐約尼克隊日前戰勝馬刺隊，贏得NBA總冠軍，尼克隊的球隊老闆杜蘭（James Dolan）17日表示，尼克隊將接受邀請訪問白宮。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054902.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 06:42", "link": "/news/story/7002/9573578"}, {"article_id": "9573577", "title": "世足賽／C羅連10場國際賽沒進球 主帥力挺：換下史上最佳射手沒意義", "summary": "在梅西（Lionel Messi）昨天於今年世足賽首秀上演「帽子戲法」帶領阿根廷取勝後，另一名超級巨星C羅（Cristiano Ronaldo）則是在今天凌晨與剛果之戰登場，不過在全場3次射門都未能形成射正的情況下，最終葡萄牙也遭到剛果以1：1踢平，C羅也寫下連續10場國際大賽未能進球紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054727.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 06:40", "link": "/news/story/123107/9573577"}, {"article_id": "9573539", "title": "世足賽／凱恩「梅開二度」 英格蘭4：2退格子軍團", "summary": "英格蘭和克羅埃西亞的L組首戰高潮迭起，「三獅軍團」靠當家球星凱恩（Harry Kane）罰球、頭錘「梅開二度」，貝林漢（Jude Bellingham）也建功，拉什福德（Marcus Rashford）第85分鐘再補刀，助英格蘭以4：2擊敗上屆奪下季軍的「格子軍團」，以3分積分暫居龍頭。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054365.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-18 06:06", "link": "/news/story/123107/9573539"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9573577", "title": "世足賽／C羅連10場國際賽沒進球 主帥力挺：換下史上最佳射手沒意義", "date": "2026-06-18 06:40", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054727.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&