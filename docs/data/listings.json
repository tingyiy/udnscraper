icle_id": "9531535", "title": "中職／打教不下台！兄弟一、二軍打擊教練互換這脈絡可以嗎？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34990958.jpg&M=1&s=Y&x=0&y=33&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9531740", "title": "哈登邁入37歲急速衰退老化 騎士暑假作業進退兩難", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992674.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9531257", "title": "碰不得的亞歷山大！哨音之力如何破壞馬刺的防守致勝", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34990424.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300"}, {"article_id": "9530153", "title": "角色球員的價值差異：雷霆發大財、馬刺補財庫", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34988552.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9530085", "title": "釀酒人王牌領銜火球世代來襲 大谷翔平、史肯斯也相形失色", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34988434.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9528843", "title": "費城人桑契斯指標數據太強成塞揚首選！ 大谷局數太少是致命傷", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34986739.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9533646", "title": "NBA／20歲哈波季後賽累積223分！ 紀錄僅輸泰托姆、赫洛、魔術強森", "summary": "馬刺在西區冠軍賽第6戰成功將系列賽逼進搶七，除了溫班亞瑪（Victor Wembanyama）與卡瑟爾（Stephon Castle）扛起核心角色外，替補出發的菜鳥後衛哈波（Dylan Harper）也成為關鍵奇兵。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34993836.jpg&M=1&s=Y&x=0&y=76&sw=1166&sh=777&exp=3600&sl=W&fw=360", "date": "2026-05-29 15:07"}, {"article_id": "9533570", "title": "日職／前廣島球員涉「喪屍煙彈」有罪 直播爆料共6人向同一人購買", "summary": "日本職棒廣島東洋鯉魚前球員羽月隆太郎，因使用俗稱「喪屍煙彈」的指定藥物「依托咪酯」遭判有罪後，28日晚間透過社群平台直播公開說明事件，更驚爆「包含我在內，共有6名廣島球員曾向同一人物購買」，再度震撼日本職棒界。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34993745.jpg&M=1&s=Y&x=23&y=0&sw=1181&sh=787&exp=3600&sl=W&fw=360", "date": "2026-05-29 14:31"}, {"article_id": "9533451", "title": "中職／周思齊引退發願成真 台北市立棒球場紀念碑小巨蛋落成", "summary": "台北小巨蛋舊址為台北市立棒球場，為了紀念原先的球場，北市府計畫「台北好球 世代交棒」棒球紀念碑，今在小巨蛋北廣場落成。亞洲棒球總會長特助周思齊也到場，他說，感謝這20多年來文史工作者及市長蔣萬安倡議，棒球教會了大家傳承。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34993560.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 13:36"}, {"article_id": "9533389", "title": "NBA／「搶6苦手」！SGA正負值-28平MVP尷尬紀錄 罰球命中多過進球惹議", "summary": "雷霆原本距離重返NBA總冠軍賽只差一步，但在西區冠軍賽第6戰，兩屆年度MVP亞歷山大（Shai Gilgeous-Alexander）卻未能挺身而出。雷霆在客場遭馬刺痛擊，以91比118慘敗，系列賽被扳成3比3平手，雙方將回到奧克拉荷馬進行生死第7戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34993447.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 13:22"}, {"article_id": "9533386", "title": "NBA／穿長袍入場還剃光頭展決心 溫班亞瑪將向前輩請益搶七經驗", "summary": "馬刺今天在西區冠軍賽第六戰，靠著溫班亞瑪（Victor Wembanyama）觸底反彈拿下28分的表現，以27分差距將系列賽帶入搶七大戰，談到將經歷生涯首度的搶七大戰，溫班亞瑪賽後也透露，將向身邊老大哥們尋求關於搶七大戰的建議與經驗分享。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34993436.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 13:08"}, {"article_id": "9533286", "title": "MLB／沒人看過這種球員！名投盛讚大谷翔平強到「令人屏息」", "summary": "大谷翔平昨日在主場以「二刀流」身分出擊，「打者大谷」首打席開轟棒打前輩菅野智之，「投手大谷」則繳出6局失1分、7K的優質先發奪勝，沒被敲安打。對此，前大聯盟名投席林（Curt Schilling）談到大谷時，更直言「根本沒有人看過這樣的球員。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34993351.jpg&M=1&s=Y&x=0&y=0&sw=1199&sh=799&exp=3600&sl=W&fw=360", "date": "2026-05-29 12:47"}, {"article_id": "9533275", "title": "NBA／霸氣喊「我們比雷霆更強」 21歲卡瑟爾全能紀錄超越Kobe", "summary": "馬刺在西區冠軍賽第6戰成功延續賽季生命，將系列賽逼進第7戰，除了溫班亞瑪（Victor Wembanyama）再度打出關鍵表現外，年輕後衛卡瑟爾（Stephon Castle）同樣扮演重要角色。他此役先發出賽32分鐘，10投5中、罰球8罰7中，繳出17分、9助攻、5籃板、1抄截，攻守兩端都展現十足侵略性。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34993267.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-29 12:36"}, {"article_id": "9533260", "title": "PLG／盧峻翔年度MVP三連霸史上首位 領航猿年度第一隊持續霸榜", "summary": "PLG今天公布2025-26球季年度MVP、年度洋將及年度第一隊，桃園璞園領航猿隊的盧峻翔成為聯盟史上第1位完成年度MVP三連霸的球員，年度洋將則由年度阻攻王兼年度防守球員的伯朗蟬聯，年度第一隊本季領航猿依舊有3名球員入選仍居各隊之冠。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34993218.jpg&M=1&s=Y&x=0&y=0&sw=1024&sh=683&exp=3600&sl=W&fw=360", "date": "2026-05-29 12:14"}, {"article_id": "9533168", "title": "NBA／溫班亞瑪展現侵略性逼出搶七 讚賞替補陣容表現出色", "summary": "面對輸球就淘汰的絕境，馬刺少主溫班亞瑪（Victor Wembanyama）很清楚第6戰需要什麼樣的態度。這位法國天才從開賽就展現侵略性，不僅率先點燃球隊外線火力，也帶動馬刺上半場轟進11記三分球，創下隊史季後賽任一上半場最多三分球紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992946.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 12:02"}, {"article_id": "9533086", "title": "田徑／羅聖欽男子5000公尺競走再奪牌 U20亞錦賽中華隊累積2銀", "summary": "在香港舉行的第22屆亞洲U20田徑錦標賽，我國代表隊繼昨天由長跑新星簡子傑在男子3000公尺以破自己所保持全國紀錄的8分00秒42成績奪下銀牌後，今天再傳奪牌捷報，羅聖欽在男子5000公尺競走決賽中，最終以19分56秒17的優異成績勇奪銀牌，為中華隊進帳本屆賽事第二面獎牌。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34993004.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 11:30"}, {"article_id": "9533060", "title": "MLB／晚場出賽防禦率不到1 海盜王牌史肯斯5.1局飆10K仍吞敗", "summary": "海盜隊王牌投手史肯斯（Paul Skenes）歷經前兩戰先發大失分後，今天在主場出戰小熊隊，先發5.1局飆10次三振仍贏不了，失3分（1分自責分），最終海盜以2：7落敗，在國聯中區排名墊底。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992979.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 11:23"}, {"article_id": "9532986", "title": "NBA／湖人續約里夫斯現變數？籃網握薪資空間伺機搶人 新合約近2億", "summary": "洛杉磯湖人後衛里夫斯（Austin Reaves）原本被外界普遍認為將在今年休賽季續留湖人，不過根據《ESPN》報導，布魯克林籃網可能成為值得關注的競爭者，為這位人氣後衛的未來增添變數。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992912.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 11:12"}, {"article_id": "9532994", "title": "NBA／溫班亞瑪觸底反彈飆28分 馬刺大勝雷霆27分逼出搶七", "summary": "在西區冠軍賽第5戰進攻遭到雷霆隊強力封鎖後，馬刺隊今天回到主場再次反彈，尤其是當家球星溫班亞瑪（Victor Wembanyama）上半場就狂轟22分，帶領馬刺取得雙位數領先，下半場馬刺更是靠著防守讓雷霆進攻窒礙難行，並將領先差距擴大到20分以上，最終馬刺就以118：91再次扳平戰局，雙方也將回到奧克拉荷馬市進行搶七大戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992911.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-29 11:01"}, {"article_id": "9532903", "title": "法網／聽牌後卻體能「撞牆」遭逆轉 辛納：我完全使不上力", "summary": "法國網球公開賽男單賽場昨天深夜爆出大冷門，世界球王、義大利名將辛納（Jannik Sinner）在手握兩盤領先時卻出現身體不適「撞牆」，慘遭世界排名第56的阿根廷黑馬塞倫多羅（Juan Manuel Cerundolo）逆轉，讓他挑戰生涯「全滿貫」的計畫又要延期一年。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992711.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 10:21"}, {"article_id": "9532670", "title": "世足賽／阿根廷26人名單有梅西！續任隊長第6度征戰拚衛冕", "summary": "阿根廷國家足球隊總教練斯卡洛尼（Lionel Scaloni）今天公布世界盃26人名單，巨星梅西（Lionel Mess...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992562.jpg&M=1&s=Y&x=77&y=129&sw=1093&sh=728&exp=3600&sl=W&fw=360", "date": "2026-05-29 09:55"}, {"article_id": "9532817", "title": "中華奧會取得2029年TAFISA世界研討會主辦權 170餘國代表將來台交流", "summary": "國際全民運動總會（TAFISA）宣布，已於15日假捷克布拉格召開的2026國際全民運動總會會員大會（TAFISA General Assembly）中，由中華台北奧林匹克委員會成功取得2029年TAFISA世界研討會暨會員大會（TAFISA World Congress & General Assembly）主辦權。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992539.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 09:49"}, {"article_id": "9532816", "title": "中職／兄弟火力無助5月已吞14敗 逼近隊史單月最多敗紀錄", "summary": "中信兄弟隊吞下7連敗，5月戰績是難堪的5勝14敗，已經逼近隊史單月最多16敗紀錄，接下來將與富邦悍將隊在台北大巨蛋進行3連戰，若黃衫軍在這波系列賽吞2敗將平紀錄，若遭到橫掃將寫下隊史破天荒的單月17敗，同時也將追平聯盟紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992538.jpg&M=1&s=Y&x=0&y=0&sw=1129&sh=753&exp=3600&sl=W&fw=360", "date": "2026-05-29 09:49"}, {"article_id": "9532814", "title": "MLB／鄧愷威30日強碰國中老大釀酒人 挑戰第4勝、先發3連勝", "summary": "效力太空人隊的台灣投手鄧愷威下一場先發出爐，將於明天早上8點10分強碰國聯中區龍頭釀酒人隊，鄧愷威將挑戰本季第4勝、先發3連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992556.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 09:49"}, {"article_id": "9532636", "title": "NBA／尼克總冠軍賽前夕傳噩耗 中鋒羅賓森右小指骨折歸期未定", "summary": "暌違27年再度殺進總冠軍賽的老牌勁旅尼克，在系列賽開打前夕卻遭遇沉重打擊，禁區悍將羅賓森（Mitchell Robinson）在備戰期間不慎遭遇右小指骨折傷勢，目前球團尚未給出具體的復出時間表，無疑是為尼克即將到來的爭冠之路蒙上一層陰影。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992317.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 07:50"}, {"article_id": "9532623", "title": "NBA／僅有灰熊投反對票 防擺爛「3-2-1」樂透新制2027年上路", "summary": "為了徹底根除聯盟多年來備受詬病的「惡意擺爛」歪風，NBA董事會於今天以29：1的壓倒性票數，通過選秀抽籤制度的重大改革，這項被稱為「3-2-1樂透制」的新版方案預計將於2027年選秀會正式上路，屆時樂透球隊將從現行的14隊擴編至16隊，連東西區的季後賽第8種子也將被納入抽籤範圍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992626.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 07:37"}, {"article_id": "9531535", "title": "中職／打教不下台！兄弟一、二軍打擊教練互換這脈絡可以嗎？", "summary": "中信兄弟一軍打擊教練表現不佳，導致球迷不滿並高舉標語抗議。球團發聲明指控報導去脈絡化，強調應珍惜支持球隊的球迷。有分析指出，調整一二軍打擊教練或能改善目前打擊疲弱的情況。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34990958.jpg&M=1&s=Y&x=0&y=33&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 07:00"}, {"article_id": "9531740", "title": "哈登邁入37歲急速衰退老化 騎士暑假作業進退兩難", "summary": "騎士面臨進退兩難，計畫以「先簽後換」交易湖人前鋒詹姆斯補強陣容，但37歲的哈登老化影響球隊未來。教練亞特金森的執教能力也備受質疑，隊伍需全面升級以應對挑戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992674.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 07:00"}, {"article_id": "9532327", "title": "棒球／推廣基層棒球 中信銀贊助菲國棒協", "summary": "中國信託商業銀行長期投入台灣五級棒球發展，為國內第一家支持五級棒球的企業。基於善盡企業社會責任，深化體育公益之理念，中國信託銀行宣布將贊助兩萬五千美元等值的球具予菲律賓棒球協會，由中國信託銀行菲律賓子行財務長Andrew Falcon，以象徵性的支票和球具致予菲國棒協會長Rodolfo Tingzon Jr.。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34991934.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-29 00:08"}, {"article_id": "9532234", "title": "新加坡羽賽／壓軸扳倒第4種子 戚又仁打出代表作勇闖8強", "summary": "世界排名18的我國羽將戚又仁今天打出代表作，新加坡公開賽壓軸上陣的他面對世界排名第4的法國名將波波夫（Christo Popov），克服決勝局兩度5分落後，在場邊觀眾讓情喊「加油」聲中以20：22、21：19、23：21逆轉勝，勇闖8強，也成單打僅存的台將希望。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34991872.jpg&M=1&s=Y&x=0&y=38&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-28 22:57"}]}, {"name": "棒球", "articles": [{"article_id": "9533451", "title": "中職／周思齊引退發願成真 台北市立棒球場紀念碑小巨蛋落成", "date": "2026-05-29 13:36", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34993560.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9533570", "title": "日職／前廣島球員涉「喪屍煙彈」有罪 直播爆料共6人向同一人購買", "date": "2026-05-29 14:31", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34993745.jpg&M=1&s=Y&x=23&y=0&sw=1181&sh=787&exp=3600&w=300"}, {"article_id": "9532816", "title": "中職／兄弟火力無助5月已吞14敗 逼近隊史單月最多敗紀錄", "date": "2026-05-29 09:49", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/29/34992538.jpg&M=1&s=Y&x=0&y=0&sw=1129&sh=753&exp=3600&w=300"}, {"article_id": "9532327", "title": "棒球／推廣基層棒球 中信銀贊助菲國棒協", "date": "2026-05-29 00:08", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/28/34991934.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=853&exp=3600&w=300"}, {"article_id": "9532157", "title": "中職／魔鷹雙響砲灌5打點 台鋼賞兄弟近7年最慘7連敗", "date": "2026-05-28 21:52", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=htt