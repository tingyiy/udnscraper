to.php?u=https://uc.udn.com.tw/photo/t3/2026/06/07/35021188.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9551432"}]}, {"name": "最新文章", "articles": [{"article_id": "9555345", "title": "世足賽／日本隊抵美備戰 遠藤航拚首戰前傷癒", "summary": "日本隊為了準備即將開幕的世界盃足球賽，已經抵達美國。而日本隊長遠藤航正在與時間賽跑，力拚首戰對上荷蘭前能恢復健康。日本隊...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027036.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-09 15:10", "link": "/news/story/123107/9555345"}, {"article_id": "9555219", "title": "排球／女子亞洲盃 中華輕取烏茲別克預賽3連勝", "summary": "2026年女子亞洲盃排球賽，中華代表隊今天在預賽第3戰對上烏茲別克，仍舊發揮出賽的團隊實力，以25比17、25比13、2...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027027.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 15:08", "link": "/news/story/7005/9555219"}, {"article_id": "9555310", "title": "MLB／近23戰狂吞18敗！布萊格曼坦言拖累小熊戰績：我爛透了", "summary": "小熊休賽季重金簽下的明星三壘手布萊格曼（Alex Bregman），面對球隊近期戰績持續下滑，忍不住公開承認自己表現遠低於預期，甚至直言本季進攻表現「糟透了」，坦承若自己能打出應有水準，現在的戰績可能會好上許多。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026931.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-09 14:52", "link": "/news/story/6999/9555310"}, {"article_id": "9555319", "title": "中職／聯盟提前宣布新莊、洲際延賽 25、26日原地補賽", "summary": "中華職棒今天原定在新莊、台中洲際球場進行兩場比賽，受到大雨影響，聯盟下午提前公告延賽訊息，球迷不必白跑一趟。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026956.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 14:46", "link": "/news/story/7001/9555319"}, {"article_id": "9554960", "title": "MLB／費城人王牌再繳塞揚級壓制力！桑契斯7局10K封鎖藍鳥打線奪勝", "summary": "費城人王牌左投桑契斯（Cristopher Sánchez）近期不斷刷新外界對他的期待。雖然日前對教士之戰結束連續50.2局無失分紀錄，但他今日面對藍鳥依舊展現賽揚等級壓制力，主投7局僅失2分、狂飆10次三振，率領球隊以5：2擊敗藍鳥，收下本季第8勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026312.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 14:31", "link": "/news/story/6999/9554960"}, {"article_id": "9555214", "title": "NBA／決賽觀賽派對數萬人身著藍橙 曼哈頓、布碌崙狂歡", "summary": "NBA紐約尼克隊(New York Knicks)8日晚在曼哈頓麥迪遜廣場花園(MSG)主場迎戰聖安東尼奧馬刺隊(San Antonio Spurs)，舉行系列賽第三場比賽。數以萬計的紐約球迷則分別聚集在曼哈頓中央公園、布萊恩公園(Bryant Park)和布碌崙(布魯克林)保齡球館(Brooklyn Bowl)透過電視轉播觀看比賽，共同見證家鄉球隊尼克隊衝刺NBA總冠軍的歷史性一刻。無論場館大廳還是街頭，身著藍橙兩色服裝的球迷們都在歡呼吶喊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026739.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 14:31", "link": "/news/story/7002/9555214"}, {"article_id": "9554907", "title": "NBA／總冠軍賽G3季票球迷天人交戰 轉賣2張票能獲利8000元", "summary": "紐約尼克隊帶著兩勝優勢回到麥迪遜廣場花園主場，有機會實現一些尼克球迷自1999年苦苦等待的總冠軍之夢。而這場史詩大戰的票價隨之飆升，轉售價上看近萬元，部分季票球迷掙扎要一睹球隊風采、有個終生難忘的回憶，或是放棄門票先讓這筆意外之財入袋為安。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026234.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 14:23", "link": "/news/story/7002/9554907"}, {"article_id": "9554981", "title": "世足賽／亞洲9隊闖會內賽 日韓領軍闖淘汰賽", "summary": "2023年世足賽，亞洲共9隊進入正賽，日韓雙雄被看好能晉級淘汰賽，尤其日本在小組中具競爭力。澳洲與伊朗也有機會出線，而伊拉克及約旦則在難度極高的小組中挑戰艱鉅。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026823.jpg&M=1&s=Y&x=0&y=0&sw=1276&sh=850&exp=3600&sl=W&fw=360", "date": "2026-06-09 14:21", "link": "/news/story/123107/9554981"}, {"article_id": "9555221", "title": "世足賽／首次擴編48隊 台灣收看方式一次了解", "summary": "2026年FIFA世界盃將於台灣時間6月12日凌晨到7月20日盛大登場，愛爾達電視連續四次取得台灣區轉播總代理，透過ELTA.tv全程完整播出史上首次擴編48隊、共計104場賽事，同時將同步授權中華電信MOD、Hami Video電視運動館完整賽事，以及有線電視東森電視、無線電視台視播出精選賽事，透過多元平台服務，讓更多台灣觀眾共同參與這場全球足球盛會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026752.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-06-09 14:07", "link": "/news/story/123107/9555221"}, {"article_id": "9555118", "title": "結合厭世迷因文化 《2026海綿寶寶人生馬拉松》北中南三地開跑", "summary": "《2026海綿寶寶人生馬拉松》正式登場，以「人生馬拉松，人生是場謎」為主題，結合近年最具共鳴的厭世迷因文化，將現代上班族職場壓力、生活疲憊與日常情緒，轉化為一場充滿幽默感與療癒的沉浸式路跑體驗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026540.png&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-09 13:22", "link": "/news/story/7005/9555118"}, {"article_id": "9555102", "title": "TPBL／前宇都宮冠軍教頭入港 紐西蘭籍齊科執掌海神兵符", "summary": "TPBL高雄全家海神今天宣布新賽季將由前日本B聯盟宇都宮皇者總教練、紐西蘭籍齊科（Zico Coronel）執掌兵符，雙方簽下複數年合約，齊科擁有超過20年執教資歷，擔任總教練及助理教練期間奪下7座總冠軍，2021年、2025年更分別獲紐西蘭NBL、日本B聯盟年度最佳教練殊榮。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026509.jpg&M=1&s=Y&x=0&y=0&sw=1023&sh=682&exp=3600&sl=W&fw=360", "date": "2026-06-09 13:14", "link": "/news/story/7003/9555102"}, {"article_id": "9555091", "title": "NBA／手感不佳卻投進關鍵球 溫班亞瑪談福克斯：最可靠的那種球員", "summary": "馬刺今天在總冠軍賽第3戰於尼克主場背水一戰，在第四節幾乎一路領先的情況下，卻又在比賽最後一分鐘被尼克步步近逼，但關鍵時刻整場比賽手感不佳的福克斯（De'Aaron Fox），卻在雙人包夾下投進致命中距離跳投，幫助馬刺守成，賽後溫班亞瑪（Victor Wembanyama）與卡瑟爾（Stephon Castle）也大讚福克斯的大心臟，並強調他絕對是球隊在關鍵時刻最可靠的球員。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026505.jpg&M=1&s=Y&x=0&y=139&sw=853&sh=569&exp=3600&sl=W&fw=360", "date": "2026-06-09 13:10", "link": "/news/story/7002/9555091"}, {"article_id": "9555088", "title": "MLB／亞土維奇襲跑壘幫太空人贏球 明天交給鄧愷威拚連勝", "summary": "太空人隊作客洛杉磯，今天對天使隊進行3連戰首戰，36歲老將亞土維（Jose Altuve）10局上發動奇襲，從三壘冒險衝向本壘得分，太空人終場以5：4獲勝，明天第2戰先發任務交給台灣投手鄧愷威。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026495.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-09 13:08", "link": "/news/story/6999/9555088"}, {"article_id": "9555039", "title": "NBA／不滿下半場罰球數24比8 尼克主帥：沒想過會在總冠軍賽遇到", "summary": "尼克在總冠軍賽第3戰以111比115不敵馬刺，終結季後賽13連勝，同時系列賽也被追成2比1。賽後尼克總教練布朗（Mike Brown）公開表達對判罰尺度的不滿，尤其針對馬刺下半場獲得24次罰球，而尼克只有8次罰球，直言這樣的落差在總冠軍賽舞台上相當難以接受。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026445.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 13:01", "link": "/news/story/7002/9555039"}, {"article_id": "9555049", "title": "NBA／聯手卡瑟爾寫最年輕記錄 溫班亞瑪還創下70阻攻新里程碑", "summary": "在主場連輸兩戰後，馬刺今天在總冠軍賽第三戰作客尼克主場，總算在末節關鍵時刻頂住壓力、成功守成，其中年輕雙星溫班亞瑪（Victor Wembanyama）與卡瑟爾（Stephon Castle）更成為史上第一對在總冠軍賽同場皆拿下20分以上的22歲以下組合，展現了這支年輕勁旅的可怕天賦。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026457.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 12:59", "link": "/news/story/7002/9555049"}, {"article_id": "9554916", "title": "馬刺贏下G3生死戰減壓 過程險象環生對「神仙尼克」仍難樂觀", "summary": "馬刺在G3生死戰中以115：111險勝尼克，成功減輕壓力，系列賽追成1：2。然而，尼克球隊狀況良好，尤其是布朗森表現堅穩，馬刺需調整防守策略及強攻禁區，才能向G4發起反擊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026372.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 12:50", "link": "/news/story/122629/9554916"}, {"article_id": "9554933", "title": "NBA／22歲繳全能數據比肩兩大傳奇 溫班亞瑪：最艱難還在後面", "summary": "主場吞下2連敗的馬刺，今天在紐約客場的第四節關鍵時刻靠著卡瑟爾（Stephon Castle）、福克斯（De'Aaron Fox）的關鍵進球，穩住最後領先優勢，最終以4分之差驚險擊退尼克，斬斷對方季後賽13連勝，避免被聽牌的命運。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026267.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 12:27", "link": "/news/story/7002/9554933"}, {"article_id": "9554707", "title": "澳洲羽賽／我大軍壓境33組人馬參賽 頭號種子周天成首戰自家人", "summary": "BWF超級500等級的澳洲羽球公開賽今天登場，台灣大軍壓境共33組人馬參賽；根據籤表，男單世界第6的周天成列為頭號種子，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026226.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 12:07", "link": "/news/story/7005/9554707"}, {"article_id": "9554831", "title": "MLB／水手內野戰力亮紅燈！大物新秀賽前緊急退場、克勞佛傷癒不如預期", "summary": "水手今日正式宣布，將主力游擊手克勞佛（J.P. Crawford）放入10天傷兵名單，原先接替克勞佛守游擊的百大新秀第7艾默森（Colt Emerson），也在對金鶯系列賽首戰前因背部緊繃臨時退場。在雙重打擊下，水手從3A拉上內野手布利斯（Ryan Bliss）遞補戰力，並讓22歲內野手楊恩（Cole Young）生涯首度擔任大聯盟先發游擊手。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026077.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 12:05", "link": "/news/story/6999/9554831"}, {"article_id": "9554687", "title": "MLB／昔日經典賽王牌遭DFA！古巴「Y-Rod」藍鳥生涯恐畫下句點", "summary": "藍鳥今日宣布，將古巴29歲右投「Y-Rod」羅德里奎茲（Yariel Rodriguez）指定讓渡（DFA）。事實上，這已是他近6個月內第二次遭到指定讓渡。去年休賽季時，他就曾通過讓渡程序卻無球隊願意承接合約，最終被下放至3A。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025906.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 12:04", "link": "/news/story/6999/9554687"}, {"article_id": "9554824", "title": "城市運動場錢薇娟、郭泓志領軍出擊 文姿云、林郁婷上演女力對決", "summary": "迎接品牌50周年，迪卡儂於日前在台北三重旗艦店揭開「全台最大城市運動場」序幕，台灣迪卡儂執行長堯傑倫（Hugo Jehlen）率領跑團起跑，排出「50」軌跡，為今夏橫跨全台9間門市、七個城市的運動盛典祭出精彩開場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026067.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 11:47", "link": "/news/story/7005/9554824"}, {"article_id": "9554765", "title": "NBA／在川普面前斷尼克13連勝 溫班亞瑪轟32分馬刺G3扳回一城", "summary": "NBA總冠軍賽第三戰今天移師尼克主場麥迪遜花園廣場，不僅美國總統川普與林書豪都到場觀戰，兩隊也再度打出激烈的拉鋸戰，其中背水一戰的馬刺在上半場打完雖然一度落後，但第四節靠著嚴密的防守，加上卡瑟爾（Stephon Castle）、福克斯（De'Aaron Fox）關鍵時刻連續進球，幫助馬刺最終以115：111扳回一城，系列賽追到1：2，也中斷尼克季後賽13連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025996.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 11:34", "link": "/news/story/7002/9554765"}, {"article_id": "9544997", "title": "NBA／讓川普看到輸球！馬刺擋住尼克反撲115:111客場扳回一勝", "summary": "NBA總冠軍賽G3，馬刺前往紐約踢館，麥迪遜花園廣場相隔27年再次迎接最高舞台賽事，尼克取得2勝0敗優勢，渴望終結長達53年的冠軍荒！", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025729.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-09 11:29", "link": "/news/story/7002/9544997"}, {"article_id": "9554696", "title": "NBA／馬刺0比2落後仍有希望？三少組合淨效率值透露反攻可能", "summary": "聖安東尼奧馬刺在NBA總冠軍賽前2戰都不敵紐約尼克，系列賽陷入0比2落後。隨著戰線移師麥迪遜花園廣場，馬刺總教練強森（Mitch Johnson）除了必須想辦法喚醒球隊進攻，也面臨幾個關鍵輪替抉擇，其中最重要的問題，就是是否進一步增加菜鳥後衛哈波（Dylan Harper）的上場時間。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025918.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 11:27", "link": "/news/story/7002/9554696"}]}, {"name": "棒球", "articles": [{"article_id": "9554501", "title": "日職／孫易磊後天對決橫濱 日媒：「台灣至寶」準備展現真正實力", "date": "2026-06-09 10:14", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025623.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/7001/9554501"}, {"article_id": "9555319", "title": "中職／聯盟提前宣布新莊、洲際延賽 25、26日原地補賽", "date": "2026-06-09 14:46", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026956.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/7001/9555319"}, {"article_id": "9554451", "title": "日職／阿部慎之助涉施暴長女案 日警函送檢方偵辦", "date": "2026-06-09 10:06", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35025503.jpg&M=1&s=Y&x=38&y=25&sw=1242&sh=828&exp=3600&w=300", "link": "/news/story/7001/9554451"}, {"article_id": "9554030", "title": "棒球／「中信60甲子緣」棒球展 參觀人次突破6萬", "date": "2026-06-09 00:00", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024818.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/7001/9554030"}, {"article_id": "9553500", "title": "棒球／「中信60甲子緣」觀展破6萬人次 天天加碼舉辦星光場活動", "date": "2026-06-08 18:23", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024355.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/7001/9553500"}]}, {"name": "MLB", "articles": [{"article_id": "9555310", "title": "MLB／近23戰狂吞18敗！布萊格曼坦言拖累小熊戰