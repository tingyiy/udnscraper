", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35001531.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9538699", "title": "NBA總冠軍大預言 尼克不是馬刺對手", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35001988.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9538984", "title": "建隊奪冠趨勢：「長輪替」創造餘裕 強隊不再只靠球星苦撐", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35002315.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9538947", "title": "世足攻略／D組4隊風格鮮明沒有絕對豪門 地主美國被看好", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35002273.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9536594", "title": "本季最強二游搭檔竟來自馬林魚 兩位浪人如何改造變明星？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/31/34998307.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9540174", "title": "NBA／獨行俠新球館選址初步敲定 2031年可能首度搬離達拉斯市中心", "summary": "達拉斯獨行俠新球館計畫有了重要進展。球團周一宣布，已就新球館預定地達成初步協議，地點位於達拉斯市中心以北約10英里、前Valley View Mall購物中心舊址，占地約104英畝。如果計畫順利推進，獨行俠最快將在2031年搬離現有主場美航中心（American Airlines Center），這也會是球隊隊史首次離開達拉斯市中心一帶。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35003853.jpg&M=1&s=Y&x=52&y=47&sw=1132&sh=755&exp=3600&sl=W&fw=360", "date": "2026-06-02 10:58"}, {"article_id": "9540113", "title": "法網／打到凌晨1點晉級！世界排名104退美國種子締義大利新頁", "summary": "義大利「世界球王」辛納（Jannik Sinner）今年法網雖提前落馬，義大利同胞卻打得爭氣，世界排名104的阿納爾迪（Matteo Arnaldi）今天凌晨在歷時5小時又26分鐘的馬拉松大戰出線，以7：6（7：5）、6：7（5：7）、3：6、7：6（7：3）、6：4力退美國好手帝亞佛（Frances Tiafoe），成為第3位挺進男單8強的義大利選手，寫下義大利網壇新頁。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35003765.jpg&M=1&s=Y&x=0&y=0&sw=1277&sh=851&exp=3600&sl=W&fw=360", "date": "2026-06-02 10:42"}, {"article_id": "9540064", "title": "NBA／總冠軍賽還沒開打索漢先成贏家 有望「保底」冠軍戒指", "summary": "馬刺在西區冠軍賽第7戰淘汰衛冕軍雷霆，睽違12年重返NBA總冠軍賽，將與東區冠軍尼克爭奪本季最高榮耀。不過系列賽尚未正式開打，一名球員卻已經率先成為話題焦點，那就是目前效力紐約的替補前鋒索漢（Jeremy Sochan）。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35003587.jpg&M=1&s=Y&x=0&y=9&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-02 10:25"}, {"article_id": "9540061", "title": "世足賽／因政治風波遭捨棄 「伊朗梅西」阿茲蒙確定無緣26人名單", "summary": "2026年世界盃足球賽開打在即，然而剛公布26人決選名單的「波斯鐵騎」伊朗也出現意外結果，有「伊朗梅西」之稱的當家球星阿茲蒙（Sardar Azmoun），遭到總教練賈蘭諾伊（Amir Ghalenoei）割愛，無緣本屆世足賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35003654.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 10:21"}, {"article_id": "9540046", "title": "NBA／加拿大男籃重組仍由SGA領銜 穆雷、維金斯因三年條款遭割愛", "summary": "加拿大男籃國家隊在今天正式對外公布了新一期的國家隊集訓名單，這份旨在備戰2027年FIBA世界盃與2028年洛杉磯奧運會的大名單，由連霸兩屆NBA年度MVP的雷霆當家球星亞歷山大（Shai Gilgeous-Alexander）領銜，不過卻也缺少了金塊後衛穆雷（Jamal Murray）與熱火前鋒維金斯（Andrew Wiggins），宣告兩位名將將無緣未來幾年的世界大賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35003687.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 10:18"}, {"article_id": "9539942", "title": "MLB／李灝宇雙安、開轟打擊率重返「2字頭」 守備有美技也有失誤", "summary": "效力老虎隊的台灣好手李灝宇，今天先發出賽5打數敲出2安打，包括第六局的陽春砲，他的大聯盟生涯第二轟出爐，此役單場雙安後打擊率也以0.205重返2字頭。此役上演出一場打擊混戰，老虎隊6分領先打到岌岌可危，終場仍以10：9擊敗光芒隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35003429.jpg&M=1&s=Y&x=201&y=17&sw=1079&sh=719&exp=3600&sl=W&fw=360", "date": "2026-06-02 09:50"}, {"article_id": "9539890", "title": "法網／直落二擊退大坂直美 球后莎芭蓮卡8強就位", "summary": "前後任球后大坂直美和莎芭蓮卡（Aryna Sabalenka）今天凌晨上演話題對決，現任球后莎芭蓮卡技高一籌，以7：5、6：3挺進8強，繼續朝生涯第一座紅土大滿貫金盃前進。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35003375.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-02 09:32"}, {"article_id": "9539889", "title": "網球／44歲小威廉絲復出！倫敦草地賽雙打出賽", "summary": "美國網壇名將小威廉絲（Serena Williams）從沒正式宣告退休，44歲的她本周為網壇投入震撼彈，宣布將持外卡參加下周登場的倫敦草地賽雙打，消息一出立刻掀起話題。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35003365.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 09:32"}, {"article_id": "9539813", "title": "MLB／李灝宇相隔36天等到第2轟 看球出牆笑得像孩子", "summary": "效力老虎隊的台灣好手李灝宇相隔36天再度再度開砲，今天面對光芒隊右投馬丁（Trevor Martin），第六局掃出一發陽春砲，大聯盟生涯第二轟出爐。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35003250.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-02 08:54"}, {"article_id": "9539791", "title": "NBA／帶領國王打出華麗球風 傳奇千勝教頭艾德曼逝世享壽79歲", "summary": "NBA今天傳出令人遺憾的消息，曾以華麗流暢的「普林斯頓戰術」風靡全球、執教生涯斬獲超過千勝的前國王名人堂教練艾德曼（Rick Adelman），於今天辭世，享壽79歲。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35003221.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 08:35"}, {"article_id": "9539790", "title": "NBA／柯瑞球鞋自由市場爭奪戰落幕 10年天價合約轉投李寧", "summary": "勇士當家球星柯瑞（Stephen Curry）的新球鞋代言合約爭奪案終於落幕，柯瑞今天正式宣布與中國大陸知名運動品牌李寧達成協議，雙方將簽下一張為期10年的巨額代言合約，為這場自去年11月點燃的「球鞋自由市場爭奪戰」劃下震撼句點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35003349.jpg&M=1&s=Y&x=119&y=16&sw=1070&sh=713&exp=3600&sl=W&fw=360", "date": "2026-06-02 08:35"}, {"article_id": "9538984", "title": "建隊奪冠趨勢：「長輪替」創造餘裕 強隊不再只靠球星苦撐", "summary": "今年分區決賽的幾支強隊，有一個逐漸清晰的共同點，他們或許擁有明星球員，但真正支撐他們走到現在的，已經不只是明星球員。無論是西區的雷霆或馬刺，還是東區的尼克，都展現出同樣的建隊趨勢「長輪替」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35002315.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 08:00"}, {"article_id": "9538339", "title": "中職／英雄不怕出身低 李東洺、曾家輝野球人生倒吃甘蔗", "summary": "富邦悍將李東洺本季表現驚豔，以6勝並列聯盟勝投王，防禦率1.83，展現投手潛力。雖然過往路途坎坷，但改變配球策略後信心倍增，前景堪期待。另有曾家輝同樣表現出色，成為投手新星。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35001531.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 07:00"}, {"article_id": "9538947", "title": "世足攻略／D組4隊風格鮮明沒有絕對豪門 地主美國被看好", "summary": "美國、土耳其、澳洲和巴拉圭齊聚的D組，4隊風格鮮明，沒有絕對的豪門球隊，都有晉級可能。正常美國和土耳其會上去，但巴拉圭和澳洲也不是省油的燈，若能逼平土耳其和美國，就有出線機會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35002273.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 07:00"}, {"article_id": "9538863", "title": "中職／CNBLUE一語意外點破問題 悍將投手崩盤前兆已現", "summary": "富邦悍將在CNBLUE演唱會後遭遇連敗，後援投手表現不佳成主要原因。三場系列戰後援投手共失13分，自責分率高。球隊亟需解決投手問題，否則前景堪憂。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35002145.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 07:00"}, {"article_id": "9538699", "title": "NBA總冠軍大預言 尼克不是馬刺對手", "summary": "2026 NBA總冠軍賽將於6月4日開打，馬刺對尼克。雖然尼克本季季後賽表現出色，但馬刺的防守實力將成為關鍵。專家預測馬刺將以4：2擊敗尼克，奪得總冠軍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35001988.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 07:00"}, {"article_id": "9539696", "title": "法網／莎芭蓮卡直落二擊倒大坂直美 闖進女單8強", "summary": "來自白俄羅斯的現任世界球后莎芭蓮卡今天晚間在法國網球公開賽女單第4輪耗費將近1個半小時，直落二淘汰大會第16種子、日本好...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35003107.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-02 06:10"}, {"article_id": "9539600", "title": "網球／小威廉絲復出 將征戰本月女王杯女雙賽場", "summary": "女王杯網賽（Queen's Club Championships）主辦單位今天宣布，美國女網名將小威廉絲（Serena ...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/02/35003477.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-02 03:03"}, {"article_id": "9539122", "title": "自行車／騎遇東北角 四大路線深度旅遊", "summary": "為響應聯合國「世界自行車日」，交通部觀光署東北角及宜蘭海岸國家風景區管理處今天正式啟動「2026 騎遇東北角低碳騎行日」系列活動，除推出「東北角自行車小旅行」四大路線，9月還將辦理「極點慢旅：自主騎乘活動」，讓騎士透過雙輪深入台灣。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35002471.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-01 20:03"}, {"article_id": "9539094", "title": "TPBL／冠軍賽G5回台中 夢想家門票1分鐘完售", "summary": "TPBL總冠軍賽第5戰明天登場，回到主場的福爾摩沙夢想家門票開賣1分鐘即完售，球隊將力拚延長戰線，阻止衛冕軍新北國王寫下連霸。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35002460.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-01 19:55"}, {"article_id": "9539071", "title": "中職／領隊會議研議 爭取建立棒球替代役機制", "summary": "中華職業棒球大聯盟今天召開領隊會議，討論1年期義務役制度對球員發展的影響，研議爭取建立棒球替代役機制", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35002458.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-01 19:53"}, {"article_id": "9539079", "title": "羽球／永續不只是口號 戴資穎隨中華電信屏東植樹", "summary": "去年正式退役的羽球傳奇戴資穎成中華電信永續發展大使，今天現身屏東縣車城鄉海口段，和中華電信在「屏護海岸 復育原生」一銅進行屏東海岸林復育植樹行動，活動攜手農業部林業及自然保育署推動恆春半島海岸林保育軸帶復育，透過移除外來入侵種銀合歡，並栽植7600株多種原生樹種，逐步恢復恆春半島帶季風林樣貌，提升海岸林棲地多樣性與防護功能。同時展現企業長期投入生物多樣性、國土韌性與自然永續的決心。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35002443.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&sl=W&fw=360", "date": "2026-06-01 19:46"}, {"article_id": "9539077", "title": "法網／第二盤連趕5局逆轉 台將僅存希望梁恩碩勇闖8強", "summary": "第一次在法網女雙亮相，我國好手「小鋼炮」梁恩碩和日本青山修子晉級第三輪就成僅存「台將希望」，今天碰香港張瑋桓／斯洛維尼亞埃里亞韋茨（Veronika Erjavec）再以6：1、6：3過關，其中第二盤更是1：3落後下連趕5局逆轉，闖進8強續寫黑馬驚奇。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/2021/06/01/1/12396267.jpg&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-01 19:46"}, {"article_id": "9538975", "title": "歐冠／法國奪冠球迷街頭暴動 被捕人數增至近900人", "summary": "法國足球隊巴黎聖傑曼30日在歐洲冠軍聯賽（Champions League）連續第2年贏得夢寐以求的冠軍後，街頭狂歡的球...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/01/35002379.jpg&M=1&s=Y&x=0&y=0&sw