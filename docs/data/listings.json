}, {"article_id": "9558372", "title": "木棒聯賽8強中職選秀名單搶先看─平鎮、穀保、普門、麥寮", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35031526.jpg&M=1&s=Y&x=0&y=0&sw=1260&sh=840&exp=3600&w=300", "link": "/news/story/122629/9558372"}, {"article_id": "9558742", "title": "從3比0可能被橫掃到看見逆轉曙光 馬刺第三戰做對了什麼？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35031957.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9558742"}, {"article_id": "9557078", "title": "中職／速差與曲球成就頂尖壓制力 龍隊蔣銲就是本季最強洋投", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030147.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9557078"}, {"article_id": "9555482", "title": "岡本打出身價、村上超乎想像 「虎大砲」佐藤輝明成最大贏家", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027706.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9555482"}, {"article_id": "9555842", "title": "世足攻略／L組英格蘭是冠軍熱門 攜手克國「魔笛」小組出線問題不大", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027942.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9555842"}]}, {"name": "最新文章", "articles": [{"article_id": "9559649", "title": "MLB／初速170公里強襲球直擊頭部當場倒地！ 皇家投手盧戈傷退", "summary": "堪薩斯市皇家投手盧戈在對德州遊騎兵的比賽中，因遭到時速超過170公里的強襲球擊中頭部當場倒地。所幸他能自行站起來，但球隊為安全考量決定讓他退場檢查。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35033196.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-11 10:55", "link": "/news/story/6999/9559649"}, {"article_id": "9559636", "title": "MLB／奇森姆3打點率洋基橫掃守護者 費爾柴德進帳2保送2得分", "summary": "洋基以8：4擊敗守護者，成功橫掃系列賽。奇森姆包辦3分打點，洛登投6局失3分獲勝。守護者費爾柴德雖獲得2保送並得分，仍無法改變敗局。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35033180.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-11 10:55", "link": "/news/story/6999/9559636"}, {"article_id": "9558444", "title": "Live／尼克反攻追回12分！馬刺三節完仍領先15分", "summary": "馬刺隊在系列賽G3歷經一番苦戰，最終以115：111險勝尼克隊扳回一城，系列賽追成1：2落後仍居劣勢。第四戰在紐約麥迪遜廣場花園續戰，等待27年才重返總冠軍賽的尼克要在主場全力搶聽牌優勢，馬刺則希望扳平系列賽、回聖安東尼奧重新開始，鹿死誰手就鎖定文字直播。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35033202.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-11 10:50", "link": "/news/story/7002/9558444"}, {"article_id": "9559623", "title": "影／孫易磊要幫火腿拚7連勝 迎接本季初登板前透露心聲", "summary": "日本火腿隊下午5點繼續在北海道主場和橫濱隊交手，台灣投手孫易磊本季一軍初登板，將挑戰生涯首勝；賽前談到這次先發任務，孫易磊形容「期待感會稍微多一點」，因為前幾次表現沒有很好，很期待這次登板會是什麼樣子。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35033162.jpg&M=1&s=Y&x=0&y=192&sw=960&sh=640&exp=3600&sl=W&fw=360", "date": "2026-06-11 10:37", "link": "/news/story/7001/9559623"}, {"article_id": "9559576", "title": "NBA／拒向喬丹、布萊恩認輸 詹姆斯談GOAT：不會選擇任何人超越我", "summary": "隨著職業生涯步入尾聲，詹姆斯（LeBron James）在歷史最佳（GOAT）的辯論中，再次展現了捨我其誰的王者霸氣，日前他在接受《時代》雜誌專訪時，面對這項圍繞他與「籃球之神」喬丹（Michael Jordan）等人多年的經典命題，他直言不諱地表示，「我不會選擇任何人超越我，這毫無疑問。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35033174.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-11 10:23", "link": "/news/story/7002/9559576"}, {"article_id": "9559541", "title": "MLB／道奇遭海盜逆轉 大谷先發勝投被搞砸後敲本季第12轟", "summary": "道奇隊日籍球星大谷翔平先發出戰海盜隊，主投6.2局，失4分（3分自責分）寫下本季單場失分新高，防禦率也升至1.06，而他的本季第7勝在牛棚接手後被轟飛，儘管「打者翔平」在9局上也敲出2分砲追分，最終仍無法改變戰局；海盜隊則靠新秀卡利漢（Tyler Callihan）單場雙響砲以9：8逆轉道奇。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35033037.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-11 10:13", "link": "/news/story/6999/9559541"}, {"article_id": "9559517", "title": "NBA／上半場狂轟14記三分球 馬刺G4半場27分大幅領先尼克", "summary": "NBA總冠軍賽第四戰今天繼續在籃球聖地麥迪遜花園廣場舉行，前一場扳回一城的馬刺，在上半場再度火力全開，前兩節打完馬刺已經投進14記三分球，包括溫班亞瑪（Victor Wembanyama）、福克斯（De'Aaron Fox）、瓦賽爾（Devin Vassell）、哈波（Dylan Harper）都有雙位數得分表現，幫助馬刺半場以76：49大幅領先尼克。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35032979.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-11 10:06", "link": "/news/story/7002/9559517"}, {"article_id": "9559470", "title": "世足賽／放輕鬆面對簽證問題 FIFA總裁發言惹議", "summary": "世界盃開幕倒數，國際足總（FIFA）今天在墨西哥舉辦記者會，總裁英凡提諾（Gianni Infantino）針對簽證問題的解方卻是要球迷和相關人士「愜意和放輕鬆」，儘管他強調國際足總並非沒有作為，一番言論仍引發爭議。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35032974.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-11 09:55", "link": "/news/story/123107/9559470"}, {"article_id": "9559450", "title": "MLB／塔提斯本季第二轟出爐 用再見陽春砲跟紅人說掰掰", "summary": "教士球星塔提斯在9局下擊出再見全壘打，幫助球隊以5：4擊退紅人，贏得系列賽。這是他本季的第二轟，本場比賽他5打數中有2安打與2打點，打擊率上升至2成81。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35032846.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-11 09:52", "link": "/news/story/6999/9559450"}, {"article_id": "9559397", "title": "MLB／八局前還1：9落後！艾德里奇再見滿貫砲 巨人史詩級大逆轉國民", "summary": "舊金山巨人今天在落後1：9的情況下，完成驚天大逆轉，以11：10擊敗華盛頓國民。艾德里奇在九局轟出再見滿貫全壘打，帶領球隊逆轉勝，賽後他渴望成為球隊未來的門面。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35032762.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-11 09:47", "link": "/news/story/6999/9559397"}, {"article_id": "9559428", "title": "MLB／薛則K掉大聯盟全壘打王史瓦柏 奪三振3500次史上第11人", "summary": "藍鳥隊41歲老將薛則（Max Scherzer）今天登板先發，開賽面對費城人隊開路先鋒史瓦柏（Kyle Schwarber）投出生涯19年第3500次三振，成為史上第11位達到里程碑的投手。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35032806.jpg&M=1&s=Y&x=0&y=0&sw=1257&sh=838&exp=3600&sl=W&fw=360", "date": "2026-06-11 09:40", "link": "/news/story/6999/9559428"}, {"article_id": "9559420", "title": "NBA／溫班亞馬領軍扳回一城 總冠軍賽G3收視寫後喬丹時代新高", "summary": "2026年NBA總冠軍賽上演命運般的宿敵對決，由馬刺與尼克重溫1999年的爭冠經典戲碼，日前在紐約舉行的關鍵第三戰，馬刺憑藉溫班亞瑪（Victor Wembanyama）隻手遮天狂飆32分，率隊以115：111險勝，不僅在系列賽扳回一城，更在全美引爆觀賽狂潮。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35032800.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-11 09:34", "link": "/news/story/7002/9559420"}, {"article_id": "9559419", "title": "MLB／大谷先發6.2局、失4分寫本季新高 防禦率升至1.06", "summary": "道奇隊與海盜隊本周3連戰第2場比賽，大谷翔平本季第11場先發登板，繼續以「二刀流」身份出賽，合計投6.2局失4分（3分自責分），失分寫下本季單場新高，防禦率也升至1.06，前7局打完道奇以6：4領先，大谷仍是勝投候選人。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35032796.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-11 09:34", "link": "/news/story/6999/9559419"}, {"article_id": "9559335", "title": "世足賽／荷蘭頭號門將訓練缺席 開幕戰上陣打問號", "summary": "世足賽開踢倒數，荷蘭頭號守門員費布呂亨（Bart Verbruggen）卻在開戰前成傷兵，他缺席了今天球隊訓練，原因是日前和烏茲別克友誼賽被撞傷臀部，能否趕上世足開幕戰打上問號。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35032764.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-11 08:43", "link": "/news/story/123107/9559335"}, {"article_id": "9559298", "title": "網球／搭檔單打傷退 小威復出旅程遇危機", "summary": "美國網壇名將小威廉絲（Serena Williams）宣布重回網壇投入震撼彈，從雙打回歸的她首戰更和19歲加拿大搭檔姆博柯（Victoria Mboko）以直落二扳倒列第3種子的同胞美國梅莉雪（Nicole Melichar-Martinez）／紐西蘭羅莉芙（Erin Routliffe），挺進倫敦女王俱樂部草地賽第二輪，不過博柯單打比賽卻發生跌倒傷退意外，讓小威的復出首戰可能打一場就結束。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35032792.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-11 08:12", "link": "/news/story/7005/9559298"}, {"article_id": "9559283", "title": "NBA／紐約警局G4下達禁聚令 尼克怒轟市長：扼殺球迷權利", "summary": "暌違27年再度迎來NBA總冠軍賽的尼克，今年季後賽掀起紐約狂熱， 在總冠軍賽第三戰就有上萬瘋狂球迷擠爆麥迪遜花園廣場（MSG）周邊，但也爆發多起暴力事件，而這份城市的狂歡也將在第四戰戛然而止，紐約市警局突襲式宣布「戶外禁聚令」，甚至引發尼克球團與市府間的激烈爭辯，讓總冠軍賽場外的煙硝味比場內更濃。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35032769.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-11 07:55", "link": "/news/story/7002/9559283"}, {"article_id": "9558035", "title": "太空人艾瓦瑞茲挑戰三冠王 大谷後以DH奪MVP有望再添一人", "summary": "太空人重砲艾瓦瑞茲在賈吉因傷退賽後，MVP希望大增。若成功奪得MVP，將成為繼大谷翔平後又一位以DH身份獲得此榮譽的選手。目前他以.316打擊率、22轟、48打點等傑出表現，正朝三冠王邁進。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35030984.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-11 07:00", "link": "/news/story/122629/9558035"}, {"article_id": "9558372", "title": "木棒聯賽8強中職選秀名單搶先看─平鎮、穀保、普門、麥寮", "summary": "2026年中華職棒季中選秀將於6月29日舉行，木棒聯賽8強球隊的多名優秀球員將參加，包括平鎮的邱文佑與穀保的帕蘇拉，皆被看好成為潛力新星。各球團聚焦球員表現，選手名單引發廣泛關注。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35031526.jpg&M=1&s=Y&x=0&y=0&sw=1260&sh=840&exp=3600&sl=W&fw=360", "date": "2026-06-11 07:00", "link": "/news/story/122629/9558372"}, {"article_id": "9559188", "title": "NBA／總冠軍G3溫班亞馬推頭惹議 川普力挺尼克批裁判", "summary": "NBA總冠軍賽第3戰，馬刺球星溫班亞馬猛推尼克主將布朗森的頭部，但裁判當下沒有吹哨，引發球迷不滿。美國總統川普今天告訴「...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35032551.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-11 06:25", "link": "/news/story/7002/9559188"}, {"article_id": "9559166", "title": "NBA／詹姆斯時代雜誌專訪 自認是史上最偉大球員", "summary": "美國職籃NBA洛杉磯湖人球星詹姆斯近日接受「時代雜誌」（Time）專訪時表示，他相信自己是「史上最偉大球員」（Great...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35032775.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-11 06:21", "link": "/news/story/7002/9559166"}, {"article_id": "9558838", "title": "PLG／從板凳殺出盼助林志傑圓冠軍夢 周桂羽：全隊一致目標", "summary": "PLG總冠軍賽前兩戰打完戰成1：1平手的台北富邦勇士與桃園璞園領航猿，今天回到和平籃球館進行系列賽第三戰，勇士在首節落後5分情況下靠著下半場強勢反撲，尤其第四節僅讓領航猿拿下8分，終場以85：76贏球，在7戰4勝制系列賽取得2：1領先。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35032065.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 22:04", "link": "/news/story/7003/9558838"}, {"article_id": "9558799", "title": "TPBL／三上悠亞盛裝出席 年度獎項一次看", "summary": "TPBL今天進行年度頒獎典禮，獲得年度人氣啦啦隊員的三上悠亞特別從日本來台，盛裝出席親自領獎，對於下個賽季她賣關子喊「我會加油」，請球迷敬請期待。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35032018.jpg&M=1&s=Y&x=0&y=102&sw=938&sh=626&exp=3600&sl=W&fw=360", "date": "2026-06-10 21:47", "link": "/news/story/7003/9558799"}, {"article_id": "9558788", "title": "PLG／領航猿末節大當機僅拿8分 富邦勇士逆轉系列賽2：1領先", "summary": "在總冠軍賽前兩戰打完後戰成1：1平手的台北富邦勇士與桃園璞園領航猿，今天在和平籃球館進行第三戰，身為地主的富邦勇士在首節打完一度落後的情況下，後三節展開猛烈反撲，甚至在第四節僅讓領航猿拿下8分，最終就以85：76取勝，冠軍賽取得2：1領先。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35032011.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 21:44", "link": "/news/story/7003/9558788"}, {"article_id": "9558742", "title": "從3比0可能被橫掃到看見逆轉曙光 馬刺第三戰做對了什麼？", "summary": "總冠軍戰白熱化，前進紐約的第三戰，雙方打出系列賽最為精采的你來我往鬥，每一節都在顛覆局勢，最終憑藉溫班亞瑪（Victor Wembanyama）在雙方都疲憊不堪第四節的絕對優勢，馬刺4分險勝，避免球隊落入0-3落後，史上從未有人完成過大逆轉的絕對逆境。此戰更積極的意義還在於，馬刺總算摸索出了一套有機會的勝利方程式，現在，輪到尼克來反擊了。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35031957.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 21:42", "link": "/news/story/122629/9558742"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9559470", "title": "世足賽／放輕鬆面對簽證問題 FIFA總裁發言惹議", "date": "2026-06-11 09:55", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35032974.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9559470"}, {"article_id": "9559335", "title": "世足賽／荷蘭頭號門將訓練缺席 開幕戰上陣打問號", "date": "2026-06-11 08:43", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35032764.jpg&M=1&s=Y&x=0&y=0&s