s": [{"article_id": "9590185", "title": "世足運彩／西班牙再不振作32強就要對阿根廷 推薦0：1讓分勝烏拉圭", "summary": "今天早上德國被厄瓜多逆轉，給同樣南美球對烏拉圭很大的鼓舞。西班牙1勝1敗4分積分領先，但是萬一這一場輸給烏拉圭，西班牙就會掉到分組第2，萬一加萬一維德角又贏了沙烏地阿拉伯，西班牙甚至會調到分組第3。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35079157.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-26 12:40", "link": "/news/story/123105/9590185"}, {"article_id": "9590182", "title": "世足賽／澳洲0：0與巴拉圭踢平收場 攜手晉級32強 澳洲小組第二", "summary": "2026美加墨世界盃小組賽D組最後一輪賽事，澳洲與巴拉圭爭取的分組2、3名之爭，雙方全場踢完以0：0和局收場，都手握4分積分，但澳洲則靠著淨勝球優勢拿下分組第二，確定挺進32強淘汰賽，巴拉圭也可晉級。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35079167.jpg&M=1&s=Y&x=0&y=0&sw=1248&sh=832&exp=3600&sl=W&fw=360", "date": "2026-06-26 12:32", "link": "/news/story/123107/9590182"}, {"article_id": "9590100", "title": "MLB／差2個出局數！9局挨轟砸鍋「無安打」比賽 金寶：我很遺憾", "summary": "光芒距離隊史睽違15年的無安打比賽只差最後2個出局數，卻在9局功虧一簣。剛遭大都會釋出的老將明星終結者「金寶」金布洛爾（Craig Kimbrel）登板關門時，被皇家菜鳥簡森（Carter Jensen）轟出兩分砲，讓合力無安打比賽就此破滅。不過光芒最終仍以13：2大勝皇家，四連戰雙方各取2勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35079024.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-26 12:23", "link": "/news/story/6999/9590100"}, {"article_id": "9590118", "title": "MLB／岡本和真新秀年18轟追平城島健司 明星賽票選挑戰日本第一人", "summary": "藍鳥日籍強打岡本和真今天主場對遊騎兵的9局下轟出兩分全壘打，本季第18號，一舉追平2006年西雅圖水手城島健司的紀錄，並列日本球員轉戰大聯盟新秀年全壘打榜第3位，距離大谷翔平保持的22轟紀錄，只差4支全壘打。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35079058.jpg&M=1&s=Y&x=0&y=9&sw=976&sh=651&exp=3600&sl=W&fw=360", "date": "2026-06-26 12:18", "link": "/news/story/6999/9590118"}, {"article_id": "9590142", "title": "TPVL／天鷹隊長完成續約 陳建禎珍惜每一次踏進球場機會", "summary": "TPVL台鋼天鷹隊今天正式宣布與隊長陳建禎完成一年續約，新賽季陳建禎將持續披上天鷹戰袍，與球隊一同迎接全新挑戰。自加入球隊以來，陳建禎不僅在場上展現穩定身手，更以豐富經驗與領袖風範凝聚團隊，成為天鷹不可或缺的重要核心。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35079087.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-06-26 12:15", "link": "/news/story/7005/9590142"}, {"article_id": "9590126", "title": "世足賽／連兩場遭零封後 土耳其一吐悶氣3：2絕殺美國", "summary": "儘管已經無關晉級，但今年世足賽地主美國與土耳其今天仍在小組賽最後一戰上演激戰，美國開賽第3分鐘就由特拉斯蒂（Auston Trusty）率先破門，但土耳其接下來卻連進兩球逆轉，甚至在傷停補時最後一分鐘靠著艾漢（Kaan Ayhan）絕殺進球，以3：2擊敗美國。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35079099.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-26 12:10", "link": "/news/story/123107/9590126"}, {"article_id": "9590083", "title": "MLB／大谷翔平獲334萬票人氣無敵 連續6年入選明星賽", "summary": "美國職棒大聯盟MLB公布全明星賽球迷票選第一階段結果，大谷翔平以334萬1257票榮登全大聯盟人氣王，將直接擔任國聯明星...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35079032.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-26 12:07", "link": "/news/story/6999/9590083"}, {"article_id": "9589947", "title": "NBA／暴龍冠軍功臣有望歸隊？雷納德若離隊僅願續約「前東家」", "summary": "快艇球星雷納德（KawhiLeonard）今夏交易傳聞不斷延燒。根據《ESPN》薪資專家馬克斯（Bobby Marks）與《The Stein Line》記者費雪（Jake Fischer）透露，若快艇最終決定交易雷納德，他只願意與兩支球隊完成長約續約，分別是暴龍與馬刺，而外界也開始討論，昔日與馬刺不歡而散的他，是否有機會重返聖安東尼奧。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078813.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-26 12:07", "link": "/news/story/7002/9589947"}, {"article_id": "9590062", "title": "MLB／賴謙凡從大溪投向洋基 賴爸爸曝在禱告中找到方向", "summary": "來自台東，高中赴桃園就讀大溪高中，賴謙凡將自己投向美國職棒傳統豪門紐約洋基隊，棒球之路上的每一次選擇，都來自他自己，爸爸賴世山透露，「去大溪，他說是他禱告來的，上帝跟他說的，洋基應該也是。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078972.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-26 11:52", "link": "/news/story/6999/9590062"}, {"article_id": "9590055", "title": "世足賽／ 厄瓜多逆轉德國晉級 普拉塔：26名球員會為國人拚盡全力", "summary": "厄瓜多在2026年世界盃小組賽最終戰力挽狂瀾，以2：1逆轉強敵德國拿下首勝，也搶下32強淘汰賽門票，繼2006年後隊史第二度挺進淘汰賽，踢進致勝球的普拉塔（Gonzalo Plata）直呼「太不可思議了！」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078969.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-26 11:49", "link": "/news/story/123107/9590055"}, {"article_id": "9589925", "title": "世足賽／厄瓜多20年後重返淘汰賽 全國放假一天慶祝", "summary": "厄瓜多今天在2026年世界盃足球賽E組以2比1逆轉擊敗德國，睽違20年再度闖進淘汰賽。厄瓜多總統諾波亞（Daniel N...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078929.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-26 11:40", "link": "/news/story/123107/9589925"}, {"article_id": "9589970", "title": "MLB／對洋基的印象不意外是王建民 賴謙凡：雖然我還沒出生", "summary": "象徵紐約洋基隊榮光歷史的條紋球衣，大溪高中18歲右投賴謙凡今天在加盟記者會正式披上，談到對這支球隊的印象，他說出的名字當然是王建民，「雖然他在投時，我還沒出生。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078877.jpg&M=1&s=Y&x=0&y=55&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-26 11:23", "link": "/news/story/6999/9589970"}, {"article_id": "9589949", "title": "世足賽／日本踢平瑞典對南韓不利！韓媒：幫不上忙的討厭日本", "summary": "南韓隊昨天在世足小組賽爆冷輸給南非隊，是否晉級需看其他隊臉色。今天德國爆冷不敵厄瓜多，日本又和瑞典1：1握手言和，都讓南韓晉級之路陷入不利局面。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078819.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-26 11:22", "link": "/news/story/123107/9589949"}, {"article_id": "9589934", "title": "NBA／40歲霍福特續留勇士拚第20個賽季 改簽2年1400萬美元新約", "summary": "40歲老將霍福特（Al Horford）計畫拒絕執行原本價值600萬美元的球員選項，將會在下個月自由市場開啟後，與勇士簽下一份2年1400萬美元的新合約。這份新約將全額保障，並包含交易保證金。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078805.jpg&M=1&s=Y&x=5&y=0&sw=1259&sh=840&exp=3600&sl=W&fw=360", "date": "2026-06-26 11:13", "link": "/news/story/7002/9589934"}, {"article_id": "9589937", "title": "MLB／很想賴謙凡留下來但是… 王建民：留下來也選不到", "summary": "紐約洋基隊過往只簽過兩位台灣選手，分別是2000年王建民、2009年郭阜林，相隔16年獵才雷達再於寶島捕獲好手。18歲右投賴謙凡今天的簽約記者會上，兩位洋基前輩也現身。王建民自己也曾親眼見證過賴謙凡的投球，身為中信兄弟隊投手教練的他，坦言很想把他留下來，但後來想想，「留下來，我們這隊也選不到，還是希望他可以挑戰美國。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078795.jpg&M=1&s=Y&x=0&y=0&sw=1166&sh=777&exp=3600&sl=W&fw=360", "date": "2026-06-26 11:10", "link": "/news/story/6999/9589937"}, {"article_id": "9589850", "title": "NBA／告別三球時代！後場殺手懷特3年21.9億續約黃蜂", "summary": "隨著黃蜂當家球星「三球」小鮑爾（LaMeloBall）被交易至灰狼後，根據《ESPN》權威記者查拉尼亞（Shams Charania）報導，後衛懷特（Coby White）與球隊完成3年7400萬美元（約新台幣21.9億元）續約，且為全額保障，合約中不包含任何球員或球隊選項，正式確立球隊未來核心方向。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078631.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-26 10:58", "link": "/news/story/7002/9589850"}, {"article_id": "9589875", "title": "MLB／相隔16年再簽台將 洋基看賴謙凡能力「不需太多考慮」", "summary": "美國職棒大聯盟傳統豪門洋基隊時隔16年再於台灣獵才，簽下來自大溪高中的18歲右投賴謙凡，今天在六福萬怡酒店為他舉辦加盟儀式，正式披上洋基球衣、球帽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078696.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-26 10:49", "link": "/news/story/6999/9589875"}, {"article_id": "9589804", "title": "高球／徐薇淩大賽維持好手感 女子PGA錦標賽首輪繳69桿", "summary": "年度五大賽之一的女子PGA錦標賽今天進行首回合，台灣好手徐薇淩維持近來的手感，抓4博蒂、吞1柏忌繳出低於標準3桿的69桿...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078669.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-26 10:45", "link": "/news/story/7005/9589804"}, {"article_id": "9589851", "title": "MiLB／林維恩傷勢不妙！美媒曝恐遭遇UCL撕裂傷", "summary": "運動家隊3A台灣左投林維恩6月14日被放進傷兵名單，運動家農場媒體《A's Farm》總編輯莫里亞蒂（Bill Moriarity）指出，林維恩可能遭遇尺側副韌帶撕裂傷勢（UCL）。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078632.jpg&M=1&s=Y&x=0&y=80&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-26 10:40", "link": "/news/story/6999/9589851"}, {"article_id": "9589847", "title": "世足賽／日本暌違24年小組賽不敗 本田圭佑盼藍武士對巴西扮巨人殺手", "summary": "日本今天在世足賽小組賽最後一戰以1：1與瑞典握手言和，以1勝2和作收並晉級到32強賽，這也是日本繼2002年後再度在世足賽小組賽保持不敗晉級，門將鈴木彩艷賽後也表示，希望能夠帶著這股不敗氣勢迎戰接下來的對手巴西。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078648.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-26 10:37", "link": "/news/story/123107/9589847"}, {"article_id": "9589765", "title": "MLB／李灝宇再先發連5場敲安 今井達也6局無失分飆10K奪勝", "summary": "老虎隊今起與太空人隊展開4連戰，「台灣怪力男」李灝宇繼續先發上陣且打滿全場，面對日籍右投今井達也吞2K，但對太空人牛棚敲1支安打，連續5場安打，最終老虎仍以1：2吞下3連敗；今井達也則是6局無失分飆10K，拿下本季第5勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078488.jpg&M=1&s=Y&x=371&y=105&sw=553&sh=369&exp=3600&sl=W&fw=360", "date": "2026-06-26 10:08", "link": "/news/story/6999/9589765"}, {"article_id": "9589762", "title": "世足賽／日本32強對巴西將頑強戰鬥 攜手瑞典晉級為南韓添變數", "summary": "「藍武士」日本今天在世足賽小組賽最後一戰與瑞典以1：1平手收場後，以小組第2名晉級到32強賽，並將強碰C組第1名的「森巴軍團」巴西，儘管雙方過去14度對戰日本僅拿下1勝，但主帥森保一仍強調，將會和支持日本的球迷一起頑強且堅韌的戰鬥到最後一刻。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078507.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-26 10:06", "link": "/news/story/123107/9589762"}, {"article_id": "9589620", "title": "世足賽／古拉索16萬人口墊底出局 教頭：為球員們感到無比驕傲", "summary": "世界盃古拉索總教練艾沃卡今天表示，儘管古拉索隊遭世界盃淘汰，但球員們雖敗猶榮。艾沃卡也不排除繼續執掌這支來自加勒比海、全...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078224.jpg&M=1&s=Y&x=0&y=0&sw=1249&sh=833&exp=3600&sl=W&fw=360", "date": "2026-06-26 09:41", "link": "/news/story/123107/9589620"}, {"article_id": "9589651", "title": "世足賽／荷蘭3：1勝突尼西亞搶分組一 32強對決摩洛哥", "summary": "世界盃小組賽F組最後一輪，不敗的荷蘭今天對上2連敗的突尼西亞，開賽前7分鐘就取得2：0領先，下半場雙方則是各進1球，終場荷蘭以3：1勝出，小組賽戰績2勝1和、積分7分取得分組第一，32強淘汰賽將對上摩洛哥。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35078255.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-26 09:33", "link": "/news/story/123107/9589651"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9589949", "title": "世足賽／日本踢平瑞典對南韓不利！韓媒：幫不