{"article_id": "9574397", "title": "日職／軟銀教練直言徐若熙天賦驚人 專家看好延續出色表現", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35055919.jpg&M=1&s=Y&x=321&y=205&sw=680&sh=454&exp=3600", "link": "/news/story/7001/9574397"}, {"article_id": "9574248", "title": "日職／孫易磊預計周末先發登板對決軟銀 日媒形容是「秘密武器」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35055591.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600", "link": "/news/story/7001/9574248"}], "subsections": [{"name": "專欄", "articles": [{"article_id": "9574891", "title": "世足攻略／第二輪東道主坐擁地利 墨對韓有6成勝率、加國有望破零勝魔咒", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056737.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9574891"}, {"article_id": "9573408", "title": "中職／鍾允華離新人王最近 但兩名自培新秀也值得肯定", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35054128.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9573408"}, {"article_id": "9573349", "title": "煮茶論戰／梅西「戴帽」寶刀未老 背後有3大關鍵", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/17/35054050.jpg&M=1&s=Y&x=0&y=22&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9573349"}, {"article_id": "9572592", "title": "世足攻略／英格蘭正常發揮應可勝老邁格子軍 葡萄牙就怕慢熱輕敵被爆冷", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/17/35052981.jpg&M=1&s=Y&x=0&y=0&sw=1253&sh=835&exp=3600&w=300", "link": "/news/story/122629/9572592"}, {"article_id": "9572114", "title": "讓西班牙27次射門成泡影 維德角40歲門將用生命寫「小卒也能成英雄」", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/17/35052448.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9572114"}, {"article_id": "9570610", "title": "中職／測試會挖掘大量珍珠 朱育賢是最閃耀的一顆星", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/16/35050121.jpg&M=1&s=Y&x=0&y=131&sw=745&sh=497&exp=3600&w=300", "link": "/news/story/122629/9570610"}]}, {"name": "最新文章", "articles": [{"article_id": "9575414", "title": "中職／「選秀小年」200人參選再寫新高 名單揭曉0旅外球員", "summary": "中華職棒新人球員選拔會將於6月29日在台中頂粵吉品舉行，今年參選人數突破新高，共有200位選手報名，包括投手83人、捕手20人、一壘手11人、二壘手13人、三壘手7人、游擊手25人及外野手41人。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35057509.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 18:49", "link": "/news/story/7001/9575414"}, {"article_id": "9575379", "title": "中職／凌晨3點多才回到桃園 桃猿今排許賀捷首扛開路先鋒", "summary": "樂天桃猿隊前一天和台鋼雄鷹隊打到延長賽10局贏球，回到桃園已半夜，今天在主場迎戰味全龍隊先發打線再做出調整，連兩戰的開路先鋒都成亮點，今天由許賀捷生涯首度擔任先發第1棒，昨天扛首棒的劉子杰則在板凳待命。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35057446.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 18:27", "link": "/news/story/7001/9575379"}, {"article_id": "9575374", "title": "世足賽／西班牙首輪爆冷被追平 運彩奪冠賠率被法國超車", "summary": "2026美加墨世界盃第一輪小組賽今天全數結束，台灣運彩今天公布銷售前三名，分別為6月17日法國對塞內加爾的9300萬、6月16日西班牙對維德角的9100萬、以及6月17日阿根廷對阿爾及利亞的8200萬；台灣運彩表示，隨著第二輪開踢，賽事熱度提高，單場銷售可望有機會破億。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35057452.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 18:24", "link": "/news/story/123107/9575374"}, {"article_id": "9575366", "title": "中職／兩名高中游擊好手投入選秀 葉總：有比江坤宇好嗎？", "summary": "中華職棒選秀名單將在今天稍後揭曉，就目前已知名單中，以兩名高中游擊手陳柏凱、許書誠最受矚目，成為首輪的最大熱門，味全龍隊葉君璋被問及對兩名選手的看法時直言：「有比江坤宇好嗎？要比他好才是『大物』。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35057442.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 18:22", "link": "/news/story/7001/9575366"}, {"article_id": "9575278", "title": "世足運彩／南韓客場硬仗硬拼 墨西哥主場優勢推不讓分和局", "summary": "南韓與墨西哥在世界盃小組賽A組展開激烈對決，墨西哥承襲主場優勢，但主力後衛缺陣可能影響防守。南韓隊擁有多名歐洲球星，具備強大攻擊能力，雙方皆希望鎖定出線權，預測本場比賽或以和局收場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35057326.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-18 17:43", "link": "/news/story/123105/9575278"}, {"article_id": "9575188", "title": "MLB／阿姆斯壯連三戰開轟 小熊灌7分大局擊敗洛磯", "summary": "小熊隊在主場以8：6擊敗洛磯，贏得系列賽。阿姆斯壯在比賽中連續第三場開轟，助攻小熊在第2局攻下7分。儘管洛磯後來追分，但小熊仍穩守勝利。阿姆斯壯表現出色，6月打擊率高達4成06。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35057165.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 17:26", "link": "/news/story/6999/9575188"}, {"article_id": "9575105", "title": "世足賽／FIFA新規定不許親密接吻？英格蘭球星帶頭違反「禁吻令」", "summary": "世足賽上，FIFA禁止球迷進行親密接吻，但英格蘭球員貝林漢卻違反規定，賽後深吻女友，引發關注。此禁令旨在防止性騷擾，除了親吻行為，觀眾也不得攜帶違禁品。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35057063.jpg&M=1&s=Y&x=0&y=146&sw=1042&sh=695&exp=3600&sl=W&fw=360", "date": "2026-06-18 17:25", "link": "/news/story/123107/9575105"}, {"article_id": "9575106", "title": "NBA／傳老鷹等3隊有意開頂薪搶里夫斯 湖人願意給就會留隊", "summary": "里夫斯（Austin Reaves）將拒絕1490萬美元的球員選項，成為自由球員。他的去留是湖人隊休賽季重點，外界預期至少能獲得年薪4000萬美元合約，最多可和湖人簽5年2.39億美元，其他球隊則是4年1.77億美元。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35057054.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 16:44", "link": "/news/story/7002/9575106"}, {"article_id": "9574839", "title": "世足運彩／和局高賠誘買南韓不敗味道不輕 讓球盤支撐主場優勢GPT推薦墨西哥勝", "summary": "世足小組賽K組將上演墨西哥對南韓的對決，賠率顯示墨西哥主勝為1.82，南韓客勝則為4.575。歷史交手上，墨西哥在近五戰中獲得四勝，戰意明顯。GPT推薦墨西哥勝出，正確比分為2:1。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35057005.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 16:29", "link": "/news/story/123105/9574839"}, {"article_id": "9574980", "title": "拳擊／黃筱雯惜敗法國好手 無緣WB盃中國站4強", "summary": "世界排名第1的「台灣拳后」黃筱雯，今天征戰拳擊WB盃中國站女子54公斤級的8強戰，可惜終場以1比4不敵法國好手拉卡狄里，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056958.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 16:12", "link": "/news/story/7005/9574980"}, {"article_id": "9574973", "title": "NBA／前公鹿主帥談字母哥下一站 看好綠衫軍比熱火更適合", "summary": "前公鹿總教練瑞佛斯看好字母哥安戴托昆波加入塞爾蒂克，認為此舉能融合完整陣容，相較之下，熱火若交易赫洛將削弱實力。他指出，塞爾蒂克仍可圍繞泰托姆建隊，維持競爭力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056877.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 16:10", "link": "/news/story/7002/9574973"}, {"article_id": "9574838", "title": "世足運彩／莊家看好地主高原主場禦敵、交戰歷史也沒輸過！Gemini預測墨西哥2：1勝南韓", "summary": "2026世界盃A組將上演關鍵戰，南韓面對墨西哥高原主場的挑戰。在海拔1670公尺的瓜達拉哈拉，巨星孫興慜需克服體能考驗，爭取晉級。賠率顯示墨西哥具優勢，過去交手紀錄亦力挺主場勝利。預計比賽將呈現防守拉鋸戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056956.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 16:09", "link": "/news/story/123105/9574838"}, {"article_id": "9574827", "title": "世足運彩／晉級生死戰地主退無可退 加拿大強攻卡達殘防Gemini推3:0或3:1", "summary": "世界盃小組賽B組，加拿大面對卡達的晉級生死戰即將上演。地主加拿大須在主場全取三分來爭取晉級機會，賠率顯示莊家對其勝算信心十足。專家預測，加拿大可能以3:0或3:1輕鬆取勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056939.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 16:06", "link": "/news/story/123105/9574827"}, {"article_id": "9574821", "title": "世足運彩／以中場壓制波赫 GPT看好瑞士進攻為主3球以上大分", "summary": "札卡掌控瑞士中場節拍，正好對上波赫仰賴前場支點與第二點衝擊的進攻模式，這組對位會直接決定比賽是否被瑞士拉進熟悉的節奏。瑞士排名第19，波赫第64，差距不只在名次，更在主力球員處理壓力球的成熟度；阿坎吉", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056907.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 15:59", "link": "/news/story/123105/9574821"}, {"article_id": "9574992", "title": "世足賽／加拿大強心針 隊長戴維斯回歸迎戰卡達爭隊史首勝", "summary": "世足賽小組賽B組明天將展開第二輪賽事，首戰與波赫握手言和的加拿大，在第二輪迎戰卡達前夕迎來好消息，加拿大總教練馬許（Jesse Marsch）於今天證實，此前因傷缺席首戰的球隊核心兼隊長戴維斯（Alphonso Davies），已確定能在此役披掛上陣。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056965.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-18 15:59", "link": "/news/story/123107/9574992"}, {"article_id": "9574986", "title": "世足賽／戲劇性絕殺巴拿馬 迦納球星曝：大家在休息室都瘋了", "summary": "FIFA世界排名落在73位的迦納，本屆世界盃首戰中場大將帕爾特伊（Thomas Partey）還被拒絕入境加拿大，缺席和巴拿馬的對決，不過20歲小將伊倫基（Caleb Yirenkyi）傷停補時的關鍵進球，助隊1：0絕殺拿下勝場，為分組接續挑戰雙強英格蘭和克羅埃西亞注入自信。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056977.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-18 15:56", "link": "/news/story/123107/9574986"}, {"article_id": "9574826", "title": "世足運彩／卡達受讓冷門賠率偏肥但對地主仍有信心 GPT推薦加拿大不讓分勝出", "summary": "在世足小組賽B組中，加拿大 vs. 卡達的比賽中，加拿大被看好取得主勝，賠率僅1.308倍。卡達若想反擊，需低調守勢，但實力差距顯著，加拿大近期狀態佳，進攻防守均具優勢。投注建議以加拿大不讓分勝出為主。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056833.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 15:47", "link": "/news/story/123105/9574826"}, {"article_id": "9574891", "title": "世足攻略／第二輪東道主坐擁地利 墨對韓有6成勝率、加國有望破零勝魔咒", "summary": "世足賽小組賽將迎來兩場焦點對決，墨西哥對南韓及加拿大對卡達。墨西哥在A組中爭取晉級，雖面臨主力停賽困擾，但主場優勢顯著。B組的加拿大則期待在主場破除歷史「零勝魔咒」，兩隊皆有機會掌控比賽局勢。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056737.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 15:42", "link": "/news/story/122629/9574891"}, {"article_id": "9574927", "title": "世足賽／曝梅西進球後落淚原因 阿根廷記者：父親身體狀況惡化", "summary": "阿根廷足球巨星梅西（Lionel Messi）昨天在2026年世界盃分組賽，上演帽子戲法，率隊以3：0擊退阿爾及利亞。梅西踢進首球後落淚，畫面引發球迷熱議，阿根廷知名記者費因曼（Eduardo Feinmann）說明梅西落淚的原因。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056761.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 15:36", "link": "/news/story/123107/9574927"}, {"article_id": "9574822", "title": "世足運彩／B組混戰十字軍團瑞士防線穩固 對決波赫Gemini看好正確比分2:1", "summary": "瑞士將於6月19日迎戰波赫，這場B組生死戰將決定晉級關鍵。瑞士士氣高昂，具備出色防線與大賽經驗，預計將以2比1戰勝波赫，爭取重要3分。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056744.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 15:35", "link": "/news/story/123105/9574822"}, {"article_id": "9574818", "title": "世足運彩／南非防線犯錯成本會被放大 GPT看好捷克勝、全場3球以上", "summary": "捷克與南非在世界盃小組賽的關鍵對決即將展開。捷克雖在首戰失利，但實力被看好，平均賠率顯示捷克勝算高於南非。考量控球穩定度與抗壓經驗，捷克有望掌控比賽節奏，預期全場進球數將超過3球。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056738.jpg&M=1&s=Y&x=352&y=220&sw=758&sh=505&exp=3600&sl=W&fw=360", "date": "2026-06-18 15:32", "link": "/news/story/123105/9574818"}, {"article_id": "9574806", "title": "排球／日本男排前國手持有大麻被起訴 交保後致歉", "summary": "日本男子排球前國手佐藤駿一郎上月因為涉嫌持有大麻被逮捕以及起訴。他今天上午交保後，面對大批媒體採訪時致歉，「我深刻反省，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056711.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 15:26", "link": "/news/story/7005/9574806"}, {"article_id": "9574817", "title": "世足運彩／南非捷克可能成進球大戰 Gemini推薦大分、正比2：1或3：1", "summary": "捷克與南非在2026世界盃A組小組賽中面對生死戰，雙方皆需全取3分保住晉級希望。捷克近期進攻火力強勁，預計將上演進球大戰，投注建議為總和2.5大分及捷克2：1或3：1的比分。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056660.jpg&M=1&s=Y&x=71&y=0&sw=1108&sh=739&exp=3600&sl=W&fw=360", "date": "2026-06-18 15:20", "link": "/news/story/123105/9574817"}, {"article_id": "9574797", "title": "世足賽／C羅首戰0次射正遭法國名將銳評 「是球隊需要進球，不是你」", "summary": "C羅在世足賽首戰遭法國名將亨利尖銳批評，因其未能協助球隊進攻，葡萄牙以平局收場。亨利指出，C羅應以球隊需求為重，而非個人利益，強調進球需集體合作。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35056496.jpg&M=1&s=Y&x=0&y=27&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-18 15:03", "link": "/news/story/123107/9574797"}]