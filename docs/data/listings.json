le_id": "9585303", "title": "NBA／承認10年前當過柯瑞黑粉 勇士首輪新秀：我是厄文球迷", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35071903.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600", "link": "/news/story/7002/9585303"}], "subsections": [{"name": "專欄", "articles": [{"article_id": "9585761", "title": "世足攻略／巴西要靠球星破蘇格蘭鐵桶估贏2球 南韓非贏不可要防南非逼平", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072655.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/122629/9585761"}, {"article_id": "9585536", "title": "輕則驚嚇、重則破網！阿根廷隊友相信梅西禁區左腳給的承諾", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072449.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9585536"}, {"article_id": "9584450", "title": "中職／要避免成為洋投聯盟 不如先制定本土先發遊戲規則", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070482.jpg&M=1&s=Y&x=0&y=0&sw=1024&sh=683&exp=3600&w=300", "link": "/news/story/122629/9584450"}, {"article_id": "9583239", "title": "世足攻略／英格蘭火力旺2連勝問題不大 葡萄牙攻擊效率差小勝機率高", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35068759.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/122629/9583239"}, {"article_id": "9581485", "title": "下放11天救贖大覺醒！李灝宇攻守兩端精算 拚卡位老虎二遊", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35066096.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9581485"}, {"article_id": "9581615", "title": "中職／悍將別等威戈神了 補強洋投才不會白費上半季好戰績", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35066229.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9581615"}]}, {"name": "最新文章", "articles": [{"article_id": "9586199", "title": "射箭／玉山國手選拔賽25日開戰 亞運國手許芯慈、顏子翔領銜出賽", "summary": "由玉山銀行第三年贊助的「玉山射箭國手選拔賽」，今天於嘉義中正大學田徑場舉行盛大的開幕儀式，今年共有來自全國236名青年、青少年射箭好手參賽，其中更有今年名古屋亞運現役國手許芯慈（反曲弓）、顏子翔（複合弓）領銜出賽，選手將在25至27日進行多達12局432箭的高強度競爭，爭奪代表台灣參加12月亞洲青年暨青少年射箭錦標賽的代表隊國手資格。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073321.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-24 18:21", "link": "/news/story/7005/9586199"}, {"article_id": "9585775", "title": "世足運彩／資金與莊家態度明確倒向美洲雄鷹 Gemini推薦順應市場潮流預測墨西哥2：1勝", "summary": "2026世界盃A組小組賽，墨西哥迎戰捷克，勢必決定兩隊前景。墨西哥以優勢主場心理、實力差距，預測將2：1獲勝，並順利晉級淘汰賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073149.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:25", "link": "/news/story/123105/9585775"}, {"article_id": "9585774", "title": "世足運彩／捷克冷門條件不完整 地主6分在手不會放慢腳步GPT看好墨西哥2：1或3：1勝", "summary": "墨西哥在世足小組賽中以二連勝和零失球的佳績領先，面對捷克的壓力戰這場比賽顯示明顯優勢。捷克需全力以赴，墨西哥有機會利用反擊擴大優勢，預測最終比分為2比1或3比1。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073093.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:21", "link": "/news/story/123105/9585774"}, {"article_id": "9585928", "title": "世足運彩／墨西哥讓淺盤有鬼！捷克尊嚴之戰戰意滿點推薦受讓過關與正比1：1", "summary": "捷克與墨西哥將於6月25日展開生死戰，捷克需勝才能晉級，而墨西哥已提前出線並可能進行陣容輪換。主要球星施克的表現至關重要，捷克有望在對手防線重組中把握機會。建議選擇捷克受讓0.5球，預測比賽結果為平局1:1。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072874.jpg&M=1&s=Y&x=0&y=0&sw=1260&sh=840&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:17", "link": "/news/story/123105/9585928"}, {"article_id": "9586026", "title": "NBA／幫溫班亞瑪找替補幫手 馬刺首輪連拿兩個禁區怪物", "summary": "馬刺在NBA選秀中連挑兩名禁區新秀，選中康乃狄克大學中鋒里德，作為替補球員支援明星溫班亞瑪。另一名選手肯塔基大學的昆坦斯則因膝傷風險高，成為一場豪賭。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073074.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:13", "link": "/news/story/7002/9586026"}, {"article_id": "9586024", "title": "世足賽／哥倫比亞率先晉級 致勝功臣穆納茲：不以此滿足", "summary": "民主剛果門將姆帕西（Lionel Mpasi）今天開賽前20分鐘就擋下哥倫比亞5次猛攻，但第76分鐘仍被穆納茲（Daniel Munoz）攻破球門，這記全場唯一進球讓哥倫比亞以2連勝率先晉級，穆納茲獲選單場最佳球員。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073076.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:02", "link": "/news/story/123107/9586024"}, {"article_id": "9585883", "title": "世足賽／巴西世界盃的球衣政治學 穿紅穿綠意義大不同", "summary": "巴西隊今天在世界盃迎戰蘇格蘭隊時，門將貝克（Alisson Becker）將身穿綠色球衣出賽，而非國際足球總會（FIFA...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073049.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:02", "link": "/news/story/123107/9585883"}, {"article_id": "9585771", "title": "世足運彩／太極虎生死戰拒絕保守求和 強碰疲憊南非利多Gemini 推薦南韓2：1勝出", "summary": "南韓將迎戰南非，若能把握機會將有望順利晉級。儘管太極虎在先前比賽中失利，但目前士氣高昂，專注求勝。反觀南非面臨疲憊與壓力，賠率顯示支持南韓不敗，預測比分為南韓2比1南非。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072997.jpg&M=1&s=Y&x=0&y=27&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:00", "link": "/news/story/123105/9585771"}, {"article_id": "9585770", "title": "世足運彩／南非搶攻易出漏洞！南韓不會把命運交給對手GPT看好2：1或3：1勝出", "summary": "南韓在世足小組賽面對南非，前者目前穩居小組第二，賠率顯示南韓勝出優勢明顯。南非需全力搶分，希望逆轉形勢，預測總進球數可達至少3球。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072665.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-24 17:00", "link": "/news/story/123105/9585770"}, {"article_id": "9585763", "title": "世足運彩／讓球盤壓力落在淨勝球需求 摩洛哥對海地GPT看好2.5大分", "summary": "摩洛哥排名第7、海地第83，國際盤卻把主勝均價放在2.14，表面不像一面倒低賠，實際搭配和局5.627、客勝11.993來看，莊家真正的態度不是懷疑摩洛哥能否贏，而是把市場焦點推向讓球盤：北非雄獅若只", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073016.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 16:58", "link": "/news/story/123105/9585763"}, {"article_id": "9585762", "title": "世足運彩／搶分爭龍頭全力開火！北非雄獅將痛擊出局海地Gemini推摩洛哥3：0或4：0", "summary": "摩洛哥在世界盃小組賽決戰中面對海地，擁有高達4分的他們力爭小組第一，反觀海地已宣告出局。數據顯示，摩洛哥實力強大，預測將以3：0或4：0輕鬆取勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072944.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 16:53", "link": "/news/story/123105/9585762"}, {"article_id": "9585914", "title": "NBA／湖人交易補強內線又夢碎？公鹿恐無意再轉售韋爾", "summary": "湖人補強計畫恐遭損壞，年輕中鋒韋爾在公鹿被熱火交易後，公鹿不考慮再次交易他，讓多隊包括湖人失去機會。韋爾本季場均11.1分、9.0籃板，成為公鹿重建基石。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072838.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 16:51", "link": "/news/story/7002/9585914"}, {"article_id": "9585978", "title": "NBA／和老闆在「選秀戰情室」吵架 勇士總管：在討論高爾夫球場", "summary": "今天選秀會最大話題不是球員本身，而是勇士隊老闆拉卡柏（Joe Lacob）和總管鄧利維（Mike Dunleavy Jr.）在戰情室爭執畫面流出。鄧利維事後受訪時聲稱，兩人對於選擇密西根大學23歲前鋒倫德伯格（Yaxel Lendeborg）有共識。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072923.jpg&M=1&s=Y&x=357&y=103&sw=923&sh=615&exp=3600&sl=W&fw=360", "date": "2026-06-24 16:49", "link": "/news/story/7002/9585978"}, {"article_id": "9585759", "title": "世足運彩／蘇格蘭難破歷史魔咒 巴西強大實力壓境Gemini推比分2:1", "summary": "2026年世界盃C組小組賽迎來焦點對決，由蘇格蘭硬碰南美強權巴西。從兩隊近期狀態與士氣來看，蘇格蘭雖剛奪首勝、士氣大振，但小組賽形勢緊迫，依舊面臨巨大晉級壓力；反觀森巴軍團目前取得一勝一和積四分，全隊", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072921.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 16:46", "link": "/news/story/123105/9585759"}, {"article_id": "9585758", "title": "世足運彩／蘇格蘭背水一戰遇南美強權爭榜首 GPT看好巴西不讓分勝出", "summary": "蘇格蘭目前3分排在巴西、摩洛哥之後，這場若輸球，晉級主控權很可能拱手讓人；巴西雖有4分在手，但同組摩洛哥同分緊追，森巴軍團也沒有本錢把節奏踢成保守消耗戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072900.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 16:40", "link": "/news/story/123105/9585758"}, {"article_id": "9585932", "title": "世足運彩／捷克搶分爭晉級 地主全力護衛拚龍頭推墨西哥不讓分", "summary": "墨西哥在世界盃小組賽中穩居第一，將迎戰全力搶分的捷克。捷克需全力挑戰墨西哥以爭取晉級機會。墨西哥總教練計畫進行主力輪休，捷克希望利用定位球戰術爭取分數。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072879.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-24 16:33", "link": "/news/story/123105/9585932"}, {"article_id": "9585755", "title": "世足運彩／積分、把握度及攻守推進都優於卡達 GPT推薦波赫1：0或2：0", "summary": "波赫在即將對陣卡達的賽事中，主場心理優勢明顯，賠率顯示主勝受看好，且攻守掌控都優於對手。卡達進攻低迷，防線信心不足，若先失球心態恐會崩盤。專家預測最可能的比分為1比0或2比0。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072827.jpg&M=1&s=Y&x=0&y=0&sw=1276&sh=850&exp=3600&sl=W&fw=360", "date": "2026-06-24 16:07", "link": "/news/story/123105/9585755"}, {"article_id": "9585863", "title": "世足運彩／森巴軍團強勢硬進攻竟開受讓 鐵桶蘇格蘭鐵了心硬守推巴西倒打讓分", "summary": "巴西與蘇格蘭在世足小組賽C組的關鍵戰將於6月25日進行。巴西隊雖然在首輪僅平摩洛哥，但第二場以3：0擊敗海地，隊內陣容強大。蘇格蘭目前進攻乏力，僅攻入1球，面對巴西必須全力爭勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072811.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-24 16:05", "link": "/news/story/123105/9585863"}, {"article_id": "9585754", "title": "世足運彩／背水一戰波赫強悍攻勢強襲卡達 Gemini推薦正比2：1", "summary": "2026年世界盃小組賽B組，波赫與卡達將上演生死戰，雙方均積1分，必須全力爭取勝利以保住晉級希望。卡達防線脆弱，波赫具備攻擊優勢，預測成果為波赫2比1勝出。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072789.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 15:54", "link": "/news/story/123105/9585754"}, {"article_id": "9585824", "title": "世足運彩／南韓拒絕高風險退防死守 南非被賽程凌虐慘敗不意外主推小分", "summary": "南韓對南非的世足小組賽中，儘管只需和局晉級，但總教練拒絕保守戰術，強調退防死守風險高。南非因賽程密集體能消耗大，加上球員禁賽，面臨挑戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072787.jpg&M=1&s=Y&x=0&y=0&sw=1275&sh=850&exp=3600&sl=W&fw=360", "date": "2026-06-24 15:51", "link": "/news/story/123105/9585824"}, {"article_id": "9585751", "title": "世足運彩／瑞士加拿大分組龍頭之爭勢均力敵 Gemini推薦雙方和局、正比1：1", "summary": "瑞士和加拿大在世足B組小組賽中同積4分，陣容實力接近。分析預測本場可能以1比1平局收場，雙方攻守均衡，賠率顯示和局投資價值高。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072774.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 15:49", "link": "/news/story/123105/9585751"}, {"article_id": "9585711", "title": "世足賽／「美國人熱愛頂級賽事」！ 票價史上最貴觀眾數仍有望創紀錄", "summary": "儘管票價驚人且川普政府旅遊限制重重，本屆世界盃足球賽觀眾人數仍有望創下歷史新高。專家表示，這與美國人是否喜愛足球關係不大...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072771.jpg&M=1&s=Y&x=26&y=0&sw=1229&sh=819&exp=3600&sl=W&fw=360", "date": "2026-06-24 15:47", "link": "/news/story/123107/9585711"}, {"article_id": "9585832", "title": "MLB／台東子弟賴謙凡加盟洋基 棒球啟蒙教練是父親", "summary": "美國職棒大聯盟紐約洋基隊宣布簽下18歲、來自台東海端鄉的投手賴謙凡。他的父親是棒球教練，從小帶他練球。因父親在山區工作，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072766.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-24 15:45", "link": "/news/story/6999/9585832"}, {"article_id": "9585744", "title": "MiLB／莊陳仲敖3A投4.2局無失分6K代表作 鄭宗哲單場雙安", "summary": "美國職棒小聯盟（MiLB）運動家隊台灣投手莊陳仲敖投出3A生涯代表作，今天先發4.2局無失分，包含6次三振；波士頓紅襪隊...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072746.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-24 15:43", "link": "/news/story/6999/9585744"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9585008", "title": "世足賽／首戰0進球被罵爆 C羅坦言是「黑暗一周」", "date": "2026-06-24 10:46", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35071451.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9585008"}, {"article_id": "9585802", "title": "世足賽／沒給12碼罰球質疑VAR判決 迦納教頭嘲諷：去喝咖啡了嗎？", "date": "2026-06-24 15:21", "thumbnail": "https://