https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/07/34926618.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300"}, {"article_id": "9489114", "title": "同樣日職明星到美國 今井達也為何水土不服？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/07/34926973.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9487893", "title": "雷霆首戰從從容容游刃有餘 湖人「小輸」背後的恐怖絕望感", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/07/34925288.jpg&M=1&s=Y&x=32&y=68&sw=1210&sh=806&exp=3600&w=300"}, {"article_id": "9486000", "title": "活塞贏G1防守強度仍不及暴龍 騎士有對位優勢看好6戰晉級東冠", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/06/34922484.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9486031", "title": "中職／打線變準一成戰隊 中信上半季剩下時間就是調打擊", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/06/34922520.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9492328", "title": "NBA／托尼兄弟執法「失控」？灰狼主帥怒噴：把那3秒還我", "summary": "灰狼今日在西區季後賽第二輪G3主場以108：115不敵馬刺，系列賽陷入1：2落後。不過比賽過程中，灰狼主帥芬奇（Chris Finch）與裁判托尼兄弟（Tony Brothers）爆發激烈衝突，反而成為賽後最大焦點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931989.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-09 16:30"}, {"article_id": "9492380", "title": "韓職／王彥程6.1局優質先發奪第3勝 相隔35天再嘗勝投滋味", "summary": "效力韓職韓華鷹隊的台灣左投王彥程，今天面對LG雙子隊繳出6.1局失3分優質先發，韓華終場以11：3大勝，王彥程拿到本季第3勝，繼4月4日後久違再拿到勝投。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_9.jpg", "date": "2026-05-09 16:30"}, {"article_id": "9492374", "title": "中職／傳到壘包算傳準還傳歪？ 葉君璋不解設嚴格三呎線規定又打破", "summary": "中華職棒再度出現三呎線討論，味全龍隊總教練葉君璋今天受訪，還原自己覺得不解的地方，「傳到壘包的球算是傳準或傳歪？」認為中職對於三呎線設定嚴格規定，才會導致難以解釋。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34932064.jpg&M=1&s=Y&x=0&y=57&sw=895&sh=597&exp=3600&sl=W&fw=360", "date": "2026-05-09 16:20"}, {"article_id": "9492301", "title": "MLB／釀酒人火球男22顆102英里！「左打法官」震撼：人生沒看過這麼快的球", "summary": "釀酒人24歲火球男米蕭洛斯基（Jacob Misiorowski）今日面對洋基徹底震撼全場，不僅主投6局無失分、狂飆11次三振，全場更投出22顆球速102英里以上的球，其中10顆突破103公里，雙雙改寫投球追蹤數據時代紀錄，率領釀酒人以6：0完封洋基。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34932047.jpg&M=1&s=Y&x=208&y=18&sw=836&sh=557&exp=3600&sl=W&fw=360", "date": "2026-05-09 16:13"}, {"article_id": "9492336", "title": "中職／總教練會議有在聽 光總看昨役3呎線判例已心裡有譜", "summary": "中華職棒3呎線再成話題，今天富邦悍將隊總教練後藤光尊賽前再次召集全隊，再次叮嚀現行規定。他也提到，昨天的play，其實已有心理準備，因為年初的總教練會議上，裁判已有明確說明，「所以都有在注意。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931996.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&sl=W&fw=360", "date": "2026-05-09 15:38"}, {"article_id": "9492329", "title": "NBA／「我就是為大場面而生！」 溫班亞瑪攻防一體接管戰局 喊話系列賽還沒結束", "summary": "儘管頂著5次犯規麻煩在身，溫班亞瑪（Victor Wembanyama）卻是在第四節宰制整個局面，攻守兩端全面接管比賽。根據統計，溫班亞瑪在第3戰客場狂轟39分15籃板5阻攻，成為史上第4位在季後賽有如此表現的球星，率領馬刺拿下重要勝利。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931992.jpg&M=1&s=Y&x=0&y=26&sw=1050&sh=701&exp=3600&sl=W&fw=360", "date": "2026-05-09 15:37"}, {"article_id": "9492323", "title": "NBA／裁判偏袒雷霆？德國坦克：湖人通常是罰球戰贏家", "summary": "昨天湖人隊在季後賽第二輪G2以107：125輸給雷霆隊，賽後許多湖人球員和球迷認為裁判偏袒雷霆。不過傳奇球星「德國坦克」諾威茨基（Dirk Nowitzki）點出，湖人一直在罰球方面獲益，因此感到不習慣。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931981.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-09 15:34"}, {"article_id": "9492324", "title": "中職／陳子豪下二軍「調整運氣」 葉總坦言心情已受影響", "summary": "味全龍隊今天選手異動，陳子豪、鋼龍降下二軍，升上曾聖安、梅賽鍶，陳子豪低潮至今，終於被降下二軍，總教練葉君璋坦言：「看他這樣，心情滿不好，也是真的該讓他下去喘息一下。」他也提到，陳子豪能把球打得扎實，因此才會一直將他留在一軍，這趟下去「不是調整實力，是調整運氣。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34932019.jpg&M=1&s=Y&x=272&y=0&sw=817&sh=545&exp=3600&sl=W&fw=360", "date": "2026-05-09 15:31"}, {"article_id": "9492291", "title": "NBA／讚布朗森是史上最偉大FA簽約 巴克利：尼克曾20年沒存在感", "summary": "尼克隊近年成為季後賽常客，傳奇球星巴克利（Charles Barkley）今天在節目直言，布朗森（Jalen Brunson）是史上最偉大自由球員市場簽約。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931929.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-09 14:50"}, {"article_id": "9492271", "title": "中職／不解為何在葉總眼中是慣犯 孔念恩：我今年第一次偷點", "summary": "富邦悍將隊孔念恩昨天跑出三呎線之爭，味全龍隊總教練葉君璋賽後直言注意他很久了，孔念恩今天對此不解，「我今年也才第一次偷點…」，對於「打到頭表示傳得很準」，他坦言：「我是不知道，但他在接球前手就擺在我的臉上，我有要閃的意思，但閃了還是被打到。」。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931889.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&sl=W&fw=360", "date": "2026-05-09 14:21"}, {"article_id": "9492263", "title": "TPBL／公布2025-26年賽季防守獎項名單 高柏鎧連霸年度防守球員", "summary": "台灣職業籃球大聯盟（TPBL）今天（9日）正式公布 2025-26年賽季年度防守獎項，由福爾摩沙夢想家隊禁區核心高柏鎧（Brandon Gilbeck）再度榮膺年度防守球員（DPOY），連續兩季站上聯盟防守之巔，持續展現其在禁區無可取代的統治力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931874.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-05-09 14:13"}, {"article_id": "9492241", "title": "MLB／小熊兩度10連勝隊史91年首見 超越洋基勇士登大聯盟龍頭", "summary": "小熊隊今天以7：1輕取遊騎兵隊，本季第2次10連勝，洋基和勇士隊都輸球，小熊以27勝12敗，登上大聯盟戰績第一。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931848.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-09 14:07"}, {"article_id": "9492218", "title": "MLB／大谷翔平勝利打點擊殺塞揚強投！道奇退勇士近5戰4勝", "summary": "洛杉磯道奇與亞特蘭大勇士兩個分區龍頭今天正面對決，大谷翔平雖然全場僅敲出1支安打，但在關鍵時刻擊出超前適時安打，成為勝利打點，幫助球隊以3比1拿下2連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931826.jpg&M=1&s=Y&x=125&y=19&sw=1016&sh=678&exp=3600&sl=W&fw=360", "date": "2026-05-09 13:57"}, {"article_id": "9492164", "title": "NBA／勇士王朝早已結束！巴克利狠酸格林「不是同一個等級」", "summary": "近日，勇士老將格林（Draymond Green）與名人堂球星巴克利（Charles Barkley）的隔空交火，成為近期NBA熱門話題。一切起因於巴克利在節目中直言，勇士王朝已正式結束，甚至認為格林與柯瑞（Stephen Curry）若還想再拚冠軍，或許該考慮離隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931730.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-09 13:55"}, {"article_id": "9492058", "title": "NBA／準備梭哈米契爾？火箭握大量選秀籤恐醞釀大交易", "summary": "火箭在季後賽首輪遭湖人淘汰後，根據美媒最新消息，火箭有可能再次積極投入球星交易市場，而米契爾（Donovan Mitchell）則被點名是潛在目標之一。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931540.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-09 13:54"}, {"article_id": "9492217", "title": "自由車／96聯賽台北站規模創新高 攜手環沖繩自行車賽接軌亞洲舞台", "summary": "96聯賽台北站暨國手選拔積分賽將於10日在天母運動公園正式登場，作為115年度國手選拔積分賽開幕戰，今年賽事規模全面升級，不僅吸引近450位選手參賽，創下歷史新高，更首度與日本Tour de Okinawa締結「台日國際賽事合作夥伴」關係。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931814.jpg&M=1&s=Y&x=0&y=0&sw=922&sh=615&exp=3600&sl=W&fw=360", "date": "2026-05-09 13:53"}, {"article_id": "9492068", "title": "世足賽／賽事倒數近1個月 3場開幕式將眾星雲集", "summary": "2026世界盃足球賽將在6月開踢。主辦國美國、加拿大、墨西哥將分別輪流舉行盛大的開幕式，並請來麥可布雷、凱蒂佩芮、韓團B...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931809.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-09 13:51"}, {"article_id": "9492188", "title": "2026國際奧林匹克路跑新北登場 中華隊國手陪跑打造最有感賽道體驗", "summary": "中華奧林匹克委員會主辦之年度全民運動盛事「2026國際奧林匹克路跑」，今天（9日）於新北市板橋浮洲橋下堤外自行車道盛大登場。本屆賽事以「為亞運選手加油」為主軸，號召全民以實際行動迎接今年9月即將登場的「2026愛知名古屋亞運」，吸引眾多跑者與民眾熱情參與，現場氣氛熱烈。本次活動更邀請到亞洲奧林匹克理事會以及日本愛知名古屋亞運籌備會貴賓出席本次活動，一同共襄盛舉、支持本次的路跑活動。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931759.jpg&M=1&s=Y&x=0&y=197&sw=720&sh=480&exp=3600&sl=W&fw=360", "date": "2026-05-09 13:21"}, {"article_id": "9492140", "title": "NBA／攻守制霸！溫班亞瑪39分飆歷史紀錄 第四節率馬刺力壓灰狼", "summary": "前一場大勝的馬刺，今天前往明尼蘇達作客，灰狼全場幾乎僅用7人作戰，試圖在自家搶下領先優勢，然而這一切都被溫班亞瑪（Victor Wembanyama）所摧毀。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931692.jpg&M=1&s=Y&x=96&y=50&sw=1025&sh=683&exp=3600&sl=W&fw=360", "date": "2026-05-09 12:48"}, {"article_id": "9492086", "title": "中職／李珠珢用中文自嘲「小笨蛋」 聽邦迷狂噓葉君璋「嚇到吃手手」", "summary": "味全龍隊總教練葉君璋昨天衝上場抗議，被富邦悍將隊球迷狂噓，韓籍啦啦隊女神李珠珢嚇到吃手手的可愛畫面，在網路上被瘋傳。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931594.jpg&M=1&s=Y&x=245&y=41&sw=801&sh=534&exp=3600&sl=W&fw=360", "date": "2026-05-09 12:18"}, {"article_id": "9492050", "title": "MiLB／費柴德敲3A本季第4轟 龍恩同場競技單場3安猛打賞", "summary": "美國職棒小聯盟體系2位台美混血好手今天同場較勁，克里夫蘭守護者隊3A的費柴德敲出本季第4轟，芝加哥小熊隊3A的龍則是3安...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931558.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-09 12:03"}, {"article_id": "9491995", "title": "MLB／李灝宇先發2支0後被換代打 皇家再見安氣走老虎", "summary": "老虎隊今天作客皇家隊主場，台灣好手李灝宇擔任第8棒、鎮守二壘，全場2打數0安打，第6局被換下場。老虎9局下被敲再見安，以3：4含恨落敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931459.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-09 11:26"}, {"article_id": "9491990", "title": "MLB／史上第一人！村上宗隆炸裂15轟出爐 追平賈吉並列全壘打王", "summary": "白襪日籍重砲村上宗隆今日面對水手系列賽首戰，首局就開轟寫下歷史紀錄，不僅追平洋基「法官」賈吉（Aaron Judge）並列全大聯盟全壘打王，更成為大聯盟史上首位「連續8個系列賽首戰開轟」的球員。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931440.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-05-09 11:23"}, {"article_id": "9491946", "title": "NBA／金塊將掀震撼彈？老闆鬆口：除了約柯奇都可能被交易", "summary": "金塊在季後賽首輪遭灰狼淘汰後，休賽季動向也成為外界焦點。對此，金塊老闆克倫克（Josh Kroenke）近日坦言，除了當家球星約柯奇（Nikola Jokic）之外，其餘球員都可能成為交易討論對象。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931362.jpg&M=1&s=Y&x=233&y=0&sw=1003&sh=669&exp=3600&sl=W&fw=360", "date": "2026-05-09 11:04"}]}, {"name": "棒