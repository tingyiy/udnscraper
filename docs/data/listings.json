u=https://uc.udn.com.tw/photo/t3/2026/04/13/34851476.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9438698", "title": "「坦克」精確優化失敗率 NBA擺爛病毒比你想得更嚴重！", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/13/34851011.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9438853", "title": "附加賽勇士對決快艇一戰定生死 勇士還有季後賽可能性", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/13/34851372.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9443630", "title": "韓職／自曝遭言語暴力、躲在廁所哭 韓啦啦隊鄭嘉睿：暫停工作接受治療", "summary": "前韓國職棒起亞虎隊啦啦隊長鄭嘉睿，今天在社群平台發文透露，曾在工作時遭受辱罵與言語暴力，比賽前一直躲在廁所裡哭。目前正接受治療，將減少與粉絲見面機會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858124.jpg&M=1&s=Y&x=0&y=193&sw=961&sh=640&exp=3600&sl=W&fw=360", "date": "2026-04-15 16:29"}, {"article_id": "9443589", "title": "亞沙運／暌違10年舉辦 中華代表團71位選手出征三亞", "summary": "亞洲沙灘運動會暌違10年終於重啟，第6屆亞沙運將於4月22日至30日在中國三亞市舉行，中華代表團共派出71位選手參加10種運動，今天運動部部長李洋為代表團授旗，並致贈20萬元加菜金，祝福選手健康、順利完賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858023.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=852&exp=3600&sl=W&fw=360", "date": "2026-04-15 16:10"}, {"article_id": "9443557", "title": "MLB／6連敗釀酒人又傳壞消息 看板球星葉力奇將休一個月", "summary": "釀酒人當家球星葉力奇因內收肌拉傷被放入傷兵名單，預計缺席一個月。球隊近期已遭遇六連敗，失去進攻主力將對戰績造成進一步影響。葉力奇開季表現良好，打擊率達3成14。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858005.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 16:06"}, {"article_id": "9443511", "title": "社區運動俱樂部說明會全台展開 近800單位搶進響應全民運動政策", "summary": "運動部推動「社區運動俱樂部實施計畫」，全台近800單位參與，顯示基層對運動發展的期待。說明會已在多地舉行，並提供實務案例解析，鼓勵學校與民間合作，促進社區運動常態化。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857899.jpg&M=1&s=Y&x=0&y=64&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 15:50"}, {"article_id": "9443497", "title": "MLB／手套有「藍色力量」？山本由伸：用起來特別順手", "summary": "山本由伸今天面對大都會隊，繳出7.2局只失1分好投，賽後被問到換回藍色手套的原因，山本直言，「手套對投球其實很重要。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857853.jpg&M=1&s=Y&x=0&y=8&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 15:38"}, {"article_id": "9443481", "title": "MLB／村上宗隆隔10天敲本季第五轟 白襪輸光芒續當分區爐主", "summary": "白襪日籍強打村上宗隆在今日對光芒的比賽中於第9局擊出本季第五轟，助隊貢獻2打點，然而白襪仍以5：8落敗。目前白襪戰績墊底，光芒則領先美聯東區。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857831.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 15:32"}, {"article_id": "9443482", "title": "千萬獎勵金捐社福 李洋：基層體育交給運動部", "summary": "運動部「金牌部長」李洋前天宣布，將宏道基金會董事長林鴻道給予的一千萬獎金全數捐出，並列出10個公益團體，消息一出正、反聲音都有，今天他出席三亞亞洲沙灘運動會授旗儀式時解釋捐款原因，並向大眾道歉。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857833.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 15:27"}, {"article_id": "9443462", "title": "少棒／棒協公告選拔賽球棒變更 避免球隊混淆、國際賽拿錯球棒", "summary": "中華棒球協會今天公告，少棒選拔賽球棒變更，除了配合世界規範，也為避免造成國際賽拿錯球棒的情形發生。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857804.jpg&M=1&s=Y&x=0&y=38&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 15:20"}, {"article_id": "9443363", "title": "羽球／安賽龍退休 國際羽總：重新定義了偉大", "summary": "丹麥羽球明星安賽龍因腰傷宣布結束32年選手生涯。他曾奪得兩屆奧運金牌和五座世界冠軍，並於社群中感謝支持者，稱「今天是異常艱難的日子」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857635.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 15:16"}, {"article_id": "9443434", "title": "籃球／籃協否認世界盃資格賽在瀋陽進行 李洋：中國不要怕我們", "summary": "中華隊上月和中國隊在世界盃籃球亞洲區資格賽第二階段交手，在FIBA要求下，中華隊無法在「主場」迎敵，賽事在菲律賓馬尼拉進行；第三階段兩軍將在7月6日再碰頭，盛傳此戰將在中國瀋陽進行，中華籃球協會今天發出聲明駁斥。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857786.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 15:11"}, {"article_id": "9443407", "title": "MLB／道奇教頭也愛BIGBANG？佐佐木朗希送GD和大聲簽名球", "summary": "韓國天團BIGBANG成員GD（權志龍）和大聲今天造訪道奇隊主場，道奇總教練羅伯茲（Dave Roberts）賽前和他們興奮交談，佐佐木朗希則是送上簽名球。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857740.jpg&M=1&s=Y&x=128&y=47&sw=1061&sh=708&exp=3600&sl=W&fw=360", "date": "2026-04-15 15:04"}, {"article_id": "9443358", "title": "羽球／兩屆奧運金牌 前球王安賽龍輸給腰傷宣布退役", "summary": "兩屆奧運羽球男單金牌、丹麥前「世界球王」安賽龍（Viktor Axelsen），今年還沒有任何出賽紀錄，今天無預警透過社群宣佈退役，為羽壇投入震撼彈。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857634.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 14:40"}, {"article_id": "9443214", "title": "NBA／熱火主帥批小鮑爾「愚蠢動作」 質疑裁判應將其趕出場", "summary": "熱火在附加賽以126：127不敵黃蜂，阿德巴約因小鮑爾的「愚蠢動作」重摔退場，主帥史波史特拉強烈質疑裁判應將小鮑爾驅逐出場。小鮑爾全場拿下30分10助攻，成為黃蜂保住季後賽希望的關鍵。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857393.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 14:01"}, {"article_id": "9443239", "title": "世足賽／尚未決定是否徵招內馬爾 巴西80歲總統：可以看C羅、梅西", "summary": "34歲巴西足球巨星內馬爾（Neymar）是國家隊隊史進球王，但今年美加墨世足賽即將開踢，教練安切洛蒂（Carlo Ancelotti）尚未決定是否讓內馬爾入隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857404.jpg&M=1&s=Y&x=162&y=85&sw=952&sh=594&exp=3600&sl=W&fw=360", "date": "2026-04-15 13:57"}, {"article_id": "9443097", "title": "NBA／阿夫迪賈狂轟41分 拓荒者「下剋上」射太陽奪第7種子", "summary": "本季第一場西區附加賽打得激烈，第7種子太陽隊和第8種子拓荒者隊最後1分鐘還互換領先，拓荒者靠阿夫迪賈（Deni Avdija）全場41分，包括最後1分鐘包辦5分領軍，驚險以114：110氣走太陽，搶下季後賽門票。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857257.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 13:02"}, {"article_id": "9443047", "title": "NBA／小鮑爾稱出手絆倒阿德巴約非惡意 媒體翻出黑歷史打臉", "summary": "黃蜂與熱火隊今天在附加賽碰頭，一路拉鋸到延長賽才分出勝負，儘管黃蜂最終以1分險勝，但身為贏球功臣的小鮑爾（LaMelo Ball）第二節出手拉阿德巴約（Bam Adebayo）的腳，導致他重摔在地並提前傷退，引發外界撻伐，小鮑爾聲稱並非惡意出手，阿德巴約賽後拒訪。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857082.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 12:39"}, {"article_id": "9443004", "title": "MLB／楚奧特率天使全場5轟 洋基慘敗近7戰只拿1勝", "summary": "洋基今晚在主場以1：7不敵天使，近7場比賽僅獲1勝。天使全場轟出5發全壘打，楚奧特、歐戴爾及索勒皆貢獻長打。洋基先發韋瑟斯雖飆10K，但仍遭打擊群壓制，僅靠高飛犧牲打攻下1分。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857059.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 12:36"}, {"article_id": "9443012", "title": "MLB／山本由伸7.2局失1分無關勝敗 大谷翔平獲敬遠連48場上壘", "summary": "道奇隊今天在主場迎戰紐約大都會隊，日籍強投山本由伸本季4場先發，繳出7.2局失1分的表現，局數、用球數都寫本季新高，在兩隊平手時退場，無緣第3勝，道奇隊直到8局下攻回超前分，終場以2：1勝出，賞給大都會7連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857043.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 12:28"}, {"article_id": "9442852", "title": "NBA／「波士頓也不喜歡我」詹姆斯曝最想在冠軍賽交手綠衫軍", "summary": "詹姆斯表示希望在總冠軍賽對陣塞爾蒂克，並認為兩隊的歷史宿敵關係將使比賽更加精彩。他回憶過去對戰綠衫軍的經驗，強調對方並不喜歡他。湖人本季面臨挑戰，唐西奇與里夫斯恐缺席首輪季後賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34856815.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 12:24"}, {"article_id": "9442723", "title": "MLB／布萊格曼醒了！小熊3人都敲3打點逆轉費城人", "summary": "小熊隊在今日比賽中逆轉費城人，以10：4獲勝。霍納與布萊格曼在第6局接連擊出關鍵安打，各自貢獻3打點，凱利則於9局轟出3分砲，助小熊成功追平系列賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34856934.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-15 12:23"}, {"article_id": "9419451", "title": "中職／開季戰力分析 樂天桃猿衛冕軍重整再出發", "summary": "【撰文・陳品宇】 終結連續三年季後賽止步悲情，樂天桃猿2025年季後賽打出驚奇之旅， 在中生代球星、冠軍老臣攜手率領下，以第三名之姿連兩輪上演不可思議「下克上」劇本，奪下暌違六年冠軍金盃，為波折不斷賽季寫下完美收尾，休賽季本土王牌黃子鵬遠走高雄，連三年有FA球員出走，教練團、戰力皆大幅調整，但目標始終不變，以嶄新面貌續拚衛冕。 強悍洋投群是去年樂天桃猿輪值主旋律，王牌威能帝狂掃年度四項大獎，當之無愧聯盟第一投，引來國內外各隊高度關注，不過樂天在眾球團夾殺下，以複數年約留人成功，保有這名大黑柱坐鎮輪值。但他隊想挖角洋投不只威能帝一人，主力左投魔神龍（原名：魔神樂）選擇琵琶別抱加盟味全龍，衛冕軍左右護法拆夥。 投捕：輪值布局大洗牌 魔神龍近兩年拿下26勝，防禦率僅2.28，好脾氣、高配合度也深獲讚賞，", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/02/34822898.jpg&M=1&s=Y&x=0&y=38&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-15 12:00"}, {"article_id": "9442919", "title": "TPBL／「夢想充電」主題周第二彈 加碼三上悠亞應援登場", "summary": "TPBL本季例行賽正式進入最後階段，剛結束客場之旅的夢想家隊目前戰績20勝12敗暫居排名第二，將在本周18、19日於台中洲際迷你蛋主場，先後對戰台北台新戰神、新竹御嵿攻城獅。球團攜手台灣充電第一服務品牌EVOASIS，推出「夢想充電」第二彈主題企劃，特別邀請三上悠亞登場應援。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34856900.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-15 11:56"}, {"article_id": "9442906", "title": "中職／塞揚強投包爾經紀人現身新莊城堡 悍將球團做出回應", "summary": "2020年國聯塞揚獎得主鮑爾（Trevor Bauer）的經紀人瑞秋（Rachel Luba），昨天被發現在新莊棒球場，觀看富邦悍將與味全龍隊之戰，引發球迷遐想，是否有機會看見鮑爾來台獻技。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34856887.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 11:56"}, {"article_id": "9442826", "title": "日職／讚徐若熙「在日本也行得通」韓媒：韓國投手全面潰敗", "summary": "徐若熙今年加盟日本職棒軟銀隊，前2場都交出優質先發且防禦率0.69。韓媒「體育朝鮮」撰文感嘆當今台韓投手的水準差距。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34856766.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-15 11:33"}]}, {"name": "棒球", "articles": [{"article_id": "9443630", "title": "韓職／自曝遭言語暴力、躲在廁所哭 韓啦啦隊鄭嘉睿：暫停工作接受治療", "date": "2026-04-15 16:29", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34858124.jpg&M=1&s=Y&x=0&y=193&sw=961&sh=640&exp=3600&w=300"}, {"article_id": "9443462", "title": "少棒／棒協公告選拔賽球棒變更 避免球隊混淆、國際賽拿錯球棒", "date": "2026-04-15 15:20", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857804.jpg&M=1&s=Y&x=0&y=38&sw=1