il": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073506.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600", "link": "/news/story/122629/9586137"}], "subsections": [{"name": "專欄", "articles": [{"article_id": "9586124", "title": "高中生旅外潮牽動U18布局 賴謙凡加盟洋基後下一個誰圓夢？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073201.jpg&M=1&x=&y=&sw=&sh=&exp=3600&w=300", "link": "/news/story/122629/9586124"}, {"article_id": "9586137", "title": "費城人王牌惠勒越老越強 生涯成績已與柯爾黃金交叉", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073506.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9586137"}, {"article_id": "9585761", "title": "世足攻略／巴西要靠球星破蘇格蘭鐵桶估贏2球 南韓非贏不可要防南非逼平", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072655.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/122629/9585761"}, {"article_id": "9585536", "title": "輕則驚嚇、重則破網！阿根廷隊友相信梅西禁區左腳給的承諾", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072449.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9585536"}, {"article_id": "9584450", "title": "中職／要避免成為洋投聯盟 不如先制定本土先發遊戲規則", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070482.jpg&M=1&s=Y&x=0&y=0&sw=1024&sh=683&exp=3600&w=300", "link": "/news/story/122629/9584450"}, {"article_id": "9583239", "title": "世足攻略／英格蘭火力旺2連勝問題不大 葡萄牙攻擊效率差小勝機率高", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35068759.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/122629/9583239"}]}, {"name": "最新文章", "articles": [{"article_id": "9587381", "title": "世足賽／墨西哥門神奧喬亞上陣 地主3比0大勝捷克奪龍頭", "summary": "身為本屆世界盃東道主之一，墨西哥今天在查維茲（Mateo Chávez）率先破網、基尼奧內斯（Julian Quinones）加入進球行列，補時階段菲達爾戈（Álvaro Fidalgo）再補刀，助隊小組賽最終戰以3：0擊敗捷克隊，以3戰全勝奪下A組龍頭，全隊賽後開心把傳奇門將奧喬亞（Guillermo Ochoa）拋到空中慶祝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074940.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 11:03", "link": "/news/story/123107/9587381"}, {"article_id": "9587380", "title": "世足賽／南韓拔孫興慜先發爆冷不敵南非 剩分組第三擇優晉級機會", "summary": "2026年世足賽進入最後高潮，A組的南韓在今天迎來與南非的晉級生死戰，教頭洪明甫卻將當家看板球星兼隊長孫興慜移出先發名單，直到下半場才讓他登場，不過卻遭到南非在下半場先馳得球，最終以0：1敗下陣來，A組確定由墨西哥與南非以分組前2名晉級到32強，至於輸球的南韓仍有機會以分組第3名擇優晉級。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074944.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-25 11:03", "link": "/news/story/123107/9587380"}, {"article_id": "9587316", "title": "NBA／雷霆獲「反斑馬專武」要感謝快艇 馬拉是喬治交易案最後一張籤", "summary": "雷霆在今年選秀會上以第12順位選中西班牙富豪馬拉，該選秀權是2019年喬治交易案的最後籌碼。這筆交易讓雷霆獲得亞歷山大等新星，並隨著後續選秀資產，成為交易的明顯勝利者。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074847.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 10:53", "link": "/news/story/7002/9587316"}, {"article_id": "9587308", "title": "MLB／成「二寶爸」後首次二刀流出賽 大谷翔平奪第8勝還敲雙安", "summary": "道奇隊與雙城隊3連戰最後一場比賽，大谷翔平「二刀流」出賽，繳出6局失3分（2分自責分）的優質先發，擔任打者也有雙安表現，道奇靠著在3局上攻進3分超前比數，終場以4：3勝出，系列賽橫掃對手，並率先拿下52勝繼續領先全大聯盟，大谷翔平則收下本季第8勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074839.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 10:42", "link": "/news/story/6999/9587308"}, {"article_id": "9587289", "title": "世足賽／維尼修斯連3場進球隊史第五人 寫此紀錄者巴西該屆都奪冠", "summary": "5屆冠軍巴西今天小組賽最終戰除迎接隊史進球王內馬爾（Neymar）回歸，維尼修斯（Vinicius Jr.）上半場更有「梅開二度」演出，助「森巴軍團」以3：0擊敗蘇格蘭，以分組第一前進32強淘汰賽，維尼修斯也締造特別紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074827.jpg&M=1&s=Y&x=0&y=0&sw=1240&sh=826&exp=3600&sl=W&fw=360", "date": "2026-06-25 10:36", "link": "/news/story/123107/9587289"}, {"article_id": "9587250", "title": "NBA／2026選秀二輪+交易結果出爐！湖人和獨行俠又交易", "summary": "2026年選秀會第二輪今天登場，昨天穿戴400萬珠寶出席選秀首輪的杜克大學後衛伊凡斯（Isaiah Evans）33順位被選中，即將加入灰狼隊。今天也發生多筆選秀權交換的小交易。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074756.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 10:34", "link": "/news/story/7002/9587250"}, {"article_id": "9587134", "title": "MLB／大都會將防禦率10千賀滉大轉牛棚 不確定索托是否進傷兵", "summary": "大都會日籍投手千賀滉大因防禦率高達10.08被調至牛棚，總教練門多薩表示此舉可簡化他的投球思維，同時明星游擊手林多回歸，但球星索托因背部緊繃未確定是否進傷兵名單。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074494.jpg&M=1&s=Y&x=8&y=0&sw=1272&sh=848&exp=3600&sl=W&fw=360", "date": "2026-06-25 10:30", "link": "/news/story/6999/9587134"}, {"article_id": "9587267", "title": "世足賽／瑞士主帥讚曼贊比百搭 被迫換上瓜帥T恤反成焦點", "summary": "世足賽小組賽進入尾聲，瑞士在關鍵戰役中以2：1險勝加拿大，順利以小組第一之姿挺進32強淘汰賽。賽後瑞士總教練雅金（Murat Yakin）除了讚賞球隊的陣容深度，更點名首發建功的曼贊比（John Manzambi）表現不可思議；而雅金在場邊因衣服顏色衝突被迫換上「瓜迪奧拉（Pep Guardiola）T恤」的插曲，也成為賽後另類焦點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074808.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 10:30", "link": "/news/story/123107/9587267"}, {"article_id": "9587156", "title": "MLB／大谷翔平6局失3分送8K收工 第8勝等對友幫守成", "summary": "道奇隊日籍球星大谷翔平成為「二寶爸」後的首場先發登板，今天「二刀流」出戰雙城隊，雖在第2局遇亂流，仍繳出6局失3分（2分自責分）的優質先發，送出8次三振，擔任開路先鋒也有安打表現，前6局打完道奇4：3領先，大谷第8勝有望。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074556.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 09:50", "link": "/news/story/6999/9587156"}, {"article_id": "9587136", "title": "Knicks in Five：當球場成為政治人物的戰場，紐約尼克能否團結紐約？", "summary": "《紐約時報》資深運動專欄作家奧康納（Ian O'Connor）在評論中寫到，從沒想過自己會寫下「紐約尼克總冠軍」這行字，但這句話在2026年成真了。紐約尼克隊的球迷為了這座冠軍，足足等了53年。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35067047.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 09:43", "link": "/news/story/7002/9587136"}, {"article_id": "9587115", "title": "MLB／李灝宇手感延燒 對洋基再敲雙安、連4場安打", "summary": "老虎隊本周在主場與洋基隊的系列戰，台灣內野手李灝宇3連戰都先發上陣，今天第6棒、二壘手，維持近期的好手感，3打數敲出2支安打，還選到1次保送，但「虎王」史庫柏（Tarik Skubal）先發挨3轟，終場老虎以2：4落敗，系列賽1勝2敗收場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074468.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 09:34", "link": "/news/story/6999/9587115"}, {"article_id": "9587109", "title": "NBA／活塞將禁區硬漢史都華交易至灰熊 傳有意換來公鹿「英雄哥」", "summary": "活塞隊今天發動交易，將待了6季的禁區硬漢史都華（Isaiah Stewart）交易至灰熊隊，換取3個未來次輪選秀權，並清出薪資空間。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074461.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-25 09:30", "link": "/news/story/7002/9587109"}, {"article_id": "9587094", "title": "世足賽／梅西過39歲生日 隊友穿上特製上衣給驚喜", "summary": "衛冕軍阿根廷當家球星「獅王」梅西（Lionel Messi）24日滿39歲，已經第5次在世界盃期間「長尾巴」的他和隊友們共同慶祝，全隊還穿上印有各自和梅西合照圖案的上衣，用特別方式為隊長慶生。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074455.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-25 09:22", "link": "/news/story/123107/9587094"}, {"article_id": "9587052", "title": "世足賽／南韓晉級關鍵戰拋變陣震撼彈 隊長孫興慜遭拔先發", "summary": "2026年世足賽進入小組賽最後高潮，A組的「太極虎」南韓在今天迎來與南非的晉級生死戰，然而南韓教頭洪明甫卻在賽前拋出震撼彈，將當家看板球星兼隊長孫興慜移出先發名單，這項大膽的用人戰術隨即引發外界熱烈討論。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074405.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 09:01", "link": "/news/story/123107/9587052"}, {"article_id": "9587012", "title": "NBA／頂薪續留湖人 里夫斯簽4年1.85億美元創落選秀紀錄", "summary": "湖人在今天傳出與陣中後場大將里夫斯（Austin Reaves）完成續約，里夫斯同意以一張4年1.85億美元（約台幣58.9億元）的頂薪合約續留紫金大軍，合約最後一年為球員選項，這筆簽約也正式刷新NBA歷史上「落選秀」的最大合約紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074343.jpg&M=1&s=Y&x=275&y=45&sw=1005&sh=669&exp=3600&sl=W&fw=360", "date": "2026-06-25 08:37", "link": "/news/story/7002/9587012"}, {"article_id": "9587005", "title": "世足賽／內馬爾回來了！巴西3比0大勝蘇格蘭奪分組龍頭", "summary": "巴西隊史進球王內馬爾（Neymar）今天小組最終戰碰蘇格蘭替補上陣，他上場前巴西已經在維尼修斯（Vinicius Jr.）上半場「梅開二度」、庫尼亞（Matheus Cunha）第60分鐘補刀下取得絕對領先，最終就以3：0擊敗蘇格蘭，勝利到手取得C組第一，以2勝1和成績前進32強淘汰賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074316.jpg&M=1&s=Y&x=0&y=0&sw=1264&sh=842&exp=3600&sl=W&fw=360", "date": "2026-06-25 08:29", "link": "/news/story/123107/9587005"}, {"article_id": "9587000", "title": "世足賽／兩度落後又扳平 摩洛哥4：2逆轉海地晉級32強", "summary": "2026世足賽小組賽最終輪賽事今天點燃戰火，其中C組的摩洛哥碰上已無緣晉級的海地卻陷入苦戰，在開賽10分鐘就因為烏龍球陷入落後劣勢的情況下，摩洛哥不僅兩度扳平戰局，甚至在第78分鐘靠著拉希米（Soufiane Rahimi）進球逆轉戰局，最終以4：2擊敗海地，與擊敗蘇格蘭的巴西攜手晉級到32強賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074303.jpg&M=1&s=Y&x=0&y=16&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 08:17", "link": "/news/story/123107/9587000"}, {"article_id": "9586999", "title": "世足賽／18歲波赫新星射進世界波 一紀錄超越姆巴佩", "summary": "波赫今天以3：1擊敗卡達，雖落到分組第3仍保有晉級生機，球隊還看到了未來希望，18歲的阿拉伊貝戈維奇（Kerim Alajbegović）以「世界波」率先破網，讓他除了最年輕登上世界盃舞台的波赫球員身份外，再締造隊史最年輕的世界盃進球紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074293.jpg&M=1&s=Y&x=0&y=54&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 08:17", "link": "/news/story/123107/9586999"}, {"article_id": "9586964", "title": "世足賽／加拿大不敵瑞士仍晉32強 教頭憂恐面臨「南韓主場」考驗", "summary": "2026世足賽小組賽最終輪賽事今天點燃戰火，身為共同主辦國之一的加拿大，在B組最終戰卻遭遇考驗，在只要踢平瑞士就能搶下分組龍頭的情況下，最終卻以1：2敗下陣來，雖然仍順利晉級到32強賽，但也失去了後續的「主場優勢」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074252.jpg&M=1&s=Y&x=0&y=110&sw=1028&sh=686&exp=3600&sl=W&fw=360", "date": "2026-06-25 07:38", "link": "/news/story/123107/9586964"}, {"article_id": "9586137", "title": "費城人王牌惠勒越老越強 生涯成績已與柯爾黃金交叉", "summary": "費城人王牌投手惠勒本季表現出色，11場投球中獲得7勝1敗、2.11防禦率，生涯bWAR值已超越柯爾，來到43.5。他今年與費城人簽下3年延長合約，彌補過去的質疑，顯示出越老越強的實力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073506.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 07:00", "link": "/news/story/122629/9586137"}, {"article_id": "9586124", "title": "高中生旅外潮牽動U18布局 賴謙凡加盟洋基後下一個誰圓夢？", "summary": "高中生旅外潮再現高峰，林珺希與賴謙凡已與美職球隊簽約，大溪高中領風騷。平鎮高中何樺與蔡辰瀧亦受到鼓勵，潛在合約價值吸引瞩目。U18亞洲青棒賽將成為他們提升身價的舞台。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073201.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-25 07:00", "link": "/news/story/122629/9586124"}, {"article_id": "9586896", "title": "世足賽／波赫3比1力克卡達 關鍵三分積分入袋保有晉級生機", "summary": "於2026年6月25日凌晨3點展開的世界盃B組小組賽，由波赫在主場迎戰卡達。在這場攸關晉級資格的關鍵戰役中，波赫憑藉著高效率的攻勢與對手防線的失誤，最終以3比1擊敗卡達，順利全取3分，繼續保有爭取淘汰", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074136.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 05:44", "link": "/news/story/123107/9586896"}, {"article_id": "9586895", "title": "世足賽／瑞士2比1力克加拿大 兩勝一和穩居B組首位晉級", "summary": "2026年世界盃足球賽B組小組賽於台灣時間6月25日凌晨3時展開。由瑞士迎戰加拿大，雙方經過90分鐘激戰，最終瑞士憑藉下半場連下兩城，以2比1擊退加拿大，順利奠定分組龍頭的領先優勢。\\n本場控球節奏由", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35074134.jpg&M=1&s=Y&x=34&y=0&sw=1051&sh=700&exp=3600&sl=W&fw=360", "date": "2026-06-25 05:36", "link": "/news/story/123107/9586895"}, {"article_id": "9586605", "title": "世足賽／挺過難熬一周曾想退役…C羅連6屆世界盃進球再創紀錄", "summary": "生涯第六度參加世界盃足球賽，四十一歲的葡萄牙當家球星Ｃ羅因小組賽首戰未進球被罵翻，昨天馬上用強勢表現回應，面對烏茲別克第六分鐘就率先破網，成為史上首位連六屆世界盃都有進球紀錄的球員。Ｃ羅不但單場「梅開二度」，還用驚人演技掩護隊友門德斯踢進自由球，率領葡萄牙以五比○大勝，累積四分積分，為前進卅二強淘汰賽占據有利位置。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073788.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-0