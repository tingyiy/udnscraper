nail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34935570.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-11 12:26"}, {"article_id": "9494915", "title": "軟銀進軍電池製造 在夏普舊廠量產鋅鹵素電池年產能目標1GWh", "summary": "軟銀集團（SoftBank）旗下行動通訊事業表示，計劃在大阪堺市原夏普（Sharp）面板廠的現址開始大規模生產電池，以滿足人工智慧（AI）服務日益增長的電力需求。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34935554.jpg&M=1&s=Y&x=0&y=0&sw=1239&sh=826&exp=3600&sl=W&fw=360", "date": "2026-05-11 12:20"}, {"article_id": "9494900", "title": "AI重塑企業決策層！76%企業設CAIO 人資長影響力看升", "summary": "人工智慧（AI）熱潮自OpenAI推出ChatGPT後席捲全球，除促成企業大規模裁員外，也重塑企業最高決策層：IBM調查逾2,000家企業發現，已有76%設立「人工智慧長」（CAIO），遠高於2025年的26%。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34935512.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-11 12:13"}, {"article_id": "9494460", "title": "日本今年搖晃次數倍增 專家指危險訊號：南海海槽地震機率攀升", "summary": "根據日媒News Post Seven報導，近期頻繁發生地震，已引起學界對「大地震前兆」的高度警戒。日本氣象廳數據顯示，今年1月至5月6日，全日本已發生21起4級以上的地震，次數是去年同期的兩倍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34934784.jpg&M=1&s=Y&x=88&y=0&sw=1098&sh=732&exp=3600&sl=W&fw=360", "date": "2026-05-11 12:04"}, {"article_id": "9494763", "title": "高盛：人民幣匯率遭低估逾20% 未來一年預料持續升值", "summary": "高盛集團表示，人民幣兌美元匯率目前被低估超過20%，預期未來一年將持續升值。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34935292.jpg&M=1&s=Y&x=0&y=0&sw=1199&sh=799&exp=3600&sl=W&fw=360", "date": "2026-05-11 11:33"}, {"article_id": "9494701", "title": "Google母公司全球「掃錢」Alphabet擬首發日圓債 投入AI資本支出", "summary": "Google母公司Alphabet正計劃首次發行日圓債券，在AI相關競爭日益激烈之際，有助於為相關投資籌措資金。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34935179.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-11 11:18"}, {"article_id": "9494680", "title": "川習會14日登場 川普還計畫參觀北京天壇", "summary": "大陸外交部今（11）日公布，美國總統川普應大陸國家主席習近平邀請，將於13日至15日對中國進行國是訪問。白宮則表示，川普將於13日傍晚抵達北京，14日上午與習近平舉行雙邊會談，下午預計參觀北京天壇。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34935151.png&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-11 11:12"}, {"article_id": "9494609", "title": "又有兩艘各載阿布達比和伊拉克石油油輪成功脫離荷莫茲海峽", "summary": "又有兩艘滿載原油的油輪在關閉追蹤器後，成功悄悄通過荷莫茲海峽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34935009.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-11 10:48"}, {"article_id": "9494564", "title": "中東戰火效應 全球央行大買黃金 避險外有何考量", "summary": "黃金是種安全但笨重的投資，隨著地緣政治緊張加劇及憂心通貨膨脹，黃金再度受到歡迎。全球各國中央銀行近年來大幅增加黃金儲備，今年金價一度突破每英兩5000美元，主因之一就是多國央行大買黃金。如今中東戰爭衝擊全球金融體系，一些中央銀行可能又會買進黃金，利用黃金作為抵禦經濟壓力的緩衝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/09/34931299.jpg&M=2&s=Y&x=0&y=0&sw=1280&sh=884&exp=3600&sl=W&fw=360", "date": "2026-05-11 10:30"}, {"article_id": "9494386", "title": "越男越痛！2螺絲帽套生殖器 男子忍痛個多月、不能自拔腫脹變形", "summary": "男人最痛！發生罕見「下體酷刑」意外，1名38歲男子於今年3月將2枚螺絲帽套在生殖器根部，但卻「不能自拔」，卡在下體整整一個多月…", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34934711.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-11 10:17"}, {"article_id": "9494505", "title": "救人變害命？豐田意外側翻 路人誤將車輛推落溝渠 司機當場死亡", "summary": "罕見奪命交通意外。1名60多歲司機在駕七人車時撞向路邊房屋拐角的石頭後側翻。多名熱心路人上前營救，先打破車窗並合力將車推正，卻意外令全車連同被困的司機推落溝渠…", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34934842.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-11 10:17"}, {"article_id": "9494394", "title": "台灣網站「2倍價轉賣御守」 日本神社震怒：對神明的嚴重褻瀆", "summary": "台灣人到日本觀光時，看到神社的御守總會忍不住購買。但近日在福岡縣柳川市有超過830年歷史的「田脇日吉神社」，在官方IG以日、繁中雙語發文，強烈譴責台灣代購網站高價轉賣其御守，更重話警告這些商品因沾染牟利的穢氣，已「失去神明庇佑」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34934676.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-11 10:11"}, {"article_id": "9494504", "title": "費半創高帶動亞洲晶片股全面爆發 韓日股同步改寫紀錄", "summary": "亞洲晶片股追隨費城半導體指數上周五漲勢，今天也創歷史新高，韓日股也同步再創新高。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34934815.jpg&M=1&s=Y&x=0&y=0&sw=983&sh=655&exp=3600&sl=W&fw=360", "date": "2026-05-11 10:09"}, {"article_id": "9494477", "title": "川普怒轟伊朗停戰方案「完全不行」！德黑蘭3個字回擊", "summary": "美國總統川普10日表態拒絕伊朗回覆，伊朗半官方媒體塔斯尼姆通訊社引述消息人士稱，川普不喜歡伊朗和談方案「不重要」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34934783.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-11 09:58"}, {"article_id": "9494474", "title": "輝達勁敵！AI晶片新創Cerebras IPO認購爆表20倍 傳發行價上看160美元", "summary": "AI 晶片新創企業Cerebras Systems被譽為輝達（Nvidia）最強潛在競爭對手，該公司傳出最快今天將調高首次公開發行股票（IPO）的釋股規模與發行價格，因為市場對該公司股票的認購需求十分熱烈，超額認購倍數超過20倍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34934777.jpg&M=1&s=Y&x=0&y=0&sw=1258&sh=838&exp=3600&sl=W&fw=360", "date": "2026-05-11 09:56"}, {"article_id": "9494459", "title": "川習會前美國釋「對台政策不變」訊號！專家：但川給習送了不少分", "summary": "華爾街日報報導，美國總統川普與中國國家主席習近平本周即將會晤，這場地表最有權勢的兩大領袖峰會籠罩在伊朗戰爭的陰影下。川習雙方希望在伊朗問題上取得各自的勝利，習近平更希望美國改變德黑蘭政權的企圖落敗。專家指出，川普此行有如高空走鋼索，必須同時應付中東戰火與美中談判，如今他少了原本可用的籌碼，反而帶著關稅爭議與中東戰爭包袱前往北京，給習近平送了不少分數。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/11/34934745.jpg&M=1&s=Y&x=0&y=0&sw=1239&sh=826&exp=3600&sl=W&fw=360", "date": "2026-05-11 09:48"}, {"article_id": "9494431", "title": "杜拜巧克力狂熱遇上伊朗戰爭：全球開心果供應鏈的完美風暴", "summary": "「買不到的開心果？」口感香脆，帶有堅果香氣和一絲奶油般柔和甜感的開心果，向來是大受歡迎的甜點原料，但近期開心果在全球市場卻因社群媒體狂熱與地緣政治衝突，正面臨著供應鏈危機。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/29/34901094.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-11 09:39"}, {"article_id": "9494429", "title": "棋局反轉的戰略伏筆：鄭習會搶占川習會先機的地緣政治盤算", "summary": "原定於2026年3月底在北京舉行的「川習會」，受制於2月底美國與以色列對伊朗發動聯合軍事行動後的連鎖反應，被迫延後至5月中旬。這一變動不僅打亂了美、中兩大強權的協商時程，更意外地讓原訂於4月至6月間登場、排在美中峰會之後的「鄭習會」，一躍成為北京外交舞台上的前導大戲。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/03/31/34814126.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-11 09:38"}, {"article_id": "9494424", "title": "轉角月影花怪談／從長崎蛋糕詛咒看日治台灣的「灣妻」", "summary": "九州名產「長崎蛋糕」（カステラ）是台灣人到日本旅遊時，十分青睞的甜點之一，福砂屋、文明堂想必已是知名的伴手禮品牌，更有平戶蔦屋將其裹上蛋衣與熱糖漿，並且撒上砂糖後，更加精緻化的「Casdous」（カスドース），是九州作為過去日本與西方世界接軌的根據地，所出現和洋混血的歷史結晶。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/07/34926158.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-11 09:37"}, {"article_id": "9494419", "title": "變動時代的陪伴策略：從消失的共讀日常看見疫後兒童的成長挑戰", "summary": "COVID-19在2020年迅速擴散至全世界，各地學校和公共區域完全關閉、大量學生被迫遠距上課，導致原本熟悉的學習模式徹底中斷。疫情對教育的衝擊不只明顯反應在這群學生的學業成績上，連當年剛出生的的嬰幼兒也受到影響，使他們現如今進入小學就讀後，閱讀與語文表現顯著落後於疫情前的同齡孩子。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34859289.png&M=1&s=Y&x=30&y=0&sw=1237&sh=825&exp=3600&sl=W&fw=360", "date": "2026-05-11 09:36"}, {"article_id": "9494414", "title": "最後一位時尚掌門人：《穿著PRADA的惡魔》角色原型扭轉時尚定義", "summary": "安娜．溫圖（Anna Wintour）就任美國版《VOGUE》總編輯的第一期雜誌送印後，編輯部接到來自印刷廠的詢問電話：「是不是出錯了？」那年是1988年，她的傳奇由此展開……", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/08/34929229.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-11 09:35"}, {"article_id": "9494413", "title": "美國總統川普將對中國進行國事訪問", "summary": "據央視11日報導，大陸外交部發言人宣布，應大陸國家主席習近平邀請，美國總統川普將於5月13日至15日對中國進行國事訪問。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34933617.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-11 09:33"}, {"article_id": "9494390", "title": "關注「川習會」 林佳龍：美方表達台灣政策不會改變 對台美關係有信心", "summary": "美國總統川普本周訪問中國大陸，可望在14日與大陸國家主席習近平「川習會」。外交部長林佳龍今天表示，我政府跟美方持續保持溝通，不管是美國政府公開發言或