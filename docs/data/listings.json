ttps://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940808.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9502059", "title": "MLB／對最會打左投的勇士繳優質先發 今永昇太7局失2分仍吞敗", "summary": "小熊隊日籍左投今永昇太今天先發登板，面對全聯盟最會打左投的勇士隊，繳出7局失2分的優質先發，送出6次三振，但勇士在第8局超前分數，終場以4：1勝出，成為大聯盟本季率先拿到30勝的隊伍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34946135.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 10:59"}, {"article_id": "9502018", "title": "MLB／讓今永昇太多投第8局出事！小熊牛棚失守吞4連敗", "summary": "小熊投手今永昇太雖表現出色，7局僅失2分卻苦無支援，最終小熊以1：4不敵勇士，吞下四連敗。勇士於8局下發動攻勢，終結小熊的連勝紀錄，今永成績為4勝3敗，防禦率2.32。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34946011.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 10:59"}, {"article_id": "9502029", "title": "MLB／林維恩入選官網百大新秀第95 因球團保護臨時取消先發", "summary": "大聯盟官網今天更新百大新秀榜，運動家隊台灣旅美左投林維恩被排在第95名。林維恩原定今天在2A先發出賽，但因身體疲勞臨時取消。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34946038.jpg&M=1&s=Y&x=433&y=97&sw=832&sh=555&exp=3600&sl=W&fw=360", "date": "2026-05-14 10:49"}, {"article_id": "9501944", "title": "NBA／聯盟將表決「3-2-1」抽籤新制 選秀降級可望試行至2029年", "summary": "為了捍衛比賽公平性並徹底根除「擺爛」問題，NBA主席席佛（Adam Silver）今天證實，聯盟已正式研擬一套名為「3-2-1」的選秀抽籤改革草案，這項新制最快將在月底的董事會中提報，其中最引人注目莫過於「選秀降級」概念，意即戰績墊底的3支球隊，獲得狀元籤的機率反而將低於後段班球隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34945952.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 10:25"}, {"article_id": "9501914", "title": "智領體育數據巔峰 虎尾科大與運科中心攜手簽訂MOU", "summary": "國立虎尾科技大學與國家運動科學中心攜手推動運動科學合作，13日於虎尾科大圖書館舉行MOU合作意向書簽署儀式。本次活動以「智領體育・數據巔峰」為主題，結合科技創新、運動科學與跨域整合應用，透過科學化數據分析與實證研究方法，深入探討運動訓練從實務經驗累積到精準驗證的核心價值，展現運動科技發展的新趨勢與未來方向。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34945821.jpg&M=1&s=Y&x=0&y=0&sw=1252&sh=834&exp=3600&sl=W&fw=360", "date": "2026-05-14 10:13"}, {"article_id": "9501867", "title": "MLB／洋基王牌弗里德投3局就傷退 打線全場僅1安遭金鶯完封", "summary": "洋基在客場以0：7遭金鶯完封，先發投手弗里德投3局因手肘疼痛退場，失掉3分。金鶯捕手拉契曼表現亮眼，轟出2分砲並貢獻3分打點，洋基全場僅擊出1支安打。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34945770.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 10:11"}, {"article_id": "9501834", "title": "中職／鄭浩均被打爆仍嘻嘻哈哈 李杜軒痛批：替兄弟球迷感到不值", "summary": "中信兄弟隊本土王牌鄭浩均昨天被打爆，日本職棒軟銀隊球探李杜軒在社群平台發文批評鄭浩均在休息室的態度，引發球迷熱烈討論。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34945739.jpg&M=1&s=Y&x=251&y=22&sw=786&sh=524&exp=3600&sl=W&fw=360", "date": "2026-05-14 10:05"}, {"article_id": "9501882", "title": "NBA／吉迪完成手術預計季前訓練營回歸 將領軍公牛進行重建", "summary": "公牛隊在休賽季初期便傳出傷情消息，球團今天宣布「一哥」吉迪（Josh Giddey）已順利完成右腳踝關節鏡手術，雖然吉迪預計將缺席籃球活動長達三個月，但公牛對於他趕在季前訓練營回歸抱持樂觀態度，這對正值重建關鍵期的風城大軍而言，無疑是個好消息。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34945794.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 10:03"}, {"article_id": "9501713", "title": "網球／45歲大威法網確認參賽！搭小21歲同胞挑戰女雙", "summary": "45歲的美國網球名將大威廉絲（Venus Williams）確定重返紅土大滿貫舞台，她今年法網將和同胞巴普蒂斯特（Hailey Baptiste）聯手出征女雙，將是2021年首度參賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34945530.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 09:04"}, {"article_id": "9501674", "title": "NBA／尼克好消息 阿努諾比有望東決前回歸", "summary": "尼克隊季後賽第二輪只花4戰就「橫掃」76人隊，率先拿到東區決賽門票，好消息還有主戰前鋒阿努諾比（OG Anunoby）的腿傷復原中，將在東區決賽開戰前歸隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34945521.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 08:46"}, {"article_id": "9501614", "title": "NBA／季後賽哨聲爆增一成 聯盟捍衛標準：侵略性不等於粗魯", "summary": "NBA季後賽進入白熱化階段，場上煙硝味也隨著執法尺度成為焦點，根據最新統計，今年季後賽場均犯規次數較例行賽激增約11％，創下史上罕見的漲幅，面對球員與教練排山倒海的質疑，NBA聯盟裁判發展與培訓高級副總裁麥卡琴（Monty McCutchen）今天在聯合選秀測試賽期間親火線回應，強調吹哨標準並未改變，而是季後賽的高強度競技自然產生的結果。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34945516.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 07:49"}, {"article_id": "9500290", "title": "中職／童堉誠從修車到職棒 父親童琮輝佩服：他自己拚來的", "summary": "童堉誠在26歲時終於實現職棒夢想，轉正成為富邦悍將一軍球員。他的父親童琮輝表示，這是童堉誠自己努力的結果。童堉誠的棒球路途過關斬將，從修車工轉型成球員，展現了不屈不撓的精神。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34943537.jpg&M=1&s=Y&x=0&y=69&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 07:00"}, {"article_id": "9500368", "title": "大谷翔平2026的極端悖論：投球0.97ERA背後的打擊節奏失序", "summary": "大谷翔平本季投出0.97ERA，但其打擊表現卻陷入低潮，連續51個打席無長打。洛杉磯道奇隊考慮讓他在投球日不參賽打擊，以確保能量分配，尋求恢復打擊節奏，協助他擺脫低迷。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34943893.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-05-14 07:00"}, {"article_id": "9500521", "title": "海盜「不一樣了」！史肯斯領軍三王牌投出國聯最佳輪值成績", "summary": "海盜隊在史肯斯的帶領下，首次建立強勁的先發輪值，團隊fWAR達4.5，名列國聯第一。艾希克拉夫特與凱勒也投出優異成績，海盜目前的勝率達0.548，期望重返季後賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34943951.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 07:00"}, {"article_id": "9501212", "title": "中職／兄弟首局失13分隊史最慘 悍將掃18安以17：2作客大勝", "summary": "富邦悍將隊今天作客台中洲際棒球場迎戰中信兄弟，首局就狂打17人次灌進13分，寫下中職單局次高、差1分追平聯盟紀錄，全場合計掃出18支安打換回17分，終場以17：2擊落中信兄弟，打下3連勝、賞兄弟3連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34944774.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-13 22:22"}, {"article_id": "9501145", "title": "路跑／肯亞薩威倫敦馬拉松「破2」寫歷史 將參加9月柏林馬", "summary": "柏林馬拉松主辦單位今天宣布，史上第一位在2小時內完成全馬的肯亞好手薩威（Sabastian Sawe），將於今年9月參加...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34944742.jpg&M=1&s=Y&x=0&y=0&sw=1268&sh=845&exp=3600&sl=W&fw=360", "date": "2026-05-13 21:59"}, {"article_id": "9501136", "title": "羽球／周天成激戰3局退丹麥好手 BWF泰國羽賽闖頭關", "summary": "BWF超級500系列的泰國羽球公開賽，「台灣一哥」周天成今天在首輪與丹麥好手霍爾姆激戰3局，終場以10比21、21比16...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34944718.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-13 21:51"}, {"article_id": "9501138", "title": "中職／黃子鵬對前東家7局0責失吞敗 猿隊3：1打退台鋼", "summary": "樂天桃猿隊今天作客嘉義市棒球場對戰台鋼雄鷹，魔爾曼先發7局失1分，加上打線在6局上從「前隊友」黃子鵬手中打下3分，終場猿隊以3：1勝出，拿下本季對戰雄鷹第2勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34944758.jpg&M=1&s=Y&x=0&y=29&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-13 21:45"}, {"article_id": "9501115", "title": "TPBL／米勒三分球6投俱中！雲豹18記外線轟垮國王扳平系列賽", "summary": "今年打下TPBL例行賽龍頭的桃園台啤永豐雲豹，季後賽首戰被新北國王「下剋上」踢館成功，今天馬上調整，除本土主力高錦瑋手感回溫，洋將麥卡洛和米勒更聯手轟下53分，帶動團隊39投18中的高命中率，從首節就一路維持兩位數領先，終場以114：92大勝，將5戰3勝制的系列賽扳平成1比1。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34944690.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-13 21:28"}, {"article_id": "9501104", "title": "中職／統一獅2：1勝味全龍 奪隊史2000勝史上第一隊", "summary": "統一獅隊今天在台南亞太棒球場對戰聯盟龍頭味全龍隊，雙方上演投手戰，獅隊在決勝第3局靠著林泓弦三壘打和陳傑憲高飛犧牲打敲回致勝2分，終場以2：1拿下勝利，在主場7527名球迷面前，收下隊史第2000勝，成為中職37年來第一隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34944715.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-13 21:16"}, {"article_id": "9500932", "title": "中職／「金控大戰」悍將首局海灌13分 差1分平聯盟紀錄", "summary": "「金控大戰」今晚在台中洲際棒球場進行開打，富邦悍將面對中信兄弟，一開賽就毫不留情，單局打了17人次、敲出10支安打，狠灌13分大局，單局得分、安打數都寫本季聯盟新高，差1分追平中職史上單隊單局次高得分紀錄，一開賽就取得13：0的大幅領先。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34944508.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-13 19:58"}, {"article_id": "9500810", "title": "中職／抱怨自己沒有好球帶可言 魔鷹：我每天來這邊都在打壞球", "summary": "台鋼雄鷹的洋砲魔鷹抱怨中職好球帶不佳，表示「每天都在打壞球」，全季全壘打僅3支，長打率創新低。此言論引起網友共鳴，感受到其不滿情緒。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34944384.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-13 19:16"}, {"article_id": "9500595", "title": "王貞治盃青棒賽／吉路．少瑪開轟4打點 率新北搶勝", "summary": "王貞治盃青棒賽今天開打，上屆冠軍新北市隊首戰與宜蘭縣隊交手，新北市黃世堯、吉路．少瑪開轟，打線發揮以14比7搶勝；吉路．...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34944275.jpg&M=1&s=Y&x=60&y=0&sw=1205&sh=803&exp=3600&sl=W&fw=360", "date": "2026-05-13 17:54"}, {"article_id": "9500519", "title": "MLB／單場挨3轟生涯最慘 山本由伸自認該更有警覺", "summary": "道奇投手山本由伸今日先發6.1局，遭巨人擊出3轟，創下自職業以來單場挨轟新高，最終失5分，賽後表示應該更加警覺。儘管吞下敗投，他對身體狀態仍感滿意，強調會持續努力幫助球隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34943944.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-13 17:05"}]}, {"name": "棒球", "articles": [{"article_id": "9501834", "title": "中職／鄭浩均被打爆仍嘻嘻哈哈 李杜軒痛批：替兄弟球迷感到不值", "date": "2026-05-14 10:05", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34945739.jpg&M=1&s=Y&x=251&y=22&sw=786&sh=524&exp=3600&w=300"}, {"article_id": "9501212", "title": "中職／兄弟首局失13分隊史最慘 悍將掃18安以17：2作客大勝", "date": "2026-05-13 22:22", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34944774.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9501138", "title": "中職／黃子鵬對前東家7局0責失吞敗 猿隊3：1打退台鋼", "date": "2026-05-13 21:45", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34944758.jpg&M=1&s=Y&x=0&y=29&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9501104", "title": "中職／統一獅2：1勝味全龍 奪隊史2000勝史上第一隊", "date": "2026-05-13 21:16", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34944715.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=360