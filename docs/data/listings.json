, "articles": [{"article_id": "9557078", "title": "中職／速差與曲球成就頂尖壓制力 龍隊蔣銲就是本季最強洋投", "summary": "蔣銲在中職表現出色，防禦率僅1.07，曾創造23又2/3局未失分紀錄，三振能力居全聯盟第三。然而，他的勝場數僅3，主要因隊友護援率過低。若能獲得更多支持，或有望成為味全龍衛冕的關鍵。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35029460.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 10:41", "link": "/news/story/122629/9557078"}, {"article_id": "9557038", "title": "MLB／「左打法官」瓊斯生涯首轟、奇森姆致勝陽春砲 洋基氣走守護者3連勝", "summary": "洋基在對戰守護者的比賽中，以3：2險勝，取得三連勝。新秀瓊斯擊出生涯首轟，奇森姆則在第八局轟出致勝陽春砲，助力球隊逆轉比賽。儘管王牌柯爾僅投4局，洋基依然成功關門。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35029375.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 10:28", "link": "/news/story/6999/9557038"}, {"article_id": "9557019", "title": "網球／「在家待膩了」44歲小威廉絲復出奪勝", "summary": "美國網壇名將小威廉絲（Serena Williams）重回網壇，持外卡參加倫敦女王俱樂部草地賽雙打的她今天迎接首戰，且和19歲加拿大搭檔姆博柯（Victoria Mboko）以7：6（7：2）、6：2拍下同胞美國梅莉雪（Nicole Melichar-Martinez）／紐西蘭羅莉芙（Erin Routliffe），超過千日回歸就收下勝利。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35029333.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 10:14", "link": "/news/story/7005/9557019"}, {"article_id": "9556906", "title": "MiLB／陳柏毓新人聯盟先發核炸 1局失4分防禦率36吞敗", "summary": "匹茲堡海盜投手陳柏毓今日在新人聯盟復健賽先發僅投1局失4分，防禦率高達36.00，最終球隊以6：10敗北，陳柏毓吞下敗投。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35029144.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 10:04", "link": "/news/story/6999/9556906"}, {"article_id": "9555482", "title": "岡本打出身價、村上超乎想像 「虎大砲」佐藤輝明成最大贏家", "summary": "岡本打出身價，村上表現超乎想像，成為日本打者在美國的大贏家。兩位球星均簽下千萬合約，吸引多隊球探前往日本視察，尤其是佐藤輝明有望成為下個受惠者。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027706.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 10:00", "link": "/news/story/122629/9555482"}, {"article_id": "9556935", "title": "NBA／唐斯決勝節神隱 尼克總教練盼加入進攻：對我們很重要", "summary": "尼克隊當家中鋒唐斯（Karl-Anthony Towns）總冠軍賽連3場都在第四節進攻「神隱」，決勝節得分都掛蛋，不同的是前兩戰尼克都打下客場勝利，昨天回到主場卻以111：115吞敗，中斷季後賽13連勝，尼克總教練布朗（Mike Brown）今天球隊練習時就說，讓唐斯加入進攻行列「極度重要」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35029215.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 09:53", "link": "/news/story/7002/9556935"}, {"article_id": "9556934", "title": "MLB／右投林珺希加盟海盜隊 本屆高中畢業旅美第一人、大溪隊史第二人", "summary": "今天國內高中畢業生旅美第一人！根據匹茲堡海盜隊官網公告，已和大溪高中畢業的17歲右投林珺希完成簽約，而他目前仍在備戰本周開打的玉山盃青棒錦標賽，這也預計將成為他旅美前在台的最後賽事。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35029609.jpg&M=1&s=Y&x=0&y=0&sw=942&sh=628&exp=3600&sl=W&fw=360", "date": "2026-06-10 09:53", "link": "/news/story/6999/9556934"}, {"article_id": "9556866", "title": "世足賽／41歲C羅迎本土謝幕戰？ 葡萄牙主帥：他心中只有世足賽", "summary": "2026年世足賽開踢在即，葡萄牙國家隊即將迎來對陣奈及利亞的最後一場本土熱身賽，外界紛紛猜測這是否會是41歲傳奇球星C羅（Cristiano Ronaldo）在祖國土地上的國家隊「最後一舞」，不過葡萄牙主帥馬丁尼茲（Roberto Martinez）在受訪時直言，這位國家隊隊長目前根本沒有心思去思考退役或告別的議題，眼中只有即將到來的世足賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35029210.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-10 09:26", "link": "/news/story/123107/9556866"}, {"article_id": "9556811", "title": "NBA／尼克球迷失控攻擊馬刺球迷 斑馬、唐斯同聲譴責", "summary": "馬刺隊昨天在紐約終結尼克隊季後賽13連勝，以115：111在總冠軍賽開胡，但賽後場外卻失控，出現尼克球迷攻擊馬刺球迷的狀況，讓馬刺當家球星「法國狀元」溫班亞瑪（Victor Wembanyama）、布魯克林長大的夏帕尼（Julian Champagnie）和來自紐澤西的哈波（Dylan Harper），還有尼克的唐斯（Karl-Anthony）都譴責暴力行為，希望球迷保持理性，互相尊重。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/10/35029320.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 09:00", "link": "/news/story/7002/9556811"}, {"article_id": "9555842", "title": "世足攻略／L組英格蘭是冠軍熱門 攜手克國「魔笛」小組出線問題不大", "summary": "L組球隊有英格蘭、克羅埃西亞、迦納和巴拿馬，英格蘭是種子隊，也是這次大賽賠率前三名的冠軍熱門，和克羅埃西亞從小組出線問題不大；迦納和巴拿馬應該有一隊可以以分組第三晉級，但需要第一場至少打平，才有機會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027942.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-10 07:00", "link": "/news/story/122629/9555842"}, {"article_id": "9556250", "title": "韓職／王彥程被金倒永敲3分砲 先發3.2局失6分吞敗", "summary": "韓職韓華鷹隊台灣左投王彥程今天先發對起亞虎隊，僅投3.2局失掉6分（4分責失分），被金倒永敲出3分砲，球隊終場以4比6吞...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35028441.jpg&M=1&s=Y&x=0&y=0&sw=1159&sh=773&exp=3600&sl=W&fw=360", "date": "2026-06-09 23:13", "link": "/news/story/7001/9556250"}, {"article_id": "9556158", "title": "奮戰不懈創奇蹟 115年身障運宜蘭狂奪20金 雙破全國紀錄締造新頁", "summary": "115年全國身心障礙國民運動會日前在新北市圓滿落幕，宜蘭縣代表隊憑著奮戰不懈的堅毅精神，一舉斬獲20金、17銀、7銅共44面獎牌，金牌數大幅超越上屆，寫下輝煌新頁，宜蘭縣政府今天舉行表揚並頒發歷史新高的95萬5千元獎勵金，讚揚選手挑戰極限的亮麗成績。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35028201.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 20:37", "link": "/news/story/7005/9556158"}, {"article_id": "9556066", "title": "世足賽／伊朗控美國撤銷其世界盃門票配額 籲FIFA維持公平性", "summary": "伊朗足球協會今天指責今年世界盃主辦國之一美國撤銷伊朗在小組賽的門票配額，在兩國激烈外交衝突的陰影下，刻意阻撓伊朗球迷進場...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35028174.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 20:21", "link": "/news/story/123107/9556066"}, {"article_id": "9556098", "title": "澳洲羽賽／「生子後」沒好運加持 王齊麟連四站一輪遊", "summary": "兩屆奧運金牌名將王齊麟，3月底迎接兒子「Rally」出世，但卻沒諺語「娶某前，生子後」的好運氣，連同今天BWF超級500系列的澳洲公開賽輸球，已是連四站「一輪遊」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35028155.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-09 20:04", "link": "/news/story/7005/9556098"}, {"article_id": "9555995", "title": "NBA／柯瑞自信加入史上最強控衛之爭 直言能與魔術強森同層級", "summary": "金州勇士球星柯瑞（Stephen Curry）再度把自己推上籃球史上最大辯論之一的中心，那就是誰才是NBA史上最偉大控球後衛。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35028021.jpg&M=1&s=Y&x=55&y=79&sw=1176&sh=784&exp=3600&sl=W&fw=360", "date": "2026-06-09 19:08", "link": "/news/story/7002/9555995"}, {"article_id": "9555962", "title": "NBA／不會為了對抗「斑馬」賣掉霍姆葛倫 傳雷霆將圍繞三劍客補強", "summary": "雷霆本季挑戰衛冕失利，在西區決賽與馬刺鏖戰7場後遭到淘汰，無緣重返總冠軍賽。不過，儘管外界因霍姆葛倫（Chet Holmgren）在對位溫班亞瑪（Victor Wembanyama）時表現不如預期，開始討論雷霆是否應該調整核心陣容，球團已向聯盟傳達明確訊息：不會動由亞歷山大（Shai Gilgeous-Alexander）、威廉斯（Jalen Williams）與霍姆葛倫組成的核心班底。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027991.jpg&M=1&s=Y&x=0&y=21&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-09 18:52", "link": "/news/story/7002/9555962"}, {"article_id": "9555935", "title": "NBA／不讓太陽2比0翻盤憾事重演 布里吉斯：G4必須控制犯規", "summary": "尼克前鋒悍將布里吉斯（Mikal Bridges）和替補後衛沙米特（Landry Shamet）在總冠軍賽第2戰的外線齊發是尼克能夠搶下勝利的關鍵，然而第3戰回到紐約主場，兩人卻是一起熄火，三分球合計10投1中，最終尼克也以4分之差飲恨，無緣3連勝聽牌。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027955.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-09 18:44", "link": "/news/story/7002/9555935"}, {"article_id": "9555831", "title": "WNBA／神射克拉克回來了！致勝三分拯救狂熱隊 總教練讚：我們真的需要這一球", "summary": "印第安納狂熱隊球星克拉克（Caitlin Clark）本季開局並不順遂，甚至可以說遠低於外界期待，不過她今天用一顆招牌遠距離三分球，提醒所有人她仍是那位能在關鍵時刻改變比賽的世代級球星。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027841.jpg&M=1&s=Y&x=97&y=18&sw=1152&sh=768&exp=3600&sl=W&fw=360", "date": "2026-06-09 18:01", "link": "/news/story/7002/9555831"}, {"article_id": "9555726", "title": "世足球星／英格蘭隊史最會進球男人 「三獅軍團」欲終結冠軍荒就看凱恩", "summary": "英格蘭隊史進球紀錄保持人凱恩，以78球帶領「三獅軍團」衝擊本屆世界盃冠軍。他在職業生涯中多次獲得金靴獎，自2016年起擔任國家隊長，曾助隊取得2018年世界盃殿軍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027703.gif&M=1&s=Y&x=0&y=0&sw=900&sh=600&exp=3600&sl=W&fw=360", "date": "2026-06-09 17:55", "link": "/news/story/123107/9555726"}, {"article_id": "9555819", "title": "世足球星／巴拿馬睽違8年二度參賽 核心中場卡拉斯基利亞帶隊爭隊史首勝", "summary": "巴拿馬國家足球隊在2023年世足賽重返舞台，將由資深中場卡拉斯基利亞帶領，力求隊史首勝。巴拿馬曾於2018年首度參賽，但未能取勝；本屆面對迦納將是最有機會的一戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027842.gif&M=1&s=Y&x=0&y=0&sw=900&sh=600&exp=3600&sl=W&fw=360", "date": "2026-06-09 17:50", "link": "/news/story/123107/9555819"}, {"article_id": "9555800", "title": "世足球星／「黑星軍團」迦納遇傷兵危機 曼城前鋒塞梅諾成攻擊要角", "summary": "「黑星軍團」迦納在小組賽中面臨挑戰，曼城前鋒塞梅諾成為攻擊重心。他的表現將直接影響迦納能否從強敵中突圍，尤其在熱刺前鋒庫杜斯因傷退賽後。塞梅諾在去年首次參加世界盃，並隨後成為隊上主力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027799.gif&M=1&s=Y&x=0&y=0&sw=900&sh=600&exp=3600&sl=W&fw=360", "date": "2026-06-09 17:31", "link": "/news/story/123107/9555800"}, {"article_id": "9555742", "title": "世足球星／克國傳奇「魔笛」五度參賽 莫德里奇力拚國家隊200場出賽", "summary": "克羅埃西亞中場莫德里奇即將迎來其第5次世界盃，目標是創造200場國家隊出賽的里程碑。這位40歲的足球傳奇，曾在2018年奪得金球獎，並是國家隊史上出賽最多的球員。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027711.gif&M=1&s=Y&x=0&y=0&sw=900&sh=600&exp=3600&sl=W&fw=360", "date": "2026-06-09 17:19", "link": "/news/story/123107/9555742"}, {"article_id": "9555763", "title": "NBA／遭溫班亞瑪「大力金剛掌」推倒 布朗森淡看衝突：你看到什麼就是什麼", "summary": "尼克在總冠軍賽第3戰主場以111比115不敵馬刺，季後賽13連勝告終，系列賽仍以2比1領先。這是尼克睽違27年後首度在麥迪遜花園廣場舉行總冠軍賽，卻未能用勝利回報近2萬名主場球迷，也讓第4戰的重要性更加升高。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027739.jpg&M=1&s=Y&x=188&y=31&sw=927&sh=618&exp=3600&sl=W&fw=360", "date": "2026-06-09 17:17", "link": "/news/story/7002/9555763"}, {"article_id": "9555690", "title": "世足賽／抗議聲浪不斷 墨西哥仍保證世界盃和平開幕", "summary": "儘管外界對墨西哥持續發酵的抗議活動感到擔憂，墨國總統薛恩鮑姆（Claudia Sheinbaum）今天表示，她保證本週登...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35027675.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 17:01", "link": "/news/story/123107/9555690"}]}, {"name": "2026美