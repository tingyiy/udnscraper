php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084527.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9593665"}, {"article_id": "9593830", "title": "世足攻略／坐擁天時地利人和 看好加拿大贏南非1球出線", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084767.jpg&M=1&s=Y&x=3&y=0&sw=1262&sh=841&exp=3600&w=300", "link": "/news/story/122629/9593830"}, {"article_id": "9592297", "title": "世足攻略／英格蘭攻守成熟巴拿馬難擋 克羅埃西亞迎戰迦納關鍵在調度", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082193.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9592297"}, {"article_id": "9592272", "title": "世足攻略／J組阿爾及利亞防空拉警報 K組C羅角色成葡萄牙勝負關鍵", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/27/35082146.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9592272"}, {"article_id": "9590591", "title": "世足攻略／姆巴佩、哈蘭德金靴巔峰對決 比利時戰紐西蘭可望火力解放", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/26/35079836.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9590591"}]}, {"name": "最新文章", "articles": [{"article_id": "9594813", "title": "MLB／鄭宗哲高飛犧牲打攻下追平分 紅襪4連戰橫掃世仇洋基", "summary": "旅美好手鄭宗哲今天再度排進紅襪隊先發打線，對洋基隊之戰擔任第9棒游擊手，延長10局下揮出高飛犧牲打，幫助紅襪追成4：4平手，下一棒杜蘭（Jarren Duran）再見安打，紅襪5：4險勝，完成主場4連戰橫掃。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35086082.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-29 10:48", "link": "/news/story/6999/9594813"}, {"article_id": "9594811", "title": "NBA／拿FMVP卻僅排塞爾蒂克陣中第7好！ 布朗怒嗆「數據毀了現代籃球」", "summary": "作為「字母哥」安戴托昆波（Giannis Antetokounmpo）交易籌碼失敗後，塞爾蒂克球星布朗（Jaylen Brown）持續被擺上談判桌。近日薪資專家馬克斯（Bobby Marks）更是透露，數據分析師僅將這位帶領綠衫軍奪冠的絕對核心排在全隊第7，讓布朗怒斥「數據毀了籃球」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35086072.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 10:47", "link": "/news/story/7002/9594811"}, {"article_id": "9594779", "title": "NBA／黃蜂再度交易送走布里吉斯 太陽補強鋒線省下2000萬美元豪華稅", "summary": "夏洛特黃蜂休賽季持續大幅調整陣容，根據報導，黃蜂將布里吉斯（Miles Bridges）、2029年首輪選秀權與2027年二輪選秀權送往鳳凰城太陽，換回艾倫（Grayson Allen）、奧尼爾（Royce O'Neale）以及2033年首輪選秀權。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35085996.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-29 10:42", "link": "/news/story/7002/9594779"}, {"article_id": "9594700", "title": "中職／曾峻岳半季16次救援成功超越高津臣吾 熬過撞牆期寫隊史紀錄", "summary": "富邦悍將隊上半季已奪33勝，寫下球團史新猷，也帶動守護神救援成功超進度累積，「護國神山」曾峻岳以16次救援成功獨居聯盟榜上領先，也超越2010年興農牛隊高津臣吾，締造隊史半季最多救援成功紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35085844.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&sl=W&fw=360", "date": "2026-06-29 10:10", "link": "/news/story/7001/9594700"}, {"article_id": "9594659", "title": "世足運彩／荷蘭火力兇猛、摩洛哥防守不穩 推薦雙方2.5大分", "summary": "1994年世界盃小組賽，荷蘭以2：1擊敗摩洛哥，開啟在世界盃連續19場不敗的紀錄。之後兩隊2度友誼賽交手，1999年摩洛哥2：1獲勝，2017年荷蘭又以2：1獲勝。荷蘭在歷屆世界盃拿過3次亞軍，2014年以後最佳成績是第3名。摩洛哥則是在上一屆淘汰賽連續淘汰西班牙與葡萄牙，最終止步4強。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35085812.jpg&M=1&s=Y&x=0&y=36&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 10:04", "link": "/news/story/123105/9594659"}, {"article_id": "9594685", "title": "溫布頓／小腿疲勞性骨折 地主一姊最後一刻宣布退賽", "summary": "草地大滿貫溫布頓台灣時間今天晚上6點正式開戰，但地主球星「英國甜心」瑞度卡努（Emma Raducanu）在最後一刻卻宣布退出，她因右小腿疲勞性骨折，無法參與在家鄉舉辦的年度盛事。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35085841.jpg&M=1&s=Y&x=0&y=19&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 10:03", "link": "/news/story/7005/9594685"}, {"article_id": "9594621", "title": "MLB／大谷翔平、貝茲聯手打下江山 道奇領先教士達10場勝差", "summary": "道奇隊作客聖地牙哥，今天對教士隊3連戰最後一戰又以4：2獲勝，大谷翔平3局上安打攻下全隊第1分，貝茲（Mookie Betts）5局上兩分打點安打更是關鍵，道奇在系列賽搶到兩勝，本季對戰4勝2敗領先。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35085749.jpg&M=1&s=Y&x=174&y=18&sw=997&sh=665&exp=3600&sl=W&fw=360", "date": "2026-06-29 09:38", "link": "/news/story/6999/9594621"}, {"article_id": "9594608", "title": "美國羽賽／退前球王奪生涯首冠 蘇力揚激動落淚", "summary": "中華羽將在美國公開賽大放異彩，今天決賽日共有5組台將亮相，混雙上演「寶島內戰」金包銀，壓軸上陣的蘇力揚更在3局大戰力退印度前球王斯里坎（Kidambi Srikanth），勇奪生涯第一座巡迴賽冠軍，讓他激動落下男兒淚，和土銀教練感動相擁。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35085741.jpg&M=1&s=Y&x=160&y=8&sw=1019&sh=652&exp=3600&sl=W&fw=360", "date": "2026-06-29 09:34", "link": "/news/story/7005/9594608"}, {"article_id": "9594607", "title": "世足賽／南韓淘汰連總統都痛批 總教練洪明甫閃電請辭", "summary": "南韓隊在美加墨世界盃止步小組賽，讓球迷罵翻，連南韓總統李在明都痛批錯愕且「荒唐」，總教練洪明甫也在確定出局後不到24小時提出辭呈，為南韓失利負責。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35085744.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 09:34", "link": "/news/story/123107/9594607"}, {"article_id": "9594528", "title": "世足賽／日本對決5冠巴西 總教練森保一：團結一心全力迎戰", "summary": "日本在世界盃挺進32強，不過淘汰賽首戰就遇上5冠王巴西。雖然日本去年曾在友誼賽擊敗對手，但總教練森保一表示，雪恥動機將讓...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35085610.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 08:58", "link": "/news/story/123107/9594528"}, {"article_id": "9594531", "title": "MLB／費城人史瓦柏率先30轟 千賀滉大慘吞開季7連敗", "summary": "費城人隊重砲史瓦柏（Kyle Schwarber）今天7局上轟出兩分砲，本季第30轟出爐，成為大聯盟第1人，幫助費城人5：4擊敗大都會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35085626.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 08:57", "link": "/news/story/6999/9594531"}, {"article_id": "9594517", "title": "MLB／紐約大都會台灣日下月26日登場 林琪兒與蔡其昌任開球嘉賓", "summary": "美國職棒大聯盟紐約大都會台灣日將於7月26日舉行，主辦機構今天公布將由美國國家航空暨太空總署（NASA）太空人林琪兒，及...", "thumbnail": "https://pgw.udn.com.