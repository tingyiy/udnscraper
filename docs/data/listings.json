: "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/02/34822502.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9427576", "title": "中職／莫忘日本火腿出走教訓 南市府應修補裂痕與統一共榮", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/07/34834270.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9427523", "title": "忙到頭來一場空 湖人功虧一簣賽季真正失去了什麼？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/07/34834230.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9426854", "title": "日職／改後援全因輪值太滿 古林轉牛棚並非不合理但還有變數", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/07/34833317.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9431137", "title": "NBA／佛雷格隔扣被「同學」馬魯阿奇封阻！太陽布克轟37分險勝獨行俠", "summary": "太陽昨天以105：119輸給火箭隊，確定無緣西區前6要打附加賽。今天背靠背與獨行俠交戰，主力中鋒威廉斯（Mark Williams）和射手艾倫（Grayson Allen）輪休。不過仍靠著布克（Devin Booker）狂轟37分，以112：107險勝獨行俠。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34839400.jpg&M=1&s=Y&x=0&y=155&sw=853&sh=569&exp=3600&sl=W&fw=360", "date": "2026-04-09 12:27"}, {"article_id": "9431083", "title": "NBA／戴維斯想再戰奧運 喊話接到邀請一定出戰", "summary": "巫師明星戴維斯表示，有意再戰2028洛杉磯奧運，如獲國家隊邀請將毫不猶豫參加。曾隨隊奪金的他，期待再次披上國家隊戰袍，展現實力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34839255.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 12:09"}, {"article_id": "9430875", "title": "運動部次長鄭世忠請辭 將回學校持續發揮專長", "summary": "運動部政務次長鄭世忠今天傳出請辭，將回國立體育大學任教。他表示，雖然借調期限還沒到，但覺得現在是離開的時間點，「回到學校...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34839057.jpg&M=1&s=Y&x=0&y=0&sw=1169&sh=779&exp=3600&sl=W&fw=360", "date": "2026-04-09 11:38"}, {"article_id": "9430962", "title": "MLB／昨引起大規模全武行 主角索勒、羅培茲遭判禁賽7場", "summary": "天使外野手索勒與勇士投手羅培茲因近身球衝突，引發大規模全武行。大聯盟宣布對兩人各禁賽7場，羅培茲後來上訴改為禁賽5場生效，索勒的上訴仍在進行中。兩人均否認故意衝突。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34839015.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-09 11:35"}, {"article_id": "9430978", "title": "PLG／富邦勇士簽下霍力飛補強禁區 兄弟倆同在台職籃發展", "summary": "台北富邦勇士隊今天正式宣布，與洋將霍力飛（Michael Holyfield）完成簽約，霍力飛已抵達台灣並投入球隊訓練，加上弟弟提傑（TJ Holyfield）目前也在TPBL新竹御嵿攻城獅隊，兄弟倆將一同在台灣職籃發展。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34839028.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-09 11:30"}, {"article_id": "9430942", "title": "NBA／故意犯規勇士小柯瑞將被聯盟調查 國王球團澄清不是「擺爛」", "summary": "勇士隊昨天以110：105擊敗國王隊，比賽關鍵時刻國王故意對小柯瑞（Seth Curry）犯規，讓球迷們紛紛質疑國王在擺爛，知名記者查拉尼亞指出，聯盟將調查國王。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838987.jpg&M=1&s=Y&x=248&y=24&sw=782&sh=521&exp=3600&sl=W&fw=360", "date": "2026-04-09 11:27"}, {"article_id": "9430904", "title": "MLB／維持最簡單的打擊策略 大谷：不投好球我很樂意被保送", "summary": "道奇隊日職球星大谷翔平今天在客場出戰藍鳥隊，本季第二度「二刀流」上陣。「打者大谷」首打席就選到保送，以連43場上壘追平鈴木一朗所保持的日本球員紀錄，大谷坦言，自己試著讓維持最簡單的打擊策略，「如果他們不對我投好球，我很樂意獲得保送。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838909.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 11:06"}, {"article_id": "9430821", "title": "MLB／今年僅投一場就動TJ 金鶯前勝投王艾佛林賽季報銷", "summary": "金鶯球團宣布右投艾佛林因手肘傷勢確定報銷，將接受TJ手術。他本季僅出賽一場，早期表現亮眼，但因手肘不適提前退場。艾佛林在2023年作為光芒投手獲得勝投王殊榮，預計明年成為自由球員。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838779.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 10:56"}, {"article_id": "9430811", "title": "MLB／大谷投球前藍鳥春天哥一動作引熱議 主播：有球隊不滿", "summary": "大谷翔平本季以二刀流之姿出賽，藍鳥隊「春天哥」史布林格（George Springer）在大谷投球前一個動作，引發轉播單位及球迷們討論。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838776.jpg&M=1&s=Y&x=0&y=15&sw=853&sh=569&exp=3600&sl=W&fw=360", "date": "2026-04-09 10:53"}, {"article_id": "9430819", "title": "足球／女足連署換帥工會提4訴求 李洋：將親自了解球員需求", "summary": "中華女足球員日前公開聯署要求撤換總教練並重組教練團，女足工會也在昨天發出4點說明，希望教練團檢討應在2周內完成，運動部部長李洋今天表示，已經與女足選手取得聯繫，也將會親自與選手了解他們的真正需求給予幫助。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838907.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 10:48"}, {"article_id": "9430779", "title": "NBA／康寧漢氣胸缺陣11場回歸 活塞輕取公鹿有望挑戰60勝", "summary": "活塞隊今天迎接當家球星康寧漢（Cade Cunningham）回歸，他氣胸缺陣11場復出就繳出13分、10助攻的「雙10」表現，助隊以137：111輕取公鹿隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838726.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-09 10:38"}, {"article_id": "9430641", "title": "日職／我想吃青菜！徐若熙透露旅日2個月最大困擾 最強娘家火速支援", "summary": "前味全龍王牌、現效力於日職福岡軟銀鷹的「龍之子」徐若熙，旅日生活已屆滿兩個月，儘管在場上展現強大競爭力，但私下卻正經歷一段艱辛的「飲食適應期」。 根據《TSNA》報導，徐若熙受訪時透露，日本飲食習慣與台灣大不同，雖然肉類與炸物豐富，卻極度缺乏熱騰騰的青菜，大部分是生菜類，即使不是生的，料理方式也不太一樣，讓他直言「吃不到青菜真的很困擾，最想念台灣的空心菜」。甚至自爆剛到日本的前幾天，一度因為太想念台灣的青菜而產生思鄉情緒。 除了飲食考驗，徐若熙也逐漸適應日職嚴謹的球隊文化。為了適應當地節奏，他逼自己早睡早起，每天早早就到球場報到，等日本駕照拿到手，就準備開車代步。。 徐若熙8日首度在主場福岡巨蛋登板，老東家味全龍特地到場應援，雖然當天失分吞下日職首敗，但", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838448.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 10:30"}, {"article_id": "9430734", "title": "MLB／只打6場就獲9年1.4億美元合約 海盜葛瑞芬：這是會贏的球隊", "summary": "海盜隊與19歲游擊手葛瑞芬簽下價值1.4億美元的九年合約，成為隊史第二張破億合約。葛瑞芬在小聯盟表現突出，並希望與隊友共同打造季後賽球隊。海盜老闆表示這是重要的長期方向。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838597.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 10:26"}, {"article_id": "9430740", "title": "羽球／上任後僅碰球4次 「麟洋配」周日再合拍李洋擔憂被嫌棄", "summary": "兩屆奧運羽球男雙金牌得主李洋去年9月上任運動部史上首任部長，本周日將在清晨盃與老搭檔王齊麟再度合拍，重現「麟洋配」風采，李洋在今天於立法院受訪時表示，上任部長後僅4度碰球，很擔心被王齊麟嫌棄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838612.jpg&M=1&s=Y&x=0&y=21&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 10:19"}, {"article_id": "9430671", "title": "婉拒王惠美爭取經費引討論 李洋：希望幫納稅人把關好每一分錢", "summary": "運動部部長李洋日前在出席彰化縣「和美全民運動館」啟用典禮時，因婉拒收下彰化縣長王惠美的體育設施經費爭取文件引發討論，李洋在今天於立法受訪時表示，當下確實有向王惠美表達預算確實沒有通過，也詢問她是否有正式發函，如果有，運動部都會入案。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838471.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 09:58"}, {"article_id": "9430660", "title": "MLB／大谷翔平6局無責失勝投被搞砸 連續43場上壘追平鈴木一朗", "summary": "道奇隊日職球星大谷翔平本季第二場「二刀流」出賽，對上藍鳥隊先發6局失1分（非自責分），但退場後勝投被牛棚搞砸，而他擔任先發第1棒沒有敲出安打，但選到1次保送，延續跨季連續43場上壘，最終道奇隊以3：4遭逆轉吞敗，終止5連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838495.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-09 09:53"}, {"article_id": "9430621", "title": "NBA／參與馬刺投籃訓練「恢復良好」 溫班亞瑪有望下戰回歸", "summary": "馬刺隊當家中鋒溫班亞瑪（Victor Wembanyama）前一場碰76人隊時傷退，好消息是沒受嚴重傷勢，儘管今天和前一場締造本季第5度「大三元」的卡瑟爾（Stephon Castle）都確定缺席和拓荒者隊的比賽，不過兩人都有參與球隊今天的投籃練習，台灣時間周六碰獨行俠隊的比賽有望上陣。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838399.jpg&M=1&s=Y&x=0&y=159&sw=895&sh=596&exp=3600&sl=W&fw=360", "date": "2026-04-09 09:44"}, {"article_id": "9430589", "title": "運動部次長鄭世忠請辭 李洋剛剛才得知：等行政院發布再說明", "summary": "運動部政務次長鄭世忠在今天證實，由於已經完成階段性任務已經主動請辭，運動部部長李洋在今天前往立法院教育及文化委員會接受質詢時表示，剛剛才得知這項訊息，但相關狀況仍須等待行政院發布人事調動後再進行說明。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838374.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 09:34"}, {"article_id": "9430569", "title": "MLB／鄧愷威連兩天登板 滿壘飆K後援1.1局無失分", "summary": "太空人隊客場面對洛磯隊三連戰最終戰，投手群大崩盤，鄧愷威連兩天出賽，在第6局滿壘局面登板「拆彈」，飆三振守住局面，後援1.1局無失分，成為今天太空人陣中唯一無失分的投手，但最終球隊以1：9不敵洛磯，吞下近期四連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838333.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 09:22"}, {"article_id": "9430565", "title": "田徑／台灣公開賽因經費喊卡 李洋：將輔導申請基金預算盼順利辦理", "summary": "台灣國際田徑公開賽在昨天傳出升級為世界田徑總會「銀標籤」賽事的好消息後，卻在傍晚宣布因為立法院總預算一直無法通過賽事喊卡的狀況，運動部部長李洋在今天前往立法院教育及文化委員會進行專案報告前表示，將會積極輔導協會申請基金預算，希望原訂在台灣舉辦的國際賽事都能順利辦理。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838332.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 09:21"}, {"article_id": "9430513", "title": "運動部次長驚傳請辭 鄭世忠：階段性任務已完成", "summary": "運動部政務次長鄭世忠驚傳請辭，他今早證實，由於「階段性任務已完成」，且考量職長期學術志業與人才培育責任，主動請辭政務次長職務，將歸建國立體育大學，回到校園持續從事教學、運科研究和體育運動專業人才育成工作。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34838276.jpg&M=1&s=Y&x=0&y=41&sw=1032&sh=688&exp=3600&sl=W&fw=360", "date": "2026-04-09 08:38"}, {"article_id": "9429649", "title": "中職／一樣的毛病今年特別早發作 牛棚成中信兄弟戰績大爆彈", "summary": "中信兄弟在本季開局出現不佳，戰績僅為1勝6敗，暫時墊底，主要問題來自牛棚表現不穩。團隊防禦率高達5.29，多名後援投手防禦率超過3.50，影響勝率。雖然打擊表現不差，但主力球員狀態回暖迫在眉睫。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34837440.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=852&exp=3600&sl=W&fw=360", "date": "2026-04-09 07:00"}, {"article_id": "9430252", "title": "從七大指標看MLB超車NBA 成為美國人第二愛看運動？", "summary": "大聯盟在收視率上超越NBA，成為美國人第二愛看的運動。世界棒球經典賽和去年的世界大賽創下高收視，專家指出棒球的改變使其重返運動舞台。然後，NBA在社群媒體及轉播權利金方面仍占優，未來發展仍需觀察。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34837873.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 07:00"}, {"article_id": "9429778", "title": "羽球／周天成輕取泰國新星 亞錦賽男單闖頭關", "summary": "在中國舉行的亞洲羽球錦標賽，「台灣一哥」周天成今天在男單首輪以直落二輕取21歲泰國新星提拉瑞薩庫，與另名台灣好手戚又仁攜...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/03/20/34780512.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 21:39"}]}, {"name": 