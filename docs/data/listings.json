"https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35068759.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/122629/9583239"}, {"article_id": "9581485", "title": "下放11天救贖大覺醒！李灝宇攻守兩端精算 拚卡位老虎二遊", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35066096.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9581485"}, {"article_id": "9581615", "title": "中職／悍將別等威戈神了 補強洋投才不會白費上半季好戰績", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35066229.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9581615"}, {"article_id": "9581639", "title": "愛德華孤掌難鳴需要二號球星？灰狼或許不要冒險交易會更好", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35066281.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9581639"}, {"article_id": "9580863", "title": "世足攻略／阿根廷爭龍頭 梅西挑戰進球王紀錄", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065236.jpg&M=1&s=Y&x=0&y=0&sw=1247&sh=831&exp=3600&w=300", "link": "/news/story/122629/9580863"}]}, {"name": "最新文章", "articles": [{"article_id": "9584653", "title": "MLB／恭喜！18歲右投賴謙凡加盟洋基 繼王建民、郭阜林後第3位台將", "summary": "台灣棒壇今天再迎好消息！紐約洋基隊今天宣布簽下18歲右投賴謙凡，成為繼2000年王建民、2009年郭阜林之後，洋基隊史第三位台灣球員，6月26日在台灣舉行加盟記者會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070913.jpg&M=1&s=Y&x=477&y=93&sw=711&sh=474&exp=3600&sl=W&fw=360", "date": "2026-06-24 08:30", "link": "/news/story/6999/9584653"}, {"article_id": "9584649", "title": "世足賽／FIFA主席證實川普將共同頒發大力神盃 去年頒獎不退場成話題", "summary": "2026年美加墨世足賽進入白熱化階段，除了球場上的強權廝殺引人關注外，頒獎大典也將迎來歷史性的一幕，國際足總（FIFA）主席因凡蒂諾（Gianni Infantino）今天證實，美國總統川普（Donald Trump）將於7月19日在紐澤西舉行的決賽中，與他一同登台頒發象徵至高榮譽的「大力神盃」，打破了近代世足賽由FIFA主席獨自頒獎的慣例。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_7.jpg", "date": "2026-06-24 08:24", "link": "/news/story/123107/9584649"}, {"article_id": "9584648", "title": "世足賽／絕佳機會球踢飛被迦納逼和 凱恩無奈：必須接受", "summary": "第一場演出「梅開二度」的英格蘭隊長凱恩（Harry Kane），今天碰上迦納卻錯失門前一次大好機會，第86分鐘把球踢飛的他當場跪地、雙手抱頭，懊惱神情擋不住；最終英格蘭被FIFA世界排名65的迦納逼和，兩隊都只進帳1分積分。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070909.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 08:23", "link": "/news/story/123107/9584648"}, {"article_id": "9584596", "title": "世足賽／頂住質疑梅開二度 C羅談可能與梅西對決：那一定很棒", "summary": "2026年世足賽K組分組賽爆出高潮，首戰表現沉寂的葡萄牙當家球星C羅（Cristiano Ronaldo），在面對烏茲別克的比賽中重振雄風，他單場獨中兩元，不僅率領球隊以5：0大勝、搶下晉級淘汰賽的關鍵優勢，更成為歷史上首位在六屆世足賽都有進球紀錄的球員，賽後談到未來可能在淘汰賽與宿敵梅西（Lionel Messi）交手，C羅直言「那一定很棒。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070868.jpg&M=1&s=Y&x=212&y=31&sw=821&sh=548&exp=3600&sl=W&fw=360", "date": "2026-06-24 07:17", "link": "/news/story/123107/9584596"}, {"article_id": "9584450", "title": "中職／要避免成為洋投聯盟 不如先制定本土先發遊戲規則", "summary": "味全龍在2023年中華職棒奪得上半季冠軍，展現強大韌性與優異投手表現。呼籲應制定本土先發遊戲規則，以減少對洋投的依賴，促進本土投手培養，提升賽事品質。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070482.jpg&M=1&s=Y&x=0&y=0&sw=1024&sh=683&exp=3600&sl=W&fw=360", "date": "2026-06-24 07:00", "link": "/news/story/122629/9584450"}, {"article_id": "9584569", "title": "世足賽／美國放寬伊朗隊旅行限制 允許賽前兩天入境", "summary": "美國國土安全部今天表示，美國已放寬對伊朗隊在世界盃期間的旅行安排限制，允許他們在下一場比賽前兩天入境", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_0.jpg", "date": "2026-06-24 06:48", "link": "/news/story/123107/9584569"}, {"article_id": "9584560", "title": "世足賽／英格蘭握79%持球率 遭迦納逼平0：0收場", "summary": "2026年6月24日清晨4時，世界盃L組迎來關鍵對決，由英格蘭迎戰迦納。在這場小組賽中，雙方展開高強度攻防。儘管英格蘭在全場展現持球優勢，卻始終未能打破僵局。經歷90分鐘鏖戰，雙方最終以0比0握手言和", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070787.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 06:15", "link": "/news/story/123107/9584560"}, {"article_id": "9584538", "title": "世足賽／C羅梅開二度 葡萄牙力挫烏茲別克摘首勝", "summary": "葡萄牙今天在世界盃K組第2輪賽事以5比0痛擊烏茲別克摘首勝，使積分暫居該組第一，足球巨星「C羅」羅納度今天上演梅開二度之...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_9.jpg", "date": "2026-06-24 06:10", "link": "/news/story/123107/9584538"}, {"article_id": "9584507", "title": "世足賽／葡萄牙5：0大勝烏茲別克 暫居K組榜首", "summary": "2026年世界盃足球賽K組小組賽於台灣時間6月24日凌晨1點展開，由歐洲勁旅葡萄牙迎戰亞洲代表烏茲別克。葡萄牙本場比賽展現強大的進攻火力，終場以5比0大勝烏茲別克順利全取3分，也讓對手在此役遺憾掛蛋。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070689.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 03:52", "link": "/news/story/123107/9584507"}, {"article_id": "9584392", "title": "世足賽／刷新歷史…梅西累計18球 登基世足進球王", "summary": "世界盃足球賽小組賽昨天上演歷史性一幕，衛冕軍阿根廷對決奧地利之戰，當家球星梅西在開賽之初意外射失禁區罰球，但他隨後展現強大心理素質「梅開二度」，率領阿根廷二比○獲勝，不僅奪下二連勝提前挺進卅二強淘汰賽，生涯在世足賽累積十八顆進球，更超越德國傳奇前鋒克洛澤，獨居史上進球王寶座。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070672.jpg&M=1&s=Y&x=44&y=0&sw=1135&sh=756&exp=3600&sl=W&fw=360", "date": "2026-06-24 00:02", "link": "/news/story/123107/9584392"}, {"article_id": "9584391", "title": "世足賽／姆巴佩、梅西、哈蘭德 卡位金靴", "summary": "今年世足賽三大射手梅西、姆巴佩、哈蘭德昨天再度上演進球大戰，都繳出「梅開二度」的成績單，也讓今年金靴獎的競爭提前進入白熱化階段，是否有人能打破單屆個人最多十三球紀錄，成為各界討論焦點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35070269.jpg&M=2&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 00:01", "link": "/news/story/123107/9584391"}, {"article_id": "9584397", "title": "世足賽／哈蘭德快攻奏效 挪威晉級", "summary": "挪威暌違廿八年重返世足賽舞台，熱情球迷將「維京戰船」的慶祝儀式划進北美，挪威當家球星哈蘭德昨天「梅開二度」，以三比二擊敗塞內加爾後，全隊連同教練團更坐在球場草地上做出划船慶祝動作，慶祝以二連勝之姿提前晉級卅二強淘汰賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070663.jpg&M=1&s=Y&x=0&y=54&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-24 00:01", "link": "/news/story/123107/9584397"}, {"article_id": "9584147", "title": "中職／兄弟近5戰4勝拉尾盤 上半季猿象爐主之爭還有得瞧", "summary": "中信兄弟隊鄰近上半季尾聲拉尾盤，今天狂敲15支安打，進攻8局有6局得分，終場以6：3擊敗富邦悍將隊。兄弟近5戰4勝，加上樂天桃猿隊吞下5連敗，雙方勝差縮小到1.5場，誰是上半季爐主還有得瞧。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35070081.jpg&M=1&s=Y&x=0&y=0&sw=1111&sh=741&exp=3600&sl=W&fw=360", "date": "2026-06-23 21:46", "link": "/news/story/7001/9584147"}, {"article_id": "9584095", "title": "中職／桃猿「開箱」日籍洋投中大獎也沒用 打線0分吞本季最長5連敗", "summary": "樂天桃猿隊「開箱」二軍核爆的日籍洋投榊原元稀，飆出令人刮目相看的6局失1分好投，然而打線0分支援，終場以0：1不敵統一隊，猿隊吞下本季最長的5連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069997.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 21:12", "link": "/news/story/7001/9584095"}, {"article_id": "9584025", "title": "世足賽／紅魔鬼世足之路顛簸 比利時媒體化身數學老師算晉級", "summary": "比利時在今年世界盃的首勝仍未開張，連帶使得球迷開始擔心晉級之路。比利時媒體化身數學老師，逐一分析接下來晉級淘汰賽或是小組...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35065620.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 20:47", "link": "/news/story/123107/9584025"}, {"article_id": "9583913", "title": "世足賽／多元族裔改寫世足樣貌 1/4球員非本土出生親兄弟鬩牆", "summary": "瑞典球員阿亞瑞世界盃首秀開賽7分鐘就進球，但是出於對父親祖國突尼西亞的尊重，他舉起雙手帶著歉意，而非熱烈慶祝", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/15/35045613.jpg&M=1&s=Y&x=0&y=30&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 20:36", "link": "/news/story/123107/9583913"}, {"article_id": "9583818", "title": "中職／郭李建夫發掘潛力 開南大學陳趙羿勳轉投手從抗拒到自信", "summary": "開南大學陳趙羿勳野手轉投手雖曾抗拒，但總教練郭李建夫看見他的潛力、耐心調教，陳趙羿勳也慢慢投出心得，目前最快球速可投到1...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069915.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-23 20:17", "link": "/news/story/7001/9583818"}, {"article_id": "9583875", "title": "紅葉少棒隊朝威廉波特邁進 北市台東縣同鄉會宴請小將喊加油", "summary": "台東縣紅葉國小少棒隊曾經創下台灣棒球史上一頁傳奇，今年又再度勇奪全國少棒冠軍，月底將前往南韓挑戰亞太盃、搶奪前進威廉波特門票，北市台東縣同鄉會行前特別舉辦餐會為選手加油，校方也期盼再次重現50多年前金龍少棒連拿17屆的冠軍榮耀。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069791.jpg&M=1&s=Y&x=1&y=111&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 19:23", "link": "/news/story/7001/9583875"}, {"article_id": "9583725", "title": "中職／南華大學廖永詮能飆速也能開轟 運動能力突出拚選秀", "summary": "南華大學廖永詮具備投打二刀實力，投球最速可達153公里，大學階段累積8轟，運動能力突出，將以外野手身分挑戰中職選秀，他表...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069630.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 18:15", "link": "/news/story/7001/9583725"}, {"article_id": "9583762", "title": "世足賽／挪威晉級32強全民歡慶 放假議題引發討論", "summary": "挪威在世界盃足球賽以3比2擊敗塞內加爾，提前晉級32強，舉國歡騰。但當地民眾徹夜未眠換來的喜悅，也讓「往後若遇深夜賽事，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069618.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 18:14", "link": "/news/story/123107/9583762"}, {"article_id": "9583700", "title": "世足運彩／三獅軍團凶猛進攻迦納鐵桶以對 主推英格蘭讓1分", "summary": "英格蘭將在世界盃小組賽對陣迦納，首戰以4：2擊敗克羅埃西亞，賽前球星薩卡傷勢恢復。迦納首戰1：0險勝巴拿馬，但防線易被擊破。勝者將鎖定32強席位，英格蘭被視為奪冠熱門。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069445.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-23 17:42", "link": "/news/story/123105/9583700"}, {"article_id": "9583568", "title": "世足運彩／葡萄牙跟西班牙一樣要解悶 C羅心態要調整可以大勝烏茲別克推大分", "summary": "葡萄牙在世足賽首輪遭民主剛果逼和，C羅心態需調整，以迎接今晚對烏茲別克的比賽。烏茲別克以年輕球員為主，首次參賽表現不俗，葡萄牙則期待大勝以振作士氣。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069283.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 17:10", "link": "/news/story/123105/9583568"}, {"article_id": "9583610", "title": "NBA／熱火留得住維金斯和鮑威爾？美媒分析詹皇回鍋可能性", "summary": "熱火隊今天發動大交易，換來｢字母哥｣安戴托昆波（Giannis Antetokounmpo），雖引進超級巨星，但陣容深度也大幅削減，《邁阿密先驅報》記者傑克森（Barry Jackson）撰文提到，41歲巨星詹姆斯（LeBron James）重返邁阿密的可能性。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069336.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 17:09", "link": "/news/story/7002/9583610"}, {"article_id": "9583584", "title": "日職／徐若熙表訂24日出戰歐力士沒了 軟銀投教：不是可以登板的狀態", "summary": "效力軟銀鷹隊台灣投手徐若熙，原訂24日先發出戰歐力士隊，近日傳出狀態出現疑問，投手教練倉野信次今天透露，徐若熙目前「不是可以馬上投球的狀態」，下一步安排將等待檢查結果。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35069296.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-23 16:57", "link": "/news/story/7001/9583584"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9584596", "title": "世足賽／頂住質疑梅開二度 C羅談可能與梅西對決：那一定很棒", "date": "2026-06-24 07:17", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070868.jpg&M=1&s=Y&x=212&y=31&sw=821&sh=548&exp=3600&w=300", "link": "/news/story/123107/9584596"}, {"article_id": "9584507", "title": "世足賽／葡萄牙5：0大勝烏茲別克 暫居K組榜首", "date": "2026-06-24 03:52", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070689.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9584507"}, {"article_id": "9584560", "title": "世足賽／英格蘭握79%持球率 遭迦納逼平0：0收場", "date": "2026-06-24 06:15", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35070787.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9584560"}, {"article_id": "9584391", "title": "世足賽／姆巴佩、梅西、哈蘭德 卡位金靴", "date": "2026-06-24 00:01", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/23/35070269.jpg&M=2&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9584391"}, {"article_id": "9584397", "title": "世