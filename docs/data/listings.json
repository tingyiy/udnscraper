: "9593665", "title": "日職／巨人受惠入札左投 中日龍迷最懂火腿迷感受", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/28/35084527.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9593665"}]}, {"name": "最新文章", "articles": [{"article_id": "9596573", "title": "世足賽／傷停補時攻入關鍵一球！巴西2：1絕殺日本", "summary": "2026年6月30日凌晨1時，世界盃足球賽淘汰賽階段迎來焦點對決，由傳統勁旅巴西迎戰亞洲強權日本。巴西憑藉全場壓制性的攻勢，在傷停補時階段攻入關鍵一球，最終以2比1逆轉擊敗日本，順利奪下晉級門票，日本", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35088554.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-30 03:25", "link": "/news/story/123107/9596573"}, {"article_id": "9596568", "title": "溫網／首輪險爆冷 球王辛納染血苦戰5盤勝出", "summary": "溫布頓網球錦標賽男單首輪，尋求衛冕的現任球王辛納面對塞爾維亞好手凱茨曼諾維奇（Miomir Kecmanovic）意外陷...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35088545.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-30 03:06", "link": "/news/story/124935/9596568"}, {"article_id": "9596527", "title": "NBA／震撼！雷納德重返暴龍倒數 快艇態度轉彎啟動交易談判", "summary": "根據《ESPN》報導，洛杉磯快艇與多倫多暴龍目前正積極針對明星前鋒雷納德（Kawhi Leonard）展開交易談判，雙方已經討論相關方案數周，這筆交易若順利完成，將讓曾帶領暴龍奪下隊史首冠的雷納德重返加拿大，也象徵快艇一個時代可能正式畫下句點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35088432.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 00:23", "link": "/news/story/7002/9596527"}, {"article_id": "9596386", "title": "煮茶論戰／替補屢絕殺 補時的奧妙", "summary": "加拿大昨天在補時階段進球絕殺南非，「天時地利人和」優勢是最重要因素，且下半場八十分鐘以後、傷停時間進球率是最高的，傷停補時成為決定比賽勝負終點的關鍵，也是「第二個下半場」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/30/35088435.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 00:22", "link": "/news/story/123107/9596386"}, {"article_id": "9596376", "title": "世足賽／追趕梅西金靴 姆巴佩、哈蘭德明分頭出擊", "summary": "金靴獎熱門人選姆巴佩、哈蘭德台灣時間明天將在世足賽卅二強賽亮相，最大目標當然是領軍法國、挪威擊敗對手，順利搶下十六強門票；法國在小組賽三連勝狂攻十球，和荷蘭、德國並列領先，除了核心人物姆巴佩，還擁有令人膽寒的進攻深度，瑞典此役將是一大挑戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088262.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 00:20", "link": "/news/story/123107/9596376"}, {"article_id": "9596363", "title": "世足賽／加拿大絕殺南非闖16強 球員成「加國英雄」", "summary": "世界盃足球賽卅二強淘汰賽昨天開踢，打頭陣的地主加拿大上演戲劇性勝利，下半場傷停補時階段靠尤斯塔基奧關鍵破網，以一比○「絕殺」南非，率先挺進十六強。加拿大第一次打進淘汰賽就迎接隊史首勝，讓總教練馬許用「加拿大英雄」稱呼子弟兵。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088250.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-30 00:19", "link": "/news/story/123107/9596363"}, {"article_id": "9596456", "title": "NBA／格林跳脫合約可能重新協商 有利勇士騰出空間追逐詹皇+AD", "summary": "金州勇士休賽季正式展開重大布局。根據《ESPN》報導，勇士老將格林（Draymond Green）決定放棄2026-27年賽季價值2770萬美元的球員選項，提前投入自由球員市場。此舉雖然讓格林成為完全自由球員，但並不代表他將離開效力14年的勇士，反而被外界視為球團與球員雙方重新協商新合約的重要一步，同時也讓勇士獲得更大的薪資操作彈性，為今夏衝擊重磅補強鋪路。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088347.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 23:33", "link": "/news/story/7002/9596456"}, {"article_id": "9596239", "title": "中職／黃宥儒「把心臟準備好」獲龍指名 謝已故教練王國慶", "summary": "畢業自北科附工的投手黃宥儒在中職選秀會第2輪獲味全龍指名，表哥賴胤豪十分關注，傳訊息要他「把心臟準備好」；他也感謝國中已...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088145.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 22:09", "link": "/news/story/7001/9596239"}, {"article_id": "9596170", "title": "中職／獅選秀7人皆高中生應屆 餅總：黃靖哲是最大重點", "summary": "中職選秀會統一7-ELEVEn獅隊首輪指名游擊手黃靖哲，總教練林岳平透露是野手首選，也是今天選秀最大重點；獅隊共選進7人...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088133.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 22:07", "link": "/news/story/7001/9596170"}, {"article_id": "9596185", "title": "中職／桃猿選秀指名8人 曾總對白井雄登蹲捕引導印象深", "summary": "中職選秀會樂天桃猿首輪指名投手陳趙羿勳，總計選入8人中，亮點是台日混血捕手白井雄登，總教練曾豪駒對白井雄登測試會印象深，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088067.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-29 22:04", "link": "/news/story/7001/9596185"}, {"article_id": "9596197", "title": "中職／邱文佑開心回報媽媽辛苦 盼與曾子祐「雙ㄧㄡˋ連線」", "summary": "平鎮高中畢業好手邱文佑選秀首輪獲得台鋼雄鷹指名，高中學長曾子祐期待組「雙ㄧㄡˋ連線」，邱文佑媽媽到場見證，邱文佑很開心終...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088112.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 21:58", "link": "/news/story/7001/9596197"}, {"article_id": "9596198", "title": "中職／兄弟指名高大游擊手許書誠 平野惠一看好跑打守", "summary": "中信兄弟隊今天在中華職業棒球大聯盟選秀會選進11人，總教練平野惠一說，以第5順位看，成果可算100分，而首輪選進身材高大...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088103.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 21:54", "link": "/news/story/7001/9596198"}, {"article_id": "9596144", "title": "中職／選秀點評！陳柏凱成狀元後再狂補投手 悍將這屆選得好", "summary": "2026年中職選秀會於29日晚間落幕，富邦選擇高卒游擊手陳柏凱成狀元。儘管今年無旅外球員回歸，且不少潛力新秀未報名，六支球隊仍積極補強，尤其針對目前戰力缺口，展現未來期望。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088046.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 21:22", "link": "/news/story/122629/9596144"}, {"article_id": "9596145", "title": "中職／龍隊榜眼考慮2人無陳柏凱 葉總看廖永詮運動能力香到想養養看", "summary": "味全龍隊的榜眼籤挑選具備二刀流潛力的南華大學外野手廖永詮，即便陳柏凱未在狀元上榜，答案依然不會變，總教練葉君璋透露，考慮的兩位人選是廖永詮和邱文佑，對廖永詮的運動能力充滿好奇，「他的運動能力是真的很好，想說用這樣的方式去選看看，看可以好到什麼程度。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088019.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 20:48", "link": "/news/story/7001/9596145"}, {"article_id": "9596127", "title": "中職／陳柏凱能否衝擊簽約金600萬？悍將領隊：審慎評估、拭目以待", "summary": "每年中職選秀季，600萬簽約金天花板都成話題，中職會長蔡其昌致詞時強調「沒有這件事」，富邦悍將隊以狀元籤帶回陳柏凱，對於他的簽約金是否有機會突破600萬，領隊陳昭如回應：「審慎評估、拭目以待。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35088007.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 20:31", "link": "/news/story/7001/9596127"}, {"article_id": "9596122", "title": "中職／林威助喊滿意！大讚陳柏凱應屆天花板最高 評估能成主力游擊", "summary": "富邦悍將隊今年在選秀會一共帶回9人，副領隊林威助評價是「滿有收穫」的一次選秀，狀元籤挑選陳柏凱早在他確定投入選秀的前一、兩天就已經有譜，早早沒有懸念，林威助說：「他應該是高中應屆畢業生裡天花板最高的游擊手，再養成幾年，應該會成為隊內主力游擊。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087998.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 20:25", "link": "/news/story/7001/9596122"}, {"article_id": "9595987", "title": "中職／悍將狀元陳柏凱看新聞才知道哥哥要來 陳品宏喊話：一起拿冠軍", "summary": "一如會前預期，富邦悍將隊狀元籤挑選來自大溪高中的游擊手陳柏凱，他與哥哥陳品宏將同隊打拚，被問到想跟即將成為隊友的弟弟說什麼？陳品宏說：「我們一起加油，一起拿總冠軍，可以嗎？」陳柏凱超乖巧，連忙回答：「可以、可以！」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087921.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-29 19:29", "link": "/news/story/7001/9595987"}, {"article_id": "9595946", "title": "世足賽／加拿大女球迷玩人浪 下秒手機「跳樓」網熱議：精彩一刻", "summary": "加拿大在這屆世界盃持續有好表現，該隊6月28日在32強賽「絕殺」南非，首度晉身16強。不過在賽事期間，看台上的一名加拿大女球迷就似乎過於投入，結果當場失去手機，更遭網友形容為「世界盃最佳片段」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087902.jpg&M=1&s=Y&x=62&y=0&sw=1055&sh=703&exp=3600&sl=W&fw=360", "date": "2026-06-29 19:18", "link": "/news/story/123107/9595946"}, {"article_id": "9595960", "title": "蔡家福、柳承敏續簽合作備忘錄 李洋見證持續深化夥伴關係", "summary": "中華奧會主席蔡家福、韓國奧會主席柳承敏今天在運動部長李洋見證下，共同正式續簽合作備忘錄，展現雙方持續深化夥伴關係、推動體育交流合作的共同承諾。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087900.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 19:11", "link": "/news/story/7005/9595960"}, {"article_id": "9595924", "title": "中職／大溪高中首度出狀元！悍將挑選陳柏凱 與陳品宏譜寫兄弟同隊", "summary": "富邦悍將球團史10年拿到的第4支狀元籤，今天確定挑選游擊手陳柏凱，他將與哥哥陳品宏同隊打拚，更一舉成為桃園大溪高中校史第一位中職選秀狀元。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087865.jpg&M=1&s=Y&x=0&y=48&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 18:44", "link": "/news/story/7001/9595924"}, {"article_id": "9595863", "title": "NBA／塞爾蒂克加入「魯超人」爭奪戰 尼克若放走羅賓森也想競逐", "summary": "塞爾蒂克傳出加入老將中鋒魯尼（Kevon Looney）的爭奪行列，同樣感興趣的還包含剛剛奪冠的尼克。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087744.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 18:08", "link": "/news/story/7002/9595863"}, {"article_id": "9595835", "title": "世足賽／運彩銷售超過40億 法國維持奪冠大熱門", "summary": "2026美加墨世界盃32強淘汰賽正式展開，台灣運彩表示，截至6月28日小組賽結束，台灣運彩銷售逾40億，淘汰賽開始後，比賽強度增加，單場銷售有機會再創高峰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087768.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-29 17:57", "link": "/news/story/123107/9595835"}, {"article_id": "9595781", "title": "NBA／哈利伯頓阿基里斯腱重傷找回健康 自信喊話：從沒感覺這麼強壯", "summary": "距離當年因阿基里斯腱撕裂重傷倒下已超過1年，溜馬當家後衛哈利伯頓（Tyrese Haliburton）如今感覺自己已經逐漸回到正常狀態。他在受訪時，談到自己預計在2026-27年賽季復出，並且對身體狀態表達高度信心。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087637.jpg&M=1&s=Y&x=7&y=0&sw=1256&sh=837&exp=3600&sl=W&fw=360", "date": "2026-06-29 17:53", "link": "/news/story/7002/9595781"}, {"article_id": "9595723", "title": "世足攻略／擁有對戰優勢 看好荷蘭再勝摩洛哥", "summary": "荷蘭在對摩洛哥的淘汰賽中擁有60%至65%的晉級機率，過去交手佔優勢，進攻火力強勁。然而，摩洛哥具備防守韌性與高效反擊，勢必成為強敵。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/29/35087526.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-29 17:07", "link": "/news/story/122629/9595723"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9596573", "title": "世足賽／傷停補時攻入關鍵一球！巴西2：1絕殺日本", "date": "2026-06-30 03:25", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.c