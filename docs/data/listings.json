"date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34965771.jpg&M=1&s=Y&x=0&y=0&sw=800&sh=533&exp=3600&w=300"}, {"article_id": "9515500", "title": "大聯盟指叉球使用量日增 為什麼左投手反而不投？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/20/34966735.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9519574", "title": "匹克球／台灣成立職業賽 鍾振煒開心不用出國拚戰", "summary": "台灣將成立「亞洲菁英匹克球聯盟」的職業聯賽，象徵這項運動邁向新領域，台灣的職業球員鍾振煒今天笑說：「終於不用一直飛到國外...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34973170.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 16:38"}, {"article_id": "9518585", "title": "NASCAR兩冠王布仕驟逝享年41歲 生涯63勝留傳奇紀錄", "summary": "美國改裝房車系列賽（NASCAR）明星車手布仕（Kyle Busch）今天辭世，享年41歲。他兩度奪得NASCAR盃系列...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34973029.jpg&M=1&s=Y&x=0&y=0&sw=1152&sh=768&exp=3600&sl=W&fw=360", "date": "2026-05-22 15:52"}, {"article_id": "9519520", "title": "世足賽／德國26人名單兩個驚喜 40歲門將諾伊爾回歸與18歲新秀入選", "summary": "德國國家隊今天公布美加墨世足26人名單，最大的驚喜是原本已退出國家隊近2年的40歲門將諾伊爾（Manuel Neuer）再度入選，將是生涯第五度出征世界盃，並且依然被總教練納格爾斯曼（Julian Nagelsmann）視為第一守門員。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34972851.jpg&M=1&s=Y&x=0&y=0&sw=1272&sh=848&exp=3600&sl=W&fw=360", "date": "2026-05-22 15:11"}, {"article_id": "9519198", "title": "降低斑馬威能！雙塔強悍變陣硬碰硬 雷霆可怕深度將成馬刺噩夢", "summary": "西區冠軍第二戰，雷霆如筆者前文「前所未見！雙向力場怪獸崛起 溫班亞瑪如何摧毀雷霆陣容深度優勢」所述，發動了非常全面而激烈的反撲，以對抗這隻不世出的雙向怪獸。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34972399.jpg&M=1&s=Y&x=52&y=40&sw=1197&sh=798&exp=3600&sl=W&fw=360", "date": "2026-05-22 15:00"}, {"article_id": "9519434", "title": "NBA／哈特擺脫G1遭放投羞辱射爆騎士布朗森讚：為大場面而生", "summary": "尼克隊前鋒哈特（Josh Hart）在東區冠軍賽首戰遭到騎士隊刻意「放投」後，今天他隨即在第二戰討回顏面，以三分球11投5中的表現猛轟全隊最高26分，幫助尼克在主場取得2連勝，賽後哈特也直言，儘管今天開賽一度找不到手感，但他也始終相信自己能有所作為。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34972704.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-22 14:30"}, {"article_id": "9519416", "title": "匹克球／亞洲菁英聯盟8月開打 總獎金100萬元", "summary": "匹克球成為全球人氣極高的新興運動，亞洲菁英匹克球聯盟（Asia Elite Pickleball League，簡稱AEPL）今天正式成立，執行長張智維宣布，聯盟第一個賽季將於8月展開，目標為台灣匹克球打造高品質、有競爭強度的舞台，並與國際接軌。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34972650.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 14:22"}, {"article_id": "9519410", "title": "TPBL／年度第六人入圍名單揭曉 林俊吉、霍爾曼、林信寬入列", "summary": "TPBL今天公布2025-26賽季「摩曼頓TPBL年度第六人」入圍名單，包括福爾摩沙夢想家隊林俊吉、霍爾曼，以及桃園台啤永豐雲豹隊林信寬，三人從不同面向詮釋替補價值，無論是外線火力、禁區影響力或攻守串聯，皆展現「第六人」在比賽中的關鍵定位。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34972628.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-05-22 14:20"}, {"article_id": "9519349", "title": "日職／徐若熙二軍飆9局無四死球完封勝 賞10K最快154公里", "summary": "日職福岡軟銀隊台灣投手徐若熙持續在二軍調整，今天先發出戰廣島隊二軍，找回超強壓制力，以87球投出9局無四死球完封勝，僅面對28名打者，讓對手敲出2支安打，飆出10次三振，最快球速達154公里，為回歸一軍做好準備。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34972565.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 14:01"}, {"article_id": "9519237", "title": "全障運／手語直播實踐運動無礙 「服務型賽會」選手開心分享", "summary": "115年全國身心障礙國民運動會以「服務型賽會」為核心，從場館到服務、從競技到生活，全面打造友善共融的運動環境。其中賽會首次全部競賽種類都有直播，總計超過200小時現場實況，並頭一回為聽障賽項提供手語播報服務，搭配專業主播與賽事講評，提升觀賽臨場感打造真正無障礙的觀賽體驗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34972363.jpg&M=1&s=Y&x=0&y=0&sw=1081&sh=721&exp=3600&sl=W&fw=360", "date": "2026-05-22 13:23"}, {"article_id": "9519206", "title": "NBA／騎士又陷入0：2落後 米契爾喊話：我們可是打了兩輪搶七", "summary": "在東區冠軍賽首戰該贏未贏後，騎士今天再度作客尼克主場，卻又在第三節出現進攻當機的狀況，讓尼克以一波18：0拉開差距，最終也以16分差吞下2連敗，儘管將帶著絕對劣勢回到克利夫蘭，但騎士一哥米契爾（Donovan Mitchell）也強調，球隊曾在0：2落後的情況下逆轉勝出，讓他們現在仍是信心滿滿。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34972309.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-22 13:07"}, {"article_id": "9519082", "title": "MiLB／鄭宗哲3A敲2安有長打 林振瑋2A先發無關勝敗", "summary": "旅美波士頓紅襪隊野手鄭宗哲今天3A出賽，單場敲出2支安打，包括本季第5支二壘打；聖路易紅雀隊2A投手林振瑋先發出賽，投4...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34972262.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-22 12:50"}, {"article_id": "9519078", "title": "PLG／伯朗獲選年度防守球員 領航猿4將入選年度防守第一隊", "summary": "PLG今天公布 2025-26球季年度防守球員及年度防守第⼀隊，年度防守球員由本季阻攻王、桃園璞園領航猿隊的伯朗獲得，⽽年度防守第⼀隊領航猿有4球員⼊選為最大贏家。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34972124.jpg&M=1&s=Y&x=0&y=0&sw=1023&sh=682&exp=3600&sl=W&fw=360", "date": "2026-05-22 12:12"}, {"article_id": "9518962", "title": "中職／「游點意思？」桃猿20歲新星遭前女友控「石垣島帶陪酒女過夜」", "summary": "中職樂天桃猿20歲新星游承勳被女攝影師控訴在石垣島帶陪酒女回飯店過夜，引發熱議。該女攝影師指控其貪玩與時間管理不當，網友也紛紛猜測該選手身份。桃猿球團及游承勳尚未回應。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34971958.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-22 11:38"}, {"article_id": "9518846", "title": "NBA／第三節18：0攻勢奠定勝基 尼克輕取騎士東決2連勝", "summary": "在東區冠軍賽首戰上演22分落後大逆轉後，尼克今天在第二戰延續前一場比賽氣勢，在先發五虎得分皆來到雙位數，以及下半場靠著一波18：0攻勢將差距擴大到雙位數，最終以109：93收下系列賽2連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34971738.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 10:46"}, {"article_id": "9518795", "title": "NBA／批評透納「背刺」公鹿行為 貝佛利：怎麼不先看看自己", "summary": "公鹿隊中鋒透納（Myles Turner）日前在錄製節目時公開批評前總教練瑞佛斯（Doc Rivers）執教期間球隊紀律極度鬆散，以及當家球星安戴托昆波（Giannis Antetokounmpo）經常遲到但不會受罰的狀況，今天曾效力過公鹿的貝佛利（Patrick Beverley）則出面反擊，並批評透納的爆料行為。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34971690.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 10:26"}, {"article_id": "9518763", "title": "日滑冰新神仙組合! 前世界冠軍情侶宇野昌磨、本田真凜將搭檔重返賽場", "summary": "日本花式滑冰情侶檔宇野昌磨與本田真凜今（22日）在IG宣布兩人將以雙人組合之姿，重返冰舞競技賽場，且將以參加奧運為目標。這個消息令日本運動迷非常興奮。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34971598.jpg&M=1&s=Y&x=0&y=0&sw=915&sh=610&exp=3600&sl=W&fw=360", "date": "2026-05-22 10:11"}, {"article_id": "9517863", "title": "雷霆見招拆招！用卡盧索+哈爾特斯坦「雙奇兵」限制斑馬", "summary": "雷霆在G2比賽中以122：113戰勝馬刺，系列賽打成1：1平手。教練戴格諾調整戰術，運用卡盧索與哈爾特斯坦有效限制斑馬溫班亞瑪，特別是在第四節僅得4分，最終幫助雷霆收穫勝利。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/21/34970408.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 09:50"}, {"article_id": "9518672", "title": "MLB／鄧愷威周日凌晨出戰小熊隊 拚先發2連勝、本季第3勝", "summary": "休士頓太空人隊客場10連戰之旅，明天前進芝加哥與小熊隊展開3連戰，27歲台灣投手鄧愷威將在系列賽第2戰先發上陣，於台灣時間周日凌晨2點20分在瑞格利球場（Wrigley Field）登板，對決小熊右投瑞伊（Colin Rea），力拚先發2連勝、本季第3勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34971432.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-22 09:37"}, {"article_id": "9518569", "title": "MLB／李灝宇連3場先發2打數無安打 老虎遭守護者橫掃吞6連敗", "summary": "底特律老虎隊本周與克里夫蘭守護者隊進行4連戰，李灝宇連續3場比賽先發上陣，今天系列賽最終戰擔任第8棒、二壘手，2打數沒有安打，中斷連2場安打，老虎隊最終以1：3落敗，系列賽遭橫掃、苦吞6連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34971436.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 08:49"}, {"article_id": "9518557", "title": "NBA／熱火加入搶人大戰 傳用赫洛等3球員加3首輪換字母哥", "summary": "公鹿在日前正式開放各隊對當家球星安戴托昆波（Giannis Antetokounmpo）進行報價後，引發聯盟各隊間的搶人大戰，繼日前傳出湖人、灰狼有意提出報價名單後，今天熱火也被報導，將以赫洛（Tyler Herro）、哈克斯（Jaime Jaquez Jr.）等人作為籌碼，爭取交易安戴托昆波。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34971485.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 08:38"}, {"article_id": "9518540", "title": "中職／嘉義市棒球場傳球迷翻牆逃票 市府：監視器鎖定查獲", "summary": "擁有百年歷史嘉義市KANO棒球場，歷經去年丹娜絲颱風重創重新修復啟用，有議員獲報球場傳出有球迷利用場館外圍防護漏洞「翻牆逃票」。球場管理單位體育場說，有名男球迷貪圖方便省票錢，從維修通道進入球場，經監視器鎖定後，通報中華職棒聯盟查獲要求補票。球場設有完整監視系統與周邊安全維護設施，會檢討強化，杜絕類似逃票事件再度發生。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34971256.jpg&M=1&s=Y&x=0&y=0&sw=927&sh=618&exp=3600&sl=W&fw=360", "date": "2026-05-22 08:27"}, {"article_id": "9518528", "title": "NBA／雷霆威廉斯G3列入逐日觀察名單 馬刺雙衛出賽成疑", "summary": "雷霆與馬刺在西區冠軍賽前兩場比賽展開高強度對抗，讓兩隊傷兵不斷，其中在昨天的第二戰中，包括雷霆威廉斯（Jalen Williams）、米契爾（Ajay Mitchell）和馬刺哈波（Dylan Harper）相繼傷退，其中威廉斯、哈波和西區決賽都還不曾登場過的福克斯（De'Aaron Fox），在明天的第三戰中也都被列入逐日觀察名單，能否出賽仍是未知數。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34971240.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 08:10"}, {"article_id": "9518507", "title": "NBA／詹姆斯7月後才會決定動向 談湖人輸在殘酷的「天賦差距」", "summary": "隨著湖人今年在西區準決賽遭強勢問鼎二連霸的雷霆淘汰，當家球星詹姆斯（LeBron James）在沉澱一周多後，對這次的失利首度發聲，他在與傳奇球星奈許（Steve Nash）錄製Podcast節目中坦言，兩隊在系列賽的最大分野無關於努力，而是殘酷的「天賦差距」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34971488.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-22 07:46"}, {"article_id": "9517366", "title": "中職／美式換成日式不對味？中信兄弟與日籍打教還在磨合中", "summary": "中信兄弟上半季戰績不佳，打擊率僅0.239，主要因新任日籍打擊教練與球員間磨合不佳。雖然依靠數據分析提升策略，但效果未如預期，亟需調整以增強球隊攻擊力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/2025/05/30/1/32153939.jpg&s=Y&x=0&y=0&sw=1068&sh=712&exp=3600&sl=W&fw=360", "date": "2026-05-22 07:00"}]}, {"name": "棒球", "articles": [{"article_id": "9519349", "title": "日職／徐若熙二軍飆9局無四死球完封勝 賞10K最快154公里", "date": "2026-05-22 14:01", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/22/34972565.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9519237", "title": "全障運／手語直播實踐運動無礙 「服務型賽會」選手開心分享", "date": "2026-05-22 13:23", "thu