"thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876674.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9419545", "title": "中職／開季戰力分析 中信兄弟全力奪還王位", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/02/34823005.jpg&M=1&x=&y=&sw=&sh=&exp=3600&w=300"}, {"article_id": "9455854", "title": "馬刺青年軍準備好了！ 溫班亞瑪展現超高球商帶來奪冠幻想", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34877221.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9453857", "title": "「死神」KD一倒火箭瞬間崩盤！首戰慘敗湖人揭露殘酷真相", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34874056.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9457487", "title": "NBA／溫班亞瑪進入腦震盪程序 G3出賽成疑馬刺強調有應對措施", "summary": "剛以全票獲得本季年度最佳防守球員的馬刺隊當家球星溫班亞瑪（Victor Wembanyama），生涯第2場季後賽只打12分鐘傷退，且可能因腦震盪缺席後續季後賽，加上球隊今天103：106遭拓荒者隊逆轉，堪稱「賠了夫人又折兵」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34879563.jpg&M=1&s=Y&x=0&y=0&sw=1152&sh=768&exp=3600&sl=W&fw=360", "date": "2026-04-22 14:24"}, {"article_id": "9457413", "title": "MLB／7連敗費城人迎王牌回歸 惠勒周日復出戰勇士", "summary": "費城人王牌投手惠勒將於台灣時間週日復出對戰勇士，結束7連敗困境。惠勒去年表現優異，但因傷缺席季末和開季。總教練湯姆森對他的狀態充滿信心，預計將給予90球的限制。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34879448.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-22 14:01"}, {"article_id": "9457401", "title": "MLB／日媒預測本季63轟 村上宗隆談連4場開轟：我不在意", "summary": "日本重砲「村神」村上宗隆連4場開轟，幫助白襪隊以11：5大勝響尾蛇隊。村上本場5打數3安打，包含1轟，選到1次保送，生涯前23場比賽狂敲9發全壘打，OPS值高達0.978。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34879381.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-22 13:54"}, {"article_id": "9457361", "title": "亞運／豐橋中繼站提供訓練、膳食、接送 支援跆拳道、空手道代表隊", "summary": "為因應本屆愛知─名古屋亞運比賽場地較分散的狀況，運動部、中華奧會和國訓中心攜手設置三個中繼站，其中「豐橋中繼站」主要提供空手道及跆拳道代表隊進行訓練、治療、用餐，也能替鄰近比賽的代表隊送餐。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34879305.jpg&M=1&s=Y&x=0&y=0&sw=1204&sh=803&exp=3600&sl=W&fw=360", "date": "2026-04-22 13:38"}, {"article_id": "9457335", "title": "NBA／KD先盛後衰加關鍵失誤 詹姆斯飆28分率湖人2連勝火箭", "summary": "西區季後賽首輪賽事，湖人隊今天繼續在主場迎戰火箭隊，後場雙星唐西奇（Luka Doncic）、里夫斯（Austin Reaves）持續缺陣，火箭則是迎回當家球星杜蘭特（Kevin Durant），但湖人在詹姆斯（LeBron James）猛轟28分下，以101：94擊敗火箭，將帶著系列賽2：0優勢轉戰休士頓。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34879284.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-22 13:28"}, {"article_id": "9457315", "title": "桌球／來看林昀儒！日聯賽海外站7月新竹登場", "summary": "日本桌球聯賽「Nojima T.LEAGUE」正式啟動聯賽史上具里程碑意義的海外計畫，首站「初陣：台灣」將於7月25日在新竹縣立體育館盛大登場，本次賽事集結男子與女子組職業對決，將呈現日本職業桌球最高強度的賽事內容，台灣一哥「小林同學」林昀儒也將回家比賽，與各國頂尖選手進行高強度對抗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34879251.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-22 13:19"}, {"article_id": "9457202", "title": "MLB／林多開轟無用 守護神威廉斯放火大都會繼續輸吞12連敗", "summary": "大都會今天以3：5不敵雙城，苦吞12連敗。林多在比賽中擊出三分砲，但守護神威廉斯在第9局失控，造成比賽逆轉。大都會目前戰績僅7勝16敗，排名國聯東區墊底。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34879058.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-22 12:50"}, {"article_id": "9457183", "title": "MLB／山本由伸7局雨中好投又「問天」 道奇全場僅3安輸巨人", "summary": "道奇隊日籍王牌山本由伸今天客場面對巨人隊，首局遇亂流丟3分，仍繳出7局失3分的優質先發，可惜道奇打線全場僅3安，終場以1：3輸球，山本問天苦吞本季第2敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34879032.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-22 12:24"}, {"article_id": "9457175", "title": "棒球／亞運主場地豐橋球場偏遠且老舊 中日龍上周才來「下鄉」", "summary": "2026年愛知─名古屋亞運棒球賽事，主球場安排在已有46年歷史的豐橋市民球場，場地設施較為老舊，且距離名古屋市區車程超過一個半小時，上周日職中日龍隊才來此處進行一年一度的下鄉賽事。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34879020.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-22 12:17"}, {"article_id": "9419545", "title": "中職／開季戰力分析 中信兄弟全力奪還王位", "summary": "中信兄弟連續兩年戰績居冠，今季全力奪回王位，補強外援與固定陣容延續奪冠傳統。投手陣容強大，本土先發需提升穩定性，而年輕野手則渴望爭取先發機會，教練團全方位策略協助選手成長。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/02/34823005.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-22 12:00"}, {"article_id": "9457034", "title": "MLB／今永昇太優質先發、鈴木誠也開轟 小熊日籍雙星助隊七連勝", "summary": "今永昇太投7局僅失1分，小熊隊以7：4擊敗費城人，收下七連勝。鈴木誠也在第7局開轟助攻，今永則獲得本季第二勝，帶領小熊戰績回升至14勝9敗，排名國聯中區第二。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34878784.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-22 11:56"}, {"article_id": "9457045", "title": "MLB／挑戰失敗後敲內野安打！大谷翔平連53場上壘打破亞洲紀錄", "summary": "道奇隊今天在主場迎戰巨人隊，大谷翔平第7局擊出內野安打，連續上壘場次推進至53場，打破亞洲球員紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34878795.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-22 11:46"}, {"article_id": "9456851", "title": "MLB／史丹頓開轟貢獻3打點 本季首次「基襪大戰」洋基開門紅", "summary": "洋基在「基襪系列戰」首戰中以4：0完封紅襪，史丹頓貢獻3打點，首次打席便擊出陽春砲，並在第六局敲出2分打點的二壘安打。先發投手希爾主投6.1局無失分，幫助洋基贏得本季首勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34878489.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-22 11:12"}, {"article_id": "9456854", "title": "NBA／斑馬腦震盪疑慮G2提前傷退 拓荒者14分大逆轉扳平系列賽", "summary": "馬刺隊以西區第2種子身分挺進季後賽，今天首輪第2戰上半場先傷當家球星溫班亞瑪（Victor Wembanyama），老將巴恩斯（Harrison Barnes）第四節再傷到手腕退場，儘管第四節一度領先14分，但讓拓荒者演出逆轉勝，以106：103踢館成功，扳平系列賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34878503.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-22 10:54"}, {"article_id": "9456710", "title": "NBA／批約柯奇是糟糕防守者 灰狼前鋒：金塊沒有能護框的人", "summary": "灰狼在系列賽中逆轉金塊，以119：114扳平比分，前鋒麥克丹尼爾斯批評金塊全隊防守差勁。他表示，面對約柯奇和穆雷等人，灰狼只需把握攻擊機會。金塊在關鍵時刻防守失誤，讓灰狼逆轉並創下隊史第二大分差紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34878247.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-22 10:47"}, {"article_id": "9456741", "title": "MLB／李灝宇保送老虎官方「發文+烙中文」網：這回覆太台了", "summary": "老虎隊今天在主場以4：12被釀酒人隊痛宰，不過社群媒體Threads相當活躍，老虎小編還用中文提醒台灣球迷：「記得按讚訂閱開啟小鈴鐺」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34878306.jpg&M=1&s=Y&x=0&y=94&sw=666&sh=444&exp=3600&sl=W&fw=360", "date": "2026-04-22 10:20"}, {"article_id": "9456737", "title": "全中運／輕艇南港雙星狂掃多金 嘉義選手寫歷史新頁", "summary": "115年全國中等學校運動會輕艇項目昨在新北市微風運河落幕，集結全台頂尖好手同場競技，多所學校選手連奪多面獎牌，近年全中運輕艇實力呈進化態勢，競技水準明顯提升。嘉義縣民雄國中以2銀1銅締造縣內歷屆最佳成績，各地強權同場爭鋒，賽況精彩紛陳。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34878286.jpg&M=1&s=Y&x=0&y=0&sw=1276&sh=850&exp=3600&sl=W&fw=360", "date": "2026-04-22 10:14"}, {"article_id": "9456691", "title": "NBA／新秀埃奇庫姆飆30分+馬克西29分 76人G2扳倒塞爾蒂克", "summary": "76人隊當家中鋒安比德（Joel Embiid）季後賽持續缺陣，不過20歲新秀埃奇庫姆（VJ Edgecombe）今天挺身而出，上半場就攻下全隊最高的20分，全場繳出30分、10籃板，寫下NBA賽史紀錄，加上馬克西（Tyrese Maxey）關鍵時刻穩住球隊領先，聯手助76人以111：97踢館成功，季後賽1比1扳平。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34878251.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-22 10:02"}, {"article_id": "9456683", "title": "橘子岸到頂超級馬拉松澳洲高爾拔頭籌 刷新賽事新紀錄", "summary": "由橘子關懷基金會主辦的「2026橘子岸到頂超級馬拉松」，17日晚間自台南台灣歷史博物館正式起跑，沿著「山海圳國家級綠道」歷經24小時長征，於18日晚間7時在玉山界碑終點圓滿落幕。在長達177公里、總升降6047公尺、日夜溫差逾20度的比賽中，選手挑戰自我極限，最終177公里菁英組由澳洲選手高爾（Phil Gore）以18時21分成績奪冠拔得頭籌，刷新橘子岸到頂紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34878210.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-0