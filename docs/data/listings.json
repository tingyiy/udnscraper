524"}, {"article_id": "9561773", "title": "布蘭特油價跌破90美元 下探4月來低點 川普說美伊最快周末簽協議", "summary": "國際油價跌至兩個月低點，因美國總統川普宣布取消原定對伊朗發動的新一波軍事打擊，並表示與伊朗的和平協議最快可能於本周末簽署，這番言論讓市場對結束戰爭的進展產生新的期待。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35036302.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 08:20", "link": "/news/story/6811/9561773"}, {"article_id": "9561771", "title": "韓股開盤後狂漲逾7% 日股也勁揚3% 跟進美國晶片股大漲", "summary": "南韓股市今天開盤後飆漲超過7%，因美國總統川普表示，美國與伊朗接近達成終結戰爭的協議，提振市場風險胃納。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35036296.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 08:16", "link": "/news/story/6811/9561771"}, {"article_id": "9561761", "title": "剛喊美伊協議快談成 川普再豪言：今天結束與伊朗戰爭", "summary": "美國總統川普11日表示，美國與伊朗已就停止衝突達成一份「非常有力的諒解備忘錄」，並宣稱美國當天已經「結束與伊朗的戰爭」。不過，伊朗方面尚未證實任何協議已經達成。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35036284.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 08:03", "link": "/news/story/124061/9561761"}, {"article_id": "9561757", "title": "Sony打破一條龍自製神話 「放手」找台積生產CMOS內幕", "summary": "索尼半導體解決方案（Sony Semiconductor Solutions）將與台積電合作開發與生產次世代CMOS影像感測器。這與台積電主導JASM、替索尼生產邏輯晶片的商業模式不同。外媒指出Sony正在「減重」以面對三星電子的逼宮，掌舵者十時裕樹正在做的是打破長年「研發到製造一條龍」的自製神話。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/09/35026993.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 08:01", "link": "/news/story/6809/9561757"}, {"article_id": "9561748", "title": "SpaceX締造史上最大IPO紀錄！4,400名員工跟著馬斯克暴富", "summary": "馬斯克（Elon Musk）旗下的火箭與衛星集團SpaceX本周完成史上最大規模的IPO。根據周四提交的監管文件，SpaceX以每股135美元發行5.556億股，募資約750億美元，遠遠超越沙烏地阿美石油公司2019年創下的IPO紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35036274.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 07:56", "link": "/news/story/6811/9561748"}, {"article_id": "9561741", "title": "美伊協議快談成？川普曝「幾天內完成」 稱伊朗最高領袖已點頭", "summary": "美國總統川普11日在白宮表示，美國與伊朗的協議已接近完成，目前只待文件最終定案，預計未來幾天內即可簽署，最快可能於本周末在歐洲舉行簽署儀式。一旦協議生效，荷莫茲海峽將重新開放。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35036263.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 07:47", "link": "/news/story/124061/9561741"}, {"article_id": "9561725", "title": "台積電ADR勁揚逾3%！聯電大漲超過9% 日月光也很猛", "summary": "台股ADR周四（11日）大漲，跟隨費城半導體指數勁揚8%的熱烈走勢。台積電ADR收盤上漲逾3%，報每股421.07美元，收盤最新價格換算並折合新台幣後為每股2,663.18元，較台北交易股票溢價率18.36%。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_0.jpg", "date": "2026-06-12 07:20", "link": "/news/story/6811/9561725"}, {"article_id": "9561722", "title": "川普提名前美國證管會主席克雷頓出任國家情報總監", "summary": "美國總統川普今天指出，他將提名前證券管理委員會（SEC）主席、現任紐約南區首席檢察官克雷頓（Jay Clayton）為國...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35036245.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 07:15", "link": "/news/story/6813/9561722"}, {"article_id": "9561723", "title": "美股收盤／費半狂漲8%！三大指數創兩個月最大漲幅 歡慶川普急喊停空襲", "summary": "美國股市周四（11日）大幅收高，美國總統川普在威脅升級伊朗戰爭後、又宣布取消原定計劃對伊朗發動的空襲，消息帶動各大股指延續漲勢，標普500指數創逾兩個月最大漲幅，費城半導體指數更大漲近8%。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35036243.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 07:09", "link": "/news/story/6811/9561723"}, {"article_id": "9559720", "title": "AI已經有意識了？為何Google、Meta大舉招聘「哲學家」做研究", "summary": "世界頂尖的AI巨頭Anthropic、Google DeepMind與Meta，近期開始擴招「哲學家」，投入龐大資源研究一個科幻小說式的命題：AI有沒有意識？AI模型已經強大到這個地步了嗎？哲學教育又如何因為AI起飛？", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35033298.jpg&M=1&s=Y&x=46&y=106&sw=1111&sh=741&exp=3600&sl=W&fw=360", "date": "2026-06-12 07:08", "link": "/news/story/6811/9559720"}, {"article_id": "9561714", "title": "川普喊美伊快簽協議了 這周末有可能…但德黑蘭未證實", "summary": "美國總統川普周四在白宮橢圓形辦公室宣稱，美國「剛與伊朗就戰爭達成重大和解安排」，目前只待文件最終定案，預計未來幾天內即可簽署。他在回應記者提問時進一步表示，有可能是這個周末。一旦協議生效，荷莫茲海峽將重新開放。不過，類似說法自戰事爆發以來，他已經講過很多次。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35036239.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 06:51", "link": "/news/story/124061/9561714"}, {"article_id": "9561557", "title": "「仁不膩」 黃仁勳韓綜首秀 四大亮點話題性十足", "summary": "全球AI晶片龍頭輝達（Nvidia）執行長黃仁勳已經離開南韓，但他在當地引發的狂潮，至今仍餘波盪漾。期間他登上南韓「國民 MC」劉在錫主持的熱門綜藝節目《You Quiz on the Block》，待他離開後才播出。他在這場個人的綜藝處女秀中展現極度親民、幽默且充滿智慧的一面，「韓版兆元宴」、創業歷程及AI前景等十足性話題更使該集收視率創新高。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35036033.jpg&M=1&s=Y&x=0&y=0&sw=1064&sh=709&exp=3600&sl=W&fw=360", "date": "2026-06-12 06:15", "link": "/news/story/6811/9561557"}, {"article_id": "9561667", "title": "第一張骨牌倒下…油價飆重創廉航 航空市場恐大洗牌", "summary": "全球航空公司正努力應對因美國和以色列與伊朗的戰爭而導致的燃油成本上漲，廉價航空公司受到的衝擊尤其嚴重，因為它們缺乏如高價艙等、高消費旅客和信用卡常客方案之類的高利潤收入來源。美國廉航公司精神航空（Spirit Airlines）今年5月倒閉，成為第一個倒下的骨牌。\n\n本文為讀者進一步解析國際航空運輸協會（IATA）的最新報告，告訴你為何今年和明年，可能有更多航空公司破產、整併……", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35033182.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 06:01", "link": "/news/story/6811/9561667"}, {"article_id": "9561627", "title": "伊媒：伊朗尚未批准美伊初步MOU文本 但批准可能性很高", "summary": "伊朗半官方的法斯（Fars）通訊社11日引述1位接近伊方談判團隊的消息人士報導，德黑蘭尚未批准美伊初步諒解備忘錄（MOU）的文本。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35036145.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 03:38", "link": "/news/story/124061/9561627"}, {"article_id": "9561455", "title": "搶買 SpaceX 散戶賣股籌錢", "summary": "馬斯克一手創辦的太空公司SpaceX，11日將辦理IPO，知情人士透露，此案吸引散戶投資人瘋狂追逐，至今已吸引超過700億美元散戶認購，許多投資人甚至拋售手中原本其他科技股持股，希望買到SpaceX的新股。彭博資訊預估，散戶將至少獲得20%的股份。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35035940.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 02:49", "link": "/news/story/6811/9561455"}, {"article_id": "9561449", "title": "俄烏開戰1,569天 超越一戰", "summary": "紐約時報報導，俄烏戰爭自2022年2月爆發至6月11日已持續1,569天，超過四年三個月，正式超越第一次世界大戰的時間。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_3.jpg", "date": "2026-06-12 02:49", "link": "/news/story/6809/9561449"}, {"article_id": "9561446", "title": "韓水泥車工會罷工 衝擊IC業", "summary": "南韓預拌混凝土運輸工人工會（KNRCTWU）正在進行罷工，已導致SK海力士京畿道龍仁市的半導體聚落工地所有澆置作業停止，三星電子平澤園區工地的澆置作業也傳出取消，這讓各界愈來愈擔心，這次罷工可能對南韓半導體業造成大規模傷害。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_0.jpg", "date": "2026-06-12 02:48", "link": "/news/story/6811/9561446"}, {"article_id": "9561602", "title": "5小時前揚言「強力打擊伊朗」 川普：已取消原定對伊朗的空襲與轟炸", "summary": "美國總統川普11日在自創社媒真實社群發文，揚言「今夜將非常、非常強力地打擊伊朗」。但約5小時後，他又發文指稱，「已取消原定對伊朗的空襲及轟炸」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35036118.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 02:19", "link": "/news/story/124061/9561602"}, {"article_id": "9561393", "title": "亞銀：亞洲面臨停滯性通膨 示警中東衝突推升物價", "summary": "亞銀（ADB）總裁神田真人警告，中東衝突推升通膨，亞洲經濟體正面臨停滯性通膨風險。此外，世界銀行將今年全球經濟成長預期下調至2.5%，理由也是中東戰爭帶來衝擊，並表示如果能源供應中斷更加嚴重，並給金融市場帶來巨大壓力，經濟增速可能腰斬，只剩1.3%。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/03/06/34738585.jpg&M=1&s=Y&x=0&y=0&sw=956&sh=637&exp=3600&sl=W&fw=360", "date": "2026-06-12 01:14", "link": "/news/story/6811/9561393"}, {"article_id": "9561400", "title": "美 PPI 增6.5% 三年半最高 伊朗戰事推升通膨", "summary": "美國勞工統計局11日公布，5月生產者物價指數（PPI）年增6.5%，升幅達2022年11月以來最大，也高於市場預期的6.4%，月升幅1.1%，同樣超出市場預期的0.7%，主因是伊朗戰爭的影響，持續加劇通膨壓力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34944630.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 01:12", "link": "/news/story/6811/9561400"}, {"article_id": "9561429", "title": "ECB升息1碼 近三年首見", "summary": "歐洲央行（ECB）11日決議升息1碼，基準的存款利率從2%調高至2.25%，為2023年9月來首度調升利率，以因應伊朗戰爭帶來的通膨壓力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_9.jpg", "date": "2026-06-12 01:12", "link": "/news/story/6811/9561429"}, {"article_id": "9561397", "title": "亞幣貶壓 各國不忍了 南韓、印度、菲國等央行出手", "summary": "因高油價、外資撤離和美元走高，亞洲貨幣最近面臨一波波貶值壓力，從南韓、印度到菲律賓的多國央行，也因此紛紛出手打擊境外匯市投機交易，試圖穩定本國匯率。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34841220.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-12 01:10", "link": "/news/story/6811/9561397"}, {"article_id": "9561454", "title": "僅僅91天就步入熊市 金價打4,000美元保衛戰", "summary": "通膨升溫將帶動利率上升的預期，使國際金價10日收在今年最低，且已陷入熊市，是四年來首見，如今正面臨4,000美元保衛戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_6.jpg", "date": "2026-06-12 00:47", "link": "/news/story/6811/9561454"}]}, {"name": "中東戰火連綿", "articles": [{"article_id": "9561761", "title": "剛喊美伊協議快談成 川普再豪言：今天結束與伊朗戰爭", "date": "2026-06-12 08:03", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35036284.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/124061/9561761"}, {"article_id": "9561741", "title": "美伊協議快談成？川普曝「幾天內完成」 稱伊朗最高領袖已點頭", "date": "2026-06-12 07:47", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35036263.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/124061/9561741"}, {"article_id": "9559561", "title": "整理包／伊朗經濟為何還沒崩潰？六大重點一次看", "date": "2026-06-11 10:18", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35033060.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/124061/9559561"}, {"article_id": "9559287