"https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34943893.jpg&M=1&x=&y=&sw=&sh=&exp=3600&w=300"}, {"article_id": "9500521", "title": "海盜「不一樣了」！史肯斯領軍三王牌投出國聯最佳輪值成績", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34943951.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9508591", "title": "TPBL／國王對決「宇宙夢」 洪志善先讚：簡浩很成功", "summary": "季中臨危受命接下新北國王總教練兵符，「小胖」洪志善率衛冕軍從例行賽第5到挺進總冠軍賽，衛冕只差最後一階段，有機會寫下單季奪下兩座冠軍的特別紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34956088.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 21:33"}, {"article_id": "9508589", "title": "中職／「連打擊練習都沒打那麼遠」 郭阜林本季首轟狙擊陳仕朋", "summary": "台鋼雄鷹隊今天以6：5擊敗富邦悍將隊，郭阜林的三分砲狙擊陳仕朋，本季首轟降落在新莊棒球場，總教練洪一中賽後說：「很久沒看他打那麼遠」，郭阜林也承認：「我自己也覺得，連打擊練習都沒辦法打那麼遠。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34956086.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 21:32"}, {"article_id": "9508586", "title": "TPBL／總冠軍賽24日開打 夢想家、國王上演本土教頭對決", "summary": "新北國王今天以116：114擊敗龍頭桃園台啤永豐雲豹，花4戰晉級總冠軍賽，將和昨天先一步晉級的福爾摩沙夢想家會師，7戰4勝制的系列賽將於24日點燃戰火。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34956084.png&M=1&s=Y&x=0&y=0&sw=1024&sh=683&exp=3600&sl=W&fw=360", "date": "2026-05-17 21:27"}, {"article_id": "9508585", "title": "中職／陳正毅初先發只撐2.1局5BB 洪總：把自己投倒了", "summary": "台鋼雄鷹隊本周在急需先發投手情況下，啟用陳正毅初先發，只撐2.1局，出現5次保送，總教練洪一中直言，一軍與二軍強度還是有差，還無法穩定去面對更強比賽，無法撐長局數並非因為挨打，「這個就是自己投倒了。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34956083.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 21:27"}, {"article_id": "9508575", "title": "和泰車跨海應援紐柏林24小時耐久賽 近千車迷擠爆GR Garage林口", "summary": "和泰集團深懂賽車迷的熱血與期待！一年一度的紐柏林24小時耐久賽於5月16日至17日登場，這項賽事向來被視為全球汽車品牌實戰鍛鍊的最高殿堂之一。和泰車特別於GR Garage林口店盛大舉辦「紐柏林24小時耐久賽應援活動」，跨海連線德國賽場，吸引近千名車迷齊聚熱血應援，現場吶喊聲不斷，氣氛沸騰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34956066.jpg&M=1&s=Y&x=0&y=0&sw=1125&sh=750&exp=3600&sl=W&fw=360", "date": "2026-05-17 21:15"}, {"article_id": "9508532", "title": "拳擊／連任拳協理事長 許明杰：培育新秀、發展職業聯賽", "summary": "中華民國拳擊協會今天舉行第14屆第1次會員大會，會中選出許明杰連任理事長。許明杰表示，未來除了積極培育新秀好手接班之外，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34956079.jpg&M=1&s=Y&x=0&y=107&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 21:12"}, {"article_id": "9508565", "title": "TPBL／龍頭雲豹被淘汰 顏行書計畫更換外援", "summary": "例行賽打下龍頭，桃園台啤永豐雲豹季後賽卻被排名第5的新北國王「下剋上」，今天第4戰以114：116輸球後賽季告終，總經理顏行書認為「沒太大遺憾」，但也承認洋將的配置應該會有「滿大的調配」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34956027.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 21:03"}, {"article_id": "9508542", "title": "中職／悍將沒啃成雞骨頭無緣3連戰清盤 攻頂計畫等下周", "summary": "富邦悍將隊挑戰本季首次3連戰橫掃功虧一簣，今天以5：6不敵台鋼雄鷹隊，5連勝畫下句點，加上同日味全龍隊完成3連戰橫掃樂天桃猿隊，悍將本周攻頂計畫失敗，落後勝差擴大為2場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34956069.jpg&M=1&s=Y&x=0&y=67&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 20:52"}, {"article_id": "9508539", "title": "田徑／東京黃金大獎賽雪恥！傅兆玄跳高奪銀", "summary": "2026世界田徑巡迴賽東京黃金大獎賽今天登場，我國跳高好手傅兆玄在男子跳高決賽跳出2公尺24，雖挑戰個人最佳的2公尺27沒能成功，仍收下銀牌，登上頒獎台。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34956009.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-17 20:51"}, {"article_id": "9508504", "title": "中職／林子豪敲安終止獅隊得點圈乾旱 朱迦恩代打當英雄", "summary": "統一獅隊得點圈18打數無安打的低潮在今天突破，林子豪6局下敲回全隊第1分，加上朱迦恩代打追平安，單局4分攻勢逆轉，以4比...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34956000.jpg&M=1&s=Y&x=0&y=27&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-17 20:49"}, {"article_id": "9508533", "title": "TPBL／克羅馬最後一擊失手 高錦瑋坦言：有想過自己來", "summary": "打下TPBL例行賽龍頭的桃園台啤永豐雲豹，連兩場都是一球差敗給新北國王，且都是有最後一擊機會但年度外援克羅馬失手。今天114：116結束賽季後，攻下TPBL個人新高32分的雲豹當家後衛高錦瑋坦言，有想過自己還承擔最後一擊，但仍按照教練給克羅馬的設定。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955996.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 20:45"}, {"article_id": "9508479", "title": "中職／張政禹隊史首位盜本壘成功 葉總：我也被盜過本壘啊", "summary": "味全龍隊今天以2：0擊敗樂天桃猿隊，7局下靠著張政禹大膽盜本壘搶下保險分，跑出味全龍隊史第1次、中職史上第6次「純」盜本壘成功，而在過去中職5次盜本壘的紀錄中，現任龍隊總教練葉君璋倒是兩度成為「苦主」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955912.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 20:07"}, {"article_id": "9508448", "title": "TPBL／烏龍爆料!攻城獅發聲感謝高虹安長期支持 揭她配合球團安排入場", "summary": "新竹市長高虹安14日與副市長林琨翰到竹北市觀看新竹攻城獅籃球賽事，卻被特定臉書粉專攻擊她「遲到」、擋住啦啦隊表演。對此「新竹御嵿攻城獅」聲明澄清，高虹安是在球團安排時間到場入座，卻因工作人員引導疏失擋到球迷觀賞表演，球團為此表達歉意。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955867.jpg&M=1&s=Y&x=0&y=0&sw=1188&sh=792&exp=3600&sl=W&fw=360", "date": "2026-05-17 19:52"}, {"article_id": "9508434", "title": "中職／陳仕朋28歲達陣800局史上第3年輕 土投只輸神獸潘威倫", "summary": "富邦悍將隊左投陳仕朋本季第二場先發，內容依然動盪，今天面對台鋼雄鷹隊投2.2局被敲6安打、失5分，此役跨過生涯800局里程碑，以28歲239天之齡達陣，排名史上第三年輕、本土第二年輕。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955860.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 19:48"}, {"article_id": "9508418", "title": "TPBL／國王上演老五傳奇！4戰淘汰龍頭雲豹挺進冠軍賽", "summary": "TPBL衛冕軍新北國王克服例行賽起伏狀態，今天四強賽第4戰全隊轟進17記三分彈，加上守住對手追平一擊，以116：114驚險擊敗桃園台啤永豐雲豹，上演下剋上的「老五傳奇」戲碼，花4場比賽淘汰龍頭雲豹，將和福爾摩沙夢想家會師總冠軍賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955844.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 19:38"}, {"article_id": "9508398", "title": "舉重／印度亞錦賽 董秉誠男子110公斤挺舉、總和獲雙銅", "summary": "在印度舉行的亞洲舉重錦標賽今天進入最後1天賽事，台灣好手董秉誠在男子110公斤A級，以抓舉166公斤、挺舉215公斤、總...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/2023/05/01/0/21661847.jpg&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-05-17 19:23"}, {"article_id": "9508404", "title": "中職／從小就想盜本壘！ 張政禹成史上第6人「沒人在理我就跑了」", "summary": "味全龍隊今天在天母棒球場面對樂天桃猿隊，7局下龍隊張政禹攻上三壘後，抓準猿隊左投林子崴沒在看管跑者，一步步離壘後，一舉發動盜本壘成功，成為龍隊隊史第1人、聯盟史上第6人，也解鎖他「從小就想盜本壘」的心願。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955829.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 19:17"}, {"article_id": "9508358", "title": "NBA／灰狼撿到寶恐留不住？43分奇兵首度成自由球員：我很興奮", "summary": "灰狼6戰不敵馬刺正式結束今年賽季，季中加盟後打出亮眼表現的後衛多森姆（Ayo Dosunmu），也談到了自己在灰狼短短數個月的感受與未來規劃。即將首度以「完全自由球員」身分投入市場的他，坦言對未來充滿興奮和期待，但也不忘感謝灰狼球團與球迷對他的接納。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955770.jpg&M=1&s=Y&x=96&y=7&sw=1122&sh=748&exp=3600&sl=W&fw=360", "date": "2026-05-17 18:28"}, {"article_id": "9508357", "title": "中職／聯盟近22年來首次盜本壘成功！味全2：0賞桃猿4連敗", "summary": "味全龍隊今天在主場迎戰樂天桃猿隊，梅賽斯先發8局無失分，打線全場僅敲4支安打比猿隊少1支，但在2局下靠對手失誤搶得先機，8局下則是由張政禹發動中職22年來首次「純」盜本壘成功，跑回第2分，終場以2：0勝出，系列賽橫掃對手，賞給桃猿4連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955754.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 18:22"}, {"article_id": "9508332", "title": "NBA／快艇樂透躺賺第5順位 格林拋震撼建議：該考慮交易雷納德？", "summary": "在先前選秀樂透結果出爐後，除了幸運抽中狀元籤的巫師之外，洛杉磯快艇也被外界視為最大贏家之一。快艇以極低機率意外獲得今年選秀第5順位籤，這張極具價值的選秀權更被認為將大幅影響球隊未來方向。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955732.jpg&M=1&s=Y&x=12&y=49&sw=1206&sh=804&exp=3600&sl=W&fw=360", "date": "2026-05-17 17:59"}, {"article_id": "9508321", "title": "NBA／禁區太弱！記者曝湖人將爭取「波神」加盟 與唐西奇再續前緣", "summary": "根據美媒最新消息指出，湖人隊可能會考慮在休賽期以低成本、高回報的方式，冒險簽下過去傷病史豐富的勇士中鋒「波神」波爾辛吉斯（Kristaps Porzingis）。鑒於他的護框、外線能力，加上過去在獨行俠時期與唐西奇（Luka Doncic）的淵源，可能對於禁區戰力薄弱的紫金軍來說是個值得一試的投資。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955715.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 17:55"}, {"article_id": "9508298", "title": "NBA／哈登生涯搶七大戰「慣性軟手」 前8次出征數據大幅下滑", "summary": "哈登最為人詬病的莫過於在搶七大戰的「軟手症」。總計前面8次搶七大戰中，哈登場均得到19.1分7.3助攻5.8籃板2.6抄截1.1阻攻，三項命中率分別是35.3%、22.2%、83.3%，幾乎都比例行賽下滑許多。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955679.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 17:26"}, {"article_id": "9508292", "title": "MLB／談大谷翔平差點達成「場內轟」 羅伯茲仍力挺：全力奔跑超讚", "summary": "道奇今在「洛城內戰」中以15：2痛宰天使，隊中日本巨星大谷翔平今天手感火燙，單場4打數貢獻2安5打點，包含一支巧妙的「另類場內全壘打」，後改判為三壘安。賽後，總教練羅伯茲（Dave Roberts）也稱讚起大谷在打擊端的好表現，並對他這記巧妙安打作出回應。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955667.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 17:20"}, {"article_id": "9508267", "title": "中職／跟年輕球員做重量提升擊球初速 拿莫・伊漾憂心花蓮災況", "summary": "味全龍隊拿莫・伊漾本季首度被升上一軍，今天回到主場天母棒球場，他坦言很感動也很期待，「很久沒有來這裡，終於上來了。」今天首戰就被排上先發第2棒、一壘手，他也盼能用更好的身體狀態上場表現、把握住機會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955601.jpg&M=1&s=Y&x=0&y=0&sw=1246&sh=831&exp=3600&sl=W&fw=360", "date": "2026-05-17 16:50"}]}, {"name": "棒球", "articles": [{"article_id": "9508542", "title": "中職／悍將沒啃成雞骨頭無緣3連戰清盤 攻頂計畫等下周", "date": "2026-05-17 20:52", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34956069.jpg&M=1&s=Y&x=0&y=67&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9508357", "title": "中職／聯盟近22年來首次盜本壘成功！味全2：0賞桃猿4連敗", "date": "2026-05-17 18:22", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955754.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9508434", "title": "中職／陳仕朋28歲達陣800局史上第3年輕 土投只輸神獸潘威倫", "date": "2026-05-17 19:48", "thumbnail": "https://pgw.udn.com.t