thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/02/34822700.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300"}, {"article_id": "9419927", "title": "The Decision最終回！41歲詹姆斯今夏「神之操作」即將炸裂", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/02/34823508.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300"}, {"article_id": "9417098", "title": "三王牌即將合體、打線幾無斷層 洋基仍是美聯頭號強權", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/01/34819294.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9424822", "title": "MLB／道奇羅哈斯迎接世界大賽第8戰？已做好被噓爆的心理準備", "summary": "道奇隊去年在世界大賽打滿7場扳倒藍鳥隊，成為本世紀首支完成2連霸的球隊，藍鳥明天在多倫多展開復仇3連戰，道奇內野手羅哈斯（Miguel Rojas）已經做好心理準備，等候敵隊球迷對他大開汽水。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_8.jpg", "date": "2026-04-06 16:29"}, {"article_id": "9424811", "title": "MLB／鈴木誠也2A復健狀態良好 主帥稱將於對海盜首戰復出", "summary": "效力小熊隊的日籍重砲鈴木誠也，先前在2026年世界棒球經典賽（WBC）期間遭遇右膝十字韌帶扭傷傷勢，他也被列入傷兵名單，至今仍在小聯盟復建。根據近期小熊總教練康索（Craig Counsell）的說法，鈴木誠也預計將在11日小熊對海盜系列賽首戰迎來復出，屆時也將是他本賽季大聯盟的首次亮相。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830481.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 16:27"}, {"article_id": "9424758", "title": "射箭／新星許芯慈拚世界盃 被點名值得關注選手", "summary": "在墨西哥舉行的射箭世界盃普艾布拉站將於明天登場，年僅18歲的台灣女將許芯慈，特別被官網列為值得關注的5名選手之一，教練吳...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830469.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-06 16:00"}, {"article_id": "9424782", "title": "拳擊／小鋼砲郭怡萱亞錦賽奪銅 教練肯定愛徒更穩", "summary": "在蒙古烏蘭巴托舉行的拳擊亞錦賽，台灣「小鋼砲」郭怡萱今天在女子51公斤級4強，雖以0比5不敵北韓安琴別，賽後教練柯文明仍...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/2025/11/19/98/33710370.jpg&s=Y&x=0&y=64&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 15:54"}, {"article_id": "9424733", "title": "MLB／終於沒被歐戴爾接殺！水手小將敲3分砲讓小編嗨喊「Not Again」", "summary": "在昨日天使1：0險勝水手的比賽中，天使右外野手歐戴爾（Jo Adell）扮演致勝功臣，連續沒收水手3發即將過牆的全壘打，成為賽後焦點。在今天比賽，水手22歲小將楊恩（Cole Young）在5局上夯出一發右外野方向的3分砲，這球夠深遠讓歐戴爾完全沒有守備機會，水手小編也隨即在官方Threads上發布這則開轟精華，並在文中寫下連續三次「Not Again」，笑翻貼文底下網友。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830391.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 15:52"}, {"article_id": "9424773", "title": "NBA／高吊傳球引起失誤 詹姆斯比賽中罕見幫兒子布朗尼「上課」", "summary": "在今日湖人、獨行俠的比賽中，湖人21歲後衛布朗尼（Bronny James）在第三節因一次給老爸「詹皇」詹姆斯（LeBron James）的高吊傳球發生失誤，讓詹姆斯先是「皺眉」看向布朗尼表達不解，並在比賽中罕見地給予兒子建議。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830441.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 15:46"}, {"article_id": "9424766", "title": "NBA／19歲狀元佛雷格連兩戰狂轟96分 上古神獸張伯倫後首見", "summary": "年僅19歲的獨行俠狀元郎佛雷格（Cooper Flagg）正以強勢得分表現席捲聯盟，繼上週對陣魔術狂炸51分後，今天面對湖人的比賽又再次發威，創下歷史級飆分紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830434.jpg&M=1&s=Y&x=185&y=16&sw=954&sh=636&exp=3600&sl=W&fw=360", "date": "2026-04-06 15:25"}, {"article_id": "9424744", "title": "MLB／藍鳥復仇系列賽薛則打頭陣 大谷9日二刀流拚第2勝", "summary": "道奇隊今天在落後5分的情況下，比賽後半段逆轉戰局，以8：6擊敗國民隊，帶著3連勝離開華府、轉戰多倫多，明起對藍鳥隊展開3連戰，雙方已經排定系列賽先發投手，大谷翔平將在9日最後一戰登板，再展二刀流威力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830412.jpg&M=1&s=Y&x=252&y=42&sw=843&sh=562&exp=3600&sl=W&fw=360", "date": "2026-04-06 14:58"}, {"article_id": "9424680", "title": "MLB／終於回來了！頂替傷兵貝茲 金慧成本季首戰代守登場", "summary": "道奇主戰游擊手貝茲（Mookie Betts）在先前比賽遭遇右側腹斜肌拉傷，後進入傷兵名單。因此，道奇稍早宣布將南韓好手金慧成從3A拉上大聯盟，他也在今天道奇8：6擊敗國民的系列賽第三戰中，迎來本賽季在大聯盟的首戰，在比賽後段接替弗里蘭（Alex Freeland）上場，鎮守二壘。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830288.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 14:56"}, {"article_id": "9424734", "title": "NBA／「復健兄弟」首度聯手 柯瑞喊特別：美夢成真", "summary": "因「跑者膝」連續缺陣27場的勇士隊當家球星柯瑞（Stephen Curry），今天總算回歸，且和弟弟小柯瑞（Seth Curry）寫下兄弟同時上陣的隊史紀錄，讓38歲的柯瑞直呼感覺特別，「說實話，那是美夢成真。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830404.jpg&M=1&s=Y&x=138&y=55&sw=855&sh=570&exp=3600&sl=W&fw=360", "date": "2026-04-06 14:50"}, {"article_id": "9424402", "title": "桌球世界盃／王楚欽首奪冠 孫穎莎3連霸史上第一", "summary": "2026國際乒聯單打世界盃5日在澳門迎來收官，中國隊在男女單打決賽中雙雙奪冠，女子單打方面，孫穎莎對陣隊友王曼昱，最終以4：1勝出，連續第三年奪得世界盃女子單打冠軍，成為自1973年賽事創辦以來首位達成此項紀錄的女子選手；男子單打方面，王楚欽以4：3逆轉擊敗日本選手松島輝空，首度加冕世界盃男子單打冠軍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34829902.jpg&M=1&s=Y&x=0&y=247&sw=1012&sh=675&exp=3600&sl=W&fw=360", "date": "2026-04-06 14:29"}, {"article_id": "9424702", "title": "拳擊／亞錦賽林郁婷奪銅牌 教練：學到很好經驗", "summary": "在蒙古烏蘭巴托舉行的亞洲拳擊錦標賽，「台灣女兒」林郁婷今天在60公斤級4強戰和北韓對手元恩景鏖戰到最終回合，才以1比4落...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830325.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-06 14:22"}, {"article_id": "9424690", "title": "日職／球評分析林安可擊球速度一流 每場1安還未發揮潛力", "summary": "日本職棒新球季開打11天，西武獅隊台灣好手林安可出賽8場，打擊率2成50、還未開轟，日職專欄作家中島大輔指出，西武目前戰績不佳，這位台灣強棒每場只能揮出1支安打，他的擊球速度一流，教練團寄予厚望。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830314.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 14:07"}, {"article_id": "9424642", "title": "中職／曾智偵、劉芙豪背號引退儀式 紀念幣和紀念報刊搶先收藏", "summary": "統一獅隊將於11、12日在亞太成棒主球場分別舉辦劉芙豪、曾智偵背號引退儀式，向兩位深刻影響隊史的經典人物致上最高敬意；獅隊指出，這不只是數字的封存，更是一段跨世代的精神傳承，連續兩天特別規劃「統一獅號碼引退紀念幣」、「號碼印退榮耀故事紀念報刊」，內野01~21區球迷進場都可各獲一份。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830228.jpg&M=1&s=Y&x=0&y=153&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 13:28"}, {"article_id": "9424616", "title": "NBA／唐西奇左腿二級拉傷歸期未定 經紀人透露先回歐洲治療", "summary": "湖人球星唐西奇（Luka Doncic）在先前球隊慘敗給雷霆的比賽中遭遇「左腿筋二級拉傷」嚴重傷勢，唐西奇的經紀人達菲（Bill Duffy）在今天告訴ESPN，在與湖人隊醫和他自己的醫療團隊協商後，唐西奇決定將前往歐洲尋求專門醫療治療，以期加快他重返賽場的時程。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830204.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 13:25"}, {"article_id": "9424620", "title": "NBA／柯瑞復出轟29分但絕殺失手 勇士1分不敵火箭吞4連敗", "summary": "連續缺陣27場的勇士隊當家球星柯瑞（Stephen Curry）今天總算回歸，復出首戰他就轟進5記三分球在內的全隊最高29分，但「絕殺」外線失手，讓火箭隊驚險以117：116帶走勝利。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830208.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 13:15"}, {"article_id": "9424613", "title": "中職／邦力多消失1天單純因感冒 悍將球團：今天已歸隊", "summary": "富邦悍將隊昨天以1：5不敵樂天桃猿隊，洋砲邦力多全場未上，加上傳出休息區也不見人影，引起球迷熱議。富邦悍將球團釋疑，單純是因感冒休養一天，今天已經歸隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830198.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 13:12"}, {"article_id": "9424587", "title": "拳擊／不敵北韓亞運銀牌 林郁婷奧運後首戰亞錦賽奪銅", "summary": "在蒙古烏蘭巴托登場的拳擊亞錦賽，各級4強賽今天第8日賽程登場，我國女將郭怡萱和巴黎奧運「金牌拳后」林郁婷接連登場，但兩人都不敵北韓對手，無緣挺進最終決賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830170.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-06 12:54"}, {"article_id": "9424566", "title": "MLB／菅野智之聽過庫爾斯恐怖故事 盯著這頭猛獸不眨眼奪勝", "summary": "洛磯隊36歲老將菅野智之，今天對費城人隊先發6局失1分，優質表現奪下本季首勝，也是大聯盟生涯第11勝，洛磯終場4：1獲勝，逃過主場3連戰遭橫掃，終止跨季對戰9連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830112.jpg&M=1&s=Y&x=99&y=88&sw=1062&sh=708&exp=3600&sl=W&fw=360", "date": "2026-04-06 12:40"}, {"article_id": "9424559", "title": "3.39億升級改造八卦山棒球場 力拚職棒賽事落腳彰化", "summary": "彰化縣棒球風氣興盛，但有42年歷史的彰化縣立棒球場，卻因設施及面積不足，無法舉辦正式比賽。縣府為展現推展棒球決心，將斥資3.39億元辦理「八卦山棒球場升級改造工程」，包括擴建符合國際規格的標準棒球場及賽務空間興建工程，目前正在規畫設計，預定年底前發包。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830096.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 12:36"}, {"article_id": "9424482", "title": "NBA／不滿球隊老闆「冷血」說辭 字母哥：像被人打了一巴掌", "summary": "公鹿當家球星「字母哥」安戴托昆波（Giannis Antetokounmpo）近期再度深陷交易傳聞中，他在近期接受《密爾瓦基哨兵報》採訪時表示，自己對密爾瓦基依舊保持忠誠，此外，他也對於先前球隊老闆之一的伊登斯（Wes Edens）所發表的冷血言論，表達強烈不滿。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830009.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 12:12"}, {"article_id": "9424503", "title": "中央補助縮水？ 國小樂樂棒球賽明年恐停辦引關注 台南爭取續命", "summary": "台南市政府剛因亞太棒球場爭議鬧上媒體版面，近期又傳出國小樂樂棒球恐因預算被砍，明年將停止辦比賽，讓南市體育局趕緊親上火線回應，強調今年將以市預算支持地方預賽，針對明年運動部恐取消舉辦樂樂棒球賽一事，將持續向運動部爭取續辦。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830035.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 12:07"}, {"article_id": "9424449", "title": "MLB／馬恰多變身足球高手踢掉牽制 美媒：下一步挑戰金靴獎？", "summary": "教士隊明星三壘手馬恰多（Manny Machado）變身足球高手？教士作客波士頓，今天對紅襪隊進行3連戰最後一戰，他在4局上一個「不小心」踢球動作引發討論，賽後成為焦點話題，教士終場以8：6獲勝，2勝1敗贏得系列賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34829996.jpg&M=1&s=Y&x=296&y=16&sw=750&sh=500&exp=3600&sl=W&fw=360", "date": "2026-04-06 11:37"}, {"article_id": "9424390", "title": "NBA／回應詹皇「不想去密爾瓦基」言論 公鹿主帥笑稱：我們應該把他交易過來", "summary": "41歲湖人隊球星「詹皇」詹姆斯（LeBron James）先前曾公開表示，密爾瓦基公鹿是他最不想去打球的地方之一，此話一出引發不小爭議。公鹿隊總教練「老河」瑞佛斯（Doc Rivers）則在稍早回應了詹皇的這段言論，他開玩笑表示，鑒於詹姆斯這番耐人尋味的言論，公鹿隊應該竭盡全力去交易得到他。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34829967.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-06 11:34"}]}, {"name": "林哲瑄專訪", "articles": [{"article_id": "9413494", "title": "林哲瑄專訪／棒球療效一輩子 過動兒踏出30年棒球生涯", "date": "2026-03-31 11:17", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/03/31/34813934.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&ex