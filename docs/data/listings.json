mbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024068.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 16:45"}, {"article_id": "9553239", "title": "MLB／爭議跑壘釀成逆轉大局 金鶯2分惜敗藍鳥賽後大吐苦水", "summary": "今日藍鳥、金鶯系列賽最終戰，前5局手握4比0領先優勢的金鶯，卻在下個半局因藍鳥二壘手克萊門特（Ernie Clement）的一次爭議跑壘釀成大禍，最終藍鳥在該局灌進5分以及8局下補上1分，終場就以6：4逆轉奪勝。然而，賽後金鶯選手和教練卻為此抱不平，認為跑壘有超出三呎線的疑慮。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024053.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 16:40"}, {"article_id": "9553074", "title": "NBA／尼克挾2連勝回主場作戰 布朗森談話間有「曼巴」影子", "summary": "儘管紐約尼克在2026總決賽已取得2：0領先，後2戰還將在自家主場舉行，似乎勝利女神已站在他們身邊，但尼克頭牌球星布朗森（Jalen Brunson）仍不以為然，在今日記者會接受採訪時表示，他希望用平靜心態去看待接下的比賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024056.jpg&M=1&s=Y&x=140&y=20&sw=1111&sh=740&exp=3600&sl=W&fw=360", "date": "2026-06-08 16:37"}, {"article_id": "9553168", "title": "擊劍／擊劍國手李讓 獲台師大114學年度績優運動選手表揚", "summary": "台師大於6/8舉行「114學年度績優運動教練、選手表揚暨頒獎典禮」。大一擊劍選手李讓榮獲公開組男子銳劍金牌，並將參加6/18的亞洲擊劍錦標賽，期許力爭獎牌及拿到亞運門票。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023917.jpg&M=1&s=Y&x=0&y=222&sw=919&sh=613&exp=3600&sl=W&fw=360", "date": "2026-06-08 16:11"}, {"article_id": "9553143", "title": "中職／龍隊公布下半季主題日活動 8月5日向徐生明致敬", "summary": "味全龍隊今天公布下半季主題日活動，超人氣IP聯名、大巨蛋音樂盛典接力引爆，邀請球迷進場見證熱血篇章。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023869.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-06-08 16:03"}, {"article_id": "9553119", "title": "日職／日本投手整體水準高配球細膩 林安可坦言要馬上適應不容易", "summary": "日本職棒西武獅上季團隊打擊率僅2成32，排名聯盟墊底，休賽季後球團以「打破」作為新球季口號，從補強到訓練都把提升攻擊火力列為最重要課題，其中包括用「2+1」合約、總額近400萬美元簽下台灣重砲手林安可。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023861.jpg&M=1&s=Y&x=0&y=0&sw=942&sh=628&exp=3600&sl=W&fw=360", "date": "2026-06-08 16:02"}, {"article_id": "9553062", "title": "日職／松坂大輔細數印象深台灣球員 讚徐若熙具備很好潛力", "summary": "「平成怪物」松坂大輔來台今天出席玉山盃開幕式，松坂大輔坦言台灣球員給他留下的印象很深，目前擔任球評，稱讚徐若熙具備很好潛...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023765.jpg&M=1&s=Y&x=0&y=43&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-08 15:32"}, {"article_id": "9553036", "title": "日職／連兩場優質先後降二軍 徐若熙最快18日重返一軍", "summary": "日本職棒軟銀鷹隊今天異動一軍名單，把台灣投手徐若熙降到二軍，最快18日才能重返一軍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023739.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 15:20"}, {"article_id": "9552904", "title": "NBA／馬刺G3作客紐約沒退路 卡瑟爾透露波波維奇用一段話點醒眾將", "summary": "聖安東尼奧馬刺隊目前遭遇今年季後賽迄今為止最嚴峻的挑戰，他們在NBA總決賽中以0比2落後尼克，第3戰將於明日於紐約麥迪遜廣場花園開打。在今日媒體記者會上，馬刺眾將溫班亞瑪（Victor Wembanyama）、哈波（Dylan Harper）、卡瑟爾（Stephon Castle）等人表示，他們仍有信心在客場取得勝利，將戰線延長至回到自家主場作戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023498.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 15:18"}, {"article_id": "9552985", "title": "MLB／大谷OPS爬到國聯第1！羅伯茲：他接下來會打更多長打", "summary": "道奇二刀流巨星大谷翔平，今日延續前一場雙安的好表現，在與天使系列賽最終戰5打數貢獻2安打，只可惜牛棚不給力，最終道奇以5：13慘敗無緣完成橫掃。總教練羅伯茲（Dave Roberts）在賽後給予打擊近況火燙的大谷讚揚，目前OPS（整體攻擊指數）高居國聯第1的他，是球隊近期取得出色戰績的關鍵，同時預估他未來會敲出更多長打。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023619.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 15:14"}, {"article_id": "9552959", "title": "從場上指揮官到ESPN球評！林書豪用哈佛球商解析馬刺致命傷", "summary": "林書豪重返紐約擔任ESPN球評，分析NBA總決賽馬刺隊的致命傷。他指出，馬刺需停止依賴溫班亞瑪單打，並強調戰術多樣性的重要性，獲得球迷高度評價。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023594.jpg&M=1&s=Y&x=102&y=0&sw=864&sh=576&exp=3600&sl=W&fw=360", "date": "2026-06-08 15:06"}, {"article_id": "9553009", "title": "世足賽／缺席最後一場熱身賽 西班牙主帥曝亞馬爾狀態", "summary": "西班牙世界盃前最後一場熱身賽將飛到墨西哥和秘魯交手，不過陣中超級球星亞馬爾（Lamine Yamal）、威廉斯（Nico Williams）和穆尼奧斯（Víctor Muñoz）都不會隨隊，將待在西班牙位於美國查塔努加的訓練基地復健。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023712.jpg&M=1&s=Y&x=0&y=41&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 15:02"}, {"article_id": "9552997", "title": "青少棒／新北完成華南金控盃3連霸 代表台灣征戰U15世界盃", "summary": "華南金控盃全國青少棒錦標賽冠軍戰因雨延後一天，今天在三重棒球場圓滿落幕，新北市隊以6：5險勝台南市隊，成為第1支完成3連霸的球隊，並獲得中華隊組訓權，將代表台灣征戰墨西哥，參加9月底開打的U15世界盃。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023663.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-08 14:56"}, {"article_id": "9552955", "title": "備戰名古屋亞運獲助力 運動部、農業部攜手", "summary": "為強化我國運動多元發展並展現跨部會合作效益，運動部成立後積極與各部會攜手合作，運動部部長李洋今天率同國家運動訓練中心及中華奧林匹克委員會代表拜會農業部。雙方除就2026年愛知－名古屋亞洲運動會期間合作事項進行討論外，並在農業部主動提議下，針對兩部長期合作機制深入交換意見，達成持續合作共識。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023573.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 14:33"}, {"article_id": "9552937", "title": "中職／讀賣巨人聯名主題日重磅回歸 長野久義13日擔任開球嘉賓", "summary": "中信兄弟隊將於13、14日在台中洲際棒球場迎戰樂天桃猿隊，球團今天宣布，去年掀起熱烈迴響的讀賣巨人聯名主題日重磅回歸。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023526.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-06-08 14:22"}, {"article_id": "9552852", "title": "世足賽／對陣烏克蘭突倒地 丹麥足球員恢復意識、狀況穩定", "summary": "丹麥足球員艾利克森（Christian Eriksen）今天在與烏克蘭的國際友誼賽中突然倒地，所幸接受緊急治療後恢復意識...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023494.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 14:16"}, {"article_id": "9552856", "title": "「5-Out」並未摧毀溫班亞瑪體系 馬刺找到破解尼克新方向", "summary": "總冠軍賽前兩戰打完，外界最熱門的討論莫過於尼克的「5-Out」進攻。當唐斯（Karl-Anthony Towns）在外圍持球，搭配布朗森（Jalen Brunson）、布里吉斯（Mikal Bridges）、阿努諾比（OG Anunoby）和哈特（Josh Hart）等四個能切能傳能投的球員時，尼克幾乎把整個進攻空間拉到極致，也讓溫班亞瑪（Victor Wembanyama）不得不離開最具統治力的禁區防守區域，許多人因此得出結論，尼克已經破解了溫班亞瑪體系。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023398.jpg&M=1&s=Y&x=50&y=24&sw=1129&sh=753&exp=3600&sl=W&fw=360", "date": "2026-06-08 14:09"}, {"article_id": "9552783", "title": "NBA／G4最低票價破31萬創史上新高 尼克前鋒痛批：太荒謬了", "summary": "隨著NBA總決賽接下來將移師紐約舉行，整座城市包含賽事場館麥迪遜廣場花園也陷入瘋狂。根據相關數據顯示，G3最便宜門票已經來到7千美金（約新台幣22萬元），G4則是更誇張，最低票價直接飆破1萬美金（約新台幣31萬元）大關，也讓尼克前鋒哈特（Josh Hart）直言，很多紐約球迷等了一輩子為了看總決賽卻要付出如此高昂的天價，這簡直不合理。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023286.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 13:52"}, {"article_id": "9552830", "title": "日職／孫易磊確定登上一軍 本周交流戰首次登板先發", "summary": "日本火腿隊21歲台灣投手孫易磊將登上一軍，本周交流戰首次扛起先發任務，他說：「希望投得比去年更好。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/04/34914751.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-08 13:47"}, {"article_id": "9552771", "title": "MLB／天使後段班砲火近126年最猛 羅伯茲坦言無法解決6到9棒", "summary": "天使隊本季在洛杉磯「高速公路大戰」一勝難求，今天終於改變命運，後4棒火力大爆發，一共出現13支安打、猛攻10分打點，終場以13：5獲勝，終止對戰5連敗，兩隊下次例行賽交手要等到明年了。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023288.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 13:21"}, {"article_id": "9552742", "title": "NBA／公牛王朝名將暨知名球評 金恩驟逝享年59歲、死因待公布", "summary": "曾與喬丹（Michael Jordan）一同寫下「公牛王朝」隊史首次三連霸偉業的NBA傳奇名將金恩（Stacey King），在稍早驚傳離世享年59歲。雖然公牛隊官方聲明中並未公布具體死因，但根據外媒透露，金恩是在其住宅中不慎摔倒後去世。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023233.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 13:19"}]}, {"name": "棒球", "articles": [{"article_id": "9553036", "title": "日職／連兩場優質先後降二軍 徐若熙最快18日重返一軍", "date": "2026-06-08 15:20", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08