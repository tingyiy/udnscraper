: "/news/story/122629/9551350"}, {"article_id": "9551336", "title": "日職／樂天金鷲大失策 改革聲浪勢必再起", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/07/35021034.jpg&M=1&s=Y&x=0&y=134&sw=960&sh=640&exp=3600&w=300", "link": "/news/story/122629/9551336"}, {"article_id": "9551320", "title": "中職／比打線復甦更重要的事 中信兄弟非常需要年輕土投竄起", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/07/35021005.jpg&M=1&s=Y&x=0&y=71&sw=926&sh=617&exp=3600&w=300", "link": "/news/story/122629/9551320"}]}, {"name": "最新文章", "articles": [{"article_id": "9554030", "title": "棒球／「中信60甲子緣」棒球展 參觀人次突破6萬", "summary": "「中信六十甲子緣」棒球特展開展三周好評不斷，應援舞蹈教學、運動體驗等周末限定活動更是場場爆滿，累計突破六萬人次觀展。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024818.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-09 00:00", "link": "/news/story/7001/9554030"}, {"article_id": "9553589", "title": "NBA／尼克爭冠陣容有甜蜜煩惱 唐斯今夏續約牽動未來薪資結構", "summary": "紐約尼克在NBA總冠軍賽前2戰連續擊敗聖安東尼奧馬刺，系列賽取得2比0領先，距離隊史自1973年後首座總冠軍只差2勝，其中唐斯（Karl-Anthony Towns）無疑是球隊能搶下優勢的重要原因之一。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024462.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 19:27", "link": "/news/story/7002/9553589"}, {"article_id": "9553564", "title": "籃球／籃協理事長正式交接 李一中再任秘書長", "summary": "中華民國籃球協會5月底辦理第14屆理事長改選，由辜家第四代、現任國際中橡集團董事長辜公怡脫穎而出，成為籃協新任理事長；今天理事長正式交接，辜公怡正式上任，前秘書長李一中回鍋，相隔4年再度擔任籃協秘書長。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024430.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-08 19:10", "link": "/news/story/7003/9553564"}, {"article_id": "9553411", "title": "NBA／瘋狂之城！尼克球迷包圍馬刺飯店 嘲諷斑馬「去打高爾夫」", "summary": "NBA總決賽G3、G4將移師紐約，稍早已抵達紐約下榻飯店的馬刺隊，卻遭到大批尼克球迷用另類的歡迎方式，熱情地招呼他們。例如，瘋狂的紐約球迷不僅聚集在飯店外，對馬刺球員發出噓聲，還有球迷建議球星溫班亞瑪（Victor Wembanyama）趕緊「去打高爾夫」，以此來嘲諷馬刺隊將在今年總決賽輸球，提前放暑假。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024222.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 19:09", "link": "/news/story/7002/9553411"}, {"article_id": "9553557", "title": "NBA／尼克主場門票飆天價 布朗森：寧願拿去看麥可傑克森", "summary": "紐約尼克在總冠軍賽前兩戰客場擊退馬刺後，距離隊史睽違53年的總冠軍只差2勝，也讓整個紐約徹底陷入籃球狂熱。隨著總冠軍賽將移師麥迪遜花園廣場，尼克主場門票在二級市場價格飆漲，連最便宜座位都超過1萬美元，成為近期紐約體壇最受矚目的話題之一。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024425.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 19:05", "link": "/news/story/7002/9553557"}, {"article_id": "9553500", "title": "棒球／「中信60甲子緣」觀展破6萬人次 天天加碼舉辦星光場活動", "summary": "「中信60甲子緣」棒球特展開展3周以來好評不斷，知名球評「團長」蔡明里與「東哥」黃忠義、Podcast節目「鍵盤球探」主持人Danny及各級棒球教練、選手大力推薦，應援舞蹈教學、運動體驗等周末限定活動更是場場爆滿，累計突破6萬人次觀展。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024355.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 18:23", "link": "/news/story/7001/9553500"}, {"article_id": "9553314", "title": "MLB／年初違反藥物規定遭禁賽80場 德國179轟重砲獲響尾蛇1年約", "summary": "亞利桑那響尾蛇今日宣布，與德國33歲外野手凱普勒（Max Kepler）簽訂為期1年的合約。今年1月，他因違反球隊禁藥政策，而被大聯盟禁賽80場，至今仍在「服球監」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024146.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 17:16", "link": "/news/story/6999/9553314"}, {"article_id": "9553294", "title": "舉重／名古屋亞運選拔 郭婞淳再披台灣戰袍", "summary": "中華民國舉重協會6日舉行名古屋亞洲運動會選拔賽，「舉重女神」郭婞淳在女子61公斤級以抓舉102公斤、挺舉128公斤、總和...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024139.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-08 17:09", "link": "/news/story/7005/9553294"}, {"article_id": "9553260", "title": "青棒／松坂大輔為玉山盃站台 和西武大前輩郭泰源互動", "summary": "被譽為「台灣甲子園」的玉山盃全國青棒錦標賽，今年正式邁入第20屆，這項承載無數台灣棒球選手夢想的頂級青棒賽事，將於11日到20日在新北市三重、新莊、桃園市平鎮棒球場進行，中華棒球協會今天特別邀請「平成怪物」松坂大輔為賽事站台。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024070.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 16:45", "link": "/news/story/7001/9553260"}, {"article_id": "9553252", "title": "日職／松坂大輔國中輸給中華隊懊悔成動力 點台灣棒球課題", "summary": "「平成怪物」松坂大輔國中時期輸給台灣的懊悔，讓他努力變得更強，之後國際賽碰頭沒再輸過，直言國高中時期對戰台灣隊很震撼，但...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024068.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 16:45", "link": "/news/story/7001/9553252"}, {"article_id": "9553239", "title": "MLB／爭議跑壘釀成逆轉大局 金鶯2分惜敗藍鳥賽後大吐苦水", "summary": "今日藍鳥、金鶯系列賽最終戰，前5局手握4比0領先優勢的金鶯，卻在下個半局因藍鳥二壘手克萊門特（Ernie Clement）的一次爭議跑壘釀成大禍，最終藍鳥在該局灌進5分以及8局下補上1分，終場就以6：4逆轉奪勝。然而，賽後金鶯選手和教練卻為此抱不平，認為跑壘有超出三呎線的疑慮。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024053.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 16:40", "link": "/news/story/6999/9553239"}, {"article_id": "9553074", "title": "NBA／尼克挾2連勝回主場作戰 布朗森談話間有「曼巴」影子", "summary": "儘管紐約尼克在2026總決賽已取得2：0領先，後2戰還將在自家主場舉行，似乎勝利女神已站在他們身邊，但尼克頭牌球星布朗森（Jalen Brunson）仍不以為然，在今日記者會接受採訪時表示，他希望用平靜心態去看待接下的比賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35024056.jpg&M=1&s=Y&x=140&y=20&sw=1111&sh=740&exp=3600&sl=W&fw=360", "date": "2026-06-08 16:37", "link": "/news/story/7002/9553074"}, {"article_id": "9553168", "title": "擊劍／擊劍國手李讓 獲台師大114學年度績優運動選手表揚", "summary": "台師大於6/8舉行「114學年度績優運動教練、選手表揚暨頒獎典禮」。大一擊劍選手李讓榮獲公開組男子銳劍金牌，並將參加6/18的亞洲擊劍錦標賽，期許力爭獎牌及拿到亞運門票。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023917.jpg&M=1&s=Y&x=0&y=222&sw=919&sh=613&exp=3600&sl=W&fw=360", "date": "2026-06-08 16:11", "link": "/news/story/7005/9553168"}, {"article_id": "9553143", "title": "中職／龍隊公布下半季主題日活動 8月5日向徐生明致敬", "summary": "味全龍隊今天公布下半季主題日活動，超人氣IP聯名、大巨蛋音樂盛典接力引爆，邀請球迷進場見證熱血篇章。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023869.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-06-08 16:03", "link": "/news/story/7001/9553143"}, {"article_id": "9553119", "title": "日職／日本投手整體水準高配球細膩 林安可坦言要馬上適應不容易", "summary": "日本職棒西武獅上季團隊打擊率僅2成32，排名聯盟墊底，休賽季後球團以「打破」作為新球季口號，從補強到訓練都把提升攻擊火力列為最重要課題，其中包括用「2+1」合約、總額近400萬美元簽下台灣重砲手林安可。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023861.jpg&M=1&s=Y&x=0&y=0&sw=942&sh=628&exp=3600&sl=W&fw=360", "date": "2026-06-08 16:02", "link": "/news/story/7001/9553119"}, {"article_id": "9553062", "title": "日職／松坂大輔細數印象深台灣球員 讚徐若熙具備很好潛力", "summary": "「平成怪物」松坂大輔來台今天出席玉山盃開幕式，松坂大輔坦言台灣球員給他留下的印象很深，目前擔任球評，稱讚徐若熙具備很好潛...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023765.jpg&M=1&s=Y&x=0&y=43&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-08 15:32", "link": "/news/story/7001/9553062"}, {"article_id": "9553036", "title": "日職／連兩場優質先發後降二軍 徐若熙最快18日重返一軍", "summary": "日本職棒軟銀鷹隊今天異動一軍名單，把台灣投手徐若熙降到二軍，最快18日才能重返一軍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023739.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 15:20", "link": "/news/story/7001/9553036"}, {"article_id": "9552904", "title": "NBA／馬刺G3作客紐約沒退路 卡瑟爾透露波波維奇用一段話點醒眾將", "summary": "聖安東尼奧馬刺隊目前遭遇今年季後賽迄今為止最嚴峻的挑戰，他們在NBA總決賽中以0比2落後尼克，第3戰將於明日於紐約麥迪遜廣場花園開打。在今日媒體記者會上，馬刺眾將溫班亞瑪（Victor Wembanyama）、哈波（Dylan Harper）、卡瑟爾（Stephon Castle）等人表示，他們仍有信心在客場取得勝利，將戰線延長至回到自家主場作戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023498.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 15:18", "link": "/news/story/7002/9552904"}, {"article_id": "9552985", "title": "MLB／大谷OPS爬到國聯第1！羅伯茲：他接下來會打更多長打", "summary": "道奇二刀流巨星大谷翔平，今日延續前一場雙安的好表現，在與天使系列賽最終戰5打數貢獻2安打，只可惜牛棚不給力，最終道奇以5：13慘敗無緣完成橫掃。總教練羅伯茲（Dave Roberts）在賽後給予打擊近況火燙的大谷讚揚，目前OPS（整體攻擊指數）高居國聯第1的他，是球隊近期取得出色戰績的關鍵，同時預估他未來會敲出更多長打。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023619.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 15:14", "link": "/news/story/6999/9552985"}, {"article_id": "9552959", "title": "從場上指揮官到ESPN球評！林書豪用哈佛球商解析馬刺致命傷", "summary": "林書豪重返紐約擔任ESPN球評，分析NBA總決賽馬刺隊的致命傷。他指出，馬刺需停止依賴溫班亞瑪單打，並強調戰術多樣性的重要性，獲得球迷高度評價。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023594.jpg&M=1&s=Y&x=102&y=0&sw=864&sh=576&exp=3600&sl=W&fw=360", "date": "2026-06-08 15:06", "link": "/news/story/122629/9552959"}, {"article_id": "9553009", "title": "世足賽／缺席最後一場熱身賽 西班牙主帥曝亞馬爾狀態", "summary": "西班牙世界盃前最後一場熱身賽將飛到墨西哥和秘魯交手，不過陣中超級球星亞馬爾（Lamine Yamal）、威廉斯（Nico Williams）和穆尼奧斯（Víctor Muñoz）都不會隨隊，將待在西班牙位於美國查塔努加的訓練基地復健。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023712.jpg&M=1&s=Y&x=0&y=41&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 15:02", "link": "/news/story/123107/9553009"}, {"article_id": "9552997", "title": "青少棒／新北完成華南金控盃3連霸 代表台灣征戰U15世界盃", "summary": "華南金控盃全國青少棒錦標賽冠軍戰因雨延後一天，今天在三重棒球場圓滿落幕，新北市隊以6：5險勝台南市隊，成為第1支完成3連霸的球隊，並獲得中華隊組訓權，將代表台灣征戰墨西哥，參加9月底開打的U15世界盃。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023663.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-08 14:56", "link": "/news/story/7001/9552997"}, {"article_id": "9552955", "title": "備戰名古屋亞運獲助力 運動部、農業部攜手", "summary": "為強化我國運動多元發展並展現跨部會合作效益，運動部成立後積極與各部會攜手合作，運動部部長李洋今天率同國家運動訓練中心及中華奧林匹克委員會代表拜會農業部。雙方除就2026年愛知－名古屋亞洲運動會期間合作事項進行討論外，並在農業部主動提議下，針對兩部長期合作機制深入交換意見，達成持續合作共識。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/08/35023573.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-08 14:33", "link": "/news/st