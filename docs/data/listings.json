://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34890864.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&sl=W&fw=360", "date": "2026-04-26 12:23"}, {"article_id": "9465060", "title": "市場預期Fed本周維持利率不變 美股本周五大變數", "summary": "富蘭克林投顧指出，未來一周美股有五大觀察變數。首先是中東局勢與油價：留意美伊談判進展、荷莫茲海峽通行狀況、油價變化。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_5.jpg", "date": "2026-04-26 12:20"}, {"article_id": "9465042", "title": "影／白宮晚宴槍手身分曝光！31歲加州男教師入住同飯店且自組長槍", "summary": "美國總統川普在美東時間25日晚間出席白宮記者協會晚宴，現場發生槍手強闖並開火事件。紐約郵報報導，聯邦執法部門消息人士證實，槍手為來自加州托倫斯（Torrance）的31歲男教師艾倫（Cole Allen）。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34890839.png&M=1&s=Y&x=0&y=0&sw=1212&sh=808&exp=3600&sl=W&fw=360", "date": "2026-04-26 12:06"}, {"article_id": "9465012", "title": "白宮記者晚宴槍擊後首發聲！川普稱槍手為「孤狼」原本還想回去演說", "summary": "美國總統川普在美東時間25日晚間出席白宮記者協會晚宴，現場發生槍手強闖並開火事件，特勤局隨即將川普與第一夫人梅蘭妮亞緊急撤離...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34890785.jpg&M=1&s=Y&x=0&y=0&sw=1242&sh=828&exp=3600&sl=W&fw=360", "date": "2026-04-26 11:41"}, {"article_id": "9464932", "title": "雷根遇刺同地點！30多歲槍手闖白宮記協晚宴開火被捕 特勤中彈", "summary": "美國總統川普在美東時間25日晚間8時（台灣時間26日早上8時）出席白宮記者協會晚宴期間，現場傳出槍響，特勤局隨扈隨即將他與第一夫人梅蘭妮亞緊急撤離。聯邦調查局（FBI）華府地方辦公室表示，嫌犯已被拘留。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34890633.jpg&M=1&s=Y&x=0&y=0&sw=1277&sh=851&exp=3600&sl=W&fw=360", "date": "2026-04-26 10:53"}, {"article_id": "9464840", "title": "海湖俱樂部舉行加密幣大會 川普幣暴跌受關注", "summary": "美國總統川普今天在佛州棕櫚灘海湖俱樂部（Mar-a-Lago）主持第2屆川普幣（$TRUMP）大會，儘管「川普幣」已從去...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34890515.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-26 10:08"}, {"article_id": "9464836", "title": "星期人物／川普次子艾瑞克訪中 步步站進權力核心", "summary": "川普次子艾瑞克五月將隨父訪中，這位操盤川普集團、掌握企業管理實權的幕後推手，首度從商業核心跨足高度敏感的外交場景。他以「私人身分」隨行，遊走於正式編制之外，究竟是為家族事業鋪路，還是將在權力結構中扮演更關鍵的外交角色？", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/25/34888807.jpg&M=2&s=Y&x=21&y=11&sw=1259&sh=839&exp=3600&sl=W&fw=360", "date": "2026-04-26 10:00"}, {"article_id": "9464829", "title": "白宮記者晚宴變驚魂現場！CNN主播曝槍聲瞬間 目擊者：男子持槍倒地", "summary": "美國總統川普在美東時間25日晚間8時（台灣時間26日早上8時）出席白宮記者協會晚宴期間，現場傳出槍響，特勤局隨扈隨即將他與第一夫人梅蘭妮亞緊急撤離。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34890456.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 09:55"}, {"article_id": "9464780", "title": "因槍響被護送離開白宮記者晚宴 川普：槍手已被捕", "summary": "美國總統川普25日出席「白宮記者協會晚宴」，不過現場出現槍響，川普被特勤人員護送離開，川普於美東時間晚間9時17分發文指出，槍手已經被逮捕。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34890376.png&M=1&s=Y&x=0&y=0&sw=1110&sh=740&exp=3600&sl=W&fw=360", "date": "2026-04-26 09:33"}, {"article_id": "9464774", "title": "出席白宮記者協會晚宴遇槍響 川普真實社群報平安稱槍手已被捕", "summary": "美國總統川普在美東時間25日晚間8時（台灣時間26日早上8時）出席白宮記者晚宴期間，現場疑似傳出槍響，特勤局隨扈隨即將他與第一夫人梅蘭妮亞緊急撤離。川普事後表示，特勤局與執法人員表現出色，槍手也已被逮捕。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34890366.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 09:28"}, {"article_id": "9464750", "title": "艾普斯坦有何魔力吸引菁英？黑名簿曝權貴版FOMO陷阱", "summary": "過去幾個月，淫魔富豪艾普斯坦（Jeffrey Epstein）的電郵陸續曝光，一個問題也逐漸浮現：那些知名的經濟學家、醫師與產業領袖，為何會尋求他的建議，甚至對他卑躬屈膝？他們交友難道不該更謹慎嗎？一部分理由其實很簡單：人們想被加入艾普斯坦那本惡名昭彰的聯絡人名冊。那本黑名簿宛如一張權力地圖，標示出哪些人真正有影響力，被納入其中將有助於攀升財富階梯。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/25/34888689.jpg&M=2&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-26 09:00"}, {"article_id": "9464744", "title": "川普出席白宮記者協會晚宴 疑似開槍 川普被護送離開", "summary": "美國總統川普25日晚間出席「白宮記者協會晚宴」，約莫美東時間晚間8時35分左右，現場疑似出現安全問題，川普被數名維安人員護送離開。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34890298.png&M=1&s=Y&x=0&y=0&sw=888&sh=592&exp=3600&sl=W&fw=360", "date": "2026-04-26 08:57"}, {"article_id": "9464740", "title": "影／川普出席白宮記者晚宴傳有人開槍 與第一夫人梅蘭妮亞緊急撤離", "summary": "美國總統川普在美東時間25日晚間8時（台灣時間26日早上8時）出席白宮記者晚宴期間，但根據Axios記者拉維德（Barak Ravid）報導，安保人員已將他從現場緊急撤離。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34890335.png&M=1&s=Y&x=173&y=0&sw=1011&sh=674&exp=3600&sl=W&fw=360", "date": "2026-04-26 08:53"}, {"article_id": "9464713", "title": "美伊沒見面但部分議題有進展！WSJ：數日內可能再談 但川普得先做這事", "summary": "美國總統川普25日取消特使威科夫（Steve Witkoff）與庫許納（Jared Kushner）前往巴基斯坦與伊朗會談的行程，理由是德黑蘭提出的方案未達白宮預期。不過，有消息人士指出，雙方在部分議題上已有進展，仍可能在未來幾天恢復談判。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34890245.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 08:01"}, {"article_id": "9464639", "title": "川普取消美伊會談後 稱收到新提案、內容更好", "summary": "美國總統川普今天宣布，已取消特使團原定赴巴基斯坦與伊朗展開會談的行程。他隨後表示，伊朗想談的時候，只要打電話就可以，並稱...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34890161.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 04:48"}, {"article_id": "9464497", "title": "費半連18紅 台積 ADR 創高 本周科技巨擘財報、Fed 會議聚焦", "summary": "英特爾（Intel）24日領軍暴衝之下，激勵輝達（NVIDIA）和台積電ADR同創新高，為費城半導體指數締造連18日漲勢，也帶動標普500指數和那斯達克指數再創歷史新高。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/22/34880906.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-26 02:15"}, {"article_id": "9464498", "title": "大賣空本尊潑冷水 押晶片股跌入熊市", "summary": "電影「大賣空」本尊、知名投資人貝瑞（Michael Burry）24日在Substack發文表示，他開始做空晶片股，買進追蹤費城半導體指數的iShares半導體ETF（SOXX）選擇權的賣權。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_6.jpg", "date": "2026-04-26 02:13"}, {"article_id": "9464533", "title": "美伊代表赴巴國全球關注 外界緊盯是否直接談判", "summary": "伊朗外交部長阿拉奇24日抵達巴基斯坦，會見該國高層；美國中東特使威科夫及總統川普女婿庫許納25日也將前往巴國，為美伊達成和平協議帶來希望。但外媒表示，兩國進行直接談判機會依舊不大，所幸股市對戰爭敏感度已大幅降低。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/25/34889971.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=852&exp=3600&sl=W&fw=360", "date": "2026-04-26 02:10"}, {"article_id": "9464593", "title": "美斬斷伊朗金脈 制裁中國一家煉油大廠", "summary": "為切斷伊朗石油外銷的資金命脈，美國財政部廿四日宣布，對大陸大型煉油廠、位於遼寧大連的「恒力石化」，以及約四十家涉嫌運輸伊朗石油的航運公司與油輪，實施制裁，進一步切斷伊朗透過「影子艦隊」出口石油的資金來源。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34890136.jpg&M=1&s=Y&x=16&y=0&sw=1264&sh=843&exp=3600&sl=W&fw=360", "date": "2026-04-26 02:04"}, {"article_id": "9464535", "title": "美將與波灣國家建換匯額度", "summary": "美國財政部長貝森特24日表示，美國正與波斯灣和亞洲國家討論換匯額度安排，因為多國求助因應伊朗戰爭衝擊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_9.jpg", "date": "2026-04-26 02:01"}, {"article_id": "9464537", "title": "超級央行周 多國估按兵不動 Fed主席鮑爾主持最後一場會議受矚目", "summary": "全球金融市場本周迎接關鍵的「超級央行周」，除美國聯準會（Fed）外，日本央行（日銀）、歐洲央行（ECB）及英國央行也將公布決策。市場預料這幾個主要經濟體都將按兵不動，但接下來歐、日央行6月極可能升息，美、英或許仍將按兵不動。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/04/34827235.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-26 02:00"}, {"article_id": "9464538", "title": "華許任命案 障礙消除", "summary": "美國司法部24日撤回對聯準會（Fed）主席鮑爾進行的刑事調查，為參議院對下任Fed主席提名人華許行使同意權鋪路。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7225_9.jpg", "date": "2026-04-26 01:58"}, {"article_id": "9464586", "title": "美對伊朗封鎖擴及全球 船舶從海峽出發都須獲准", "summary": "美國國防部長赫塞斯廿四日在對美以伊戰爭的新聞簡報會中說，美國對伊朗的封鎖正擴大至全球，從荷莫茲海峽（下稱海峽）出發的任何船舶要前往全球任何地方，都必須獲美國海軍許可。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/26/34890130.jpg&M=1&s=Y&x=124&y=183&sw=952&sh=634&exp=3600&sl=W&fw=360", "date": "2026-04-26 01:55"}]}, {"name": "美以轟炸伊朗", "articles": [{"article_id": "9464713", "title": "美伊沒見面但部分議題有進展！WSJ：數日內可能再談 但川普得先做這事", "date": "2026-04-26 08:01", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https: