ttps://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/25/34981210.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9528648", "title": "NBA／稱打出生涯最糟開局 SGA罰球創紀錄感謝隊友挺身而出", "summary": "西區決賽今天迎來關鍵的「天王山之戰」，前一場進攻受挫的衛冕軍雷霆，在主場展現強大的調整能力，靠著當家球星亞歷山大（Shai Gilgeous-Alexander）轟下32分，加上卡盧索（Alex Caruso）與年輕後衛麥肯（Jared McCain）合砍42分的火力支援，系列賽搶先聽牌。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34986373.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 13:03"}, {"article_id": "9528558", "title": "MiLB／林維恩2A挨轟悲情吞敗 陽念希新人聯盟4局生涯新高", "summary": "美職小聯盟運動家隊台灣投手林維恩今天在2A先發6局，因1發2分砲造成傷害，加上隊友被完封讓他吞敗；在新人聯盟登板的巨人隊...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34986329.jpg&M=1&s=Y&x=0&y=35&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 13:01"}, {"article_id": "9528470", "title": "法網／地主17歲網球小將高梅 大滿貫會內賽17年來最年輕贏家", "summary": "法國17歲少年高梅（Moise Kouame），今天在法國網球公開賽首輪以7比6（4）、6比2、6比1擊敗前美網冠軍西里...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34986328.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 13:00"}, {"article_id": "9528590", "title": "MLB／大谷翔平挨觸身球提前退場 道奇領先14分換羅哈斯登板", "summary": "道奇隊日本球星大谷翔平明天預計「投打二刀流」面對洛磯隊，但今天比賽打擊時，右手被觸身球砸到，提前退場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34986276.jpg&M=1&s=Y&x=343&y=57&sw=934&sh=623&exp=3600&sl=W&fw=360", "date": "2026-05-27 12:48"}, {"article_id": "9528563", "title": "PLG／葉惟捷滿分獲選新人王 阿提諾奪第六人寫紀錄", "summary": "P. LEAGUE+今天公佈2025-26球季年度第六人、年度新人王及年度進步獎，桃園璞園領航猿的阿提諾成為聯盟史上第1位拿下年度第六人的外籍球員，年度新人王則由洋基工程的葉惟捷滿分獲選，台鋼獵鷹的谷毛唯嘉本季攻守數據全面成長，拿下年度進步獎。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34986231.jpg&M=1&s=Y&x=0&y=0&sw=1024&sh=683&exp=3600&sl=W&fw=360", "date": "2026-05-27 12:37"}, {"article_id": "9528495", "title": "NBA／前馬刺球員說布朗森優於唐西奇 強調無球打法是分水嶺", "summary": "尼克球星布朗森在季後賽表現出色，前馬刺球員丹尼爾斯指出他優於唐西奇，強調布朗森的無球打法更具信賴度。布朗森率隊闖進總冠軍賽，而唐西奇因傷未能參賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34986141.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 12:34"}, {"article_id": "9528512", "title": "MLB／如何看阿部慎之助家暴案？菅野智之：不是輕率發言時機", "summary": "大聯盟洛磯隊日本投手菅野智之今天賽前接受日媒採訪，被問到日職讀賣巨人隊前總教練阿部慎之助因家暴被逮捕事件。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34986157.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 12:23"}, {"article_id": "9528461", "title": "世足賽／不只梅西、衛冕軍阿根廷爆傷兵潮 考驗斯卡洛尼調兵智慧", "summary": "距離世界盃足球賽點燃戰火僅剩不到一個月，衛冕軍阿根廷隊卻拉響了嚴重的傷兵警報，除了當家球星梅西（Lionel Messi）的傷勢牽動全球無數球迷的心，總教練斯卡洛尼（Lionel Scaloni）目前更面臨球隊多名主力集體高掛免戰牌的嚴峻考驗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34986075.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 12:08"}, {"article_id": "9483568", "title": "中職／第九局新任把關者 鍾允華獅軍守護神養成中", "summary": "統一7-ELEVEN獅的22歲投手鍾允華近期表現出色，成為球隊新任守護神。在主場開幕戰中，他成功抵擋台鋼雄鷹的攻勢，首度登板便獲得救援。休賽季的系統性調整使他的控球和投球表現明顯提升，教練團對他未來的潛力充滿期待。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/05/34918748.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-27 12:00"}, {"article_id": "9528417", "title": "NBA／WNBA冠軍教頭捍衛「矮個無法奪冠」觀點 但歡迎布朗森打臉", "summary": "WNBA拉斯維加斯王牌的教練哈蒙（Becky Hammon）曾發表「小個子球員無法帶領球隊拿NBA總冠軍」的說法，儘管尼克隊今年在當家球星布朗森（Jalen Brunson）領軍下打進總冠軍賽，哈蒙仍維持個人觀點，但也歡迎布朗森用行動「打臉」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985993.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 11:57"}, {"article_id": "9528370", "title": "NBA／騎士有望留住當家球星？ 美記曝米契爾想簽延長約", "summary": "騎士球星米契爾渴望續約，ESPN記者報導他有意簽下四年2.77億美元的續約合約。儘管本季季後賽失利，米契爾仍希望成為球隊未來的一部分，並準備再次挑戰總冠軍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985894.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 11:54"}, {"article_id": "9528240", "title": "NBA／率殘陣塞爾蒂克奪東區第二 馬祖拉獲選年度最佳總教練", "summary": "美國職籃NBA波士頓塞爾蒂克教頭馬茲拉（Joe Mazzulla）今天首度獲選年度最佳總教練。儘管當家球星塔特姆3月6日...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985961.jpg&M=1&s=Y&x=0&y=0&sw=1024&sh=683&exp=3600&sl=W&fw=360", "date": "2026-05-27 11:50"}, {"article_id": "9528318", "title": "NBA／封鎖溫班亞瑪15投僅4中 麥肯G5再扮奇兵雷霆搶先聽牌", "summary": "NBA西區冠軍賽第五戰，雷霆與馬刺今天進行「天王山之戰」，前一場比賽僅拿下82分輸球的雷霆，今天回到主場後找回進攻手感，尤其是從替補被拉上先發的麥肯（Jared McCain）全場進帳20分中有18分是在下半場拿下，搭配上亞歷山大（Shai Gilgeous-Alexander）的32分，最終雷霆就以127：114擊敗馬刺，取得3：2聽牌優勢。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985827.jpg&M=1&s=Y&x=0&y=0&sw=1277&sh=851&exp=3600&sl=W&fw=360", "date": "2026-05-27 11:28"}, {"article_id": "9528230", "title": "NBA／不滿「冠軍=偉大」的文化 米契爾挺哈登：和柯瑞同等級", "summary": "哈登表示「百分之百」會重返騎士，並對明年的奪冠充滿信心。他相信球隊經過休賽季磨合後，能夠加強陣容，攜手米契爾共創佳績。米契爾則讚揚哈登的努力和影響。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985688.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-27 11:27"}, {"article_id": "9528271", "title": "MLB／村上宗隆本季第19轟出爐！追平麥奎爾和阿隆索紀錄", "summary": "白襪隊日本重砲「村神」村上宗隆再度開砲，今天與雙城隊交手，8局下轟出追平2分砲，本季第19轟出爐，但白襪最終仍在延長賽11局以3：5輸球。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985750.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 11:22"}, {"article_id": "9528166", "title": "NBA／創無簽名卡紀錄 溫班亞瑪新人卡天價1.66億元售出", "summary": "馬刺當家球星溫班亞瑪（Victor Wembanyama）在球場外的影響力，正全面席捲收藏市場，根據《ESPN》報導，一張全球僅有一張的「1-of-1」2023-24 Panini Prizm Black 溫班亞瑪平行卡，近日在收藏市場交易中以511萬美元（約合台幣1.66億元）天價售出，寫下NBA無簽名籃球卡的歷史新頁。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985605.jpg&M=1&s=Y&x=0&y=0&sw=1024&sh=683&exp=3600&sl=W&fw=360", "date": "2026-05-27 10:37"}, {"article_id": "9528125", "title": "MLB／李灝宇滿壘代打未建功 老虎近20戰17敗與天使並列爐主", "summary": "老虎隊今天與天使隊交手，台灣內野手李灝宇5局下滿壘代打未能建功，全場2打數0安打。老虎牛棚崩盤，終場以6：10慘遭逆轉，近20戰狂吞17敗，賽後以21勝34敗與天使並列美聯爐主。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985522.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 10:32"}, {"article_id": "9528095", "title": "法網／巴黎驚魂！高芙拚衛冕前遇車禍沒影響比賽表現", "summary": "去年在巴黎迎接生涯第一座法網女單冠軍，美國名將高芙（Coco Gauff）今年再到花都卻遇到車禍驚魂，所幸行車意外沒影響比賽表現，首輪她以6：4、6：0擊敗同胞湯森（Taylor Townsend），強勢挺進第二輪。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985436.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 10:18"}, {"article_id": "9528065", "title": "中職／球迷怒嗆「哪來的白目老猴」韓啦台灣成員RONA回應網笑翻", "summary": "中華職棒味全龍隊昨天在大巨蛋主場迎戰富邦悍將隊，邀請韓職LG雙子啦啦隊演出，包含台灣成員RONA（張競）。有球迷不滿一名男子從觀眾席走下樓梯，擋住攝影畫面，開轟「哪來的白目老猴」，對此Rona親回：「他是我爸。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985389.jpg&M=1&s=Y&x=0&y=56&sw=960&sh=640&exp=3600&sl=W&fw=360", "date": "2026-05-27 10:17"}, {"article_id": "9528043", "title": "MLB／光芒簽下大都會棄將「金寶」 金布洛爾轉隊立刻出賽", "summary": "光芒隊簽下前大都會投手金布洛爾，該投手在首次為球隊登板便以1局無失分的表現亮相。儘管光芒最終以1：6敗給金鶯，金布洛爾的加入有望改善隊伍牛棚壓力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985353.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 10:12"}, {"article_id": "9527875", "title": "籃球／賀家兄弟婉拒世界盃資格賽 賀丹不排除返台打職籃", "summary": "台灣男籃將在世界盃亞洲區資格賽第3階段分別迎戰韓國、中國，不過「賀家兄弟」賀丹、賀博已經婉拒邀請，其中哥哥賀丹準備投身職...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/27/34985189.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-27 09:23"}, {"article_id": "9527902", "title": "法網／賞對手貝果 吳芳嫺闖第二輪平最佳", "summary": "排上法網女雙16種子的我國女將吳芳嫺，和日本搭檔穂積繪莉首輪打出強勢表現，面對羅馬尼亞克莉絲蒂安