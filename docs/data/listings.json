0"}, {"article_id": "9458466", "title": "淺談ABS上路一個月 造成大聯盟好球帶縮水和其他效應", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/23/34881852.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9463597", "title": "NBA／塞爾蒂克瘋狂三分雨強壓76人 系列賽2勝1負領先", "summary": "波士頓塞爾蒂克今天遠征主場作戰的76人，塞爾蒂克最後關頭發揮三分火力，終場以108比100射垮76人，在7戰4勝系列賽中以2比1領先。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/25/34888704.jpg&M=1&s=Y&x=17&y=6&sw=945&sh=630&exp=3600&sl=W&fw=360", "date": "2026-04-25 10:49"}, {"article_id": "9463607", "title": "NBA／馬刺面臨考驗！溫班亞瑪腦震盪缺陣G3 主帥強調健康最優先", "summary": "馬刺宣布當家球星溫班亞瑪（Victor Wembanyama）因腦震盪持續恢復，確定缺席與波特蘭拓荒者的第3戰，讓系列賽戰局增添更多變數。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/25/34888655.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-25 10:39"}, {"article_id": "9463486", "title": "NBA／老鷹連兩年奪最佳進步獎 丹尼爾斯：我們有很棒的養成體系", "summary": "亞特蘭大老鷹後衛亞歷山大-華克（Nickeil Alexander-Walker）今天獲頒年度最佳進步獎，這是老鷹球員連兩年獲此殊榮，去年拿下此獎的是丹尼爾斯（Dyson Daniels）。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/25/34888602.jpg&M=1&s=Y&x=3&y=51&sw=835&sh=557&exp=3600&sl=W&fw=360", "date": "2026-04-25 09:56"}, {"article_id": "9463560", "title": "MLB／康索澄清批「大谷條款」非針對大谷或道奇 「但這規則真的爛」", "summary": "小熊隊總教練康索（Craig Counsell）近日提出對「大谷條款」的質疑，認為只為一人、一隊存在的規則很奇怪，小熊、道奇隊正好在今天展開3連戰，話題熱度也升溫，道奇教頭羅伯茲（Dave Roberts）對此指出，「這條規則從大谷在天使時就存在」，康索則是澄清自己並非針對道奇或大谷，「但這真的是爛規則」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/25/34888605.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-25 09:52"}, {"article_id": "9463537", "title": "MLB／李灝宇首度先發二壘打半場 2打數沒安打遭代打換掉", "summary": "台灣好手李灝宇今天再獲先發機會，首度負責二壘防區，擔綱老虎隊第八棒，但2打數沒有安打後，就在第6局輪到他的棒次時換上代打。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/25/34888578.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-25 09:32"}, {"article_id": "9463489", "title": "NBA／撕掉「SGA表弟」標籤 老鷹亞歷山大-華克勇奪年度進步獎", "summary": "NBA官方於今天宣布，老鷹後衛亞歷山大-華克（Nickeil Alexander-Walker）憑藉本賽季破繭而出的表現，獲選為季年度進步最快球員，這不僅是老鷹隊史連續第二年奪下此獎項，亞歷山大-華克更在受訪時激動落淚，直言這個獎項讓他終於能以「自己」的身分被世界看見。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/25/34888587.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-25 08:37"}, {"article_id": "9463102", "title": "中職／朱迦恩3安打、4打點兩度追平救命 獅隊終止4連敗", "summary": "統一獅隊的外野之鬼源源不絕產出，今天朱迦恩一人敲3安打、貢獻4分打點，兩度幫助球隊追平，獅隊歷經延長10局以7：6擊敗台鋼雄鷹隊，終止4連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/25/34888608.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-24 22:35"}, {"article_id": "9463023", "title": "亞運射擊國手之女廖可容 青少年世界盃空氣手槍摘銅", "summary": "在埃及開羅舉行的射擊青少年世界盃，身為亞運射擊國手馬瑜梅的女兒廖可容，在女子10公尺空氣手槍決賽以218.3分拿下銅牌，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887906.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-24 22:07"}, {"article_id": "9463048", "title": "棒球／陳偉殷拍廣告揭露返台的一天 私下是愛車的熱血男子", "summary": "退役旅美左投陳偉殷近日與全台最大的賓士經銷商中華賓士展開一系列的品牌合作，透過影片揭開自己返台的一天，用最日常的方式，讓大家看見這位傳奇球星不為人知的一面。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887903.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-24 22:02"}, {"article_id": "9463038", "title": "TPBL／國王雙衛開火斷夢想家3連勝 助雲豹重返龍頭", "summary": "已經晉級季後賽的福爾摩沙夢想家，與仍在為季後賽席次卡位的新北國王今天在新莊體育館交手，國王在團隊5人得分上雙下，以及第四節成功壓制夢想家進攻火力，最終以105：99中斷夢想家3連勝，也保住直接晉級季後賽的希望。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887892.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-24 21:55"}, {"article_id": "9463025", "title": "亞運／曾自強透過日本友人牽線 租借鄰近小拳館供拳擊隊賽前練習", "summary": "我國拳擊代表隊在本屆愛知－名古屋亞運仍是奪牌重點之一，但比賽場地、住宿飯店距離都較遠，為了讓選手們可以就近維持訓練，教練曾自強透過在日本教練牽線，於飯店附近借到一處拳館，提供選手進行賽前練習，免於舟車勞頓。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887878.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-24 21:35"}, {"article_id": "9462973", "title": "亞沙運／中華隊單日進帳2獎牌 總領隊王景成頒發得牌獎金", "summary": "第六屆亞洲沙灘運動會前天在中國大陸海南島三亞開幕，我國代表團在前兩天賽事舉行完後，共計拿下1銀、2銅，中華奧會副主席兼第6屆亞洲沙灘運動會總頒隊王景成也頒獎得牌獎金，運動部競技司科長賴郅如則代表部長李洋頒發得牌賀電給三位奪牌選手。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887791.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-24 20:40"}, {"article_id": "9462901", "title": "桌球／日本T.LEAGUE海外開幕戰開賣 高價位前排搶購一空", "summary": "日本職業桌球聯賽「Nojima T.LEAGUE」首場海外開幕戰「初陣：台灣」，於今天中午12點正式啟售，主辦單位「蛋牌」表示，系統開啟後即湧入大量球迷，最高價位的「極速臨場席」與「直擊對抗席」在短時間內全數售罄，顯見台灣球迷對國際頂尖職桌賽事的高度渴望。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887728.jpg&M=1&s=Y&x=93&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-24 19:43"}, {"article_id": "9462877", "title": "中職／朱迦恩跑出聯盟史上第1萬5000盜 還記得1萬盜是誰嗎？", "summary": "中職聯盟史上的第1萬5000次盜壘成功，誕生在亞太棒球場，今天由統一獅隊朱迦恩第二局盜二壘成功，在聯盟歷史上留名。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887663.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-24 19:25"}, {"article_id": "9462857", "title": "射擊／全中運雙金攜手 蔡婕穎、陳宥安青少年世界盃混雙步槍奪銀", "summary": "在埃及開羅舉行的2026射擊青少年世界盃，我國選手傳來奪牌捷報，日前剛在全中運包辦高中男、女10公尺空氣步槍個人賽金牌的南崁高中陳宥安、新北市光復高中蔡婕穎，今天攜手拿下10公尺空氣步槍混合賽銀牌。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887595.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-24 19:01"}, {"article_id": "9462791", "title": "NBA／湖人里夫斯G3升級出賽存疑 杜蘭特又列火箭傷兵名單", "summary": "湖人在首輪系列賽前兩戰取得2連勝，第3戰將前往休士頓作客，賽前雙方都有最新的傷兵情況。湖人後衛里夫斯（Austin Reaves）在因左腹斜肌二級拉傷缺陣多場後，最新被列為「出賽存疑」，而火箭球星杜蘭特（Kevin Durant）則因左腳踝扭傷，同樣進入傷兵觀察名單，為系列戰增添更多變數。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887464.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-24 18:18"}, {"article_id": "9462586", "title": "NBA／「大橋」下半場被冰、得分掛蛋 紐媒痛批：將尼克拖進谷底", "summary": "尼克隊「大橋」布里吉斯（Mikal Bridges）今天繳出生涯最差季後賽表現，下半場遭到棄用，全場上陣21分鐘0分，還發生4次失誤，正負值-26，布里吉斯的表現受到外界抨擊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887116.jpg&M=1&s=Y&x=345&y=236&sw=882&sh=588&exp=3600&sl=W&fw=360", "date": "2026-04-24 17:04"}, {"article_id": "9462559", "title": "足球／足協推動企甲擴編走向準職業化 已償還債務6730萬", "summary": "中華民國足球協會理事長張璨今天表示，自新任團隊上任以來，已全面啟動台灣足球制度改革，並以「競賽發展」與「財務治理」為雙核心主軸，推動聯賽升級、裁判專業化、女子與青訓深化，以及財務體系重建，逐步為台灣足球建立長期穩定的發展基礎。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887070.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-24 16:40"}, {"article_id": "9462540", "title": "足球／回應理事會質疑 足協理事長張璨：盼用同一把尺，量所有人", "summary": "中華足協在近日爆發協會內部的茶壺風暴，針對理事會在昨天提出的4點質疑，理事長張璨在今天親上火線回應，並指出將會在明天下午舉行的理事會上提出完整報告讓各界檢驗、監督，也期待理事會能「用同一把尺，量所有人。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887054.jpg&M=1&s=Y&x=0&y=0&sw=1219&sh=812&exp=3600&sl=W&fw=360", "date": "2026-04-24 16:29"}, {"article_id": "9462525", "title": "日職／閃歐力士？日媒推估徐若熙5月1日回歸一軍對樂天", "summary": "效力軟銀鷹隊的台灣投手徐若熙4月18日被降下二軍，根據日本媒體Sponichi Annex報導，他預計最快會在5月1日起面對樂天金鷲隊的系列賽回歸，閃過前役為他帶來重傷害的歐力士隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887038.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-24 16:16"}, {"article_id": "9462487", "title": "全中運落幕 台南奪120面獎牌、游泳奪多金破紀錄最亮眼", "summary": "115年全國中等學校運動會已於昨天落幕，台南市代表隊表現優異，總計奪得44面金牌、55面銀牌及41面銅牌，共120面獎牌，並締造5項5人次破大會紀錄的佳績，整體表現亮眼，成果豐碩。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34886981.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-24 16:03"}, {"article_id": "9462437", "title": "MLB／教士米勒連33.2局無失分平紀錄 無三振球迷驚：狀況糟糕？", "summary": "聖地牙哥教士火球終結者米勒（Mason Miller）在客場對洛磯之戰意外有登板拿救援點的機會，雖然持續繳出無失分內容，防禦率仍維持驚人的「0.00」，但這場比賽卻出現一項罕見情況—竟然沒有送出任何三振，意外成為外界關注焦點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34886920.jpg&M=1&s=Y&x=0&y=9&sw=1183&sh=788&exp=3600&sl=W&fw=360", "date": "2026-04-24 15:55"}, {"article_id": "9462447", "title": "NBA／雙塔不合問題難解？尼克主帥：盡量不安排同時上場", "summary": "尼克隊今天以108：109輸給老鷹隊，紐約郵報指出一項關鍵原因，唐斯（Karl-Anthony Towns）和羅賓森（Mitchell Robinson）的雙塔組合沒有奏效。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34886938.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-24 15:54"}, {"article_id": "9462453", "title": "中職／兩地延賽…今晚有沒有中職可看只剩寄望亞太鷹獅戰", "summary": "中華職棒今天兩地延賽，桃園棒球場味全龍與樂天桃猿隊之戰、洲際棒球場富邦悍將、中信兄弟隊之戰，都受到雨勢影響無法進行，僅剩台鋼雄鷹、統一獅隊在亞太棒球場交手目前尚未泡湯。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34886969.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-24 15:53"}]}, {"name": "棒球", "articles": [{"article_id": "9463102", "title": "中職／朱迦恩3安打、4打點兩度追平救命 獅隊終止4連敗", "date": "2026-04-24 22:35", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/25/34888608.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9463048", "title": "棒球／陳偉殷拍廣告揭露返台的一天 私下是愛車的熱血男子", "date": "2026-04-24 22:02", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887903.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9462877", "title": "中職／朱迦恩跑出聯盟史上第1萬5000盜 還記得1萬盜是誰嗎？", "date": "2026-04-24 19:25", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/24/34887663.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9462525", "title": "日職／閃歐力士？日媒推估徐若熙5月1日回歸一軍對樂天", "date": "2026-04-24 16:16", "thumbnail": "https://pgw.udn.com.tw/gw