te": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/02/34822898.jpg&M=1&s=Y&x=0&y=38&sw=1280&sh=854&exp=3600&w=300"}, {"article_id": "9441827", "title": "中職／牛棚泡麵組已不復在 中信投手調度應更大膽", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34855380.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9441502", "title": "教士敲響新地獄喪鐘 米勒「火球無雙」展現歷史獨一檔宰制力", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/14/34854881.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9446131", "title": "田徑／開季表現亮眼人氣再爆漲 張博雅緊張到未與許光漢互動", "summary": "我國跨欄甜心張博雅今年開季表現亮眼，除了在室內賽打破全國紀錄外，在室外賽也有亮眼佳績，好表現也吸引了不少國外粉絲的關注，在今天出席活動時張博雅也先感謝國內外粉絲的支持，不過她也強調比賽時都將專注力放在自己身上，包括今天與「男神」許光漢同場剪綵，張博雅也因為緊張到不斷幫自己加油，而未與他有太多互動。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861999.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 16:35"}, {"article_id": "9446080", "title": "MLB／大谷談二刀流和專注投球差異 不確定「可愛女兒」能不能認出自己", "summary": "道奇隊大谷翔平今天專注投球，繳出6局10K失1分好投。賽後他分享專注投球與二刀流的差別，也談到即將滿一歲的女兒。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861919.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 16:18"}, {"article_id": "9445962", "title": "高球／國華啟動綠色高球場元年 攜中興大學柳婉郁教授揭淺山綠色奇蹟", "summary": "北投國華高爾夫俱樂部宣佈啟動「綠色高球元年」，與中興大學合作進行碳盤查，顯示球場已達負碳排並展現多元生態，突破對高球場不環保的刻板印象。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861710.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-16 15:50"}, {"article_id": "9445989", "title": "運動品牌體驗店開幕 陳念琴、張博雅、許光漢見證全新運動文化據點", "summary": "象徵創新與運動精神的Nike台北品牌體驗店，4月於國際地標台北101正式開幕，為共同見證這個全新都市運動基地地誕生，我國拳擊好手陳念琴、田徑跨欄甜心張博雅，以及藝人許光漢今天一同參與剪綵儀式，台北品牌體驗店也將成為激發靈感、感受都市運動活力的舞台。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861723.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 15:40"}, {"article_id": "9445963", "title": "NBA／快艇遭淘汰保羅發梗圖嘲諷！勇士巴特勒和柯瑞「學山羊叫」", "summary": "快艇隊今天在附加賽以121：126輸給勇士隊，本賽季確定告終。季初被快艇球團請回家的「控衛之神」保羅（Chris Paul）在社群平台，發梗圖嘲諷快艇。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861695.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 15:36"}, {"article_id": "9445969", "title": "日職／開季後援出賽5場防禦率6.23 古林睿煬今被抹消一軍登錄", "summary": "日職北海道火腿鬥士隊台灣投手古林睿煬，今年開季前轉任後援，至今出賽5場，防禦率6.23，今天被火腿抹消登錄，目前日職一軍台將剩徐若熙（軟銀）、宋家豪（樂天）及林安可（西武）3人。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861815.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 15:34"}, {"article_id": "9445940", "title": "NBA／柯瑞下半場大爆發 柯爾：這就是他！", "summary": "勇士隊今天靠當家球星柯瑞（Stephen Curry）下半場大爆發，克服第四節最多13分劣勢，硬是以126：121逆轉快艇隊，挺進附加賽最終戰，將和太陽隊爭搭西區季後賽末班車。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861679.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 15:26"}, {"article_id": "9445871", "title": "MLB／培瑞茲陽春砲老虎險勝皇家 巴耶茲絕妙滑壘躲觸殺", "summary": "老虎隊在主場以2：1險勝皇家，外野手培瑞茲在8局下打出關鍵陽春砲，助隊收下5連勝。巴耶茲在3局的滑壘巧妙閃過觸殺助攻得分，展現棒球技巧。總教練辛區對其反應能力表示讚賞。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861578.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 15:10"}, {"article_id": "9445812", "title": "柔道／楊勇緯力退哈薩克好手 闖亞錦賽金牌戰", "summary": "在中國舉行的亞洲柔道錦標賽，世界排名第8的台灣「柔道男神」楊勇緯，今天在男子60公斤級4強戰靠著招牌三角固擊敗哈薩克好手...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861481.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 14:42"}, {"article_id": "9445668", "title": "世足賽／FIFA主席：伊朗篤定會參加今夏世足賽", "summary": "國際足球總會（FIFA）主席英凡提諾（Gianni Infantino）今天證實，儘管目前中東戰爭未歇，伊朗「篤定」將參...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861311.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 14:01"}, {"article_id": "9445692", "title": "MLB／霍納開轟5打點小熊擊潰費城人 今永昇太6局11K奪本季首勝", "summary": "小熊以11比2大勝費城人，今永昇太先發6局僅失1分並奪下本季首勝，霍納貢獻3安打及5打點，史旺森也打出全壘打。費城人左投盧札多遭重擊，失掉9分吞下本季第3敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861253.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 13:55"}, {"article_id": "9445592", "title": "桃園運動卡特約場館僅14家 議員點名「公安門檻」是痛點", "summary": "桃園市去年起推動「運動卡」計畫，鼓勵市民走進公民營運動場館，受益人數突破10萬人，但特約場館目前僅14家，遭民代質疑數量太少、民營場館加入誘因不足。體育局回應，許多場館不願開放非會員進入、加上公安門檻高，是擴充特約場館的主要阻力，將再檢討現行機制與補助模式，提升業者參與意願。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861099.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 13:01"}, {"article_id": "9445581", "title": "MLB／道奇4轟煙火秀 「投手大谷」6局10K收下第2勝", "summary": "道奇隊日籍「二刀流」球星大谷翔平今天單刀出擊，暌違近5年來首次專職投手出賽，今天首度在羅賓森日（Jackie Robinson Day）先發，對上紐約大都會隊主投6局失1分，送出10次三振，道奇打線靠4轟煙火秀以8：2取得3連勝，大谷收下本季第2勝；大都會則是苦吞8連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861101.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-16 12:59"}, {"article_id": "9445570", "title": "NBA／柯瑞35分、霍福特連飆4外線 勇士逆轉快艇附加賽續命", "summary": "快艇隊和勇士隊今天附加賽正面碰頭，勇士第四節上演瘋狂逆轉，老將霍福特（Al Horford）連飆4記三分彈，加上當家球星柯瑞（Stephen Curry）狂轟35分發揮，以126：121打下快艇，再一勝就能挺進季後賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861077.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 12:55"}, {"article_id": "9445467", "title": "NBA／班凱羅談魔術將遇黃蜂 直言例行賽遭「狠狠教訓」", "summary": "魔術在附加賽不敵76人，班凱羅強調對黃蜂必須全力以赴，他表示：「黃蜂已把我們打爆了。」面對爭奪季後賽的關鍵戰，班凱羅需提升表現以求勝利。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34860936.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 12:22"}, {"article_id": "9445476", "title": "MLB／大谷翔平6局10K失1分 連33局無自責分寫日投紀錄", "summary": "洛杉磯道奇隊今天在主場迎戰紐約大都會隊，日籍球星大谷翔平首次在羅賓森日（Jackie Robinson Day）先發登板，身披42號球衣，且是他近五年來首次在擔任先發投手時不上場打擊，繳出6局失1分的表現，送出10次三振，退場時列勝投候選人。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34860942.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 12:17"}, {"article_id": "9445372", "title": "NBA／76人季後賽將第23度交手綠衫軍 諾斯：巨大的挑戰", "summary": "76人隊今天在東區附加賽以12分差距擊敗魔術隊後，以東區第七種子晉級到季後賽首輪，並將與塞爾蒂克隊上演第23度的季後賽交鋒，也是聯盟史上在季後賽碰頭次數最多的兩支球隊，這也讓76人總教練諾斯（Nick Nurse）直言，這個系列賽將會對他們是巨大挑戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34860873.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 11:56"}, {"article_id": "9445318", "title": "MiLB／費爾柴德開轟、3安猛打 李灝宇也敲本季首轟", "summary": "老虎隊3A的台灣野手李灝宇今天敲出本季首轟，紅襪隊3A鄭宗哲2度保送上壘；另外2位台美混血好手同場較勁，守護者隊費柴德單...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34860777.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-16 11:53"}, {"article_id": "9445320", "title": "MLB／教士開幕戰先發皮維塔手肘拉傷 恐缺陣「數週甚至數月」", "summary": "教士開幕戰先發投手皮維塔因右手肘屈肌拉傷進入傷兵名單，缺陣恐數週甚至數月，對陣容影響重大。他曾於昨季表現出色，展現高效能，這次傷勢或需更長時間復原，教士計劃由瓦德隆接替其位置。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34860673.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 11:48"}, {"article_id": "9445256", "title": "NBA／新轉播合約啟動4平台攜手轉播 例行賽收視成長86％", "summary": "NBA全新媒體轉播合約在本賽季正式啟動，其帶來的市場效益遠超預期，根據NBA官方今天公布的例行賽收視報告，本季全美透過各平台觀看比賽的總人數達到1.7億人，不僅較上季成長86%，更寫下聯盟24年來的最高紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34860584.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 11:18"}, {"article_id": "9445182", "title": "MLB／賈吉、楚奧特又同場開砲 洋基游擊手再見安逆轉天使", "summary": "洋基在9局下靠卡波雷拉的再見安打，以5：4逆轉天使。賈吉與楚奧特再次同場開轟，賈吉首局便擊出陽春砲，天使一度反超，但最終無法守住勝利。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34860469.jpg&M=1&s=Y&x=0&y=0&sw=1253&sh=835&exp=3600&sl=W&fw=360", "date": "2026-04-16 11:10"}, {"article_id": "9445178", "title": "TPBL／中信特攻「貘力滿滿Lucky Day」主題周 邊荷律、峮峮登場演出", "summary": "新北中信特攻隊將於本周末18、19日在新莊體育館進行例行賽最後主場，屆時也將盛大舉辦「貘力滿滿Lucky Day」主題日，中信特攻與人氣插畫家cherng 筆下的 LAIMO 馬來貘跨界聯名，LAIMO將化身為最強幸運「貘術師」，與球員、PS女孩一起在新莊球場發威，為「特攻基地」注入滿滿「貘力」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34860451.png&M=1&s=Y&x=0&y=0&sw=960&sh=640&exp=3600&sl=W&fw=360", "date": "2026-04-16 10:58"}, {"article_id": "9445076", "title": "NBA／安比德缺陣馬克西狂飆31分 76人退魔術以東區第7種子晉級", "summary": "東區附加賽魔術隊與76人隊今天上演東區第七種子之爭，兩隊展開一場激烈的拉鋸戰，76人在球隊一哥安比德（Joel Embiid）缺陣的情況下，靠著馬克西（Tyrese Maxey）全場猛轟31分，最終以109：97擊敗魔術，搶下東區第7種子晉級季後賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34860253.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 10:26"}, {"article_id": "9445051", "title": "網球／巴塞隆納贏球後退賽 阿爾卡拉斯重返球王再等等", "summary": "剛讓出世界球王寶座的西班牙「小蠻牛」阿爾卡拉斯（Carlos Alcaraz），本周巴塞隆納公開賽若奪冠就能重登世界第一，但他贏完首輪後進行右手腕檢查，決定退出賽事，代表想搶回球王寶座還要再等等。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34860221.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-16 10:15"}]}, {"name": "棒球", "articles": [{"article_id": "9445969", "title": "日職／開季後援出賽5場防禦率6.23 古林睿煬今被抹消一軍登錄", "date": "2026-04-16 15:34", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34861815.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9446131", "title": "田徑／開季表現亮眼人氣再爆漲 張博雅緊張到未與許光漢互動", "date": "2026-04-16 16:35", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16