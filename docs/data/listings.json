300"}, {"article_id": "9446213", "title": "中職／中信兄弟最爛開季 還展望季後賽嗎？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/16/34862228.jpg&M=1&s=Y&x=0&y=36&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9443464", "title": "美媒揭大都會搶人失敗內幕 但狄亞茲球速下滑道奇虧大了？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/15/34857969.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9452733", "title": "經典賽／返美每場比賽仍見台灣球迷 費爾柴德對中華隊表達感激", "summary": "第6屆世界棒球經典賽已經結束1個多月，官網今天推出台美混血球員費爾柴德（Stuart Fairchild）的專訪，從他本來擔心加入中華隊，到台灣球迷瘋狂支持，都有非常詳盡的報導，這位30歲好手說：「台灣人民對棒球的影響和關心，我在經典賽前完全不知。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872503.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 14:31"}, {"article_id": "9452728", "title": "全障運5月登場 新北推七大服務讓運動無礙", "summary": "2026年全國身心障礙國民運動會將從5月23日至26日在新北市登場，新北市長侯友宜今天主持「賽會有服務」開箱體驗，新北針對選手提供包含器材損壞、身體恢復、交通接駁等，打造「服務型賽會」，也邀請民眾一起來參與這次全國盛會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872491.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-20 14:29"}, {"article_id": "9452698", "title": "棒球／亞運副場地岡崎球場 內野黑土、界外區人工草皮", "summary": "愛知・名古屋亞運將在9月登場，棒球賽事將分在兩個戶外球場進行，主球場為豐橋市民棒球場，今天亞運考察團先至副球場岡崎市民球場進行視察，擔任賽會技術代表的葉志仙指出，場地基本上沒有問題，就是希望能選手村離球場的路程不要太長。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872439.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 14:08"}, {"article_id": "9451916", "title": "NBA／綠衫軍雙槍首戰飆分寫紀錄 泰托姆敬重76人：他們不像傳統第7種子", "summary": "東區季後賽首輪，後勢看漲的波士頓塞爾蒂克以壓倒性勝利痛宰費城76人，最終大勝32分之多，輕鬆在系列賽首戰奪勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872332.jpg&M=1&s=Y&x=73&y=41&sw=1207&sh=804&exp=3600&sl=W&fw=360", "date": "2026-04-20 14:00"}, {"article_id": "9452655", "title": "台灣體壇美少女學霸姊妹 國際花式滑輪溜冰公開賽再創佳績", "summary": "2026年台灣國際花式溜冰公開賽圓滿落幕，姊妹花黃海琍獲得自由型青女組第四名，妹妹黃敏琍在少女組中贏得第二名。她們展示出超凡韌性及潛力，將為即將到來的世錦賽繼續努力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872339.jpg&M=1&s=Y&x=0&y=212&sw=960&sh=640&exp=3600&sl=W&fw=360", "date": "2026-04-20 13:59"}, {"article_id": "9452241", "title": "NBA／曾遭斑馬戲稱「罰球很多」 拓荒者一哥回應：沒太在意", "summary": "今年NBA全明星賽期間，馬刺隊球星「斑馬」溫班亞瑪（Victor Wembanyama）曾對拓荒者隊明星前鋒阿夫迪賈（Deni Avdija）的買犯能力發表了一番尖銳評論。雖然有些人可能認為這是在暗諷，但阿夫迪賈似乎對此毫不在意。在今日馬刺交手拓荒者的首輪季後賽G1前，這位明星前鋒回應了溫班亞瑪的評論表示絲毫不在意，並強調他現在只專注在比賽本身。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871661.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=852&exp=3600&sl=W&fw=360", "date": "2026-04-20 13:35"}, {"article_id": "9452581", "title": "MLB／慘！道奇守護神投0局狂失3分 總教練分析可能「太久沒登板」", "summary": "休賽季獲得3年6900萬美元（約新台幣22億元）大合同的道奇明星終結者狄亞茲（Edwin Diaz），睽違8天再度於今日登板，在面對洛磯比賽第8局登板救援，但他卻1個局數都沒拿就被敲3安狂失3分，賽後防禦率更飆到雙位數。道奇總教練羅伯茲（Dave Roberts）賽後總結，狄亞茲可能因為太久沒上場，所以控球、球速都有些生疏。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872205.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 13:34"}, {"article_id": "9452605", "title": "MiLB／林維恩先發5局8K勇奪2A首勝 表弟柯敬賢1A開轟", "summary": "旅美運動家隊左投林維恩今天小聯盟2A登板，先發飆出8次三振、無失分，奪下2A生涯首勝；洛杉磯道奇隊1A野手柯敬賢維持手感...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872281.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-20 13:32"}, {"article_id": "9452556", "title": "全中運／花蓮洪災後剩1支標槍練習 光復國中田佳恩拚出金牌", "summary": "花蓮光復國中選手田佳恩在全中運男子標槍項目奪得金牌，這面金牌得來不易，因去年光復洪災學校操場被淹沒，標槍剩1支得輪流練習...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872246.jpg&M=1&s=Y&x=0&y=320&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-20 13:22"}, {"article_id": "9452104", "title": "NBA／76人不妙！「大帝」安比德可能缺席整個首輪系列賽", "summary": "根據美媒ESPN記者塞達諾（Jorge Sedano）報導，費城76人隊明星中鋒「大帝」安比德（Joel Embiid）日前因闌尾切除手術缺席附加賽，目前仍尚未恢復籃球訓練。因此記者認為，他很可能將缺席整個76人對塞爾蒂克的東區季後賽首輪系列賽。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871415.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 13:18"}, {"article_id": "9452337", "title": "MLB／大聯盟首秀貢獻2安1打點 「台灣之友」瓦德：感覺真的很棒", "summary": "道奇隊在日前宣布將3A好手瓦德（Ryan Ward）拉上大聯盟，他在今天對洛磯比賽迎來在大聯盟的首次出賽，他也不負眾望交出火燙表現，全場5打數貢獻2安和1分打點。賽後，瓦德也難掩興奮表示在大聯盟出賽的感覺真的很棒。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871808.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 13:11"}, {"article_id": "9452506", "title": "PLG／音樂結合籃球 洋基工程辦嘻哈主題周", "summary": "PLG新球隊洋基工程隊本周4月25日、26日在新竹市立體育館舉辦「洋基嘻哈時代」主題周，兩日賽事分別由晃誼科技與大亞集團冠名支持，攜手結合籃球、音樂與街頭文化元素，規劃多項主題活動與演出內容，邀請球迷一同進場感受方舟主場的嘻哈魅力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872114.jpg&M=1&s=Y&x=0&y=0&sw=1076&sh=717&exp=3600&sl=W&fw=360", "date": "2026-04-20 12:35"}, {"article_id": "9452484", "title": "亞運／射箭場地射向面光 從國內找場地提前適應", "summary": "2026年愛知・名古屋亞運會射箭賽事將在岡崎中央公園綜合多功能廣場進行，考察團今天前往比賽場地進行視察，亞運射箭隊總教練廖健男指出，根據去年來參與模擬賽的經驗，因射向面東邊，選手需要再適應面太陽的環境。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872076.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 12:27"}, {"article_id": "9452452", "title": "日職／徐若熙推算年薪排名高居第6 軟銀5人身價超過5億日圓", "summary": "日本職棒軟銀鷹隊以3年15億日圓（約台幣3億元）合約簽下徐若熙，本季年薪數字並未正式公布，但從日本相關網站的資訊看來，他的身價在所有日職球員排名高居第6，確實相當頂級。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872035.jpg&M=1&s=Y&x=76&y=9&sw=1153&sh=769&exp=3600&sl=W&fw=360", "date": "2026-04-20 12:15"}, {"article_id": "9452383", "title": "NBA／「班馬」季後賽處女秀轟35分破隊史紀錄 馬刺輕取拓荒者", "summary": "入圍年度MVP的馬刺隊當家球星溫班亞瑪（Victor Wembanyama），今天迎接生涯第一場季後賽就頻頻寫紀錄，先是上半場攻下21分創季後賽處女秀半場最高分紀錄，全場轟進35分更超越隊史傳奇「石佛」鄧肯（Tim Duncan）紀錄，並在前輩現場見證下率隊以111：98擊敗拓荒者隊，季後賽開出紅盤。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871898.jpg&M=1&s=Y&x=100&y=51&sw=1180&sh=786&exp=3600&sl=W&fw=360", "date": "2026-04-20 11:53"}, {"article_id": "9452265", "title": "中職／非重磅主題日照樣破萬「新莊城堡」光速累積5場直逼隊史紀錄", "summary": "即便不是重點主題日，新莊棒球場依然湧入破萬人潮，加上上周六、周日兩場比賽，本季在「新莊城堡」已賽8場、5場破萬，富邦悍將隊挑戰去年締造的8場破萬紀錄，機會濃厚。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871702.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-20 11:14"}, {"article_id": "9452256", "title": "MLB／「法官」賈吉開賽特別恐怖 解釋9轟有5轟首局出現之因", "summary": "「法官」賈吉（Aaron Judge）首局轟出兩分砲，萊斯（Ben Rice）2局下跟進陽春砲，洋基隊今天在紐約主場以7：0擊敗皇家隊，完成3連戰橫掃，本季戰績13勝9敗在美聯排名第1，兩人聯手寫下隊史罕見紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871782.jpg&M=1&s=Y&x=26&y=1&sw=1137&sh=757&exp=3600&sl=W&fw=360", "date": "2026-04-20 11:10"}, {"article_id": "9452190", "title": "NBA／G1狂勝太陽35分寫另類紀錄 雷霆：不是想打爆對手", "summary": "去年奪下NBA總冠軍，雷霆隊今年的衛冕路再有強勢起步，今天季後賽首戰以119：84狂勝太陽隊，連兩年的首戰大勝寫下另項紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871713.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-20 10:47"}, {"article_id": "9452180", "title": "MLB／李灝宇置物櫃1罐啤酒掀熱議 美國網友想批評結果逆風了", "summary": "一罐出現在李灝宇置物櫃的啤酒，掀起美國網友討論，發起話題的事主語帶批評，但多數回覆並不認同，認為初登場賽後的啤酒並不值得大驚小怪。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871592.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-20 10:45"}, {"article_id": "9452120", "title": "MLB／守護神威廉斯搞砸戰局 大都會慘吞近22年首次11連敗", "summary": "大都會隊近況慘不忍睹，今天對小熊隊領先到9局下被追平比數，10局下被揮出再見高飛犧牲打，終場以1：2落敗，吞下隊史近22年首次11連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871549.jpg&M=1&s=Y&x=228&y=41&sw=1052&sh=701&exp=3600&sl=W&fw=360", "date": "2026-04-20 10:26"}, {"article_id": "9452095", "title": "NBA／老八魔術狙擊龍頭 活塞慘吞季後賽主場11連敗", "summary": "今年NBA季後賽第一場「下剋上」的賽事出爐，透過附加賽搭上東區晉級末班車的魔術隊，今天在班凱羅（Paolo Banchero）23分、9籃板領軍下，以112：101扳倒頭號種子活塞隊，讓NBA史上最長季後賽主場連敗場次再往上累加。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871411.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-20 10:16"}, {"article_id": "9452087", "title": "MLB／藍鳥開賽連續7安追平隊史 岡本和真加碼開轟屠蛇", "summary": "藍鳥隊今天火力凶猛，開賽連續出現7支安打狂攻5分，打完1局上進帳8分，一路領先到比賽結束，以10：4擊敗響尾蛇隊，終止最近4連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871386.jpg&M=1&s=Y&x=69&y=34&sw=1028&sh=685&exp=3600&sl=W&fw=360", "date": "2026-04-20 10:14"}, {"article_id": "9451939", "title": "NBA／個人獎項入圍名單出爐 斑馬、亞歷山大、約柯奇角逐MVP", "summary": "今年率馬刺隊打下西區第2種子的「法國狀元」溫班亞瑪（Victor Wembanyama），離MVP目標前進了一步，他和上季奪下雙料MVP的雷霆隊亞歷山大（Shai Gilgeous-Alexander），以及拿過3座MVP的金塊隊約柯奇（Nikola Jokic）成為本季年度MVP的最終入選球員，讓年度大獎有機會出現新面孔。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871181.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-20 09:12"}, {"article_id": "9451938", "title": "MLB／生涯前22戰8轟大幅超越大谷 村上宗隆躍居全壘打榜第3", "summary": "白襪隊日本重砲村上宗隆近況火熱，今天對運動家隊之戰5局上轟出兩分砲，本季第8支全壘打出爐，大聯盟生涯前22戰8轟，再創日本球員新紀錄，白襪終場7：4獲勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34871104.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-20 08:58"}]}, {"name": "棒球", "articles": [{"article_id": "9452733", "title": "經典賽／返美每場比賽仍見台灣球迷 費爾柴德對中華隊表達感激", "date": "2026-04-20 14:31", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872503.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9452452", "title": "日職／徐若熙推算年薪排名高居第6 軟銀5人身價超過5億日圓", "date": "2026-04-20 12:15", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/20/34872035.jpg&M=1&s=Y&x=76&y=9&sw=1153&sh=769&exp=3600&w=300"}, {"article_id": "9451265", "title": "中職／每1敗都是連敗開端 兄弟開季15戰1