icle_id": "9432154", "title": "是公平也是球員義務 NBA個人獎出賽65場規定不該有例外！", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/10/34842100.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9429649", "title": "中職／一樣的毛病今年特別早發作 牛棚成中信兄弟戰績大爆彈", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34837440.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=852&exp=3600&w=300"}, {"article_id": "9430252", "title": "從七大指標看MLB超車NBA 成為美國人第二愛看運動？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34837873.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9419212", "title": "經典賽／台灣血脈一線牽 「費仔」用球棒為母親故鄉而戰", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/02/34822502.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9427576", "title": "中職／莫忘日本火腿出走教訓 南市府應修補裂痕與統一共榮", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/07/34834270.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9433560", "title": "NBA／柯瑞輪休、詹姆斯轟26分準大三元 湖人輕取勇士止3連敗", "summary": "近期都飽受傷病所苦的湖人與勇士今天交鋒，不過日前才剛終止4連敗的勇士，在主控柯瑞（Stephen Curry）今天再度缺陣的情況下陷入苦戰，第四節湖人在詹姆斯（LeBron James）領軍下一度取得20分領先優勢，最終湖人也以119：103輕取勇士，終止近期3連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/10/34842902.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-10 12:44"}, {"article_id": "9433512", "title": "籃球／曾在秋田執教阿巴西 中華女籃新任教頭前田4月中報到", "summary": "中華民國籃球協會今天表示，中華民國女子籃球代表隊前教練歐森離隊後，籃協積極洽談並面試多位教練人選，並在運動部及國家運動訓練中心的大力支持下，於1月15日以日本籍教練「前田顯藏Kenzo Maeda」為主要人選通過第13屆中華女籃選訓委員會審議，並於3月4日經國訓中心核定通過，正式於3月12日簽訂合約聘任前田教練作為下一任中華女籃的總教練。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/10/34842821.jpg&M=1&s=Y&x=0&y=0&sw=1275&sh=850&exp=3600&sl=W&fw=360", "date": "2026-04-10 12:19"}, {"article_id": "9433421", "title": "MLB／當道奇王牌遇上任天堂團寵 「山本耀西」娃娃如何引爆熱潮？", "summary": "作為老牌名門、21世紀首個達成連霸壯舉的勁旅，道奇在本賽季首周迎接滿座主場球迷一事並不稀奇。然而，當自家王牌山本由伸，與任天堂人氣角色耀西達成跨界合作、推出「山本耀西」搖頭娃娃時，一場更加瘋狂的球迷盛會，便降臨在了洛杉磯。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/10/34842696.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-10 11:56"}, {"article_id": "9433422", "title": "中職／味全龍台北雙主場平日門票買1送1 投名片抽小龍女點心外送", "summary": "味全龍隊今年擴大推出台北雙主場周間門票買一送一優惠，即日起，針對平日（周一至周五）的天母與台北大巨蛋主場賽事，凡是台北市民、在學學生或上班族，透過味全龍官方售票網線上預訂即可享有指定區域「買一送一」的優惠套票。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/10/34842673.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-10 11:47"}, {"article_id": "9433359", "title": "MLB／美媒預測「魚王」3大下家 運動家可能拿林維恩等人爭取交易", "summary": "馬林魚隊「魚王」阿坎塔拉（Sandy Alcantara）本季大復活，先發3場，投24.1局只失2分，防禦率0.74。美媒《Fox Sports》指出，阿坎塔拉可能在交易市場獲得多隊豐厚報價，運動家隊可能拿包含台灣左投林維恩在內的包裹去問價。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/10/34842545.jpg&M=1&s=Y&x=0&y=57&sw=853&sh=569&exp=3600&sl=W&fw=360", "date": "2026-04-10 11:30"}, {"article_id": "9433330", "title": "NBA／重返傷心地獲尼克球迷支持 泰托姆：這是我必須跨過的坎", "summary": "塞爾蒂克一哥泰托姆（Jayson Tatum）今天重返上季受傷倒下的尼克主場麥迪遜花園廣場，並且在出賽近40分鐘中拿下24分、13籃板、8助攻的亮眼數據，儘管最終塞爾蒂克仍是以106：112不敵尼克，但今天比賽過程中不時有尼克主場球迷為他歡呼，也讓泰托姆直言感激。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/10/34842491.jpg&M=1&s=Y&x=0&y=0&sw=1258&sh=839&exp=3600&sl=W&fw=360", "date": "2026-04-10 11:20"}, {"article_id": "9433215", "title": "MLB／50轟50盜進度緩慢！洋基奇森姆：天氣暖狀態就會回來", "summary": "洋基隊明星二壘手奇森姆（Jazz Chisholm Jr.）開季陷入大低潮，但他今天受訪時自信表示，等天氣回暖後，手感也會暖起來。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/10/34842234.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-10 10:43"}, {"article_id": "9433090", "title": "MLB／讓洋基連17局得分掛蛋！運動家寫47年來首見紀錄", "summary": "洋基隊今天在主場迎戰運動家隊，先發左投韋瑟斯（Ryan Weathers）8局只失1分，但打線連17局掛蛋，終場以0：1慘遭完封，運動家創下47年來首見紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/10/34842081.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-10 10:04"}, {"article_id": "9432858", "title": "NBA／安比德因闌尾炎將動刀 76人季後賽卡位添變數", "summary": "美國職籃NBA費城76人明星中鋒安比德（Joel Embiid）被診斷出罹患闌尾炎，預計16日在休士頓接受手術。76人在...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/10/34841929.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-10 09:19"}, {"article_id": "9432154", "title": "是公平也是球員義務 NBA個人獎出賽65場規定不該有例外！", "summary": "NBA要求個人獎項參賽者至少出賽65場，卻因傷病影響多位明星球員資格。唐西奇和康寧漢因出賽不足，無緣個人榮耀，引發對規定合理性的熱議。這引導對公平競爭和職業態度的深入思考。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/10/34842100.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-10 07:00"}, {"article_id": "9431625", "title": "中職／台南亞太球場並非台北大巨蛋 何不就讓統一獅認養！", "summary": "台南亞太球場與統一獅的認養協商陷入僵局，市政府要求的認養範圍及費用難以達成共識，導致統一獅選擇日租方式使用。中職會長呼籲，透過認養可創造三贏局面，誠邀市府回頭思考。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34840511.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-10 07:00"}, {"article_id": "9432681", "title": "田徑公開賽喊卡 立委批卓揆不放行預算", "summary": "中華民國田徑協會八日宣布，停辦二○二六台灣田徑公開賽，劍指立法院總預算沒過，被迫取消賽事。國民黨立委反擊稱，立法院通過的新興計畫七一八億元中，就包含田協要申請的預算項目，是行政院長卓榮泰不放行，犧牲體育賽事來做政治操作。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/10/34842006.jpg&M=1&s=Y&x=0&y=0&sw=1276&sh=851&exp=3600&sl=W&fw=360", "date": "2026-04-10 00:22"}, {"article_id": "9432679", "title": "觀察站／「雙金部長」李洋上任7個月 還在狀況外", "summary": "運動部在昨天成立滿七個月，兩屆奧運羽球男雙金牌好手李洋頂著光環空降，成為史上首位運動部部長，也是最年輕部長，外界一度期待他能帶給沉痾多時的體育圈全新氣象，不過截至目前為止，李洋的「政壇之路」卻讓人覺得是格格不入。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/10/34841496.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-10 00:18"}, {"article_id": "9432677", "title": "彰縣爭取運動館興建補助 李洋：有發函都會評估", "summary": "運動部長李洋日前出席彰化縣「和美全民運動館」啟用典禮時，因婉拒收下彰化縣長王惠美有關地方體育設施經費爭取文件引發討論。李洋昨表示，當下確實有向王惠美表達預算沒有通過、難以補助，但也詢問王惠美是否有正式發函，如果有的話，運動部都會入案評估。彰化縣府昨不回應。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/10/34841485.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-10 00:11"}, {"article_id": "9432675", "title": "副手閃辭 李洋看報導才知 立委質疑人事遭架空", "summary": "運動部部長李洋昨天上任滿七個月，卻在前往立法院教育及文化委員會進行專題報告時，因為剛升級為世界田徑總會Ｂ級賽事的台灣國際田徑公開賽停辦，以及副手、運動部政務次長鄭世忠閃辭卻不知情一事，遭到立委猛烈轟炸；據了解，鄭世忠疑似因為部內人和、職權問題，自認已經完成階段性任務，決定重返校園。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34841426.jpg&M=2&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-10 00:05"}, {"article_id": "9432477", "title": "全大運／陳玟卉雙破舉重全國紀錄奪金 放眼亞錦賽再突破", "summary": "台灣師大陳玟卉今天出賽115年全國大專校院舉重公開女子組69公斤級決賽，以抓舉108公斤、挺舉130公斤，總和238公斤奪金。值得一提的是，陳玟卉抓舉3把及總和都刷新自己去年締造的全國紀錄，接下來要在5月亞錦賽力拼再舉起更重的重量。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34841274.jpg&M=1&s=Y&x=43&y=0&sw=1139&sh=760&exp=3600&sl=W&fw=360", "date": "2026-04-09 22:14"}, {"article_id": "9432454", "title": "BCL／阿提諾猛轟22分15籃板7助攻 領航猿逆轉香港南華勝場開胡", "summary": "亞洲籃球冠軍聯賽東亞區資格賽（BCL Asia East 2026），桃園璞園領航猿在今天進行分組賽首場比賽對上香港南華，在上半場一度落後的情況下，靠著下半場本土球員甦醒逆轉戰局，最終以79：76擊敗香港南華，奪下首勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34841258.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 22:00"}, {"article_id": "9432280", "title": "田徑／與田協密切溝通 運動部稱將努力爭取復辦台灣公開賽", "summary": "有關「2026年台灣國際田徑公開賽」停辦一事，運動部表示，該賽事為我國重要國際田徑賽事，亦為世界田徑總會認證之積分賽，對我國選手與國際交流具重要意義，經與中華民國田徑協會密切溝通，將向世界田徑總會爭取復辦，運動部也將提供相關協助，朝賽事順利辦理方向努力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34841080.jpg&M=1&s=Y&x=0&y=0&sw=1152&sh=768&exp=3600&sl=W&fw=360", "date": "2026-04-09 20:13"}, {"article_id": "9432262", "title": "日職／宋家豪、古林睿煬第7局接力登板 各投1局飆2K無失分", "summary": "日職樂天金鷲隊與火腿隊今天在仙台進行交手，分屬兩隊的兩名台灣投手接力登板亮相，樂天宋家豪在7局上投出3上3下，7局下火腿古林睿煬登板，同樣連續解決3名打者，兩人各飆出2次三振皆無失分，最終由火腿隊以4：2拿下二連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34841060.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 20:00"}, {"article_id": "9432222", "title": "日職／林安可連10場上壘、中斷連9場安打 西武全場僅1安遭軟銀完封", "summary": "日職西武隊今天繼續作客福岡巨蛋面對軟銀隊，林安可連續兩場比賽被排為先發第6棒、右外野手，但2打數沒有揮出安打，中斷初登場起連9場安打，但靠保送延續連10場出賽上壘。西武隊打線全場首局首打席出現1支安打，終場以0：2遭軟銀完封。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/03/28/34805968.jpg&M=1&s=Y&x=0&y=80&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-09 19:36"}, {"article_id": "9432163", "title": "拳擊／亞運前亞錦賽奪金 陳念琴繼續提身自我", "summary": "我國「拳擊女王」陳念琴今天在亞錦賽女子65公斤決賽和北韓黃孝順（Hyo Sun Hwang，音譯）對決，陳念琴第一回合雖落下風，但調整後第二、三回合打出優勢，最終以4：1逆轉勝，勇奪生涯第2面亞錦賽金牌，為今年名古屋亞運注入強心針。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34840961.jpg&M=1&s=Y&x=0&y=430&sw=853&sh=569&exp=3600&sl=W&fw=360", "date": "2026-04-09 18:58"}, {"article_id": "9432144", "title": "姚連地當選射箭協會新任理事長 盼精進騎馬射箭技藝", "summary": "中華民國射箭協會今於台北選舉新任理事長姚連地，他期盼結合騎馬與射箭技藝。會員大會也選出多位理事，推動射箭運動持續向前發展。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34840940.jpg&M=1&s=Y&x=0&y=69&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 18:45"}, {"article_id": "9432009", "title": "中職／猿隊開季7戰換4人「開路」 第一棒26打數仍是0安打", "summary": "樂天桃猿隊去年拿下隊史第8座總冠軍，也是樂天集團接手後的首冠，但今年開季有多名主力因傷缺陣，球隊仍在依現有陣容排出最佳陣型，目前開季打完7場比賽，排過4名球員擔任開路先鋒，第一棒至今仍是0安打。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/09/34840773.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-09 17:39"}, {"article_id": "9431982", "title": "拳擊／黃筱雯亞錦賽鍍銀 教練：名古屋亞運仍信心滿滿", "summary"