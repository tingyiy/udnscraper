photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062720.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9579234"}, {"article_id": "9579349", "title": "世足攻略／西班牙非勝不可 亞馬爾扮重要角色", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062895.jpg&M=1&s=Y&x=0&y=24&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/122629/9579349"}, {"article_id": "9578142", "title": "世足攻略／日、德兩強掌握主動權 慎防突尼西亞與象牙海岸的變數反撲", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/20/35061239.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9578142"}, {"article_id": "9576652", "title": "世足攻略／巴西沒退路碰海地鐵桶陣忌急躁 美國迎黑馬澳洲應能勝1球", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/19/35059219.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9576652"}, {"article_id": "9575298", "title": "棒球／林羿豪當年赴日是台灣之光 為何歐子喬卻成鑽漏洞？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/18/35057370.jpg&M=1&s=Y&x=0&y=144&sw=917&sh=611&exp=3600&w=300", "link": "/news/story/122629/9575298"}, {"article_id": "9575115", "title": "大聯盟首次台灣對決充滿機緣巧合 鄧愷威、李灝宇18年後接棒王建民", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/16/35047751.png&M=1&s=Y&x=111&y=0&sw=1080&sh=720&exp=3600&w=300", "link": "/news/story/122629/9575115"}]}, {"name": "最新文章", "articles": [{"article_id": "9580023", "title": "MLB／金鶯狂電道奇讓羅伯茲面色凝重 大谷翔平生涯300轟仍差4支", "summary": "道奇先發投手西恩（Emmet Sheehan）陷入低潮，今天對金鶯隊投3.1局失6分退場，牛棚再失6分，道奇從開賽就落後到終場，在洛杉磯主場以1：12慘敗，3連戰讓金鶯帶著2勝離開。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_5.jpg", "date": "2026-06-22 08:37", "link": "/news/story/6999/9580023"}, {"article_id": "9580004", "title": "世足賽／維德角續寫黑馬驚奇 2比2逼平烏拉圭", "summary": "初次闖進世界盃的大西洋小國維德角，處女秀逼平「無敵艦隊」西班牙技驚四座，今天小組賽第2戰再度演出驚奇，面對FIFA世界排名19的南美強權烏拉圭，維德角第21分鐘率先破網，烏拉圭上半場雖連進2球超前，但維德角把握下半場的對手邊線球失誤、攻進追平球，最終以2：2逼和烏拉圭，兩戰都有1分積分進帳。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_7.jpg", "date": "2026-06-22 08:22", "link": "/news/story/123107/9580004"}, {"article_id": "9579987", "title": "MLB／鄧愷威優質先發收拾守護者 終止3連敗奪下第4勝", "summary": "太空人台灣投手鄧愷威今天登板先發，對守護者隊先發6局失1分，優質表現奪下本季第4勝，太空人終場2：1獲勝，艾瓦瑞茲（Yordan Alvarez）本季第25轟出爐，獨居美聯全壘打王。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35063663.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 07:58", "link": "/news/story/6999/9579987"}, {"article_id": "9579234", "title": "中職／天花板高很多時候只是想像！葉君璋評選秀大物一針見血", "summary": "中華職棒新人選秀會即將舉行，報名人數創新紀錄，但外界評估為「選秀小年」。味全龍總教練葉君璋指出，球員潛力不僅依賴天賦，心理素質同樣關鍵。過去被看好的選手許多表現不佳，反而是低順位球員逆襲成星。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35062720.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 07:00", "link": "/news/story/122629/9579234"}, {"article_id": "9579926", "title": "世足賽／比利時狂攻未果吞紅牌 伊朗頑抗守成零比零言和", "summary": "2026年世界盃足球賽G組分組賽於台灣時間6月22日凌晨3點展開，由歐洲紅魔比利時對陣亞洲勁旅伊朗。兩隊在經過90分鐘的激烈交鋒後，均未能攻破對方球門，最終以0比0握手言和。本場比賽雙方防守端表現優異", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35063581.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-22 05:46", "link": "/news/story/123107/9579926"}, {"article_id": "9579909", "title": "世足賽／西班牙掌握絕對優勢 4比0擊潰沙烏地阿拉伯暫居H組榜首", "summary": "2026年6月22日，世界盃足球賽H組分組賽迎來重要對決，由西班牙對陣沙烏地阿拉伯。西班牙展現強大的整體戰力，終場以4比0大勝對手，順利全取三分。本場比賽西班牙在攻守兩端皆展現壓倒性實力，迅速奠定勝基", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35063555.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-06-22 02:50", "link": "/news/story/123107/9579909"}, {"article_id": "9579676", "title": "世足賽／全球經濟大補帖 帶動GDP成長450億美元", "summary": "分析師指出，2026美加墨世界盃足球賽不僅將成為主辦單位國際足總（FIFA）的巨大搖錢樹，也可望成為全球經濟的一大助力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35063283.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 01:22", "link": "/news/story/123107/9579676"}, {"article_id": "9579883", "title": "世足賽／無敵艦隊雪恥！上半場西班牙3比0領先沙烏地阿拉伯", "summary": "身為本屆美加墨世界盃冠軍熱門，「無敵艦隊」西班牙隊小組賽首戰卻被維德角隊意外0：0逼和，今天第二戰立刻拿沙烏地阿拉伯開刀，開賽才10分鐘超級新星亞馬爾（Lamine Yamal）就率先破網，奧亞爾薩巴爾（Mikel Oyarzabal）更在3分鐘內連進兩球，讓西班牙半場就取得3：0絕對領先。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/22/35063494.jpg&M=1&s=Y&x=188&y=44&sw=1072&sh=714&exp=3600&sl=W&fw=360", "date": "2026-06-22 00:58", "link": "/news/story/123107/9579883"}, {"article_id": "9579728", "title": "世足賽／日本「紀錄秀」 打開晉級道路", "summary": "「藍武士」日本昨天在世界盃小組賽第二戰碰突尼西亞，正好是世界盃第一千場比賽，開賽僅四分鐘鎌田大地就幸運進球，締造日本在世界盃最快進球紀錄，上半場攻進日本第二球的上田綺世第八十三分鐘頭錘再破網，成為日本首位世界盃「梅開二度」的選手；最終日本以四比○大勝突尼西亞，隊史首度單場攻進四球，本屆勝場開張。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35063323.jpg&M=1&s=Y&x=0&y=0&sw=1010&sh=673&exp=3600&sl=W&fw=360", "date": "2026-06-22 00:00", "link": "/news/story/123107/9579728"}, {"article_id": "9579731", "title": "世足賽／溫達夫「工人」登世足 夢幻絕殺象牙海岸", "summary": "廿九歲才首度登上世界盃舞台的德國替補前鋒溫達夫，首戰就有進球紀錄，昨天碰象牙海岸更成致勝英雄，「梅開二度」包括傷停補時的進球，助四屆冠軍以二比一「絕殺」象牙海岸，小組賽二連勝、提前晉級卅二強淘汰賽，寫下工人登上足壇最大舞台的勵志故事。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35063325.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 00:00", "link": "/news/story/123107/9579731"}, {"article_id": "9579732", "title": "煮茶論戰／對手實力差距 造就古拉索「門神」", "summary": "古拉索首度登上世界盃舞台，門將羅姆第一戰被四屆冠軍德國攻進七球，第二戰碰厄瓜多卻寫下紀錄，以十五次撲救創世界盃一九六六年來非加時賽單場撲救次數新紀錄，兩場比賽呈現巨大反差，除了本身實力，對手的差距也是關鍵。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35063407.jpg&M=1&s=Y&x=0&y=49&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-22 00:00", "link": "/news/story/123107/9579732"}, {"article_id": "9579586", "title": "中職／張育成打打停停仍率先10轟 想幫李東洺延續連勝有壓力", "summary": "富邦悍將重砲張育成今年因傷打打停停，但沒影響他的長程砲火，今天對上樂天桃猿隊，3局上轟出陽春全壘打，近3戰敲3轟，成為今年率先10轟的打者，他笑說：「可能休息夠了吧，力量也滿足夠的。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35063192.jpg&M=1&s=Y&x=0&y=0&sw=975&sh=650&exp=3600&sl=W&fw=360", "date": "2026-06-21 21:12", "link": "/news/story/7001/9579586"}, {"article_id": "9579557", "title": "中職／李東洺8局收工沒挑戰首場完投 下一場再拚半季10勝", "summary": "富邦悍將隊本土王牌李東洺今天先發出戰樂天桃猿隊，生涯首度投滿8局、失1分，在用球數91球後被換下場，由守護神曾峻岳登板替他關門，成功收下先發9連勝，再次獨居聯盟勝投王。李東洺賽後坦言，沒想過要挑戰生涯首場完投，「看能投幾局就投幾局。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35063167.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-21 20:53", "link": "/news/story/7001/9579557"}, {"article_id": "9579523", "title": "體操／唐嘉鴻分數新高摘金自評90分 放閃愛妻驚喜相伴", "summary": "台灣男子體操好手唐嘉鴻，今天在亞洲錦標賽單槓決賽，以打破個人生涯新高的15.500分摘金，這個分數也是今年正式國際賽事最...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35063128.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-21 20:28", "link": "/news/story/7005/9579523"}, {"article_id": "9579520", "title": "田徑／亞運培訓隊好消息！亞洲接力賽飆出全國新紀錄", "summary": "2026年第二屆亞洲接力錦標賽（2nd Asian Relays Championships）今天在浙江進行最終日賽程，由賴柏翔、陳玟溥、黃左軍和葛吳諺明組成的中華男子接力隊，在男子400公尺接力決賽飆出38秒41的全國紀錄，也為中華隊帶回一面銅牌。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35063116.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-06-21 20:18", "link": "/news/story/7005/9579520"}, {"article_id": "9579513", "title": "中職／李東洺8局失1分奪9連勝、張育成敲第10轟 悍將上半季30勝到手！", "summary": "富邦悍將隊今天在在桃園球場以3：1勝出擊敗樂天桃猿隊，拿下近期3連勝，半季30勝達陣。本土王牌李東洺主投8局失1分投出生涯最長一役，拿下先發9連勝，打線則有張育成開砲，上半季第10轟出爐；猿隊則吞下4連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/21/35063107.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "202