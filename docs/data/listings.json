/pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/19/34869519.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9450968", "title": "日職／新庄剛志雖老神在在 仍須找到恐鷹症解方", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/2026/01/08/0/34125459.jpg&x=&y=&sw=&sh=&exp=3600&w=300"}, {"article_id": "9448636", "title": "冠軍老將終極合體！太陽致命弱點被抓到 勇士可掌握最強優勢", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/17/34865828.jpg&M=1&s=Y&x=192&y=0&sw=935&sh=624&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9455030", "title": "NBA／防守悍將梅爾頓表態願續留勇士 但不急於立刻做決定", "summary": "金州勇士球員梅爾頓表達願意續留球隊，但不急於做出決定。他稱讚總教練柯爾，並強調會與經紀人討論未來選擇。目前他正面臨合約選擇權，並希望能持續為勇士效力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876102.jpg&M=1&s=Y&x=0&y=14&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 14:37"}, {"article_id": "9455051", "title": "PLG／飆出得分新高 領航猿葛拉漢奪單周MVP", "summary": "PLG今天公布2025-26球季第26周單周最佳球員，由上周斬獲個人例行賽新高的桃園璞園領航猿洋將葛拉漢榮獲此殊榮。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876108.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-21 14:34"}, {"article_id": "9454808", "title": "亞運／參訪團考察羽球場館 奧運雙金李洋被籌委會認出", "summary": "名古屋亞運參訪團今天到羽球場地一宮市綜合體育館勘查，從羽球選手退役的運動部長李洋，不但仔細詢問設備、動線等細節，還被亞運...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875991.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 14:14"}, {"article_id": "9454971", "title": "NBA／56年來第一人！麥凱倫飆分寫老鷹隊史神紀錄：我必須站出來", "summary": "麥凱倫全場出賽35分鐘，22投12中高效攻下32分，外帶6助攻3籃板2抄截，不僅全面掌控進攻節奏，更在比賽最後關鍵時刻挺身而出，多次穩定得分幫助球隊守住領先優勢。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875971.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-21 14:13"}, {"article_id": "9454896", "title": "NBA／勇士老將霍福特鬆口考慮退役 休季決定是否執行選擇權", "summary": "金州勇士老將霍福特在季後訪談中透露考慮退役。儘管遭遇傷病困擾，本季表現仍不俗，三分命中率達36.1%。他將與家人討論是否執行選擇權，或尋求新機會。霍福特強調會謹慎決定，並對球隊經歷表達感激。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875855.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 13:53"}, {"article_id": "9454864", "title": "NBA／約柯奇末節失常只拿2分 金塊慘遭灰狼逆轉系列賽平手", "summary": "金塊隊今天在季後賽首輪G2主場迎戰灰狼隊，當家球星約柯奇（Nikola Jokic）末節失常只攻下2分，末節慘遭灰狼逆轉，以114：119輸球。系列賽形成1比1平手，接下來兩戰將移師到灰狼主場進行。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875790.jpg&M=1&s=Y&x=191&y=256&sw=895&sh=597&exp=3600&sl=W&fw=360", "date": "2026-04-21 13:36"}, {"article_id": "9454814", "title": "NBA／庫明加成老鷹逆轉尼克奇兵！紐媒痛批唐斯：最需要的時候沒影響力", "summary": "尼克隊今天浪費三節打完領先12分，末節慘遭老鷹隊逆轉，季後賽首輪戰成1比1平手。「紐約郵報」賽後點名尼克明星長人唐斯（Karl-Anthony Towns），關鍵時刻未能挺身而出。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875700.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-21 13:15"}, {"article_id": "9454756", "title": "MLB／小熊主帥不滿「大谷條款」僅道奇受惠 羅伯茲：其他隊也能找二刀流", "summary": "小熊總教練康索對「大谷條款」表示不滿，認為該規則僅惠及道奇隊，並使小熊在投手傷兵情況下承受壓力。道奇教練羅伯茲則強調，其他隊伍若能找到類似球員，也能享有同樣的優勢。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875626.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 12:55"}, {"article_id": "9454755", "title": "全中運／嘉義縣角力新秀穩健成長 朴子國中黃珞旖奪金", "summary": "嘉義縣角力代表隊在今年全中運表現亮眼，朴子國中選手黃珞旖在開幕儀式擔任聖火手，並在國女組自由式第五級賽事中穩定發揮，一路過關斬將摘下金牌，成為賽會焦點。黃珞旖與擔任教練的父親黃俊勝合影，父女檔臉上露出開心笑容，展現多年共同訓練成果。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875612.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 12:46"}, {"article_id": "9454716", "title": "NBA／18投僅5中照樣打爆太陽！SGA揭密「買犯」關鍵：我大量切入", "summary": "在季後賽首輪系列賽首戰中，雷霆以119比84大勝鳳凰城太陽，當家球星亞歷山大（Shai Gilgeous-Alexander）再次展現MVP級影響力，不僅繳出全能數據，更憑藉頻繁切入製造大量犯規，帶給對手不少麻煩。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875566.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-21 12:36"}, {"article_id": "9454601", "title": "NBA／勇士全隊唯一全勤！ 波傑姆斯基盼提前續約長留灣區", "summary": "金州勇士後衛波傑姆斯基希望儘快與球隊完成合約延長，表示希望長期留在灣區。他本季表現亮眼，場均13.8分且全勤出賽82場，已展現成為勇士未來重要拼圖的潛力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875434.jpg&M=1&s=Y&x=0&y=8&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-21 12:32"}, {"article_id": "9454684", "title": "體操／提三訴求要求停止片面抹黑 小師大學員家長：別讓孩子淪為工具", "summary": "人本教育基金會今天與立委聯手指控台師大教練翁士航與麥劉湘涵霸凌體操隊成員與小師大小學員，不過多項針對兩人的指控都遭到小師大學員家長否認，並提出三項訴求，包括還原事情真相、在調查出爐前請各界停止抹黑，以及把焦點回到孩子成長上，不要淪為各方工具。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875189.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 12:22"}, {"article_id": "9454669", "title": "宏道基金會盼善意回歸制度 已將奧運獎金領據寄給李洋", "summary": "針對外界關心宏道運動發展基金會頒發奧運奪牌選手獎金予運動部長李洋一事，宏道運動發展基金會今天特此說明相關立場、制度原則及法規依據，並強調已經將獎金簽收領據快遞至運動部給部長李洋。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875549.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 12:16"}, {"article_id": "9454649", "title": "MLB／瑞格利球場去年鵝築巢、今年鵝守備 見球來從踱步變快逃", "summary": "芝加哥瑞格利球場（Wrigley Field）再度有鵝現蹤，今天這隻甚至會守外野，比賽在鵝仍於外野草皮踱步情況下繼續進行，直到小熊隊布許（Michael Busch）敲出左外野方向安打嚇得牠振翅快逃。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875478.jpg&M=1&s=Y&x=0&y=135&sw=1024&sh=683&exp=3600&sl=W&fw=360", "date": "2026-04-21 12:14"}, {"article_id": "9454646", "title": "中職／飛力獅改披黃衫取名「菲力士」今日抵台 兄弟相準即戰力", "summary": "中信兄弟球團今日正式公布，與去年效力統一獅隊的洋投飛力獅達成合約共識，譯名改為「菲力士」。球團期盼藉由菲力士卓越的職棒經驗與去年在台的宰制力，能夠攜手隊內的洋投戰力與本土先發群，共同組成更穩固的先發防線，進一步厚植球隊的先發輪值深度。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875465.png&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&sl=W&fw=360", "date": "2026-04-21 12:07"}, {"article_id": "9454472", "title": "MLB／洋基斯萊特勒將回芬威球場先發 收到紅襪迷死亡威脅不在意", "summary": "洋基投手斯萊特勒在面對死亡威脅後，仍期待於芬威球場首度登板，並不畏懼紅襪球迷的激烈反應。他已做好迎接對抗氛圍的準備，並強調將以表現回應挑釁。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875136.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-21 12:04"}, {"article_id": "9454617", "title": "NBA／湖人女老闆對唐西奇「特別好感」 原因與Kobe有關", "summary": "湖人隊前老闆珍妮巴斯（Jeanie Buss）最近受訪時透露，對當家球星唐西奇（Luka Doncic）有特別的好感，與已故傳奇球星布萊恩（Kobe Bryant）有關。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875408.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 12:01"}, {"article_id": "9454603", "title": "體操／打臉人本禁上廁所指控 小師大學員家長：我每天都在沒人來問我", "summary": "人本教育基金會今天與立委聯手指控台師大教練翁士航、麥劉湘涵霸凌體操隊成員與小師大小學員，不過多名遭到點名遭霸凌的家長一起出席由翁士航召開的記者會聲援教練，其中一名兒子被指控教練禁止上廁所導致兩次失禁的家長就表示，自己與太太過去一年半每次都到場陪伴兒子訓練，會失禁只是小孩玩到忍不住，並非如人本所指控的遭教練禁止上廁所。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875372.jpg&M=1&s=Y&x=0&y=0&sw=720&sh=480&exp=3600&sl=W&fw=360", "date": "2026-04-21 11:54"}, {"article_id": "9454582", "title": "飛鏢／打破負面標籤！亞洲國際飛鏢公開賽周末花博登場", "summary": "第13屆亞洲國際飛鏢公開賽（Asia International Darts Tournament Taiwan）將於25、26日在台北花博公園爭豔館登場，中保科技持續贊助推廣全民運動，讓飛鏢成為人人都能上手的運動，董事長林建涵相信，飛鏢可以讓人們打破科技隔閡，讓運動不僅限於競技，更像一場溫暖的家庭聚會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875313.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 11:46"}, {"article_id": "9454560", "title": "體操／家長、學員到場力挺 翁士航澄清、提申訴：希望呈現事件全貌", "summary": "台師大體操隊教練翁士航、麥劉湘涵今天遭到立委與人本教育基金會指控霸凌與性平案，當事人翁士航在台師大學生與小師大學生家長聲援下召開記者會澄清，強調台師大體操隊絕不存在霸凌情事，希望調查過程能夠多聽各方說法，讓事件回歸全貌。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875287.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 11:41"}, {"article_id": "9454551", "title": "全中運／熱浪下逆襲 金門林于辛1500公尺跑出4分08秒43勇奪金牌", "summary": "115年全國中等學校運動會在嘉義市昨日進入第二天賽程，烈嶼國中林于辛在國中男子組1500公尺決賽跑出4分08秒43奪金，為金門縣及烈嶼國中勇奪首面田徑金牌。賽後他氣喘未平，第一句話卻是「真的很熱，但我一直告訴自己要撐住，最後一圈一定要衝。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875231.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 11:38"}, {"article_id": "9454524", "title": "MLB／大谷1安打、2保送連52場上壘平亞洲紀錄 道奇5轟終止2連敗", "summary": "大谷翔平今天4打數敲1安打，另有2次保送上壘（含1次故意四壞），他的連續上壘紀錄再達到一項里程碑，以52場追平韓籍打者秋信守在2018年締造的亞洲紀錄，而道奇終場以12：3擊敗洛磯隊，終止2連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875216.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 11:34"}, {"article_id": "9454469", "title": "NBA／尼克第四節進攻崩盤 老鷹逆轉1分險勝扳平系列賽", "summary": "三節打完落後12分的老鷹隊上演驚奇逆轉，在麥凱倫（CJ McCollum）第四節連進3球下打出單節28：15的反撲攻勢，加上尼克隊最後一擊失手，讓老鷹首輪季後賽第2戰踢館成功，以107：106擊敗尼克，將系列賽1比1扳平。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875149.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 11:16"}, {"article_id": "9454456", "title": "體操／翁士航、台師大體操隊遭控霸凌 唐嘉鴻：非當事人不多作評論", "summary": "台師大體操隊教練翁士航與助理教練麥劉湘涵遭指控霸凌，過去在翁士航指導下在巴黎奧運奪下銅牌佳績的「世界貓王」唐嘉鴻，今天也透過經紀公司表示，唐嘉鴻與翁士航已在巴黎奧運後結束合作關係，並回到國訓中心訓練，由於已進入調查程序，且本人並非當事者，故不便多作評論。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875146.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 11:15"}]}, {"name": "棒球", "articles": [{"article_id": "9454646", "title": "中職／飛力獅改披黃衫取名「菲力士」今日抵台 兄弟相準即戰力", "date": "2026-04-21 12:07", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34875465.png&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&w=300"}, {"article_id": "9453235", "title": "中職／林辰勳回憶高中對決李灝宇 點不服輸勇敢拚特質", "date": "2026-04-20 18:45", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc