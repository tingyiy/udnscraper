ttps://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35075805.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/122629/9587895"}, {"article_id": "9586137", "title": "費城人王牌惠勒越老越強 生涯成績已與柯爾黃金交叉", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073506.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9586137"}, {"article_id": "9586124", "title": "高中生旅外潮牽動U18布局 賴謙凡加盟洋基後下一個誰圓夢？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35073201.jpg&M=1&x=&y=&sw=&sh=&exp=3600&w=300", "link": "/news/story/122629/9586124"}, {"article_id": "9585761", "title": "世足攻略／巴西要靠球星破蘇格蘭鐵桶估贏2球 南韓非贏不可要防南非逼平", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072655.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/122629/9585761"}, {"article_id": "9585536", "title": "輕則驚嚇、重則破網！阿根廷隊友相信梅西禁區左腳給的承諾", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/24/35072449.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9585536"}]}, {"name": "最新文章", "articles": [{"article_id": "9588651", "title": "中職／悍將簽新洋投仍等威戈神 後藤光尊：因為付很多錢", "summary": "中華職棒富邦悍將隊今天宣布簽下新洋投瑪帝斯，不過仍在等待二軍的威戈神回歸，悍將總教練後藤光尊誠實回答：「因為球隊付了很多...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35077073.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 18:45", "link": "/news/story/7001/9588651"}, {"article_id": "9588663", "title": "國訓董事長林鴻道請辭南下揮別亞運培訓隊 林郁婷、林俊易代表致意", "summary": "國家運動訓練中心董事會本月23日召開董事會議，董事長林鴻道於會中正式提出辭去董事長職務，今天特地南下國家運動訓練中心，向長期並肩努力的亞運培訓隊教練、選手及行政團隊辭別，並親自感謝大家多年來對國家競技運動發展的投入與付出，勉勵全體教練、選手持續專注訓練、勇於挑戰自我，在即將到來的名古屋亞洲運動會全力以赴，為國爭光。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35077074.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 18:45", "link": "/news/story/7005/9588663"}, {"article_id": "9588623", "title": "中職／蔣銲有國外球團關注 龍隊：目標留到年底", "summary": "味全龍隊奪得今年中華職棒上半季冠軍，洋投戰力是關鍵之一，其中防禦率1.44的蔣銲傳出有國外職棒球隊關注，龍隊透露目前合約...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35077068.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 18:43", "link": "/news/story/7001/9588623"}, {"article_id": "9588558", "title": "高球／台灣第一座！國華摘下高球界「綠色奧斯卡認證」", "summary": "北投國華高爾夫俱樂部成為台灣首座獲得GEO Certified®國際認證的球場，此認證僅有全球不到2%的高球場取得，象徵台灣高爾夫產業邁向永續發展的里程碑。國華致力於環境保護，強調將更好的土地傳承給未來世代。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076862.jpg&M=1&s=Y&x=0&y=103&sw=1082&sh=721&exp=3600&sl=W&fw=360", "date": "2026-06-25 18:07", "link": "/news/story/7005/9588558"}, {"article_id": "9588477", "title": "中職／「爐主之爭」台中象猿戰因雨延賽 上、下半季無縫接軌", "summary": "中華職棒上半季進入補賽周，但碰上颱風外圍環流影響，許多地區下起大雨，賽程持續受影響，今天原訂在台中洲際棒球場進行中信兄弟與樂天桃猿的「爐主之爭」，比賽因雨延至7月2日舉行，上、下半季宣告「無縫接軌」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076814.jpg&M=1&s=Y&x=109&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-06-25 17:21", "link": "/news/story/7001/9588477"}, {"article_id": "9588446", "title": "NBA／拓荒者新主帥僅獲一年保障約 活塞教練認為價值被貶低", "summary": "拓荒者新任主帥諾里僅獲得一年保障合約，引發活塞教練比克斯塔夫不滿，直言此合約貶低教練價值。比克斯塔夫提到，教練無法建立威信，將影響球員責任感。新老闆鄧頓的做法引發廣泛關注。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076680.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 17:15", "link": "/news/story/7002/9588446"}, {"article_id": "9588142", "title": "世足運彩／土耳其進攻0進球難擋美國2連勝氣勢 GPT推薦美國不讓分勝與大分", "summary": "世界盃D組小組賽，土耳其將對陣美國。美國已兩戰全勝、攻入6球，土耳其則遭遇兩敗且未進一球，士氣低落。投注建議美國不讓分勝，並預測總進球數3球以上。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076704.jpg&M=1&s=Y&x=0&y=0&sw=1250&sh=833&exp=3600&sl=W&fw=360", "date": "2026-06-25 17:15", "link": "/news/story/123105/9588142"}, {"article_id": "9588141", "title": "世足運彩／美國預計輪休與土耳其變五五波 Gemini推薦「和局」具獲利空間", "summary": "美國隊在世足小組賽對土耳其預計將輪休主力，導致雙方實力接近。賠率顯示和局機會高，預測最終比分可能為1:1。整體戰術或將陷入互相試探的拉鋸戰，缺乏求勝動機。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076674.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-25 17:07", "link": "/news/story/123105/9588141"}, {"article_id": "9588134", "title": "世足運彩／和局賠率異常壓低顯示莊家在防範 Gemini預測巴澳生死戰1：1言和", "summary": "巴拉圭與澳洲將於世足賽生死戰中對決，兩隊皆需防守穩健以爭取16強門票。預計比賽節奏緩慢，中場將展開激烈肉搏，賠率顯示和局機率極高，最終預測以1比1握手言和。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076591.jpg&M=1&s=Y&x=0&y=0&sw=1257&sh=838&exp=3600&sl=W&fw=360", "date": "2026-06-25 16:54", "link": "/news/story/123105/9588134"}, {"article_id": "9588391", "title": "NBA／勇士選秀拿2側翼補強缺口！柯瑞幽默歡迎小老弟", "summary": "勇士隊昨天用首輪第11順位，選進23歲前鋒倫德伯格（Yaxel Lendeborg），沒想到倫德伯格竟自爆，自己曾經很討厭柯瑞（Stephen Curry）。今天柯瑞在倫德伯格的IG貼文下，留言歡迎這位小老弟加入灣區大軍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076577.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-25 16:52", "link": "/news/story/7002/9588391"}, {"article_id": "9588135", "title": "世足運彩／巴拉圭對澳洲出線壓力逼出保守盤勢 GPT看好「和局」機率最高", "summary": "巴拉圭與澳洲展開生死戰，雙方積分相同，競爭出線壓力高漲。賠率顯示和局可能性大，巴拉圭勝2.96、和局2.215、澳洲勝4.175，球隊在進攻與防守上優勢互抵。此役投注方向以和局最具價值，建議參考比分1比1。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076549.jpg&M=1&s=Y&x=0&y=0&sw=1259&sh=839&exp=3600&sl=W&fw=360", "date": "2026-06-25 16:44", "link": "/news/story/123105/9588135"}, {"article_id": "9588315", "title": "世足運彩／土耳其使盡全力 要攻破美國大門得分推大分", "summary": "美國隊已確定晉級，將於6月26日對陣土耳其，主教練波切蒂諾將進行陣容輪換，休息多名主力。土耳其雖然陣中有多位明星球員，但預賽全敗，仍需努力爭取進球。預測本場比賽將出現2.5大分。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076524.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 16:40", "link": "/news/story/123105/9588315"}, {"article_id": "9588307", "title": "世界盃男籃／FIBA評亞洲區資格賽戰力 中華排第八南韓已遭看扁落居12", "summary": "FIBA官網公布中華男籃戰力排名第八，核心成員包括高柏鎧、盧峻翔與阿巴西。第三階段資格賽將挑戰中國和南韓，其中南韓主力李賢重可能缺席，提升中華隊勝算。中國隊則持平第二，期待楊瀚森的表現。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076431.jpg&M=1&s=Y&x=0&y=75&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 16:33", "link": "/news/story/7003/9588307"}, {"article_id": "9588320", "title": "棒球／四國菁英對抗賽下月11日台中開打 U23培訓隊戰美、日、韓大學明星", "summary": "由中華民國棒球協會及台中市政府共同主辦、中國信託冠名支持的「中國信託2026年四國菁英棒球對抗賽」，將於7月11日至15日在台中洲際棒球場盛大舉行。賽事邀集台灣、美國、日本及韓國四支青年菁英代表隊同場競技，透過高水準國際交流，展現亞洲與美洲新生代棒球好手的實力與潛力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076440.jpg&M=1&s=Y&x=0&y=0&sw=1073&sh=716&exp=3600&sl=W&fw=360", "date": "2026-06-25 16:19", "link": "/news/story/7001/9588320"}, {"article_id": "9588183", "title": "世足賽／貝林漢遮嘴說話竟沒被罰 法國名將質疑有巨星待遇", "summary": "英格蘭球星貝林漢在世足賽中被拍到遮嘴說話，卻未遭紅牌處罰，引發外界質疑是否存在雙重標準。巴拉圭隊已向FIFA提出申訴，強調應一視同仁。法國名將亨利批評此為對明星球員的特殊待遇。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076177.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 16:17", "link": "/news/story/123107/9588183"}, {"article_id": "9588130", "title": "世足運彩／瑞典冷門賠率仍有想像 但日本優勢明確GPT看好2:1或3:1", "summary": "瑞典客勝被抬到3.673，冷門空間確實存在，但這個價格更像莊家給高波動球隊的誘惑，而不是對瑞典真正勝算的肯定。日本不讓分勝賠2.13，沒有被壓到過熱，反而保留盤口投資價值；和局3.503也提醒，莊家並", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076411.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 16:17", "link": "/news/story/123105/9588130"}, {"article_id": "9588129", "title": "世足運彩／藍武士穩健攻防壓瑞典防線 分組關鍵大分戰Gemini推日本2:1或3:1", "summary": "2026年世界盃F組迎來出線關鍵對決，兩隊近期狀態與士氣呈現黃金交叉。「藍武士」日本隊憑藉穩健的戰術體系，前兩輪小組賽拿下1勝1和，攻防兩端展現極高紀律性，團隊士氣正值高點；反觀「北歐海盜」瑞典隊前兩", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076379.jpg&M=1&s=Y&x=0&y=0&sw=1221&sh=814&exp=3600&sl=W&fw=360", "date": "2026-06-25 16:10", "link": "/news/story/123105/9588129"}, {"article_id": "9588127", "title": "世足運彩／突尼西亞連連大敗 橙衣軍團誓奪分組龍頭Gemini上看荷蘭3:0或4:0", "summary": "突尼西亞在小組賽遭遇兩連敗，防線漏洞百出、狂丟9球，士氣已然徹底崩盤且提前遭到淘汰；反觀「橙衣軍團」荷蘭目前以1勝1和暫居小組榜首，球員鬥志高昂、攻勢流暢，全隊正處於爭奪分組龍頭的最佳狀態，兩隊在士氣", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076360.jpg&M=1&s=Y&x=0&y=2&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-25 16:02", "link": "/news/story/123105/9588127"}, {"article_id": "9588124", "title": "世足運彩／古拉索恐難敵象牙海岸狂轟猛炸 Gemini推薦3：0或3：1", "summary": "在2026世界盃E組小組賽即將迎來的關鍵對決中，古拉索與象牙海岸的交鋒呈現出截然不同的心理狀態。坐鎮主場的古拉索，首戰遭到德國以7比1血洗，防線脆弱的心理陰影揮之不去，場均失球高達2.2球的數據，更讓", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076339.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 15:55", "link": "/news/story/123105/9588124"}, {"article_id": "9588126", "title": "世足運彩／突尼西亞防線崩盤 遇對手爭龍頭搶分壓力GPT推荷蘭不讓分及2.5大", "summary": "突尼西亞兩戰全敗、進1球失9球，所謂主隊身分很難轉化成心理優勢，反而像是背著提前出局陰影上場；荷蘭1勝1和、進7球失3球，仍要鞏固F組前段位置，客場作戰的壓力反而更接近推進力。\n\n國際不讓分平均賠率開", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076322.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 15:52", "link": "/news/story/123105/9588126"}, {"article_id": "9588123", "title": "世足運彩／攻守推進層級與排名差距都優於古拉索 GPT看好象牙海岸不讓分勝、3球以上", "summary": "象牙海岸在世足賽面對古拉索，實力優勢明顯，有望不讓分勝出。古拉索若無法全取3分，將面臨出線危機。賠率顯示市場對象牙海岸勝出的信心，投注總進球數可選3球以上。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076304.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 15:50", "link": "/news/story/123105/9588123"}, {"article_id": "9588117", "title": "世足運彩／厄瓜多有冷門想像空間但火力落差太大 GPT看好德國不讓分勝、3球以上", "summary": "2026年世足賽中，厄瓜多面對德國的比賽吸引關注。雖然厄瓜多有搶分需求，卻因德國火力強大，且歷史交手優勢明顯，投注重點在德國不讓分勝及3球以上。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076225.jpg&M=1&s=Y&x=0&y=0&sw=1270&sh=847&exp=3600&sl=W&fw=360", "date": "2026-06-25 15:36", "link": "/news/story/123105/9588117"}, {"article_id": "9588050", "title": "NBA／赫洛女友曾是新隊友庫茲瑪戀人 成公鹿休息室另類風波", "summary": "赫洛因交易從熱火加盟公鹿，與前隊友庫茲瑪成為新隊友。赫洛的女友亨利曾與庫茲瑪交往，為公鹿休息室增添話題。亨利和赫洛共同育有兩名孩子，儘管曾引發分手傳聞，但目前兩人關係依然穩定。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076005.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-25 15:33", "link": "/news/story/7002/9588050"}, {"article_id": "9588184", "title": "世足運彩／日耳曼戰車啟動 厄瓜多全力進攻求饒推德國不讓分", "summary": "2026世界盃小組賽E組，德國隊已鎖定小組第一，將對戰亟需取勝的厄瓜多。厄瓜多在兩場比賽中未能進球，面對德國的強勁攻勢，有幾分困難。主教練納格爾斯曼預計將進行主力輪換，或為厄瓜多創造機會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076191.jpg&M=1&s=Y&x=108&y=0&sw=1078&sh=719&exp=3600&sl=W&fw=360", "date": "2026-06-25 15:32", "link": "/news/story/123105/9588184"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9587810", "title": "世足賽／小組晉級戰況更新：巴西搶下分組龍頭 南韓需看別人臉色", "date": "2026-06-25 13:43", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35075680.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9587810"}, {"article_id": "9588034", "title": "世足賽／拔掉孫興慜先發卻輸南非 南韓教頭扛責：令人遺憾的結果", "date": "2026-06-25 14:35", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35076146.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9588034"}, {"article_id": "9587846", "title": "世足賽／國家隊「最後一舞」 墨西哥門神奧喬亞：享受一切", "date": "2026-06-25 13:37", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/25/35075714.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/123107/9587846"}, {"artic