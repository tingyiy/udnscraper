ate": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34943951.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9507994", "title": "MLB／大谷翔平首支三壘打貢獻新高5打點 道奇痛宰天使奪4連勝", "summary": "洛杉磯道奇日籍球星大谷翔平在客場面對老東家天使之戰全面爆發，擔任先發第1棒指定打擊的他，全場4打數敲出2支安打、選到2次保送，貢獻本季單場新高5分打點，外加1次盜壘成功，帶領道奇以15比2痛宰天使，收下4連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955068.jpg&M=1&s=Y&x=122&y=27&sw=1158&sh=772&exp=3600&sl=W&fw=360", "date": "2026-05-17 13:17"}, {"article_id": "9507935", "title": "MLB／單季投球31局創新高 鄧愷威想為球隊多吃局數", "summary": "休士頓太空人隊台灣投手鄧愷威今天先發5局、7次三振無失分奪勝，本季投球局數累計31局，寫下生涯新高。鄧愷威表示，無論是先...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955051.jpg&M=1&s=Y&x=42&y=22&sw=1220&sh=813&exp=3600&sl=W&fw=360", "date": "2026-05-17 13:05"}, {"article_id": "9507959", "title": "棒球／沒說一句「請來火腿」 栗山當年留住大谷靠掛保證：更快上MLB", "summary": "世界棒球經典賽冠軍教頭、大谷翔平恩師栗山英樹，透過棒球講座分享自己的棒球經驗，談到當年如何將高中生大谷翔平留在日本職棒，他透露從頭到尾沒說過任何一句「請來火腿」，而是向他分析，為何透過日職體系養成，會讓他更快站上大聯盟。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954995.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 12:48"}, {"article_id": "9507911", "title": "LPGA／皇后鎮錦標賽第3天 徐薇淩排名跌至第60", "summary": "LPGA皇后鎮錦標賽今天結束第3回合激戰，台灣好手徐薇淩抓4博蒂、吞4柏忌外帶1次雙柏忌繳出72桿，並以3天高於標準3桿...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954936.jpg&M=1&s=Y&x=0&y=17&sw=1100&sh=733&exp=3600&sl=W&fw=360", "date": "2026-05-17 12:20"}, {"article_id": "9507859", "title": "NBA／談落選新人王 克努佩爾讚好友佛雷格「完全配得上獎項」", "summary": "上個月底NBA頒布「年度新人王」獎項，獨行俠新科狀元「旗子哥」佛雷格（Cooper Flagg）以26分極小差距，擠下昔日杜克隊友、呼聲同樣很高的黃蜂神射手克努佩爾（Kon Knueppel）。近期，克努佩爾在上節目中談到落選一事，除表示已經盡全力了，並強調沒有任何遺憾。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954838.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 12:10"}, {"article_id": "9507908", "title": "棒球／栗山英樹看WBC台韓激戰也深受感動 「用靈魂在比賽」", "summary": "世界棒球經典賽冠軍教頭栗山英樹，應「中信60甲子緣」棒球特展之邀來台，今天舉辦棒球講座，談到中華隊在今年世界棒球賽最後一場預賽與南韓隊的交手，他看了也深受感動，「已經超越技術層面，是用靈魂在比賽。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954916.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 12:10"}, {"article_id": "9507893", "title": "影／中信60周年棒球特展揭幕 蔣萬安盼台灣棒球持續發光", "summary": "中國信託成立60周年，特別策畫「中信60甲子緣」棒球特展，5月19日起至6月21日在中國信託多功能會場展出，回顧台灣棒球百年發展史和中國信託投入五級棒球的成果，向台灣棒球精神致敬。台北市長蔣萬安出席致詞，特別感謝中國信託及各界長年支持台灣棒球，期許台灣棒球能在基層扎根、職棒推動與國際賽舞台上持續發光。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954898.jpg&M=1&s=Y&x=0&y=0&sw=1238&sh=825&exp=3600&sl=W&fw=360", "date": "2026-05-17 11:57"}, {"article_id": "9507885", "title": "棒球／「中信60甲子緣」揭幕 蔣萬安、辜仲諒學王貞治打擊", "summary": "中國信託成立60周年，策畫「中信60甲子緣」棒球特展，台北市長蔣萬安出席揭幕儀式，與中國信託慈善基金會董事長辜仲諒一起觀展，面對鏡頭重現稻草人打擊法。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954883.jpg&M=1&s=Y&x=0&y=208&sw=987&sh=658&exp=3600&sl=W&fw=360", "date": "2026-05-17 11:51"}, {"article_id": "9507789", "title": "NBA／季後賽證明油箱還有油 灰狼38歲老將康利將「再戰一年」", "summary": "灰狼昨天在西區次輪G6以109：139大比分落敗馬刺，賽季宣告結束。經美媒報導指出，灰狼陣中38歲老將控衛康利（Mike Conley）不會退役，將續戰一年，這也意味著下賽季將是他NBA職業生涯的第20個球季。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954731.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-17 11:42"}, {"article_id": "9507822", "title": "MLB／村上宗隆首演雙響砲！新人年17轟超越松井 瞄準大谷翔平紀錄", "summary": "芝加哥白襪日籍重砲村上宗隆火力持續全面爆發。今日在主場迎戰同城對手小熊隊的「芝加哥大戰」中，擔任先發第2棒、一壘手的村上繳出3打數2安打、3分打點、1次保送成績，更是大聯盟生涯首度轟出雙響砲，率隊拿下勝利。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954787.jpg&M=1&s=Y&x=0&y=8&sw=1215&sh=810&exp=3600&sl=W&fw=360", "date": "2026-05-17 11:19"}, {"article_id": "9507610", "title": "世足賽／伊朗隊放眼世界盃 前往土耳其集訓、申請美簽", "summary": "伊朗國家足球隊總教練蓋勒諾伊（Amir Ghalenoei）今天表示，國腳們將於18日前往土耳其進行集訓、踢友誼賽，並在...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954670.jpg&M=1&s=Y&x=17&y=0&sw=1256&sh=837&exp=3600&sl=W&fw=360", "date": "2026-05-17 10:32"}, {"article_id": "9507650", "title": "MiLB／蘇嵐鴻生涯首秀新人聯盟先發2局 廖宥霖首安出爐", "summary": "19歲投手蘇嵐鴻旅美加盟聖地牙哥教士隊，今天新人聯盟首場先發亮相，投2局4K無失分，無關勝敗；密爾瓦基釀酒人隊18歲野手...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954651.jpg&M=1&s=Y&x=51&y=193&sw=1150&sh=767&exp=3600&sl=W&fw=360", "date": "2026-05-17 10:24"}, {"article_id": "9507736", "title": "角力／紐約奪金放眼亞運 張惠慈從禁賽浴火重生", "summary": "2025年底的美國紐約公開賽，我國角力張惠慈在女子自由式76公斤級接連擊敗美、加強敵，站上最高頒獎台。今年24歲的她，臉上帶著歷盡風霜後的從容，因為就在五年前，她幾乎已經放棄了一切。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954645.jpg&M=1&s=Y&x=0&y=448&sw=959&sh=640&exp=3600&sl=W&fw=360", "date": "2026-05-17 10:22"}, {"article_id": "9507735", "title": "角力／醫界葉問接理事長 名醫選手帶來改革遠景", "summary": "全國小學生角力賽本周末在台東縣立體育館登場，共有三百多名小學生角力選手齊集台東。場上小選手們在場上奮力角逐，場邊家長與教練的加油聲此起彼落，台灣角力運動新的掌舵者、中華民國角力協會新任理事長何宗融也親臨會場，他盼透過在偏鄉舉辦國小賽事，從小選手扎根，並營造環境，幫助好選手在奧運中奪牌。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954662.jpg&M=1&s=Y&x=0&y=314&sw=960&sh=640&exp=3600&sl=W&fw=360", "date": "2026-05-17 10:22"}, {"article_id": "9507691", "title": "MLB／招牌橫掃球製造6成揮空率 鄧愷威屢化解堆壘危機", "summary": "太空人隊台灣投手鄧愷威今天面對遊騎兵隊，送出5次四死球、屢屢上演「劇場」，但靠著7次三振投出本季新高的5局無失分，幫助太...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954630.jpg&M=1&s=Y&x=0&y=80&sw=1079&sh=719&exp=3600&sl=W&fw=360", "date": "2026-05-17 10:21"}, {"article_id": "9507715", "title": "NBA／活塞搶七大戰添變數？ 3名球員因傷被列入出戰成疑", "summary": "活塞、騎士目前在東區次輪賽事戰成3：3平手，明天兩隊將上演關鍵生死戰。然而，在G7開打前夕，活塞在稍早公布隊中多達3名球員因傷勢，被列入出戰成疑名單（Questionable），分別是羅賓森（Duncan Robinson）、勒佛特（Caris LeVert）與赫爾特（Kevin Huerter）。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954618.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 10:16"}, {"article_id": "9507696", "title": "羅馬女網／回福地奪暌違8年冠軍 烏克蘭媽媽球員寫個人里程碑", "summary": "羅馬堪稱烏克蘭媽媽球員史維托莉娜（Elina Svitolina）「福地」，今天羅馬女網賽決賽，她經歷將近3小時的馬拉松大戰，以6：4、6：7（3：7）、6：2力退美國名將高芙（Coco Gauff），迎接暌違8年的WTA1000分級大賽金盃。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954626.jpg&M=1&s=Y&x=0&y=53&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-17 10:02"}, {"article_id": "9507671", "title": "MLB／鄧愷威5局7K無失分技壓狄葛隆 勇奪本季首場先發勝", "summary": "休士頓太空人隊今天在主場與德州遊擊兵隊上演「德州內戰」，27歲台灣投手鄧愷威先發上陣，主投5局0失分，送出7次三振，技壓先發6局挨4轟的塞揚強投狄葛隆（Jacob deGrom），最終太空人4：1勝出，鄧愷威拿下本季首場先發勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954516.jpg&M=1&s=Y&x=184&y=0&sw=841&sh=561&exp=3600&sl=W&fw=360", "date": "2026-05-17 09:53"}, {"article_id": "9507603", "title": "NBA／回歸接受完整訓練 阿努諾比期待東冠開戰", "summary": "儘管傷了主戰前鋒阿努諾比（OG Anunoby），尼克隊季後賽第二輪仍花4戰就「橫掃」76人隊，阿努諾比今天也加入球隊訓練，且透露右大腿傷勢沒有兩年前的嚴重。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954402.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-05-17 08:54"}, {"article_id": "9507595", "title": "MLB／鄧愷威先發5局飆7K無失分 太空人打線敲4轟助他取得勝投資格", "summary": "太空人隊27歲台灣投手鄧愷威本季第3度先發，今天在主場出戰德州遊騎兵隊，主投5局0失分，寫下本季最長投球局數，僅被敲2安、飆8次三振，隊友也用4轟砲擊賽揚強投狄葛隆（Jacob deGrom），前5局就打下4：0領先，讓鄧愷威帶著勝投候選人身份退場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954500.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-05-17 08:46"}, {"article_id": "9507564", "title": "MLB／因應藍鳥「假先發」 李灝宇首扛第3棒僅獲1打席但有精彩雙殺", "summary": "底特律老虎隊今天在主場迎戰多倫多藍鳥隊，面對藍鳥排出的「假先發」左投弗勒哈蒂（Mason Fluharty），李灝宇生涯首度被排進中心打線，擔任先發第3棒、三壘手，但僅獲1打席就被換代打退場，老虎隊最終則是在延長賽第10局以1：2落敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954350.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-17 07:54"}, {"article_id": "9507067", "title": "76人慘遭尼克橫掃，安比德核心體系為何始終走不遠？", "summary": "當尼克在第二輪用四場比賽橫掃76人時，外界其實沒有太多「爆冷」的震驚感。因為系列賽內容看起來，雙方確實不像同一個層級的球隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/16/34953653.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 07:00"}, {"article_id": "9507196", "title": "運動人生／李協興 醫師轉身視障鐵人", "summary": "方向對了 路就不遠了", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/16/34953832.jpg&M=1&s=Y&x=0&y=0&sw=941&sh=628&exp=3600&sl=W&fw=360", "date": "2026-05-17 00:00"}, {"article_id": "9507203", "title": "運動人生／「因禍得福」 運動給他重生勇氣", "summary": "「失明不是突如其來的，是一段長達七、八年的過程，有時上個月看書還很清楚，這個月就變得模糊。」鐵人三項視障選手李協興，談到自己從骨科醫師到喪失視力的人生，不斷重複著說「因禍得福」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/16/34953847.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 00:00"}]}, {"name": "棒球", "articles": [{"article_id": "9507908", "title": "棒球／栗山英樹看WBC台韓激戰也深受感動 「用靈魂在比賽」", "date": "2026-05-17 12:10", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954916.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&w=300"}, {"article_id": "9507959", "title": "棒球／沒說一句「請來火腿」 栗山當年留住大谷靠掛保證：更快上MLB", "date": "2026-05-17 12:48", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954995.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&w=300"}, {"article_id": "9507893", "title": "影／中信60周年棒球特展揭幕 蔣萬安盼台灣棒球持續發光", "date": "2026-05-17 11:57", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954898.jpg&M=1&s=Y&x=0&y=0&sw=1238&sh=825&exp=3600&w=300"}, {"article_id": "9507885", "title": "棒球／「中信60甲子緣」揭幕 蔣萬安、辜仲諒學王貞治打擊", "date": "2026-05-17 11:51", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954883.jpg&M=1&s=Y&x=