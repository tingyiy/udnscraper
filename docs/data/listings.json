to.php?u=https://uc.udn.com.tw/photo/t3/2026/04/01/34817067.jpg&M=1&s=Y&x=425&y=1&sw=480&sh=320&exp=3600&w=300"}, {"article_id": "9497981", "title": "最頂擊球品質換不回一轟 塔提斯真的純粹是運氣差嗎？", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940085.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9498591", "title": "中職／富邦補強林岱安成效浮現 刺激戴培峰成「超級捕手」", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/12/34940808.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9503071", "title": "NBA／熱火有望成交易「字母哥」第一順位 美記者點出交易時機", "summary": "公鹿球星安戴托昆波交易傳聞不斷，記者曼尼克斯指出，熱火將成為首選球隊。若公鹿無法與字母哥續約，交易將可能在選秀會前完成。熱火擁有多名潛力新秀和未來的選秀權，令球迷期待。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34947984.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 16:50"}, {"article_id": "9502999", "title": "NBA／活塞明星中鋒決勝期被冰起來 杜倫自知需打得更好", "summary": "活塞在系列賽第五戰延長賽以113：117不敵騎士，明星中鋒杜倫上場25分鐘後在決勝期被棄用，表現不佳。他坦言需更加努力，也讚揚替補里德的出色表現。活塞目前系列賽2：3落後，面臨背水一戰的壓力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34947824.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 16:26"}, {"article_id": "9502971", "title": "MLB／大谷坦言不在意防禦率數字 道奇記者盛讚：地球最好投手", "summary": "大谷翔平今天熱投105球，繳出7局無失分好投，防禦率0.82暫居大聯盟第1。對此大谷表示，自己不太會去在意數字。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34947781.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-14 16:06"}, {"article_id": "9502874", "title": "中職／悍將推「李阿勇」搞怪毛巾 李雅英鬥雞眼笑翻粉絲喊收藏", "summary": "富邦悍將推出隱藏版「李阿勇」毛巾，以李雅英的鬥雞眼搞怪照片吸引球迷關注。這款新商品將於5月15日正式販售，激發了粉絲熱烈討論及搶購熱潮。李雅英喜愛「阿勇」稱號，展現其活潑形象。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34947640.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 15:40"}, {"article_id": "9502894", "title": "網球／謝淑薇羅馬止步第二輪 下一站法網拚第三冠", "summary": "2023年一起拿下法網女雙冠軍的我國「一姊」謝淑薇和中國「金花」王欣瑜，相隔近3年在羅馬女網賽重新攜手，首輪就拍下第3種子，但第二輪不敵俄羅斯組合，無緣8強。「海峽組合」接續將挑戰法網，尋求謝淑薇生涯第3座紅土大滿貫金盃。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/10/34934188.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-14 15:36"}, {"article_id": "9502734", "title": "MLB／戰績慘大都會傷兵再加一 主戰捕手艾瓦瑞茲右膝動刀休6到8週", "summary": "大都會主戰捕手艾瓦瑞茲因右膝半月板撕裂動刀，預計缺席6到8週，對球隊造成重大打擊。他在對老虎比賽中受傷，將面臨長期休養，暫由托倫斯擔任先發捕手。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34947367.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 15:33"}, {"article_id": "9502843", "title": "中職／桃猿為「蹭票蹭飯」爭議發聲！籃籃感動轉發、球迷力挺", "summary": "樂天桃猿隊應援團推進隊長籃籃最近被爆料，今年3月經典賽期間，把綜藝大哥胡瓜當成工具人，樂天球團今天發聲力挺籃籃，讓他非常感動。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34947573.jpg&M=1&s=Y&x=269&y=36&sw=810&sh=540&exp=3600&sl=W&fw=360", "date": "2026-05-14 15:22"}, {"article_id": "9502803", "title": "泰國羽賽／台灣女雙內戰 胡綾芳、鄭宇倢組合晉8強", "summary": "BWF超級500系列泰國羽球公開賽今天進行的女雙16強上演台灣內戰，胡綾芳與鄭宇倢以21比13、21比14擊敗大會第3種...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34947577.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 15:18"}, {"article_id": "9502758", "title": "世足賽／美放寬簽證規定 球隊與參賽國球迷免繳保證金", "summary": "2026世界盃倒數1個月，美國今天宣布放寬世足賽期間的簽證保證金規定，除了參與球員及隨團人員，來自參賽國、持門票並登記的...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34947519.jpg&M=1&s=Y&x=0&y=25&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 15:06"}, {"article_id": "9502763", "title": "MLB／還年輕想繼續「二刀流」 大谷談打擊低潮：單純實力不足", "summary": "洛杉磯道奇隊31歲日籍球星大谷翔平今天在主場迎戰巨人隊，對舊金山巨人隊先發7局無失分，送出8次三振，拿下本季第3勝，雖是投手「單刀」出擊，但他賽後坦言，自己還是想要持續以「二刀流」身份繼續努力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34947432.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 14:45"}, {"article_id": "9502687", "title": "MLB／鄧愷威下一次出賽是先發！太空人記者曝17日對遊騎兵", "summary": "太空人隊台灣右投鄧愷威最近轉先發，隨隊記者羅姆（Chandler Rome）和卡瓦哈拉（Matt Kawahara）都發文提到，鄧愷威將在17日先發對上遊騎兵隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34947283.jpg&M=1&s=Y&x=282&y=23&sw=763&sh=509&exp=3600&sl=W&fw=360", "date": "2026-05-14 14:24"}, {"article_id": "9502616", "title": "MLB／扶不起的天使！被守護者橫掃開季輸了28場續當大聯盟爐主", "summary": "大聯盟天使隊今日以2：4不敵守護者，遭橫掃並創下28場失利，領跑大聯盟。首局即落後，投手德特莫斯表現不佳，最終天使戰績墊底。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34947111.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 14:20"}, {"article_id": "9502667", "title": "TPBL／攻城獅在地經營有成 年度主場、吉祥物雙包", "summary": "台灣職業籃球大聯盟（TPBL）今天公布2025-26賽季年度主場與年度吉祥物獎項，新竹御嵿攻城獅隊包辦兩大獎，其中今年新增的年度吉祥物獎項由球團吉祥物「瑞迪」奪下肯定，展現本季場內外的高人氣。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34947226.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-05-14 14:12"}, {"article_id": "9502529", "title": "NBA／幫勇士湖人奪冠領不到正式合約 2冠後衛嘆：經紀人太爛", "summary": "33歲後衛庫克（Quinn Cook）曾幫勇士和湖人隊拿下冠軍，最近他在社群平台有感而發，感嘆自己的經紀人太爛，讓3年2冠的他領不到保障合約。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34946979.jpg&M=1&s=Y&x=262&y=73&sw=907&sh=605&exp=3600&sl=W&fw=360", "date": "2026-05-14 13:32"}, {"article_id": "9502531", "title": "NBA／OT挺身助騎士聽牌 米契爾：我不需要一個人扛", "summary": "騎士今天在東區季後賽第二輪第五戰，與活塞一路拚戰到延長賽，最終靠著整場比賽手感不佳的米契爾（Donovan Mitchell）在延長賽的及時甦醒以4分差距勝出，成為系列賽首支在主場贏球的球隊，賽後米契爾也強調，即使整場比賽手感不佳，但只要輪到自己時，隨時都會整裝待發。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34946967.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 13:27"}, {"article_id": "9502436", "title": "MLB／「投手大谷」開季7戰ERA0.82登頂 替道奇終止4連敗", "summary": "道奇隊日籍球星大谷翔平今天先發登板，只投不打「單刀出擊」，面對巨人隊投7局無失分，送出8次三振，率領道奇4：0完封巨人，終止近期4連敗，「投手大谷」也以防禦率0.82重新登上大聯盟防禦率王。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34946788.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 12:47"}, {"article_id": "9502362", "title": "MLB／前洋基「痛痛人」與前妻鬧翻！遭指控「尿在洗髮精瓶」", "summary": "前洋基隊投手「痛痛人」帕瓦諾（Carl Pavano）與前妻艾莉莎（Alissa Pavano）因婚前協議爭議鬧上法庭，如今有更多不堪入目的細節曝光，他被指控尿進前妻的洗髮精瓶，還弄髒前妻的床。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34946664.jpg&M=1&s=Y&x=0&y=0&sw=1219&sh=812&exp=3600&sl=W&fw=360", "date": "2026-05-14 12:27"}, {"article_id": "9502361", "title": "MLB／隊友、對手都有幫忙 大谷「單刀」登板7局8K無失分", "summary": "道奇隊日籍球星大谷翔平，今天以投手身分出戰巨人隊，這次他本季第4次、連續第3次在先發登板時「單刀出擊」只投不打，主投7局，用了本季新高的105球，送出8次三振，沒有失分，道奇打線也用雙轟替他打下分數，7局打完道奇4：0領先。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34946645.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 12:20"}, {"article_id": "9502331", "title": "MLB／外野手瓦修10局下敲再見滿貫 藍鳥逆轉光芒逃過橫掃", "summary": "藍鳥在主場靠外野手瓦修的再見滿貫砲，以5：3逆轉光芒，避免系列賽橫掃。比賽前9局雙方僵持不下，延長賽藍鳥連續保送，最終瓦修擊出本季第5轟，助隊取得勝利。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34946570.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 12:19"}, {"article_id": "9502214", "title": "MLB／海瓦德重返道奇加入制服組 羅伯茲：對休息室很熟悉", "summary": "前明星外野手海瓦德（Jason Heyward）退休不到兩個月就重返棒球界，將但任道奇隊棒球營運部門特別助理。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34946376.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 11:43"}, {"article_id": "9502125", "title": "MiLB／火球男潘文輝高階1A首戰飆速157 今年出賽7場已飆16K", "summary": "潘文輝在高A首戰以98英里（約157.7公里）的球速登板，無失分並送出兩次三振，成功復出。此次登板為他在小聯盟的第七場比賽，至今已累積16K，投出2勝，防禦率4.70。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34946238.jpg&M=1&s=Y&x=0&y=35&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-14 11:29"}, {"article_id": "9502114", "title": "中職／味全龍×LG雙子聯名主題日 26、27日大巨蛋入場贈品曝光", "summary": "味全龍在5月26、27日在台北大巨蛋的主場賽事，將舉辦與南韓職棒人氣球隊LG TWINS的聯名主題日「Red가자!」，除了規劃場內外活動與韓式應援外，也特別準備兩隊聯名的精美入場贈品，發送給指定區域與票種的進場球迷。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34946204.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-05-14 11:16"}, {"article_id": "9502113", "title": "NBA／米契爾OT甦醒連得7分 騎士天王山之戰攻破活塞先聽牌", "summary": "系列賽前4場比賽打完戰成平手的活塞與騎士隊，今天在活塞主場上演「天王山之戰」，兩隊在一路拉鋸的情況下也進入到延長賽，延長賽整場比賽手感不佳的騎士米契爾（Donovan Mitchell）即時甦醒一度連得7分，加上哈登（James Harden）的關鍵罰球，最終騎士就以117：113擊敗活塞，系列賽取得3：2聽牌。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34946214.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 11:16"}, {"article_id": "9502059", "title": "MLB／對最會打左投的勇士繳優質先發 今永昇太7局失2分仍吞敗", "summary": "小熊隊日籍左投今永昇太今天先發登板，面對全聯盟最會打左投的勇士隊，繳出7局失2分的優質先發，送出6次三振，但勇士在第8局超前分數，終場以4：1勝出，成為大聯盟本季率先拿到30勝的隊伍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34946135.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-14 10:59"}]}, {"name": "棒球", "articles": [{"article_id": "9502843", "title": "中職／桃猿為「蹭票蹭飯」爭議發聲！籃籃感動轉發、球迷力挺", "date": "2026-05-14 15:22", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34947573.jpg&M=1&s=Y&x=269&y=36&sw=810&sh=540&exp=3600&w=300"}, {"article_id": "9501834", "title": "中職／鄭浩均被打爆仍嘻嘻哈哈 李杜軒痛批：替兄弟球迷感到不值", "date": "2026-05-14 10:05", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34945739.jpg&M=1&s=Y&x=251&y=22&sw=786&sh=524&exp=3600&w=300"}, {"article_id": "9502874", "title": "中職／悍將推「李阿勇」搞怪毛巾 李雅英鬥雞眼笑翻粉絲喊收藏", "date": "2026-05-14 15:40", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/