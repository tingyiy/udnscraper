dn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/07/34834230.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9426854", "title": "日職／改後援全因輪值太滿 古林轉牛棚並非不合理但還有變數", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/07/34833317.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300"}, {"article_id": "9419212", "title": "經典賽／台灣血脈一線牽 「費仔」用球棒為母親故鄉而戰", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/02/34822502.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9424998", "title": "日職／成績在洋砲排中段班 林安可還需加強得點圈及長打力", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830714.jpg&M=1&s=Y&x=154&y=0&sw=1080&sh=720&exp=3600&w=300"}, {"article_id": "9425072", "title": "最對味的柯瑞回來了！為勇士帶來季後賽能量和幻想", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830788.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9429462", "title": "日職／徐若熙前5局挨1轟、被林安可敲1安 前5局軟銀0：1落後西武", "summary": "日職福岡軟銀隊台灣投手徐若熙本季第2場出賽，首度在軟銀主場福岡巨蛋登板，首局挨了一發陽春全壘打首度失分，之後雖局局讓打者上壘，但都能化解危機，其中兩度對決林安可，被揮出1支安打，前5局打完，軟銀隊0：1落後。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34837204.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 18:22"}, {"article_id": "9429309", "title": "不斷更新／徐若熙投完5局送出3K只失1分 軟銀0:1落後西武", "summary": "日本職棒軟銀隊台灣投手徐若熙今天下午5點先發登板，將與西武獅隊台灣強打林安可交手。兩人都是今年從中華職棒轉戰日職舞台，因此這次對戰備受台日球迷關注。西武派出旅美失敗的高橋光成擔任先發投手。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836983.jpg&M=1&s=Y&x=0&y=42&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-08 18:06"}, {"article_id": "9429340", "title": "MLB／9局遭換下無緣完封 「魚王」阿坎塔拉質疑換投調度", "summary": "馬林魚的「魚王」阿坎塔拉在對紅人的比賽中前8局未失分，但在第9局遭換下，引發質疑。最終馬林魚在延長賽以3：6落敗，阿坎塔拉賽後感到不滿，強調希望能有繼續投球的機會。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836916.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 16:57"}, {"article_id": "9429329", "title": "日職／徐若熙主場先發迎接「台灣對決」 林安可第6棒、右外野手", "summary": "日職軟銀隊今天在主場福岡巨蛋迎戰西武獅隊，台灣強投徐若熙本季第二場登板、首次主場出賽；西武隊強打林安可則是擔任西武獅隊第6棒、右外野手，將上演本季日職一軍首次「台灣對決」。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836889.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 16:42"}, {"article_id": "9429230", "title": "NBA／勇士是今年效力第4隊 奈及利亞「賣雞」中鋒：工作是提供活力", "summary": "25歲奈及利亞中鋒貝西（Charles Bassey）日前與勇士隊簽約，第2次披上勇士戰袍就上場27分鐘，拿下14分12籃板2抄截2火鍋，幫助勇士以110：105險勝國王，貝西優異的表現受到教練及隊友盛讚。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836635.jpg&M=1&s=Y&x=575&y=330&sw=683&sh=455&exp=3600&sl=W&fw=360", "date": "2026-04-08 15:58"}, {"article_id": "9429205", "title": "MLB／太空人王牌出狀況 布朗右肩拉傷將缺陣數週", "summary": "太空人王牌投手布朗因右肩二級拉傷將缺陣數週，已被放入15天傷兵名單。總教練艾斯帕達表示，布朗肩膀不適，球團將於兩週後檢查情況。他的缺席將對太空人的連戰挑戰造成影響。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836594.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 15:44"}, {"article_id": "9429194", "title": "羽球／第54屆清晨盃燃戰火 「麟洋配」周日將合體", "summary": "邁入第54屆的世界清晨盃暨吳文達紀念盃羽球錦標賽今天點燃戰火，今年賽事吸引來自世界26國好手齊聚台北，總共參賽人數將近6千人，運動部部長李洋也將與會，周日更預計和奧運金牌搭檔王齊麟重新合體，再現「麟洋配」風采。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836564.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 15:35"}, {"article_id": "9429149", "title": "擊劍／備戰亞運！台師大好手李讓首度出征大運會 記者會獲邀出席", "summary": "全國大專校院運動會於8日舉行聖火引燃儀式，台灣師範大學擊劍好手李讓受邀出席。他誓言為校爭光，瞄準金牌，並全力爭取名古屋亞運參賽資格。李讓將參加匈牙利大獎賽及瑞士世界盃，為亞運做準備。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836481.jpg&M=1&s=Y&x=0&y=443&sw=919&sh=613&exp=3600&sl=W&fw=360", "date": "2026-04-08 15:21"}, {"article_id": "9429092", "title": "NBA／巫師雙星合體等明年 楊恩、戴維斯本季不再出賽", "summary": "巫師總教練基夫宣布，季中交易來的戴維斯與楊恩本季將不再出賽，雙星合體將等到明年。戴維斯因手傷未能回歸，楊恩則因腿傷提前關機，巫師本季以17勝62敗垫底。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836428.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 14:56"}, {"article_id": "9429084", "title": "花蓮秀姑巒溪泛舟鐵人三項吸千人參戰 南區觀光熱度提前升溫", "summary": "今年「秀姑巒溪泛舟鐵人三項」將於6月在花蓮縣瑞穗鄉登場，儘管報名尚未截止，已吸引逾千人報名參加，賽事前夕周邊住宿更接近滿房，帶動地方觀光市場，業者看好賽事效益，期待進一步擴散至花蓮其他地區。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836360.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 14:42"}, {"article_id": "9429063", "title": "跳水／中國體壇醜聞！全紅嬋遭國家隊選手、裁判「集體霸凌」協會發聲了", "summary": "該群組有多位大咖成員，包含中國跳水選手陳芋汐、昌雅妮、陳藝文、龍道一、楊健等，央視體育記者楊爍、跳水國際裁判饒琅及選手家屬。幾乎無人敢制止群內霸凌言論，據傳一位澳門跳水選手看不下去退群，遭群內成員集體攻擊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836335.png&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 14:41"}, {"article_id": "9429071", "title": "中職／AirAsia亞洲航空與味全龍攜手合作 打造天母「航空主題日」", "summary": "中華職棒味全龍隊將在4月17日至19日在天母棒球場推出「亞洲領航，氣勢如紅 Batter up， Buckle up聯名航空主題日」與AirAsia亞洲航空跨界合作，正式開啟航空品牌與台灣棒球文化的全新合作。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836329.png&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-08 14:37"}, {"article_id": "9428999", "title": "MLB／勇士、天使大亂鬥！索勒不爽近身球與前隊友羅培茲大打出手", "summary": "勇士與天使今日比賽驚現大亂鬥，天使外野手索勒與勇士投手羅培茲因投球衝突而揮拳相向，導致雙方板凳清空。最終，勇士以7：2贏得比賽，兩人皆遭驅逐出場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836229.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 14:29"}, {"article_id": "9429017", "title": "羽球亞錦賽／連三組台將不敵第二種子 戚又仁先闖關", "summary": "2026年羽球亞錦賽在中國寧波點燃戰火，中華隊男雙「麟榤配」王齊麟／邱相榤、女單「一姊」邱品蒨和男單李佳豪接連在有轉播的第一球場上陣，但三組台將都抽到第2種子，最終都沒能闖關，只有另外場地的混雙許尹鏸／陳政寬、男單戚又仁和雙胞胎男雙李芳任／李芳至先闖關。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/2025/09/16/98/33158515.jpg&s=Y&x=0&y=0&sw=1277&sh=852&exp=3600&sl=W&fw=360", "date": "2026-04-08 14:12"}, {"article_id": "9429004", "title": "MLB／時隔157天重返藍鳥投手丘 山本噓聲中再奪勝「感覺比前兩場好」", "summary": "道奇隊日籍強投山本由伸去年在世界大賽鎖死藍鳥隊拿下3勝，時隔157天重返藍鳥隊主場羅傑斯中心（Rogers Centre）投手丘，今天受到全場球迷的「噓聲」伺候，但他再繳出先發6局失1分的優質先發奪下勝投，讓藍鳥吞下近期6連敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836236.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 14:06"}, {"article_id": "9428981", "title": "全台唯一泛舟鐵人賽 秀姑巒溪泛舟鐵人三項報名倒數中", "summary": "由交通部觀光署東部海岸國家風景區管理處（下稱東管處）主辦的東海岸年度指標運動賽事「長濱雙浪金剛馬拉松」與「秀姑巒溪泛舟鐵人三項」，今天於花蓮福容大飯店盛大舉行花蓮宣傳記者會，本次活動不僅延續台東場的運動熱潮，更透過跨區域資源整合與數位交通創新，展現東海岸運動觀光「品牌化、國際化、永續化」的強大能量。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836207.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 14:00"}, {"article_id": "9428888", "title": "MiLB／沙子宸高階1A先發好投 3A莊陳仲敖先發挨2轟吞敗", "summary": "美國職棒運動家隊體系2名台灣投手今天都有登板，沙子宸在高階1A先發，投5局失掉1分責失分、無關勝敗；莊陳仲敖在3A先發投...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836184.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-08 13:57"}, {"article_id": "9428963", "title": "TPBL／以吉祥物Brownie為主軸 海神「浪潮製造所」邀神隊友守護海洋", "summary": "TPBL高雄全家海神隊本季最後一次主場周11日、12日在高雄巨蛋登場，特別以吉祥物Brownie作為應援主軸，推出全新主題「浪潮製造所」，邀請球迷一起守護海洋，創造應援浪潮。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836174.jpg&M=1&s=Y&x=1&y=282&sw=1023&sh=682&exp=3600&sl=W&fw=360", "date": "2026-04-08 13:54"}, {"article_id": "9428901", "title": "PLG／穩定火力助富邦勇士保晉級優勢 古德溫獲選3月MVP", "summary": "PLG公佈2025-26球季3月最有價值球員，台北富邦勇士的古德溫繳出單月場均24.8分、5.2籃板、2.2助攻的成績單，幫助勇士3月5戰3勝超過5成勝率持續保住晉級季後賽的優勢，古德溫出色的表現也讓他獲選單月最有價值球員。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836050.jpg&M=1&s=Y&x=0&y=0&sw=1080&sh=720&exp=3600&sl=W&fw=360", "date": "2026-04-08 13:29"}, {"article_id": "9428892", "title": "必衝海泳盛事基隆外木山長泳即起報名 3人以上團體限2500人", "summary": "2026基隆外木山海上長泳6月7日在外木山漁港停車場登場，即日起開放報名至4月17日止，採限額2500 名，從外木山澳救生站礁岩區下水，沿著海岸線至大武崙澳底沙灘，橫跨3200公尺海域。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836034.jpg&M=1&s=Y&x=0&y=0&sw=1277&sh=852&exp=3600&sl=W&fw=360", "date": "2026-04-08 13:25"}, {"article_id": "9428860", "title": "NBA／三巨頭全缺陣湖人慘輸雷霆36分 恐失季後賽首輪主場優勢", "summary": "在球隊雙衛唐西奇（Luka Doncic）、里夫斯（Austin Reaves）雙雙掛傷號後，湖人隊今天在詹姆斯（LeBron James）也因左腳不適缺陣的情況下出戰衛冕軍雷霆隊，在整場比賽沒有領先且一度落後達到41分的情況下，最終以87：123苦吞3連敗，恐失季後賽主場優勢。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34836142.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 13:17"}, {"article_id": "9425719", "title": "《獅王背後的故事》攝影集 17林岳平、18潘威倫數字藏玄機", "summary": "統一7-ELEVEn獅隊將於4月11、12日舉辦背號引退主題日，致敬傳奇球員曾智偵及劉芙豪。為保存這些背號故事，獅隊推出《獅王背後的故事》攝影集，重溫隊史榮耀與球迷回憶。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/07/34833393.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-08 13:14"}, {"article_id": "9428806", "title": "NBA／柯瑞替補轟17分、貝西驚喜繳雙十 勇士險勝國王止4連敗", "summary": "勇士隊前一場比賽迎回主控柯瑞（Stephen Curry），卻以1分差距不敵火箭隊，今天在主場迎戰國王隊，柯瑞替補上陣拿下17分，先發的波傑姆斯基（Brandin Podziemski）、梅爾頓（De'Anthony Melton）合力攻下41分，最終以110：105險勝，終止4連敗，。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835959.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-08 12:55"}, {"article_id": "9428749", "title": "MLB／「平常都在電視上看他投球」 岡本和真首度對決山本由伸敲長打", "summary": "藍鳥隊本周和道奇隊進行三連戰，本季赴美發展的日籍強打岡本和真，今天在第二戰面對經典賽日本隊隊友山本由伸，第三打席靠電子好球帶系統（ABS）改判，逃過三振改敲二壘打，明天將要對上「年輕時對決過」的大谷翔平。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/08/34835779.jpg&M=1&s=Y&x