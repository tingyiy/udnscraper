": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35041187.jpg&M=1&s=Y&x=17&y=11&sw=1263&sh=842&exp=3600&w=300", "link": "/news/story/122629/9564608"}, {"article_id": "9564449", "title": "世足攻略／內馬爾缺陣考驗巴西平局機率近五成 瑞士穩定攪局卡達難爆冷", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040924.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9564449"}, {"article_id": "9563581", "title": "煮茶論戰／世足首戰就發3紅牌 後面還會更多", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35039525.jpg&M=1&s=Y&x=0&y=0&sw=1275&sh=850&exp=3600&w=300", "link": "/news/story/123107/9563581"}, {"article_id": "9563228", "title": "尼克示範如何把溫班亞瑪拉出禁區 馬刺必須面對的攻防課題", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35038965.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300", "link": "/news/story/122629/9563228"}, {"article_id": "9562529", "title": "世足攻略／美國碰「南美滾泥土」防爆冷 加拿大少戴維斯戰波赫怕逼和", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35037670.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9562529"}, {"article_id": "9562359", "title": "破除西媒稱梅西是藏鏡人陷阱 阿根廷主帥要捍衛頭上冠冕", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/12/35037373.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9562359"}]}, {"name": "最新文章", "articles": [{"article_id": "9564630", "title": "Live／末節與馬刺拉鋸戰分差5分內 尼克追分噩夢又來了？", "summary": "隨著系列賽即將回到聖安東尼奧進行G5，馬刺將全力避免遭到淘汰，而尼克距離隊史自1973年以來首座總冠軍僅差1勝，不過從布朗森到唐斯，尼克全隊目前都展現出相同態度：29分大逆轉已經成為過去式，眼前唯一的目標，就是再拿下一場勝利，將總冠軍帶回紐約。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042086.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 11:05", "link": "/news/story/7002/9564630"}, {"article_id": "9565329", "title": "NBA／溫班亞瑪「法國神墊」布朗森引熱議 美媒怒批：該吹惡意犯規", "summary": "NBA總冠軍賽第5戰再度引發爭議，布朗森在外線命中三分球後落地踩到溫班亞瑪的腳，疑似扭傷腳踝卻未獲判罰。媒體與專家普遍認為應判定為惡意犯規，可能導致溫班亞瑪面臨禁賽懲處，這一判罰引發廣泛討論和批評。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042267.jpg&M=1&s=Y&x=32&y=6&sw=1248&sh=827&exp=3600&sl=W&fw=360", "date": "2026-06-14 10:57", "link": "/news/story/7002/9565329"}, {"article_id": "9565308", "title": "世足賽／不滿意巴西首戰表現 總教練：輸掉很多對抗和控球", "summary": "缺少頭號巨星內馬爾（Neymar）坐鎮的「森巴軍團」，今日在世界盃C組首戰碰頭上屆4強得主摩洛哥，在比賽第21分鐘先是被摩洛哥攻破大門，好在維尼修斯（Vinicius Jr.）在隨後補上一記內切射門，將比分扳平。下半場雙方皆未能越雷池一步，終場以1：1踢平。賽後巴西選手、教練也談到開局球隊表現不佳，以致他們遲遲未能找到節奏。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042237.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 10:47", "link": "/news/story/123107/9565308"}, {"article_id": "9565289", "title": "NBA／溫班亞瑪遭尼克球迷丟雞蛋 巴克利怒轟：這些人是真正懦夫", "summary": "NBA總冠軍賽第4戰後，尼克球迷朝馬刺球星溫班亞瑪丟雞蛋，引發巴克利強烈譴責，稱該行為懦弱。溫班亞瑪坦言未受到影響，並強調這類行為不當。隨著賽事升溫，球迷失序行為成為焦點，NBA需加強場外安全維護。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042231.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 10:36", "link": "/news/story/7002/9565289"}, {"article_id": "9565256", "title": "滑板世界盃羅馬站 13歲林逸凡首進前10有利亞運", "summary": "在義大利舉行的滑板世界盃羅馬站，台灣13歲小將林逸凡今天在16強以81.80高分，居分組第3，可惜總排名第10，未能闖進...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042181.jpg&M=1&s=Y&x=0&y=238&sw=960&sh=640&exp=3600&sl=W&fw=360", "date": "2026-06-14 10:28", "link": "/news/story/7005/9565256"}, {"article_id": "9565215", "title": "NBA／斑馬上半場搧5火鍋 馬刺G5上半場領先5分", "summary": "NBA總冠軍賽第5戰今天回到馬刺隊主場進行，馬刺首節雖取得23：13領先，但第4戰上演落後29分瘋狂逆轉的尼克，第二節在當家球星布朗森（Jalen Brunson）領軍下追分，半場打完差距縮小到37：42。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042101.jpg&M=1&s=Y&x=0&y=94&sw=853&sh=569&exp=3600&sl=W&fw=360", "date": "2026-06-14 09:55", "link": "/news/story/7002/9565215"}, {"article_id": "9565208", "title": "MLB／白襪球迷昨贏到喊「想看翔平」 大谷1轟、3BB「款待」對手", "summary": "白襪隊昨天以8：2大勝大谷翔平缺陣的道奇隊，球迷高喊「\"We want Shohei! We want Shohei!\"」呼喚大谷翔平，今天回歸打線的他，首局首打席就以全壘打「款待」白襪球迷。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042103.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 09:50", "link": "/news/story/6999/9565208"}, {"article_id": "9565116", "title": "NBA／尼克熱潮壓倒世界盃 紐約市民目光聚焦53年來首冠", "summary": "世界盃足球賽嘉年華氣氛今天席捲紐約，但完全敵不過紐約民眾更關心尼克隊爭奪NBA總冠軍的狂熱，足球盛事的聲勢因而相形失色", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042078.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 09:48", "link": "/news/story/7002/9565116"}, {"article_id": "9565206", "title": "MLB／山本由伸無安打比賽又在第9局破功 「棒球真的好難」", "summary": "道奇隊日籍強投山本由伸又一次與偉大紀錄擦身而過，今天面對白襪隊演出23上23下後，先因游擊手貝茲（Mookie Betts）接球失誤，挑戰完全比賽在7.2局夢碎，第9局被敲此役第1支安打，為首位打者彼得斯（Tristan Peters）的陽春砲，無安打比賽的挑戰也畫下句點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042091.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 09:47", "link": "/news/story/6999/9565206"}, {"article_id": "9565205", "title": "MLB／貝茲失誤搞砸完全比賽扛責 山本、魯辛都緩頰「不好處理」", "summary": "道奇隊日籍強投山本由伸前7.2局仍維持完全比賽局面，一顆朝游擊手貝茲（Mookie Betts）而去的滾地球，在下一幕出現令人錯愕的瞬間，一記失誤讓完全比賽夢碎，貝茲扛責：「沒能處理好平常應該處理起來的滾地球，我沒有任何藉口。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042092.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 09:47", "link": "/news/story/6999/9565205"}, {"article_id": "9565148", "title": "MLB／李灝宇隔11天重返大聯盟！ 與「費仔」同場先發都敲安", "summary": "台灣內野手李灝宇相隔11天回到大聯盟！今天在對上守護者之戰擔任先發第9棒、三壘手，2打數敲出1支安打；另一名經典賽國手「費仔」費爾柴德（Stuart Fairchild）同場出賽則有雙安表現。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042004.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 09:00", "link": "/news/story/6999/9565148"}, {"article_id": "9565139", "title": "世足賽／維尼修斯秀個人能力踢進追平分 巴西、摩洛哥1：1握手言和", "summary": "5度冠軍巴西隊今天在2026美加墨世足賽首度亮相，面對非洲勁旅摩洛哥先失球，不過維尼修斯（Vinicius Jr.）11分鐘後就進球回應；巴西追平比數後兩隊再沒破網紀錄，中場1：1戰平，在C組各取得1分積分。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042048.jpg&M=1&s=Y&x=0&y=0&sw=1255&sh=836&exp=3600&sl=W&fw=360", "date": "2026-06-14 08:45", "link": "/news/story/123107/9565139"}, {"article_id": "9565112", "title": "世足賽／裁判英文口音太重 「南非球員迷惘樣」變網路迷因", "summary": "2026年美加墨世界盃（FIFA World Cup 2026）正式開始，6月11日的揭幕戰為東道主墨西哥對戰南非，裁判全場共出示多達3張紅牌，成為話題之一。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35041932.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-14 08:39", "link": "/news/story/123107/9565112"}, {"article_id": "9565133", "title": "NBA／哈登非法持有槍枝休士頓被捕 繳納100美元保釋金獲釋", "summary": "騎士隊當家球星「大鬍子」哈登（James Harden）驚傳被捕，他在德州休士頓被指非法持有武器，在半夜遭逮。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35041979.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-14 08:33", "link": "/news/story/7002/9565133"}, {"article_id": "9565132", "title": "匹克球協會交接 新理事長楊哲明上任", "summary": "中華民國匹克球協會昨天舉辦「第五屆理事長就任暨理監事授證典禮」，由新任理事長楊哲明正式接棒，現場貴賓雲集，共同見證協會邁向全新發展的重要時刻。典禮除完成理事長交接儀式外，並頒發第五屆理監事及秘書處幹部聘書，象徵新團隊正式啟航，攜手推動台灣匹克球邁向國際。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35041969.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 08:33", "link": "/news/story/7005/9565132"}, {"article_id": "9565049", "title": "世足賽／卡達傷停補時驚險絕平 1比1爆冷逼和瑞士拿到隊史首分", "summary": "2026年6月14日凌晨3時，世界盃B組小組賽迎來卡達與瑞士的對決。主場作戰的卡達在落後大半場的情況下，於傷停補時階段頂住壓力，最終以1比1與瑞士握手和局。本場比賽展現了兩隊在攻守端的拉鋸，卡達憑藉頑", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35041849.jpg&M=1&s=Y&x=78&y=0&sw=1202&sh=802&exp=3600&sl=W&fw=360", "date": "2026-06-14 05:33", "link": "/news/story/123107/9565049"}, {"article_id": "9564921", "title": "運動人生／許績勝：效法日本實業團 延續選手運動生命", "summary": "「台灣長跑競技最大困境不在人才不足，而在於培養制度不夠完善，不過讓我更擔心的是新世代選手精神力不足。」許績勝對台灣長跑發展感到憂心忡忡。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://p.udn.com.tw/upf/2017_news/noimg_cid7227_6.jpg", "date": "2026-06-14 02:03", "link": "/news/story/7005/9564921"}, {"article_id": "9564912", "title": "運動人生／許績勝奔騰17年 贏得母遲來的理解", "summary": "跑步人生最讓我難忘的，不是在哪場比賽創佳績，而是母親遲了十六年的認可。」許績勝聊起自己不平凡的跑步人生，語氣平靜卻露出些許苦笑地說，他跑了十七年，媽媽卻反對了十六年。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35041796.png&M=1&s=Y&x=0&y=68&sw=911&sh=608&exp=3600&sl=W&fw=360", "date": "2026-06-14 02:02", "link": "/news/story/7005/9564912"}, {"article_id": "9564906", "title": "運動人生／許績勝 跑馬傳奇引領後浪", "summary": "●成立實業團 留住優秀選手", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35041636.jpg&M=1&s=Y&x=0&y=0&sw=1215&sh=810&exp=3600&sl=W&fw=360", "date": "2026-06-14 01:59", "link": "/news/story/7005/9564906"}, {"article_id": "9564795", "title": "網球／梁恩碩利貝馬網賽女雙稱后 奪WTA巡迴賽首冠", "summary": "在荷蘭舉行的WTA利貝馬公開賽，台灣「小鋼砲」梁恩碩今天與日本搭檔青山修子在女雙冠軍戰以6比2、2比6、10比7封后，梁...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35041791.jpg&M=1&s=Y&x=0&y=71&sw=959&sh=639&exp=3600&sl=W&fw=360", "date": "2026-06-14 01:54", "link": "/news/story/7005/9564795"}, {"article_id": "9564833", "title": "世足賽／美國隊地主光環 巴洛根世足首秀 雙響踢走巴拉圭", "summary": "三年前才從英格蘭轉籍到美國，前鋒巴洛根昨天首度在世足賽披上美國隊戰袍，以地主身分登場，上半場上演「梅開二度」，搭配開賽第七分鐘巴拉圭就送上烏龍球大禮，以及傷停壓哨前小將雷納的錦上添花，助美國小組賽首戰以四比一大勝巴拉圭，寫下本屆賽事三支地主球隊首戰均保持不敗的傲人紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35041570.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 00:00", "link": "/news/story/123107/9564833"}, {"article_id": "9564834", "title": "世足賽／教頭神調度出奇兵 加拿大替補拉林神來一腳逼平波赫", "summary": "美加墨世足賽地主國之一的加拿大，昨天在多倫多體育場迎來歷史性新頁，面對在歐洲區資格賽淘汰傳統強權義大利、球風剽悍的波赫，加拿大雖在先失一球的劣勢下苦追，但憑藉主帥馬許神調度，換上被排入替補名單的拉林扮演板凳奇兵，上場短短一二一秒即踢進關鍵追平球，終場加拿大以一比一逼平波赫，終結世足賽六連敗陰霾，更收下歷史性的第一分積分。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042075.jpg&M=1&s=Y&x=0&y=0&sw=1180&sh=787&exp=3600&sl=W&fw=360", "date": "2026-06-14 00:00", "link": "/news/story/123107/9564834"}, {"article_id": "9564836", "title": "世足賽／巴西今戰摩洛哥 內馬爾確定缺陣", "summary": "美加墨世足賽Ｃ組今天將迎來強強對決，五屆冠軍「森巴軍團」巴西，將在紐約遭遇上屆四強黑馬「北非雄獅」摩洛哥，也是兩隊相隔廿八年再度在世足賽碰頭，但開踢前夕卻雙雙面臨嚴重的傷兵打擊，其中巴西頭牌前鋒內馬爾確定因小腿傷勢缺席首戰，為主帥安切洛蒂的執教首航增添不少隱憂。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35041789.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-14 00:00", "link": "/news/story/123107/9564836"}, {"article_id": "9564824", "title": "中職／墊底大戰端華麗跑壘失誤全集 兄弟、桃猿打滿12局白忙一場", "summary": "兩支墊底軍團過招，殺得難分難解，卻在結尾畫出誰也想不到的結局，中信兄弟、樂天桃猿隊一路打滿12局，兄弟示範華麗跑壘失誤全集，12局下有機會延續攻勢、進而再見贏球，卻因代跑林瑞鈞的謎之跑壘形成最後一個出局數，兩隊最終以9：9和局收場。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35041564.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 22:28", "link": "/news/story/7001/9564824"}]}, {"name": "2026美加墨世足", "articles": [{"article_id": "9565139", "title": "世足賽／維尼修斯秀個人能力踢進追平分 巴西、摩洛哥1：1握手言和", "date": "2026-06-14 08:45", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35042048.jpg&M=1&s=Y&x=0&y=0&sw=1255&sh=836&exp=3600&w=300", "link": "/news/story/123107/9565139"}, {"article_id": "9565049", "title": "世足賽／卡達傷停補時驚險絕平 1比1爆冷逼和瑞士拿到隊史首分", "date": "2026-06-14 05:33", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/14/35041849.jpg&M=1&s=Y&x=78&y=0&sw=1202&sh=802&exp=3600&w=300", "link": "/news/story/123107/9565049"}, {"article_id": "9565308", "title": "世足賽／不滿意巴西首戰表現 總教練：輸掉很