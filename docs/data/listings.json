le_id": "9503129", "title": "打造唐西奇紫金時代新陣容 詹姆斯已不在湖人未來藍圖", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/14/34948364.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9500290", "title": "中職／童堉誠從修車到職棒 父親童琮輝佩服：他自己拚來的", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34943537.jpg&M=1&s=Y&x=0&y=69&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9500368", "title": "大谷翔平2026的極端悖論：投球0.97ERA背後的打擊節奏失序", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34943893.jpg&M=1&x=&y=&sw=&sh=&exp=3600&w=300"}, {"article_id": "9500521", "title": "海盜「不一樣了」！史肯斯領軍三王牌投出國聯最佳輪值成績", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/13/34943951.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9508066", "title": "MLB／今日先發5局7K！賽後談轉隊心境 鄧愷威曝：這邊投球比較自在", "summary": "本季轉戰太空人的台灣好手鄧愷威，今天對上遊騎兵先發投出本季代表作，總計5局投球交出7K無失分好成績，幫助太空人4：1擊敗遊騎兵，個人也收下本季第2勝。賽後，他談到從巨人轉戰太空人表現漸入佳進的關鍵，他指出球隊的整體環境與支持，讓他投球起來相當自在。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955250.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-17 14:28"}, {"article_id": "9508065", "title": "中職／剋星一棒決勝負！獅洋投布雷克無語問天 創隊史37年最悲紀錄", "summary": "在將近18000位球迷的見證下，中華職棒昨天在亞太成棒主球場上演罕見的頂級投手大對決，中信兄弟王牌德保拉與統一7-ELEVEn獅洋投布雷克生涯第11度同場先發對決，雙方再度繳出精彩內容。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955249.jpg&M=1&s=Y&x=0&y=5&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-17 14:12"}, {"article_id": "9508004", "title": "NBA／曾在總教練討論人選！美媒稱伊古達拉可能轉當勇士助教", "summary": "勇士隊助理教練團隊在休賽季迎來空缺，在史達茲（Terry Stotts）、史戴克豪斯（Jerry Stackhouse）這2位原先助教相繼離開後，有傳言稱昔日勇士王朝元老伊古達拉（Andre Iguodala）可能會加入勇士總教練柯爾（Steve Kerr）的團隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955074.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 14:07"}, {"article_id": "9507715", "title": "NBA／活塞G7添變數？3名球員因傷列入出戰成疑", "summary": "活塞、騎士目前在東區次輪賽事戰成3：3平手，明天兩隊將上演關鍵生死戰。然而，在G7開打前夕，活塞在稍早公布隊中多達3名後衛球員因傷勢，被列入出戰成疑名單（Questionable），分別是羅賓森（Duncan Robinson）、勒佛特（Caris LeVert）與赫爾特（Kevin Huerter）。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954614.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 14:00"}, {"article_id": "9508026", "title": "MLB／村上宗隆雙響砲秘密曝光！神秘儀式加持 隊友：他超愛魔法棒", "summary": "白襪日籍重砲村上宗隆今天上演大聯盟生涯首度單場雙響砲，瞬間點燃主場球迷熱情，這也是他本季第16和第17轟，在聯盟全壘打王排行榜躍居第2。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955125.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 13:38"}, {"article_id": "9507994", "title": "MLB／大谷翔平首支三壘打貢獻新高5打點 道奇痛宰天使奪4連勝", "summary": "洛杉磯道奇日籍球星大谷翔平在客場面對老東家天使之戰全面爆發，擔任先發第1棒指定打擊的他，全場4打數敲出2支安打、選到2次保送，貢獻本季單場新高5分打點，外加1次盜壘成功，帶領道奇以15比2痛宰天使，收下4連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955068.jpg&M=1&s=Y&x=122&y=27&sw=1158&sh=772&exp=3600&sl=W&fw=360", "date": "2026-05-17 13:17"}, {"article_id": "9507935", "title": "MLB／單季投球31局創新高 鄧愷威想為球隊多吃局數", "summary": "休士頓太空人隊台灣投手鄧愷威今天先發5局、7次三振無失分奪勝，本季投球局數累計31局，寫下生涯新高。鄧愷威表示，無論是先...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34955051.jpg&M=1&s=Y&x=42&y=22&sw=1220&sh=813&exp=3600&sl=W&fw=360", "date": "2026-05-17 13:05"}, {"article_id": "9507959", "title": "棒球／沒說一句「請來火腿」 栗山當年留住大谷靠掛保證：更快上MLB", "summary": "世界棒球經典賽冠軍教頭、大谷翔平恩師栗山英樹，透過棒球講座分享自己的棒球經驗，談到當年如何將高中生大谷翔平留在日本職棒，他透露從頭到尾沒說過任何一句「請來火腿」，而是向他分析，為何透過日職體系養成，會讓他更快站上大聯盟。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954995.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 12:48"}, {"article_id": "9507911", "title": "LPGA／皇后鎮錦標賽第3天 徐薇淩排名跌至第60", "summary": "LPGA皇后鎮錦標賽今天結束第3回合激戰，台灣好手徐薇淩抓4博蒂、吞4柏忌外帶1次雙柏忌繳出72桿，並以3天高於標準3桿...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954936.jpg&M=1&s=Y&x=0&y=17&sw=1100&sh=733&exp=3600&sl=W&fw=360", "date": "2026-05-17 12:20"}, {"article_id": "9507859", "title": "NBA／談落選新人王 克努佩爾讚好友佛雷格「完全配得上獎項」", "summary": "上個月底NBA頒布「年度新人王」獎項，獨行俠新科狀元「旗子哥」佛雷格（Cooper Flagg）以26分極小差距，擠下昔日杜克隊友、呼聲同樣很高的黃蜂神射手克努佩爾（Kon Knueppel）。近期，克努佩爾在上節目中談到落選一事，除表示已經盡全力了，並強調沒有任何遺憾。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954838.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 12:10"}, {"article_id": "9507908", "title": "棒球／栗山英樹看WBC台韓激戰也深受感動 「用靈魂在比賽」", "summary": "世界棒球經典賽冠軍教頭栗山英樹，應「中信60甲子緣」棒球特展之邀來台，今天舉辦棒球講座，談到中華隊在今年世界棒球賽最後一場預賽與南韓隊的交手，他看了也深受感動，「已經超越技術層面，是用靈魂在比賽。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954916.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-05-17 12:10"}, {"article_id": "9507893", "title": "影／中信60周年棒球特展揭幕 蔣萬安盼台灣棒球持續發光", "summary": "中國信託成立60周年，特別策畫「中信60甲子緣」棒球特展，5月19日起至6月21日在中國信託多功能會場展出，回顧台灣棒球百年發展史和中國信託投入五級棒球的成果，向台灣棒球精神致敬。台北市長蔣萬安出席致詞，特別感謝中國信託及各界長年支持台灣棒球，期許台灣棒球能在基層扎根、職棒推動與國際賽舞台上持續發光。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954898.jpg&M=1&s=Y&x=0&y=0&sw=1238&sh=825&exp=3600&sl=W&fw=360", "date": "2026-05-17 11:57"}, {"article_id": "9507885", "title": "棒球／「中信60甲子緣」揭幕 蔣萬安、辜仲諒學王貞治打擊", "summary": "中國信託成立60周年，策畫「中信60甲子緣」棒球特展，台北市長蔣萬安出席揭幕儀式，與中國信託慈善基金會董事長辜仲諒一起觀展，面對鏡頭重現稻草人打擊法。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954883.jpg&M=1&s=Y&x=0&y=208&sw=987&sh=658&exp=3600&sl=W&fw=360", "date": "2026-05-17 11:51"}, {"article_id": "9507789", "title": "NBA／季後賽證明油箱還有油 灰狼38歲老將康利將「再戰一年」", "summary": "灰狼昨天在西區次輪G6以109：139大比分落敗馬刺，賽季宣告結束。經美媒報導指出，灰狼陣中38歲老將控衛康利（Mike Conley）不會退役，將續戰一年，這也意味著下賽季將是他NBA職業生涯的第20個球季。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954731.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-05-17 11:42"}, {"article_id": "9507822", "title": "MLB／村上宗隆首演雙響砲！新人年17轟超越松井 瞄準大谷翔平紀錄", "summary": "芝加哥白襪日籍重砲村上宗隆火力持續全面爆發。今日在主場迎戰同城對手小熊隊的「芝加哥大戰」中，擔任先發第2棒、一壘手的村上繳出3打數2安打、3分打點、1次保送成績，更是大聯盟生涯首度轟出雙響砲，率隊拿下勝利。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954787.jpg&M=1&s=Y&x=0&y=8&sw=1215&sh=810&exp=3600&sl=W&fw=360", "date": "2026-05-17 11:19"}, {"article_id": "9507610", "title": "世足賽／伊朗隊放眼世界盃 前往土耳其集訓、申請美簽", "summary": "伊朗國家足球隊總教練蓋勒諾伊（Amir Ghalenoei）今天表示，國腳們將於18日前往土耳其進行集訓、踢友誼賽，並在...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954670.jpg&M=1&s=Y&x=17&y=0&sw=1256&sh=837&exp=3600&sl=W&fw=360", "date": "2026-05-17 10:32"}, {"article_id": "9507650", "title": "MiLB／蘇嵐鴻生涯首秀新人聯盟先發2局 廖宥霖首安出爐", "summary": "19歲投手蘇嵐鴻旅美加盟聖地牙哥教士隊，今天新人聯盟首場先發亮相，投2局4K無失分，無關勝敗；密爾瓦基釀酒人隊18歲野手...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954651.jpg&M=1&s=Y&x=51&y=193&sw=1150&sh=767&exp=3600&sl=W&fw=360", "date": "2026-05-17 10:24"}, {"article_id": "9507736", "title": "角力／紐約奪金放眼亞運 張惠慈從禁賽浴火重生", "summary": "2025年底的美國紐約公開賽，我國角力張惠慈在女子自由式76公斤級接連擊敗美、加強敵，站上最高頒獎台。今年24歲的她，臉上帶著歷盡風霜後的從容，因為就在五年前，她幾乎已經放棄了一切。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954645.jpg&M=1&s=Y&x=0&y=448&sw=959&sh=640&exp=3600&sl=W&fw=360", "date": "2026-05-17 10:22"}, {"article_id": "9507735", "title": "角力／醫界葉問接理事長 名醫選手帶來改革遠景", "summary": "全國小學生角力賽本周末在台東縣立體育館登場，共有三百多名小學生角力選手齊集台東。場上小選手們在場上奮力角逐，場邊家長與教練的加油聲此起彼落，台灣角力運動新的掌舵者、中華民國角力協會新任理事長何宗融也親臨會場，他盼透過在偏鄉舉辦國小賽事，從小選手扎根，並營造環境，幫助好選手在奧運中奪牌。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/05/17/34954662.jpg&M=