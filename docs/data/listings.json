ttps://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35035214.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9560821"}, {"article_id": "9560501", "title": "中職／仿效富邦悍將模式！彭政閔任CBO 成中信兄弟解藥", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/11/35034654.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300", "link": "/news/story/122629/9560501"}]}, {"name": "最新文章", "articles": [{"article_id": "9564294", "title": "世足運彩／開打後最硬的一場！森巴軍團火拼上屆殿軍摩洛哥 主推巴西不讓分", "summary": "巴西隊在23屆世界盃小組賽對摩洛哥，期望以其明星球員和強大實力開門紅。摩洛哥則主打防守反擊，教練誓言力爭獎盃。主推薦巴西不讓分。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040572.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-13 13:18", "link": "/news/story/123105/9564294"}, {"article_id": "9564239", "title": "NBA／林書豪離隊真相曝光！安東尼澄清「荒謬合約」真正含意", "summary": "2012年席捲全球的「林來瘋」至今仍是NBA史上最勵志的傳奇故事之一，但林書豪當年離開尼克的真相，卻始終伴隨著爭議與誤解。近日林書豪先後接受《Pablo Torre Finds Out》與前隊友安東尼（Carmelo Anthony）的Podcast《7PM in Brooklyn》專訪，不僅首度詳細談論自己離開尼克的痛苦過程，也與安東尼公開解開長達14年的心結。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040551.jpg&M=1&s=Y&x=0&y=12&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 13:16", "link": "/news/story/7002/9564239"}, {"article_id": "9564281", "title": "世足運彩／預測4：0大勝！看好瑞士十字軍擊穿卡達防線強勢超越讓分", "summary": "瑞士在世界盃小組賽首輪將對陣卡達，被認為實力懸殊，瑞士存有高達17名的大賽經驗球員。預計瑞士將主導進攻，卡達的防守恐遭重重考驗。運彩盤點顯示瑞士讓1.75球，預測比分為瑞士4比0擊敗卡達。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040557.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 13:02", "link": "/news/story/123105/9564281"}, {"article_id": "9564280", "title": "日職／古林睿煬重返一軍先發！ 明主場出戰中日隊", "summary": "日職火腿隊明天將在主場對戰中日龍隊，將再推出台灣投手登板，由剛過26歲生日的古林睿煬迎接本季第2場先發出賽，對決中日隊39歲老將涌井秀章。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040558.jpg&M=1&s=Y&x=0&y=1&sw=1071&sh=714&exp=3600&sl=W&fw=360", "date": "2026-06-13 12:56", "link": "/news/story/7001/9564280"}, {"article_id": "9564279", "title": "世足賽／逾7萬球迷面前奪首勝 美國隊長：我們要的開局！", "summary": "美國今天在世足賽分組賽首戰，於加州SoFi體育場超過7萬名球迷的吶喊聲中，以4：1大勝巴拉圭，迎來完美的開門紅，賽後陣中洋溢著高昂的士氣，隊長里姆（Tim Ream）也直言，這對於美國對來說無疑是完美開局。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040571.jpg&M=1&s=Y&x=0&y=42&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 12:55", "link": "/news/story/123107/9564279"}, {"article_id": "9564269", "title": "世足運彩／瑞士特快車要輾壓卡達 贏一球似乎還嫌不夠看好讓1球勝", "summary": "瑞士在世足小組賽對卡達的比賽中，實力明顯佔優，讓一球的賠率為1.45。卡達過去表現不佳，瑞士必須努力搶進球以減輕後續對手的壓力。預期本場將是開幕以來最有機會大量進球的一戰。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040528.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-13 12:55", "link": "/news/story/123105/9564269"}, {"article_id": "9564165", "title": "世足賽／洛杉磯好萊塢風格開幕式 星光雲集阿湯哥、貝克漢都來了", "summary": "世界盃足球賽東道主之一美國今天在洛杉磯舉行一場好萊塢風格的開幕式，星光雲集。美國隊隨後以4比1擊敗巴拉圭，旗開得勝", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040417.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 12:22", "link": "/news/story/123107/9564165"}, {"article_id": "9564101", "title": "世足賽／中國男足6度無緣世界盃 法媒歸咎腐敗與體制", "summary": "世界盃足球已經開踢，據信擁有2億球迷的中國6度無緣世界盃。法國廣播電台（法廣）引述法國媒體的分析指出，中國奧運總能奪金，...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040410.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 12:17", "link": "/news/story/123107/9564101"}, {"article_id": "9564167", "title": "MLB／查普曼喊話凱許曼先道歉！洋基教頭正面回擊：不要阿", "summary": "38歲古巴火球終結者查普曼（Aroldis Chapman）近日公開表示，若未來有機會重返紐約洋基，洋基總管凱許曼（Brian Cashman）必須先向他道歉。對此，洋基總教練布恩（Aaron Boone）也首度回應，認為自己與球團並不欠查普曼任何道歉。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040371.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-13 12:16", "link": "/news/story/6999/9564167"}, {"article_id": "9564201", "title": "NBA／馬刺尼克球迷G4互嗆爆發衝突 17歲少年遭波及毆打昏迷", "summary": "尼克在NBA總冠軍賽第4戰完成史上最大逆轉，一度落後馬刺29分，最終以107比106驚險取勝，系列賽取得3比1聽牌優勢。不過這場讓紐約球迷陷入狂歡的比賽，也在場外引發一連串失控事件，從麥迪遜花園廣場附近的球迷鬥毆，到馬刺球星溫班亞瑪（Victor Wembanyama）返回飯店時遭球迷辱罵並差點被雞蛋砸中，都讓這輪總冠軍賽的場外秩序再度成為焦點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040397.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 12:15", "link": "/news/story/7002/9564201"}, {"article_id": "9564190", "title": "世足賽／VAR輔助判決新規首度啟用 美國隊長黃牌轉移至假摔對手", "summary": "美加墨世足賽最後一支登場的地主隊美國，今天在與巴拉圭之戰發起猛攻，最終以4：1搶下小組賽首勝，這場比賽也出現歷史性的一刻，本屆賽事擴大使用的VAR新規首次以跨隊「MISTAKE IDENTITY（錯誤身分判定）」介入裁判判罰，讓原本吹給美國隊長里姆（Tim Ream）的黃牌，變到了「假摔」的巴拉圭阿爾米龍（Miguel Almiron）身上。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040393.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-13 11:57", "link": "/news/story/123107/9564190"}, {"article_id": "9564081", "title": "NBA／別相信任何消息！經紀人闢謠：沒和詹姆斯談過下一步", "summary": "湖人球星詹姆斯（LeBron James）未來動向持續成為NBA最受矚目的話題之一，外界不斷猜測他究竟會選擇續戰、退休，甚至重返騎士。不過，詹姆斯的經紀人保羅（Rich Paul）近日親自出面闢謠，直言目前所有傳聞都不可信，因為他至今甚至還沒和詹姆斯正式討論過未來規劃。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040294.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 11:36", "link": "/news/story/7002/9564081"}, {"article_id": "9564116", "title": "NBA／1比3落後尼克不絕望 溫班亞瑪相信馬刺能隨騎士腳步寫歷史", "summary": "馬刺目前已經瀕臨淘汰邊緣，但本輪系列賽前4戰，他們每一場都曾取得雙位數領先，但球隊卻未能把握這些優勢，反而是被尼克耐心蠶食鯨吞，在第2戰和第4戰皆以1分之差飲恨，突顯球隊在關鍵時刻收尾能力的不足強森。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040242.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 11:26", "link": "/news/story/7002/9564116"}, {"article_id": "9564098", "title": "世足賽／巴洛根梅開二度率美國4：1大勝巴拉圭 3支地主隊首戰都不敗！", "summary": "身為今年美加墨世足賽最後一支登場的地主球隊，美國今天在分組賽首戰遭遇巴拉圭，現場可說是政商名流雲集，而美國也在上半場就發起猛攻，先是靠著巴拉圭烏龍球於開賽第7分鐘就先馳得球，巴洛根（Folarin Balogun）更是在上半場就梅開二度，僅管巴拉圭下半場追回一球，但最終美國仍是以4：1取勝，寫下今年世足賽3支地主隊首戰都不敗的紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040205.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 11:09", "link": "/news/story/123107/9564098"}, {"article_id": "9564087", "title": "MLB／佐佐木朗希先發4.1局爆7分生涯最慘 飆速162公里", "summary": "道奇隊日籍投手佐佐木朗希前役繳出7局無失分的旅美代表作，休一周後今天客場登板，但對上白襪隊僅投4.1局失7分，寫下生涯單場最多失分，最終道奇以2：8落敗，佐佐木朗希吞下第4敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040180.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 11:01", "link": "/news/story/6999/9564087"}, {"article_id": "9564067", "title": "NBA／頂薪福克斯表現受質疑 強森不甩批評力挺：有最高信任", "summary": "系列賽陷入1比3落後。面對外界對福克斯（De'Aaron Fox）關鍵時刻表現的批評，馬刺總教練強森（Mitch Johnson）今天公開表態力挺，強調自己仍對這名明星後衛有最高信任。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040169.jpg&M=1&s=Y&x=0&y=3&sw=1065&sh=710&exp=3600&sl=W&fw=360", "date": "2026-06-13 10:52", "link": "/news/story/7002/9564067"}, {"article_id": "9564006", "title": "NBA／14年心結解開！安東尼澄清「對立」傳聞：從沒忌妒過林書豪", "summary": "尼克退役球星「甜瓜」安東尼（Carmelo Anthony）與林書豪（Jeremy Lin）近日在《7PM in Brooklyn》Podcast節目中首度公開談論「林來瘋（Linsanity）」時期的種種傳聞。兩人坦言，經過長達14年的時間，終於有機會坐下來把當年的誤會與疑問一次說清楚，也正式為外界流傳多年的不合傳聞劃下句點。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040124.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 10:40", "link": "/news/story/7002/9564006"}, {"article_id": "9563947", "title": "國際泳渡澎湖灣 1100多名國內外選手下水挑戰", "summary": "「2026 PENGHU OCEANMAN 國際泳渡澎湖灣」，今天進行國際組10公里與挑戰組2公里，共有1100多名泳者...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040087.jpg&M=1&s=Y&x=99&y=0&sw=1081&sh=721&exp=3600&sl=W&fw=360", "date": "2026-06-13 10:21", "link": "/news/story/7005/9563947"}, {"article_id": "9563924", "title": "世足賽／加拿大首戰踢平波赫 總教練：滿意但上半場欠積極", "summary": "加拿大足球國家隊總教練馬許（Jesse Marsch）表示，他對今天在世界盃B組與波士尼亞與赫塞哥維納（以下簡稱波赫）以...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040083.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 10:21", "link": "/news/story/123107/9563924"}, {"article_id": "9563969", "title": "NBA／林書豪是誰？甜瓜首度公開「豪小子」38分打臉布萊恩背後真相", "summary": "2012年席捲全球的「林來瘋」至今仍是NBA最經典的傳奇故事之一，而當年湖人傳奇球星布萊恩（Kobe Bryant）那句著名的「林書豪是誰？」也成為球迷津津樂道的話題。如今，尼克退役球星「甜瓜」安東尼（Carmelo Anthony）首度揭露背後真相，坦言這句話其實和自己有關。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040174.jpg&M=1&s=Y&x=0&y=14&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-06-13 10:20", "link": "/news/story/7002/9563969"}, {"article_id": "9563881", "title": "世足賽／世界盃重返墨西哥 紀錄片揭紅魔鬼1986年義助兒童善舉", "summary": "1986年墨西哥世界盃期間，比利時國家隊「紅魔鬼」捐出部分獎金在當地成立兒童庇護所Casa Hogar，保護孤兒和貧困兒...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040048.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 10:14", "link": "/news/story/123107/9563881"}, {"article_id": "9563968", "title": "MLB／扯！釀酒人火球男27人次完封勝 15K寫「瘋狗級完封」新紀錄", "summary": "釀酒人隊火球男米蕭洛斯基（Jacob Misiorowski）投出生涯最扯一役，今天以95球完成9局完封勝，只面對27人次，送出15次三振，釀酒人終場以6：0擊敗費城人隊。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35040000.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-06-13 09:51", "link": "/news/story/6999/9563968"}, {"article_id": "9563961", "title": "MLB／又爆了…今井達也9分領先仍0.2局遭KO 美媒已經無言以對", "summary": "太空人隊日籍投手今井達也又留下一場慘烈戰役，今天面對皇家隊撐不滿1局，0.2局狂失5分退場，繼美國時間4月10日0.1局後，再次上演1局投不完遭到KO窘狀。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/06/13/35039955.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360",