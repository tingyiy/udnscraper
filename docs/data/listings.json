humbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/02/34823508.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&w=300"}, {"article_id": "9417098", "title": "三王牌即將合體、打線幾無斷層 洋基仍是美聯頭號強權", "date": "", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/01/34819294.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9424908", "title": "中職／林哲瑄引退轉任教練 喊話老闆「奪冠就發股票」", "summary": "富邦悍將隊林哲瑄在引退轉任教練後深刻理解，自己在外野跑步啟動、守備判斷的能力不僅是天賦，也能透過訓練加強，目前專注培育年...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830601.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 18:04"}, {"article_id": "9424913", "title": "拳擊／不被跳電意外影響 陳念琴第三度闖亞錦賽決賽", "summary": "2026年拳擊亞錦賽在蒙古烏蘭巴托登場，我國共有4名女將打進4強，今天接連上陣搶決賽門票，日場出賽的郭怡萱和巴黎奧運「金牌拳后」林郁婷雖接連敗陣，不過晚場率先上陣的黃筱雯和壓軸登場的「拳擊女王」陳念琴都闖決賽，周四下午將挑戰帶回金牌。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830619.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 18:00"}, {"article_id": "9424892", "title": "中職／當教練承諾很重要 林漢森想起林哲瑄兒時買車承諾真的兌現了", "summary": "富邦悍將隊將在今天賽後舉辦林哲瑄引退儀式，賽前邀請他的父親林漢森、「牛爸」陳献榮擔任開球嘉賓。談到兒子的人生下一篇章，林漢森說當教練，承諾很重要，想起兒子小時候童言童語說要幫他買車，在2016年義大犀牛隊奪冠後真的送了他一台車，「就像現在他希望帶富邦走向總冠軍，我希望他也可以做到。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830592.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 17:44"}, {"article_id": "9424877", "title": "NBA／征戰聯盟18年仍是頂尖巨星 杜蘭特稱「基本功」是關鍵", "summary": "休士頓火箭超級球星「KD」杜蘭特（Kevin Durant）近日接受NBC記者夏哈馬迪（Ashley ShahAhmadi）採訪，內容談到他如何在NBA長年保持競爭力，這位37歲的球星表示，保持活力、不斷進步，同時他認為堅守「基本功」至關重要。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830568.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-06 17:38"}, {"article_id": "9424879", "title": "拳擊／打下中國全運會金牌 黃筱雯再闖亞錦賽決賽", "summary": "2026年拳擊亞錦賽在蒙古烏蘭巴托登場，我國共派出11名選手參賽，其中4名女將打進4強；今天日場出賽的郭怡萱和巴黎奧運「金牌拳后」林郁婷雖接連敗陣，不過晚場率先上陣的黃筱雯打下中國女將趙軒，打進決賽至少追平個人亞錦賽最佳的銀牌成績。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830575.jpg&M=1&s=Y&x=0&y=38&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 17:27"}, {"article_id": "9424865", "title": "NBA／柯瑞復出險上演絕殺秀 杜蘭特心有餘悸：球飛在空中看了很緊張", "summary": "勇士當家球星柯瑞（Stephen Curry）在歷經長達27場比賽缺陣後，於今天主場迎戰火箭正式回歸，僅出賽26分鐘便攻下29分，一度率隊完成逆轉，可惜最終絕殺三分彈未能命中，勇士以一分之差飲恨落敗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830549.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-06 17:13"}, {"article_id": "9424851", "title": "MLB／牛棚砸鍋小熊遭守護者1分逆轉 今永昇太本季首勝飛了", "summary": "小熊日籍左投今永昇太今日擔任先發投手，客場面對守護者交出5局失1分好投，然而，後續接替上來的後援投手群卻不給力，讓小熊隊終場前遭到守護者逆轉，以5：6吞下敗仗，讓原本有望拿下勝投的今永昇太，變成本場比賽無關勝敗，本季首勝至今還未開張。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830540.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 17:11"}, {"article_id": "9424850", "title": "中職／為「大董」擦臉有先得到應允 林威助笑答哪敢造次", "summary": "富邦悍將隊這兩天在新莊棒球場舉辦林哲瑄引退主題日，眼尖球迷注意到，昨天副領隊林威助在休息區內為富邦「大董」蔡明忠擦拭臉頰，今天他還原現場，並非主動一把摸上大董，而是有先詢問，「是他請我幫他擦。」笑說自己哪敢造次。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830534.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-06 16:51"}, {"article_id": "9424836", "title": "中職／提前認定輸球因以為看到對方終結者 勝騎士：以後不會了", "summary": "中信兄弟隊昨天以4：9不敵統一獅隊，意外插曲是8局下打完，洋投勝騎士已經邁開步伐走出休息室，提前認為比賽結束，今天面對媒體約訪已經知道會被問到糗事，「我有猜到要問這個…。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830519.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 16:42"}, {"article_id": "9424828", "title": "中職／帶弱隊變強更有價值 平野惠一：越在谷底越有幹勁", "summary": "中信兄弟隊開季不順，吞下3連敗後，目前以1勝5敗居聯盟爐主，前兄弟教頭林威助接受日本媒體訪問時一句「只要3連敗就會被喊下台」，也再次成為話題。兄弟教頭平野惠一談到是否有壓力，他說：「完全沒有」，他說自己是越在谷底越有幹勁的類型，「知道球迷一定還是抱持期待，希望大家可以看我們怎樣從谷底爬起來。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830509.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 16:36"}, {"article_id": "9424822", "title": "MLB／道奇羅哈斯迎接世界大賽第8戰？已做好被噓爆的心理準備", "summary": "道奇隊去年在世界大賽打滿7場扳倒藍鳥隊，成為本世紀首支完成2連霸的球隊，藍鳥明天在多倫多展開復仇3連戰，道奇內野手羅哈斯（Miguel Rojas）已經做好心理準備，等候敵隊球迷對他大開汽水。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830520.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 16:29"}, {"article_id": "9424811", "title": "MLB／鈴木誠也2A復健狀態良好 主帥稱將於對海盜首戰復出", "summary": "效力小熊隊的日籍重砲鈴木誠也，先前在2026年世界棒球經典賽（WBC）期間遭遇右膝十字韌帶扭傷傷勢，他也被列入傷兵名單，至今仍在小聯盟復建。根據近期小熊總教練康索（Craig Counsell）的說法，鈴木誠也預計將在11日小熊對海盜系列賽首戰迎來復出，屆時也將是他本賽季大聯盟的首次亮相。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830481.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 16:27"}, {"article_id": "9424758", "title": "射箭／新星許芯慈拚世界盃 被點名值得關注選手", "summary": "在墨西哥舉行的射箭世界盃普艾布拉站將於明天登場，年僅18歲的台灣女將許芯慈，特別被官網列為值得關注的5名選手之一，教練吳...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830469.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-06 16:00"}, {"article_id": "9424782", "title": "拳擊／小鋼砲郭怡萱亞錦賽奪銅 教練肯定愛徒更穩", "summary": "在蒙古烏蘭巴托舉行的拳擊亞錦賽，台灣「小鋼砲」郭怡萱今天在女子51公斤級4強，雖以0比5不敵北韓安琴別，賽後教練柯文明仍...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/2025/11/19/98/33710370.jpg&s=Y&x=0&y=64&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 15:54"}, {"article_id": "9424733", "title": "MLB／終於沒被歐戴爾接殺！水手小將敲3分砲讓小編嗨喊「Not Again」", "summary": "在昨日天使1：0險勝水手的比賽中，天使右外野手歐戴爾（Jo Adell）扮演致勝功臣，連續沒收水手3發即將過牆的全壘打，成為賽後焦點。在今天比賽，水手22歲小將楊恩（Cole Young）在5局上夯出一發右外野方向的3分砲，這球夠深遠讓歐戴爾完全沒有守備機會，水手小編也隨即在官方Threads上發布這則開轟精華，並在文中寫下連續三次「Not Again」，笑翻貼文底下網友。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830391.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 15:52"}, {"article_id": "9424773", "title": "NBA／高吊傳球引起失誤 詹姆斯比賽中罕見幫兒子布朗尼「上課」", "summary": "在今日湖人、獨行俠的比賽中，湖人21歲後衛布朗尼（Bronny James）在第三節因一次給老爸「詹皇」詹姆斯（LeBron James）的高吊傳球發生失誤，讓詹姆斯先是「皺眉」看向布朗尼表達不解，並在比賽中罕見地給予兒子建議。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830441.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 15:46"}, {"article_id": "9424766", "title": "NBA／19歲狀元佛雷格連兩戰狂轟96分 上古神獸張伯倫後首見", "summary": "年僅19歲的獨行俠狀元郎佛雷格（Cooper Flagg）正以強勢得分表現席捲聯盟，繼上週對陣魔術狂炸51分後，今天面對湖人的比賽又再次發威，創下歷史級飆分紀錄。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830434.jpg&M=1&s=Y&x=185&y=16&sw=954&sh=636&exp=3600&sl=W&fw=360", "date": "2026-04-06 15:25"}, {"article_id": "9424744", "title": "MLB／藍鳥復仇系列賽薛則打頭陣 大谷9日二刀流拚第2勝", "summary": "道奇隊今天在落後5分的情況下，比賽後半段逆轉戰局，以8：6擊敗國民隊，帶著3連勝離開華府、轉戰多倫多，明起對藍鳥隊展開3連戰，雙方已經排定系列賽先發投手，大谷翔平將在9日最後一戰登板，再展二刀流威力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830412.jpg&M=1&s=Y&x=252&y=42&sw=843&sh=562&exp=3600&sl=W&fw=360", "date": "2026-04-06 14:58"}, {"article_id": "9424680", "title": "MLB／終於回來了！頂替傷兵貝茲 金慧成本季首戰代守登場", "summary": "道奇主戰游擊手貝茲（Mookie Betts）在先前比賽遭遇右側腹斜肌拉傷，後進入傷兵名單。因此，道奇稍早宣布將南韓好手金慧成從3A拉上大聯盟，他也在今天道奇8：6擊敗國民的系列賽第三戰中，迎來本賽季在大聯盟的首戰，在比賽後段接替弗里蘭（Alex Freeland）上場，鎮守二壘。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830288.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 14:56"}, {"article_id": "9424734", "title": "NBA／「復健兄弟」首度聯手 柯瑞喊特別：美夢成真", "summary": "因「跑者膝」連續缺陣27場的勇士隊當家球星柯瑞（Stephen Curry），今天總算回歸，且和弟弟小柯瑞（Seth Curry）寫下兄弟同時上陣的隊史紀錄，讓38歲的柯瑞直呼感覺特別，「說實話，那是美夢成真。」", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830404.jpg&M=1&s=Y&x=138&y=55&sw=855&sh=570&exp=3600&sl=W&fw=360", "date": "2026-04-06 14:50"}, {"article_id": "9424402", "title": "桌球世界盃／王楚欽首奪冠 孫穎莎3連霸史上第一", "summary": "2026國際乒聯單打世界盃5日在澳門迎來收官，中國隊在男女單打決賽中雙雙奪冠，女子單打方面，孫穎莎對陣隊友王曼昱，最終以4：1勝出，連續第三年奪得世界盃女子單打冠軍，成為自1973年賽事創辦以來首位達成此項紀錄的女子選手；男子單打方面，王楚欽以4：3逆轉擊敗日本選手松島輝空，首度加冕世界盃男子單打冠軍。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34829902.jpg&M=1&s=Y&x=0&y=247&sw=1012&sh=675&exp=3600&sl=W&fw=360", "date": "2026-04-06 14:29"}, {"article_id": "9424702", "title": "拳擊／亞錦賽林郁婷奪銅牌 教練：學到很好經驗", "summary": "在蒙古烏蘭巴托舉行的亞洲拳擊錦標賽，「台灣女兒」林郁婷今天在60公斤級4強戰和北韓對手元恩景鏖戰到最終回合，才以1比4落...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830325.jpg&M=1&x=&y=&sw=&sh=&exp=3600&sl=W&fw=360", "date": "2026-04-06 14:22"}, {"article_id": "9424690", "title": "日職／球評分析林安可擊球速度一流 每場1安還未發揮潛力", "summary": "日本職棒新球季開打11天，西武獅隊台灣好手林安可出賽8場，打擊率2成50、還未開轟，日職專欄作家中島大輔指出，西武目前戰績不佳，這位台灣強棒每場只能揮出1支安打，他的擊球速度一流，教練團寄予厚望。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830314.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 14:07"}, {"article_id": "9424642", "title": "中職／曾智偵、劉芙豪背號引退儀式 紀念幣和紀念報刊搶先收藏", "summary": "統一獅隊將於11、12日在亞太成棒主球場分別舉辦劉芙豪、曾智偵背號引退儀式，向兩位深刻影響隊史的經典人物致上最高敬意；獅隊指出，這不只是數字的封存，更是一段跨世代的精神傳承，連續兩天特別規劃「統一獅號碼引退紀念幣」、「號碼印退榮耀故事紀念報刊」，內野01~21區球迷進場都可各獲一份。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/06/34830228.jpg&M=1&s=Y&x=0&y=153&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-06 13:28"}]}, {"name": "林哲瑄專訪", "articles": [{"article_id": "9413494", "title": "林哲瑄專訪／棒球療效一輩子 過動兒踏出30年棒球生涯", "date": "2026-03-31 11:17", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/03/31/34813934.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9413488", "title": "林哲瑄專訪／「我真的那麼糟糕嗎？」 擺脫不了的關鍵字已被罵到看開", "date": "2026-03-31 11:13", "thumbnail": "https://pgw.udn.com.tw/gw/photo.