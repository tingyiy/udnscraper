=300"}]}, {"name": "最新文章", "articles": [{"article_id": "9456187", "title": "路跑／華航星光馬拉松 10月31日登場", "summary": "「二○二六華航馬拉松 星光夜跑」將於十月卅一日在台北大佳河濱公園登場，即日起開放網路報名。今年規畫半程馬拉松組廿一公里、漫遊健跑組十公里及親子星空組六公里等三大組別，以「親子嘉年華」為主題，打造一場結合親子運動、戶外市集、星光音樂會與公益合作的路跑活動，邀民眾大手牽小手，一同跑進華航馬拉松。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34877516.png&M=1&s=Y&x=0&y=0&sw=1279&sh=852&exp=3600&sl=W&fw=360", "date": "2026-04-22 00:00"}, {"article_id": "9455942", "title": "中職／換與不換都需要勇氣 悍將陳品宏好投栽在1打席逆轉三分砲", "summary": "換與不換一念之間，富邦悍將隊今天在第七局一個換投遲疑，結局是樂天桃猿隊李勛傑的逆轉三分砲，悍將終場以1：6不敵猿隊，終止2連勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34877294.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 21:14"}, {"article_id": "9455901", "title": "中職／今天PitchCom有乖乖！鄭浩均飆生涯第二場接力無安打比賽", "summary": "中信兄弟隊鄭浩均前7局投完仍維持無安打局面，並未獲得繼續挑戰的機會，加上呂彥青、李振昌，3投聯手締造中職例行賽史上第12場無安打比賽，僅有的兩場「接力」都是鄭浩均先發。兄弟終場以6：0擊敗統一獅隊，開季打16場拿到第4勝。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34877263.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=851&exp=3600&sl=W&fw=360", "date": "2026-04-21 20:57"}, {"article_id": "9455890", "title": "全中運／最年輕亞運游泳國手何康婗初體驗 首秀締造三項全金", "summary": "已經成為台灣游泳史上最年輕的亞運國手，年僅12歲來自台南麻豆國中的「游泳神童」何康婗今年終於首度站上全中運的游泳舞台，而她也不負眾望，在參加的三項蛙式項目中全都如願摘金且三破大會紀錄，而且在先前已經達亞運標的200公尺蛙式中二度達亞運標，表現令全場嘖嘖稱奇。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34877252.jpg&M=1&s=Y&x=0&y=0&sw=1215&sh=810&exp=3600&sl=W&fw=360", "date": "2026-04-21 20:54"}, {"article_id": "9455888", "title": "全中運／國中男雙、高中女雙奪冠 「後壁體系」軟網單日4金大進補", "summary": "115年全中運軟式網球項目今天進行雙打與混雙決賽，台南市傳統勁旅後壁高中、國中單日4面金牌大進補，目前在軟網已獲得6金3銀1銅，團體賽尚未登場已經預告成為最大贏家。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34877248.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 20:53"}, {"article_id": "9455854", "title": "馬刺累積奪冠能量 溫班亞瑪展現超高球商", "summary": "馬刺時隔六年重返季後賽，首場以111：98擊敗拓荒者，226公分的「斑馬」溫班亞瑪首秀砍下35分，展現超高球商與成熟度。他的全面表現，助馬刺奪冠夢想更接近。教練強森亦展現卓越指揮能力，為球隊搭建成功基石。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34877221.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 20:43"}, {"article_id": "9455718", "title": "全中運／林子婕100公尺跨欄摘金 跑出世界U16第3傑", "summary": "115年全國中等學校運動會，跨欄新星林子婕今天在國女組100公尺跨欄決賽以13秒30破大會紀錄摘下金牌，同時名列世界U1...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34877330.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 20:13"}, {"article_id": "9455723", "title": "日職／西武、軟銀攻擊戰只是「1局限定」 林安可4支1、吞2K", "summary": "西武、軟銀隊今天的火力都是「一局限定」，台灣好手林安可也一樣，此役4打數敲出1安打為第一局的一壘打，接下來3打席都空手而歸、吞下2次三振，西武終場以6：4擊敗軟銀。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34877187.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 19:47"}, {"article_id": "9455645", "title": "桌球／日本T聯賽開幕戰7月新竹登場 林昀儒上陣", "summary": "日本職業桌球聯賽T.LEAGUE今天宣布，將於7月25日在新竹縣立體育館舉行開幕戰，同時是首度移師海外，「台灣一哥」林昀...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34877065.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 19:06"}, {"article_id": "9455591", "title": "亞運／有望二度前進亞運 13歲滑板女將林逸凡更有自信", "summary": "年僅13歲的滑板女將林逸凡今年有望第二度前進亞運，近期她與日籍教練笹岡拳道人在名古屋進行訓練，今天也隨參訪團一起前往亞運比賽場地愛知縣國際會展中心參觀，雖然目前還無法得知屆時的場地設施，但提前體驗了室內的空間感。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876959.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 18:27"}, {"article_id": "9455560", "title": "中職／陳傑憲二軍先發3打數敲1安 連2場出賽敲安", "summary": "中職統一7-ELEVEn獅隊野手陳傑憲18日起開始二軍實戰，今天繼續在二軍先發出賽，總計3打數敲出1支安打，近2場出賽都...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876928.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 18:13"}, {"article_id": "9455482", "title": "NBA／走出淘汰低潮現身科切拉音樂祭 柯瑞陪妻子享受小賈斯汀演出", "summary": "對於金州勇士隊而言，要從一個未達預期的賽季中重新振作並不容易，但如果行程表上有科切拉音樂祭（Coachella），或許能稍微撫平失利的苦澀。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876859.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=854&exp=3600&sl=W&fw=360", "date": "2026-04-21 17:59"}, {"article_id": "9455523", "title": "3對3籃球／北市、永豐冠名旺寶 啟動青年培育計畫培育新血", "summary": "臺灣3x3籃球持續邁向國際舞臺，「臺北永豐旺寶3x3職業籃球隊」今天舉辦冠名記者會，宣布球隊正式完成臺北市政府球隊註冊，並持續由永豐銀行冠名贊助，球隊也宣布2026賽季的陣容，共有3位外籍成員加入，提升球隊整體競爭力與國際實戰經驗。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876875.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 17:57"}, {"article_id": "9455509", "title": "亞沙運／UBA得分王當掌旗官 張俊生喊緊張", "summary": "2026年第6屆三亞亞洲沙灘運動會將於明天晚間8點整於三亞亞沙公園舉行開幕典禮，中華代表團男、女掌旗官人選出爐，將由男子3x3籃球選手張俊生，以及女子龍舟選手菈后・苡婭出任。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876841.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 17:45"}, {"article_id": "9455506", "title": "亞運／目標超越上屆2銀2銅 電子競技本屆也有新挑戰", "summary": "2026年愛知─名古屋亞運將在愛知縣國際會展中心進行4個競賽種類，包括滑板、自由車、電子競技運動以及擊劍，其中電子競技分在展場及會議室進行，目前相關設備都還未進駐，但實際走訪飯店與場館，距離就在不遠處，讓代表隊教練也安心不少。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876839.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 17:45"}, {"article_id": "9455425", "title": "NBA／勇士曾全力追逐雷納德遭快艇老闆否決 交易截止日前補強計畫曝光", "summary": "根據消息來源指出，金州勇士在今年2月季中交易截止日前，曾積極嘗試交易取得快艇球星雷納德（Kawhi Leonard），但最終遭到快艇老闆鮑默（Steve Ballmer）明確拒絕，交易未能成行。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876715.jpg&M=1&s=Y&x=62&y=17&sw=1155&sh=770&exp=3600&sl=W&fw=360", "date": "2026-04-21 17:14"}, {"article_id": "9455397", "title": "MLB／讚鄧愷威是太空人投手群少數亮點 美媒分析「轉先發」利與弊", "summary": "太空人隊投手群陷入傷兵潮，去年牛棚表現優異；今年防禦率5.99，排名聯盟倒數第2。美國媒體《FanSided》點出，這片低迷中仍有少數亮點，就是台灣投手鄧愷威。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876698.jpg&M=1&s=Y&x=289&y=10&sw=785&sh=523&exp=3600&sl=W&fw=360", "date": "2026-04-21 17:01"}, {"article_id": "9455339", "title": "NBA／麥凱倫罰球送禮、布里吉斯絕殺失手 尼克主帥：投籃機會很好", "summary": "尼克首輪第二戰持續在主場麥迪遜廣場花園進行，不過最終是以1分之差飲恨老鷹，系列賽被扳成1比1平手。接下來戰線將移往亞特蘭大，尼克面臨必須迅速反彈的壓力。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876609.jpg&M=1&s=Y&x=57&y=77&sw=1165&sh=776&exp=3600&sl=W&fw=360", "date": "2026-04-21 16:36"}, {"article_id": "9455321", "title": "NBA／年度防守球員只排第4 戈貝爾守住約柯奇喊幸運", "summary": "今年在年度防守球員只排第4位，灰狼隊中鋒戈貝爾（Rudy Gobert）用另種方式證明自己，今天季後賽第2戰對位金塊隊3屆MVP約柯奇（Nikola Jokic），他讓金塊當家球星8投僅1中，成為球隊克服19分落後，以119：114逆轉勝的功臣之一。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876593.jpg&M=1&s=Y&x=0&y=512&sw=853&sh=569&exp=3600&sl=W&fw=360", "date": "2026-04-21 16:21"}, {"article_id": "9455233", "title": "MLB／大聯盟官網點評村上宗隆！ 打擊型態被比擬為「日版史瓦柏」", "summary": "日本強打村上宗隆登上MLB後火力全開，已敲出8發全壘打，成為新世代長打者之一。大聯盟官網評比他的打擊型態類似「日版史瓦柏」，並指出其三振、保送與全壘打表現極為突出。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876530.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 16:20"}, {"article_id": "9455291", "title": "體操／遭控灌人頭企圖掌控體操協會 翁士航：把我影響力渲染太大", "summary": "台師大體操隊教練翁士航今天遭到指控霸凌與透過教練權勢，要求學生申請加入體操協會，試圖操控體操協會，對於這樣的指控，翁士航今天在記者會中表示，台師大絕沒有外界說的想掌控協會一事，尤其是否加入運動單項協會屬於個人意願，這樣的指控將他的影響力渲染得太大了。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876567.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 16:12"}, {"article_id": "9455278", "title": "MLB／流量密碼！大聯盟置頂李灝宇影片 紅襪先前發文遭台灣球迷謾罵", "summary": "老虎隊23歲台灣內野手李灝宇，今天在對上紅襪隊比賽中擊出生涯首安，影片被大聯盟官方Threads，吸引大批台灣球迷留言朝聖。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876515.jpg&M=1&s=Y&x=0&y=0&sw=853&sh=569&exp=3600&sl=W&fw=360", "date": "2026-04-21 16:10"}, {"article_id": "9455279", "title": "籃球／夏日最強鬥牛戰開打 良金盃3對3開放報名高手齊聚拚榮耀", "summary": "第三屆「良金盃」3對3籃球鬥牛賽將於5月30日至31日在金門縣立體育館登場，即日起開放報名，報名期限至5月15日止。主辦單位盼透過賽事串聯在地籃球能量，邀請各路好手組隊參與，為初夏金門再添一場運動盛事。", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876507.jpg&M=1&s=Y&x=0&y=421&sw=907&sh=605&exp=3600&sl=W&fw=360", "date": "2026-04-21 16:04"}, {"article_id": "9455224", "title": "中職／「2026閱讀MVP」贈棒球票 宋晟睿出席分享會", "summary": "中信銀行推出「2026閱讀MVP」活動今天正式啟動，兩波活動預計將送出1萬2000張中職中信兄弟門票；昨天分享會上，兄弟...", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876810.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&sl=W&fw=360", "date": "2026-04-21 15:56"}]}, {"name": "棒球", "articles": [{"article_id": "9455942", "title": "中職／換與不換都需要勇氣 悍將陳品宏好投栽在1打席逆轉三分砲", "date": "2026-04-21 21:14", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34877294.jpg&M=1&s=Y&x=0&y=0&sw=1279&sh=853&exp=3600&w=300"}, {"article_id": "9455901", "title": "中職／今天PitchCom有乖乖！鄭浩均飆生涯第二場接力無安打比賽", "date": "2026-04-21 20:57", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34877263.jpg&M=1&s=Y&x=0&y=0&sw=1278&sh=851&exp=3600&w=300"}, {"article_id": "9455723", "title": "日職／西武、軟銀攻擊戰只是「1局限定」 林安可4支1、吞2K", "date": "2026-04-21 19:47", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34877187.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9455560", "title": "中職／陳傑憲二軍先發3打數敲1安 連2場出賽敲安", "date": "2026-04-21 18:13", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2026/04/21/34876928.jpg&M=1&s=Y&x=0&y=0&sw=1280&sh=853&exp=3600&w=300"}, {"article_id": "9455224", "title": "中職／「2026閱讀MVP」贈棒球票 宋晟睿出席分享會", "date": "2026-04-21 15:56", "thumbnail": "https://pgw.udn.com.tw/gw/photo.php?u=https://uc.udn.com.tw/photo/t3/2